# HMS 개발 환경 변수 템플릿
# 사용법: 이 파일을 .env 로 복사한 뒤 값을 채워 넣으세요.
#   cp .env.example .env
#   (Windows) copy .env.example .env

# ─────────────────────────────────────────────────────────────────────────────
# Claude API (LLM 증상 분석, 규칙 챗봇 — §4, §8)
# Anthropic API Key: https://console.anthropic.com/
# ─────────────────────────────────────────────────────────────────────────────
CLAUDE_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Python LLM 서버 (FastAPI — 증상 상담, 의료 Q&A, 규칙 챗봇)
# python-llm 서버 주소. 기본값: http://localhost:8000
# ─────────────────────────────────────────────────────────────────────────────
LLM_SERVICE_URL=http://192.168.0.73:8000
