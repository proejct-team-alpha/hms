# LLM 백엔드 선택 (huggingface | ollama)
LLM_BACKEND=huggingface

# Hugging Face 모델명
# 예: gpt2, meta-llama/Llama-2-7b-chat-hf
LLM_MODEL=gpt2

# Ollama 설정 (LLM_BACKEND=ollama 시 사용)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b

# torch 미지원 환경(예: Windows DLL 오류)에서 mock 사용
# true/1로 설정 시 실제 모델 대신 mock 응답 반환
# LLM_FALLBACK_MOCK=false

# MySQL (필수)
MYSQL_USER=hms_admin
MYSQL_PASSWORD=hms_password
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_DB=hms_db

# API 서버
# HOST=0.0.0.0
# PORT=8000

# 추론 타임아웃 (초, 기본 60)
# LLM_INFER_TIMEOUT_SEC=60

# 입력 최대 길이 (문자 수, 기본 2048)
# LLM_INPUT_MAX_LENGTH=2048

# LLM 실패 시 반환할 기본 응답 (설정 시 fallback 사용)
# LLM_FALLBACK_RESPONSE=죄송합니다. 일시적으로 응답을 생성할 수 없습니다.
