<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>병원규칙 Q&A - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
  <style>
    :root {
      --bg: #0f172a;
      --surface: #1e293b;
      --surface-light: #334155;
      --border: rgba(255,255,255,0.06);
      --text: #e2e8f0;
      --text-dim: #94a3b8;
      --text-muted: #64748b;
      --accent: #4ade80;
      --accent-dim: rgba(74,222,128,0.12);
      --user-bg: #059669;
      --red: #fca5a5;
      --red-bg: rgba(239,68,68,0.1);
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Noto Sans KR', sans-serif;
      background: var(--bg);
      color: var(--text);
      display: flex;
      flex-direction: column;
    }
    .llm-body {
      flex: 1;
      display: flex;
      flex-direction: column;
      height: calc(100vh - 64px); /* header-staff 높이 제외 */
    }

    .chat-header {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 18px 40px;
      display: flex;
      align-items: center;
      gap: 14px;
      flex-shrink: 0;
    }
    .header-pulse {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--accent);
      animation: pulse 2s infinite;
      flex-shrink: 0;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.35; }
    }
    .header-info { flex: 1; }
    .header-title { font-size: 15px; font-weight: 600; color: var(--text); }
    .header-sub { font-size: 12px; color: var(--text-muted); margin-top: 2px; }

    .chat-messages {
      flex: 1;
      overflow-y: auto;
      padding: 32px 40px;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }
    .chat-messages::-webkit-scrollbar { width: 4px; }
    .chat-messages::-webkit-scrollbar-thumb { background: var(--surface-light); border-radius: 2px; }

    .message { display: flex; gap: 12px; align-items: flex-start; }
    .message.user { flex-direction: row-reverse; }

    .avatar {
      width: 34px; height: 34px;
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 600; flex-shrink: 0;
    }
    .avatar.bot { background: var(--accent-dim); color: var(--accent); }
    .avatar.user { background: var(--user-bg); color: #fff; }

    .message-bubble {
      max-width: 72%;
      padding: 14px 20px;
      border-radius: 16px;
      font-size: 14px;
      line-height: 1.7;
      word-break: break-word;
    }
    .message.user .message-bubble {
      background: var(--user-bg); color: #fff; border-bottom-right-radius: 4px;
    }
    .message.bot .message-bubble {
      background: var(--surface); color: var(--text);
      border-bottom-left-radius: 4px; border: 1px solid var(--border);
    }
    .message.error .message-bubble {
      background: var(--red-bg); color: var(--red);
      border: 1px solid rgba(239,68,68,0.15); border-bottom-left-radius: 4px;
    }

    .typing-indicator { display: none; gap: 12px; align-items: flex-start; }
    .typing-indicator.active { display: flex; }
    .typing-indicator .message-bubble {
      background: var(--surface); padding: 16px 28px;
      border-bottom-left-radius: 4px; border: 1px solid var(--border);
      display: flex; gap: 6px; align-items: center;
      min-width: 72px; justify-content: center;
    }
    .typing-dot {
      width: 7px; height: 7px;
      background: var(--text-muted); border-radius: 50%;
      animation: bounce 1.2s ease-in-out infinite;
    }
    .typing-dot:nth-child(2) { animation-delay: 0.15s; }
    .typing-dot:nth-child(3) { animation-delay: 0.3s; }
    @keyframes bounce {
      0%, 60%, 100% { transform: translateY(0); }
      30% { transform: translateY(-5px); }
    }

    .quick-chips {
      display: flex; gap: 8px; flex-wrap: nowrap; overflow-x: auto;
      padding: 14px 40px 6px; scrollbar-width: none;
    }
    .quick-chips::-webkit-scrollbar { display: none; }
    .chip {
      padding: 8px 16px; border: 1px solid var(--border); border-radius: 20px;
      font-size: 13px; color: var(--text-dim); cursor: pointer; background: transparent;
      transition: all 0.15s; white-space: nowrap; flex-shrink: 0; font-family: inherit;
    }
    .chip:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }

    .chat-input-area {
      background: var(--surface); border-top: 1px solid var(--border);
      padding: 18px 40px; flex-shrink: 0;
    }
    .chat-input-wrapper { display: flex; gap: 12px; align-items: flex-end; }
    .chat-input-wrapper textarea {
      flex: 1; border: 1px solid var(--border); border-radius: 14px;
      padding: 14px 20px; font-size: 14px; font-family: inherit;
      resize: none; min-height: 50px; max-height: 120px; line-height: 1.5;
      background: var(--bg); color: var(--text); transition: border-color 0.15s;
    }
    .chat-input-wrapper textarea::placeholder { color: var(--text-muted); }
    .chat-input-wrapper textarea:focus { outline: none; border-color: var(--accent); }
    .send-btn {
      width: 46px; height: 46px; border: none; border-radius: 12px;
      background: var(--user-bg); color: #fff; font-size: 18px;
      cursor: pointer; transition: all 0.15s; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
    }
    .send-btn:hover { background: #047857; }
    .send-btn:disabled { background: var(--surface-light); color: var(--text-muted); cursor: not-allowed; }
  </style>
</head>
<body class="min-h-screen flex flex-col" style="background: var(--bg);">
  {{> common/header-staff}}

  <div class="llm-body">
    <div class="chat-header">
      <div class="header-pulse"></div>
      <div class="header-info">
        <div class="header-title">병원규칙 Q&A</div>
        <div class="header-sub">당직, 물품, 위생 등 병원 내부 규칙에 대해 질문해 주세요</div>
      </div>
    </div>

    <div class="chat-messages" id="chatMessages">
      <div class="message bot">
        <div class="avatar bot">AI</div>
        <div class="message-bubble">
          안녕하세요! 병원 내부 규칙(당직, 물품, 위생 등)에 대해 궁금한 점을 질문해 주세요.
        </div>
      </div>

      <div class="typing-indicator" id="typingIndicator">
        <div class="avatar bot">AI</div>
        <div class="message-bubble">
          <div class="typing-dot"></div>
          <div class="typing-dot"></div>
          <div class="typing-dot"></div>
        </div>
      </div>
    </div>

    <div class="quick-chips" id="quickChips">
      <div class="chip" onclick="sendChip(this)">당직 규정</div>
      <div class="chip" onclick="sendChip(this)">물품 요청 절차</div>
      <div class="chip" onclick="sendChip(this)">위생 관리 지침</div>
      <div class="chip" onclick="sendChip(this)">휴가 신청</div>
      <div class="chip" onclick="sendChip(this)">응급 대응 매뉴얼</div>
    </div>

    <div class="chat-input-area">
      <div class="chat-input-wrapper">
        <textarea id="chatInput" rows="1" placeholder="질문을 입력하세요..." oninput="autoResize(this)"></textarea>
        <button class="send-btn" id="sendBtn" onclick="sendMessage()">&#9654;</button>
      </div>
    </div>
  </div>

  <script>
    feather.replace();

    var STREAM_URL = "/llm/chatbot/query/stream";
    var FALLBACK_URL = "/llm/chatbot/query";
    var chatHistory = [];

    function autoResize(el) {
      el.style.height = "auto";
      el.style.height = Math.min(el.scrollHeight, 120) + "px";
    }
    function sendChip(el) {
      document.getElementById("chatInput").value = el.textContent.trim();
      sendMessage();
    }
    function scrollToBottom() {
      var c = document.getElementById("chatMessages");
      c.scrollTop = c.scrollHeight;
    }
    function escapeHtml(text) {
      var div = document.createElement("div");
      div.textContent = text;
      return div.innerHTML;
    }
    function renderMarkdown(text) {
      var html = escapeHtml(text);
      html = html.replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>");
      html = html.replace(/\*(.+?)\*/g, "<em>$1</em>");
      html = html.replace(/\n/g, "<br>");
      return html;
    }
    function addMessage(role, text) {
      var container = document.getElementById("chatMessages");
      var indicator = document.getElementById("typingIndicator");
      var msgDiv = document.createElement("div");
      msgDiv.className = "message " + role;
      var av = document.createElement("div");
      av.className = "avatar " + role;
      av.textContent = role === "bot" ? "AI" : "나";
      var bubble = document.createElement("div");
      bubble.className = "message-bubble";
      bubble.innerHTML = renderMarkdown(text);
      msgDiv.appendChild(av);
      msgDiv.appendChild(bubble);
      container.insertBefore(msgDiv, indicator);
      scrollToBottom();
      return bubble;
    }
    function addStreamBubble() {
      var container = document.getElementById("chatMessages");
      var indicator = document.getElementById("typingIndicator");
      var msgDiv = document.createElement("div");
      msgDiv.className = "message bot";
      msgDiv.style.display = "none";
      var av = document.createElement("div");
      av.className = "avatar bot";
      av.textContent = "AI";
      var bubble = document.createElement("div");
      bubble.className = "message-bubble";
      msgDiv.appendChild(av);
      msgDiv.appendChild(bubble);
      container.insertBefore(msgDiv, indicator);
      return bubble;
    }
    async function sendMessage() {
      var input = document.getElementById("chatInput");
      var query = input.value.trim();
      if (!query) return;
      addMessage("user", query);
      chatHistory.push({ role: "user", content: query });
      input.value = "";
      input.style.height = "auto";
      document.getElementById("sendBtn").disabled = true;
      document.getElementById("typingIndicator").classList.add("active");
      document.getElementById("quickChips").style.display = "none";
      scrollToBottom();
      var answered = false;
      try {
        var answer = await streamResponse(query);
        if (answer) { chatHistory.push({ role: "assistant", content: answer }); answered = true; }
      } catch (streamErr) {
        console.warn("스트리밍 실패, 폴백 사용:", streamErr);
      }
      if (!answered) {
        try {
          var response = await fetch(FALLBACK_URL, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ query: query }),
          });
          if (!response.ok) {
            var err = await response.json().catch(function () { return {}; });
            throw new Error(err.detail || "서버 오류 (" + response.status + ")");
          }
          var fallbackAnswer = await response.text();
          addMessage("bot", fallbackAnswer);
          chatHistory.push({ role: "assistant", content: fallbackAnswer });
        } catch (error) {
          addMessage("error", "오류: " + error.message);
        }
      }
      document.getElementById("sendBtn").disabled = false;
      document.getElementById("typingIndicator").classList.remove("active");
      input.focus();
    }
    async function streamResponse(query) {
      var bubble = addStreamBubble();
      var response = await fetch(STREAM_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ query: query, max_length: 512, temperature: 0.3, history: chatHistory.slice(-6) }),
      });
      if (!response.ok) throw new Error("스트리밍 오류 (" + response.status + ")");
      var reader = response.body.getReader();
      var decoder = new TextDecoder();
      var fullText = "";
      var buffer = "";
      var firstToken = true;
      while (true) {
        var result = await reader.read();
        if (result.done) break;
        buffer += decoder.decode(result.value, { stream: true });
        var lines = buffer.split("\n");
        buffer = lines.pop();
        for (var i = 0; i < lines.length; i++) {
          var line = lines[i];
          if (!line.startsWith("data:")) continue;
          var sseData = line.substring(5).trim();
          if (sseData === "[DONE]") continue;
          try {
            var parsed = JSON.parse(sseData);
            if (parsed.error) throw new Error(parsed.error);
            if (parsed.token) {
              if (firstToken) { firstToken = false; bubble.parentElement.style.display = ""; document.getElementById("typingIndicator").classList.remove("active"); }
              fullText += parsed.token;
              bubble.innerHTML = renderMarkdown(fullText);
              scrollToBottom();
            }
          } catch (e) { /* ignore */ }
        }
      }
      if (!fullText) { bubble.parentElement.remove(); throw new Error("빈 응답"); }
      return fullText;
    }
    document.getElementById("chatInput").addEventListener("keydown", function (e) {
      if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); sendMessage(); }
    });
  </script>
</body>
</html>
