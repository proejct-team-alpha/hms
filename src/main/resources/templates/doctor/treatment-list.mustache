<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>진료 목록</title>
    <link rel="stylesheet" href="/css/tailwind.min.css">
    <script src="/js/lucide.min.js"></script>
</head>
<body class="bg-slate-50 p-6">
    <div class="max-w-7xl mx-auto space-y-6">
        <div class="flex items-center gap-3 mb-8">
            <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600">
                <i data-lucide="stethoscope" class="w-6 h-6"></i>
            </div>
            <div>
                <h1 class="text-2xl font-bold text-slate-800">진료 목록</h1>
                <p class="text-slate-500 mt-1">오늘 전체 진료 일정입니다.</p>
            </div>
            <div class="relative w-full md:w-64 ml-auto">
                <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
                <input type="text" placeholder="환자명 검색..." class="w-full pl-10 pr-4 py-2 border border-slate-200 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none text-sm"/>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <div onclick="location.href='/doctor/treatment/1'" class="bg-white rounded-2xl p-6 border transition-all cursor-pointer hover:shadow-md border-slate-200 hover:border-indigo-300">
                <div class="flex justify-between items-start mb-4">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full flex items-center justify-center bg-slate-100 text-slate-500">
                            <i data-lucide="user" class="w-5 h-5"></i>
                        </div>
                        <div>
                            <h3 class="font-bold text-slate-800 text-lg">홍길동</h3>
                            <div class="flex items-center gap-1.5 text-sm text-slate-500 font-medium">
                                <i data-lucide="clock" class="w-3.5 h-3.5"></i>
                                09:00
                            </div>
                        </div>
                    </div>
                    <span class="px-2.5 py-1 rounded-full text-xs font-bold bg-orange-100 text-orange-600">진료 대기</span>
                </div>
                <div class="bg-slate-50 rounded-xl p-3 text-sm text-slate-600 line-clamp-2 border border-slate-100">
                    두통
                </div>
                <div class="mt-4 flex justify-between items-center">
                    <div class="flex gap-2">
                        <button onclick="event.stopPropagation(); location.href='/doctor/treatment/1/start'" class="text-sm font-medium text-indigo-600 hover:text-indigo-800 flex items-center gap-1">
                            진료 시작
                        </button>
                    </div>
                    <span class="text-xs font-medium px-2 py-1 rounded-md bg-blue-50 text-blue-600">온라인</span>
                </div>
            </div>
        </div>
        
        <nav class="flex gap-2 mt-6 justify-center"><span class="px-3 py-1 bg-indigo-600 text-white rounded">1</span></nav>
    </div>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>