<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>진료 목록 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-doctor}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="space-y-6 max-w-5xl mx-auto">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600">
            <i data-feather="file-text" class="w-6 h-6"></i>
          </div>
          <div>
            <h1 class="text-2xl font-bold text-slate-800">진료 목록</h1>
            <p class="text-slate-500 mt-1">오늘 전체 진료 일정입니다.</p>
          </div>
        </div>

        {{#message}}
          <div class="p-4 bg-green-50 border border-green-200 rounded-xl text-green-700 text-sm">{{message}}</div>
        {{/message}}
        {{#errorMessage}}
          <div class="p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">{{errorMessage}}</div>
        {{/errorMessage}}

        <div id="treatment-card-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {{#reservations}}
            <div onclick="location.href='/doctor/treatment-detail?id={{id}}'"
                 class="bg-white rounded-2xl p-6 border transition-all cursor-pointer hover:shadow-md {{cardClass}}">
              <div class="flex justify-between items-start mb-4">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-full flex items-center justify-center bg-slate-100 text-slate-500">
                    <i data-feather="user" class="w-5 h-5"></i>
                  </div>
                  <div>
                    <h3 class="font-bold text-slate-800 text-lg">{{patientName}}</h3>
                    <div class="flex items-center gap-1.5 text-sm text-slate-500 font-medium">
                      <i data-feather="clock" class="w-3.5 h-3.5"></i>
                      {{timeSlot}}
                    </div>
                  </div>
                </div>
                <span class="px-2.5 py-1 rounded-full text-xs font-bold {{statusBadgeClass}}">
                  {{statusText}}
                </span>
              </div>

              <div class="bg-slate-50 rounded-xl p-3 text-sm text-slate-600 border border-slate-100 line-clamp-2">
                {{note}}
              </div>

              <div class="mt-4 flex justify-between items-center">
                <div>
                  {{#canStartTreatment}}
                    <form method="post" action="/doctor/treatment/start" onclick="event.stopPropagation()">
                      <input type="hidden" name="id" value="{{id}}">
                      <input type="hidden" name="_csrf" value="{{_csrf.token}}">
                      <button type="submit"
                              class="text-sm font-medium text-indigo-600 hover:text-indigo-800 flex items-center gap-1">
                        진료 시작
                      </button>
                    </form>
                  {{/canStartTreatment}}
                  {{^canStartTreatment}}
                  {{#canComplete}}
                    <a href="/doctor/treatment-detail?id={{id}}"
                       onclick="event.stopPropagation()"
                       class="text-sm font-medium text-indigo-600 hover:text-indigo-800 flex items-center gap-1">
                      진료실 입장
                    </a>
                  {{/canComplete}}
                  {{/canStartTreatment}}
                </div>
                <span class="text-xs font-medium px-2 py-1 rounded-md {{sourceBadgeClass}}">
                  {{sourceText}}
                </span>
              </div>
            </div>
          {{/reservations}}
          {{^reservations}}
            <div class="col-span-3 p-8 text-center text-slate-500 bg-white rounded-2xl border border-slate-200">
              진료 내역이 없습니다.
            </div>
          {{/reservations}}
        </div>

        <!-- 페이징 -->
        <div class="flex items-center justify-center gap-1 py-4">
          {{#hasPrev}}
          <a href="{{prevUrl}}" class="px-3 py-1.5 rounded-lg text-sm text-slate-600 border border-slate-300 bg-white hover:bg-slate-100 transition-colors">이전</a>
          {{/hasPrev}}
          {{#pageLinks}}
          <a href="{{url}}" class="px-3 py-1.5 rounded-lg text-sm font-medium transition-colors {{#current}}bg-indigo-600 text-white{{/current}}{{^current}}text-slate-600 border border-slate-300 bg-white hover:bg-slate-100{{/current}}">{{num}}</a>
          {{/pageLinks}}
          {{#hasNext}}
          <a href="{{nextUrl}}" class="px-3 py-1.5 rounded-lg text-sm text-slate-600 border border-slate-300 bg-white hover:bg-slate-100 transition-colors">다음</a>
          {{/hasNext}}
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>feather.replace();</script>
  <script>
    // [W3-1] 5초 폴링 — 오늘 진료 대기 목록 실시간 갱신
    (function () {
      const POLL_INTERVAL = 5000;
      const POLL_URL = '/doctor/treatment-list/poll';

      function buildCard(r) {
        const actionHtml = r.canStartTreatment
          ? `<form method="post" action="/doctor/treatment/start" onclick="event.stopPropagation()">
               <input type="hidden" name="id" value="${r.id}">
               <button type="submit"
                       class="text-sm font-medium text-indigo-600 hover:text-indigo-800 flex items-center gap-1">
                 진료 시작
               </button>
             </form>`
          : r.canComplete
            ? `<a href="/doctor/treatment-detail?id=${r.id}"
                 onclick="event.stopPropagation()"
                 class="text-sm font-medium text-indigo-600 hover:text-indigo-800 flex items-center gap-1">
                 진료실 입장
               </a>`
            : '';
        return `
          <div onclick="location.href='/doctor/treatment-detail?id=${r.id}'"
               class="bg-white rounded-2xl p-6 border transition-all cursor-pointer hover:shadow-md ${r.cardClass}">
            <div class="flex justify-between items-start mb-4">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full flex items-center justify-center bg-slate-100 text-slate-500">
                  <i data-feather="user" class="w-5 h-5"></i>
                </div>
                <div>
                  <h3 class="font-bold text-slate-800 text-lg">${r.patientName}</h3>
                  <div class="flex items-center gap-1.5 text-sm text-slate-500 font-medium">
                    <i data-feather="clock" class="w-3.5 h-3.5"></i>
                    ${r.timeSlot}
                  </div>
                </div>
              </div>
              <span class="px-2.5 py-1 rounded-full text-xs font-bold ${r.statusBadgeClass}">
                ${r.statusText}
              </span>
            </div>
            <div class="bg-slate-50 rounded-xl p-3 text-sm text-slate-600 border border-slate-100 line-clamp-2">
              ${r.note}
            </div>
            <div class="mt-4 flex justify-between items-center">
              <div>${actionHtml}</div>
              <span class="text-xs font-medium px-2 py-1 rounded-md ${r.sourceBadgeClass}">
                ${r.sourceText}
              </span>
            </div>
          </div>`;
      }

      async function pollTreatmentList() {
        try {
          const response = await fetch(POLL_URL);
          if (!response.ok) return;
          const data = await response.json();
          if (!data.body) return;

          const container = document.getElementById('treatment-card-list');
          if (!container) return;

          const items = data.body;
          if (items.length === 0) {
            container.innerHTML = `
              <div class="col-span-3 p-8 text-center text-slate-500 bg-white rounded-2xl border border-slate-200">
                진료 내역이 없습니다.
              </div>`;
          } else {
            container.innerHTML = items.map(buildCard).join('');
          }
          feather.replace();
        } catch (e) {
          console.error('[poll] treatment-list 갱신 오류', e);
        }
      }

      setInterval(pollTreatmentList, POLL_INTERVAL);
    })();
  </script>
</body>
</html>
