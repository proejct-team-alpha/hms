<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>진료 목록 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body>
  
  {{> components/sidebar}}

  <div class="main-content">
    {{> components/header}}
    
    <main class="content-wrapper">
      <div class="space-y-6 max-w-5xl mx-auto">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600">
            <i data-feather="file-text" class="w-6 h-6"></i>
          </div>
          <div>
            <h1 class="text-2xl font-bold text-slate-800">진료 목록</h1>
            <p class="text-slate-500 mt-1">오늘 전체 진료 일정입니다.</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {{#patients}}
          <div onclick="window.location.href='/treatments/{{id}}'" 
               class="bg-white rounded-2xl p-6 border transition-all cursor-pointer hover:shadow-md 
                      {{#isInProgress}}border-indigo-500 shadow-sm ring-1 ring-indigo-500{{/isInProgress}}
                      {{^isInProgress}}border-slate-200 hover:border-indigo-300{{/isInProgress}}">
            <div class="flex justify-between items-start mb-4">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full flex items-center justify-center {{#isInProgress}}bg-indigo-100 text-indigo-600{{/isInProgress}}{{^isInProgress}}bg-slate-100 text-slate-500{{/isInProgress}}">
                  <i data-feather="user" class="w-5 h-5"></i>
                </div>
                <div>
                  <h3 class="font-bold text-slate-800 text-lg">{{name}}</h3>
                  <div class="flex items-center gap-1.5 text-sm text-slate-500 font-medium">
                    <i data-feather="clock" class="w-3.5 h-3.5"></i>
                    {{time}}
                  </div>
                </div>
              </div>
              
              <span class="px-2.5 py-1 rounded-full text-xs font-bold 
                           {{#isInProgress}}bg-indigo-600 text-white{{/isInProgress}}
                           {{#isReceived}}bg-orange-100 text-orange-600{{/isReceived}}
                           {{#isReserved}}bg-slate-100 text-slate-600{{/isReserved}}">
                {{statusText}}
              </span>
            </div>

            <div class="bg-slate-50 rounded-xl p-3 text-sm text-slate-600 line-clamp-2 border border-slate-100">
              {{symptoms}}
            </div>

            <div class="mt-4 flex justify-between items-center">
              <div class="flex gap-2">
                {{#isReceived}}
                <form action="/treatments/{{id}}/start" method="POST" onsubmit="event.stopPropagation();">
                  <button type="submit" class="text-sm font-medium text-indigo-600 hover:text-indigo-800 flex items-center gap-1">
                    진료 시작
                  </button>
                </form>
                {{/isReceived}}
              </div>

              <span class="text-xs font-medium px-2 py-1 rounded-md 
                           {{#isOnline}}bg-blue-50 text-blue-600{{/isOnline}}
                           {{#isPhone}}bg-purple-50 text-purple-600{{/isPhone}}
                           {{^isOnline}}{{^isPhone}}bg-orange-50 text-orange-600{{/isPhone}}{{/isOnline}}">
                {{type}}
              </span>
            </div>
          </div>
          {{/patients}}

          {{^patients}}
          <div class="col-span-full p-8 text-center text-slate-500 bg-white rounded-2xl border border-slate-200">
            진료 내역이 없습니다.
          </div>
          {{/patients}}
        </div>
      </div>
    </main>

    {{> components/footer}}
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      feather.replace();
    });
  </script>
</body>
</html>