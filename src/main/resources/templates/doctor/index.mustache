<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>의사 페이지 - 사이드바 포함</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="bg-slate-50 h-screen flex overflow-hidden">
    <!-- 사이드바 -->
    <aside class="w-64 bg-white border-r border-slate-200 flex flex-col shrink-0">
        <div class="p-6 border-b border-slate-200">
            <h1 class="text-xl font-bold text-slate-800 flex items-center gap-2">
                <i data-lucide="stethoscope" class="text-indigo-600"></i>
                MediCare+
            </h1>
        </div>
        
        <div class="p-4 border-b border-slate-200 bg-slate-50 flex items-center justify-between">
            <div>
                <div class="text-sm font-bold text-slate-800">김의사 원장</div>
                <div class="text-xs text-slate-500">내과 전문의</div>
            </div>
            <div class="flex items-center gap-1">
                <button class="p-2 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors" title="로그아웃">
                    <i data-lucide="log-out" class="w-5 h-5"></i>
                </button>
            </div>
        </div>

        <nav class="flex-1 overflow-y-auto p-4 space-y-1">
            <a href="dashboard.html" target="contentFrame" class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors bg-indigo-50 text-indigo-700" onclick="setActive(this, '의사 대시보드')">
                <i data-lucide="layout-dashboard" class="w-5 h-5"></i>
                대시보드
            </a>
            <a href="treatment-list.html" target="contentFrame" class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors text-slate-600 hover:bg-slate-100 hover:text-slate-900" onclick="setActive(this, '진료 목록')">
                <i data-lucide="stethoscope" class="w-5 h-5"></i>
                진료 목록
            </a>
            <a href="completed-list.html" target="contentFrame" class="nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors text-slate-600 hover:bg-slate-100 hover:text-slate-900" onclick="setActive(this, '진료 완료 목록')">
                <i data-lucide="clipboard-list" class="w-5 h-5"></i>
                진료 완료 목록
            </a>
        </nav>
    </aside>

    <!-- 메인 콘텐츠 영역 -->
    <main class="flex-1 flex flex-col overflow-hidden relative">
        <header class="bg-white border-b border-slate-200 h-16 flex items-center px-8 justify-between shrink-0">
            <h2 id="headerTitle" class="text-lg font-semibold text-slate-800">의사 대시보드</h2>
            <div class="flex items-center gap-4">
                <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-700 font-bold text-sm">
                    의
                </div>
            </div>
        </header>
        
        <div class="flex-1 overflow-hidden">
            <iframe name="contentFrame" src="dashboard.html" class="w-full h-full border-none"></iframe>
        </div>
    </main>

    <script>
        // 아이콘 초기화
        lucide.createIcons();

        // 활성 메뉴 상태 관리
        function setActive(element, title) {
            // 모든 링크에서 활성 스타일 제거
            document.querySelectorAll('.nav-link').forEach(link => {
                link.classList.remove('bg-indigo-50', 'text-indigo-700');
                link.classList.add('text-slate-600', 'hover:bg-slate-100', 'hover:text-slate-900');
            });
            
            // 클릭된 링크에 활성 스타일 추가
            element.classList.remove('text-slate-600', 'hover:bg-slate-100', 'hover:text-slate-900');
            element.classList.add('bg-indigo-50', 'text-indigo-700');

            // 헤더 타이틀 변경
            document.getElementById('headerTitle').textContent = title;
        }
    </script>
</body>
</html>
