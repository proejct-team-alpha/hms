<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>의사 대시보드 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body>
  
  {{> common/sidebar-doctor}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}
    
    <main class="content-wrapper">
      <div class="space-y-6 max-w-5xl mx-auto">
        <h1 class="text-2xl font-bold text-slate-800">의사 대시보드</h1>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6" id="stats-container">
          <!-- Stats injected by JS -->
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
          <div class="flex justify-between items-center mb-6">
            <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2">
              <i data-feather="calendar" class="w-5 h-5 text-indigo-600"></i>
              오늘의 진료 일정 미리 보기
            </h2>
            <a href="treatment-list.html" class="text-sm text-indigo-600 font-medium flex items-center gap-1 hover:text-indigo-800">
              진료 목록 전체보기 <i data-feather="arrow-right" class="w-4 h-4"></i>
            </a>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="schedule-container">
            <!-- Schedule injected by JS -->
          </div>
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script src="/js/data.js"></script>
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const reservations = getReservations();
      const todayPatients = reservations.filter(r => r.status !== 'CANCELLED');
      const waitingList = reservations.filter(r => r.status === 'RECEIVED' || r.status === 'IN_PROGRESS');
      const completedList = reservations.filter(r => r.status === 'COMPLETED');
      
      // Render Stats
      document.getElementById('stats-container').innerHTML = `
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-indigo-50 rounded-xl flex items-center justify-center text-indigo-600">
              <i data-feather="users" class="w-6 h-6"></i>
            </div>
            <div>
              <div class="text-sm font-medium text-slate-500">오늘 진료 환자 수</div>
              <div class="text-2xl font-bold text-slate-800">${todayPatients.length}명</div>
            </div>
          </div>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-green-50 rounded-xl flex items-center justify-center text-green-600">
              <i data-feather="check-circle" class="w-6 h-6"></i>
            </div>
            <div>
              <div class="text-sm font-medium text-slate-500">진료 완료</div>
              <div class="text-2xl font-bold text-slate-800">${completedList.length}명</div>
            </div>
          </div>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-orange-50 rounded-xl flex items-center justify-center text-orange-600">
              <i data-feather="clock" class="w-6 h-6"></i>
            </div>
            <div>
              <div class="text-sm font-medium text-slate-500">현재 대기 중</div>
              <div class="text-2xl font-bold text-slate-800">${waitingList.filter(r => r.status === 'RECEIVED').length}명</div>
            </div>
          </div>
        </div>
      `;

      // Render Schedule
      const schedulePreview = [...todayPatients]
        .filter(r => r.status !== 'COMPLETED')
        .sort((a, b) => a.time.localeCompare(b.time));

      const scheduleContainer = document.getElementById('schedule-container');
      if (schedulePreview.length > 0) {
        scheduleContainer.innerHTML = schedulePreview.map(patient => {
          let bgClass = 'bg-white border-slate-200';
          let badgeClass = 'bg-slate-100 text-slate-400';
          let statusText = '예약';
          let link = \`treatment-detail.html?id=\${patient.id}\`;

          if (patient.status === 'IN_PROGRESS') {
            bgClass = 'bg-indigo-50 border-indigo-200 ring-2 ring-indigo-100';
            badgeClass = 'bg-indigo-600 text-white';
            statusText = '진료 중';
          } else if (patient.status === 'COMPLETED') {
            bgClass = 'bg-slate-50 border-slate-200 opacity-60';
            badgeClass = 'bg-slate-200 text-slate-600';
            statusText = '진료 완료';
            link = 'completed-list.html';
          } else if (patient.status === 'RECEIVED') {
            badgeClass = 'bg-orange-100 text-orange-600';
            statusText = '진료 대기';
          }

          return \`
            <a href="\${link}" class="block p-4 rounded-xl border transition-all cursor-pointer hover:shadow-md \${bgClass}">
              <div class="flex justify-between items-start mb-2">
                <span class="text-sm font-bold text-slate-500">\${patient.time}</span>
                <span class="text-xs font-bold px-2 py-1 rounded-lg \${badgeClass}">\${statusText}</span>
              </div>
              <div class="font-bold text-slate-800 mb-1">\${patient.name}</div>
              <div class="text-xs text-slate-500 truncate">\${patient.symptoms || '일반 진료'}</div>
            </a>
          \`;
        }).join('');
      } else {
        scheduleContainer.innerHTML = \`
          <div class="col-span-full p-12 text-center text-slate-500 bg-slate-50 rounded-2xl border border-dashed border-slate-300">
            오늘 예정된 진료 일정이 없습니다.
          </div>
        \`;
      }

      feather.replace();
    });
  </script>
</body>
</html>
