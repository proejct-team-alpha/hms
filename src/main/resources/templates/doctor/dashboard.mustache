<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>의사 대시보드 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-doctor}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="space-y-6 max-w-5xl mx-auto">
        <h1 class="text-2xl font-bold text-slate-800">의사 대시보드</h1>

        {{#message}}
          <div class="p-4 bg-green-50 border border-green-200 rounded-xl text-green-700 text-sm">{{message}}</div>
        {{/message}}

        <!-- 통계 카드 -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-indigo-50 rounded-xl flex items-center justify-center text-indigo-600">
                <i data-feather="users" class="w-6 h-6"></i>
              </div>
              <div>
                <div class="text-sm font-medium text-slate-500">오늘 진료 환자 수</div>
                <div class="text-2xl font-bold text-slate-800">{{dashboard.totalPatients}}명</div>
              </div>
            </div>
          </div>
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-green-50 rounded-xl flex items-center justify-center text-green-600">
                <i data-feather="check-circle" class="w-6 h-6"></i>
              </div>
              <div>
                <div class="text-sm font-medium text-slate-500">진료 완료</div>
                <div class="text-2xl font-bold text-slate-800">{{dashboard.completedCount}}명</div>
              </div>
            </div>
          </div>
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-orange-50 rounded-xl flex items-center justify-center text-orange-600">
                <i data-feather="clock" class="w-6 h-6"></i>
              </div>
              <div>
                <div class="text-sm font-medium text-slate-500">현재 대기 중</div>
                <div class="text-2xl font-bold text-slate-800">{{dashboard.waitingCount}}명</div>
              </div>
            </div>
          </div>
        </div>

        <!-- 오늘의 진료 일정 미리보기 -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
          <div class="flex justify-between items-center mb-6">
            <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2">
              <i data-feather="calendar" class="w-5 h-5 text-indigo-600"></i>
              오늘의 진료 일정 미리 보기
            </h2>
            <a href="/doctor/treatment-list" class="text-sm text-indigo-600 font-medium flex items-center gap-1 hover:text-indigo-800">
              진료 목록 전체보기 <i data-feather="arrow-right" class="w-4 h-4"></i>
            </a>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {{#dashboard.schedulePreview}}
              <a href="/doctor/treatment-detail?id={{id}}" class="block p-4 rounded-xl border transition-all cursor-pointer hover:shadow-md {{cardClass}}">
                <div class="flex justify-between items-start mb-2">
                  <span class="text-sm font-bold text-slate-500">{{timeSlot}}</span>
                  <span class="text-xs font-bold px-2 py-1 rounded-lg {{statusBadgeClass}}">{{statusText}}</span>
                </div>
                <div class="flex items-center gap-2 mb-1">
                  {{#isFirstVisit}}
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-[9px] font-medium bg-slate-100 text-slate-500 shrink-0">초</span>
                  {{/isFirstVisit}}
                  {{^isFirstVisit}}
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-[9px] font-medium bg-slate-100 text-slate-500 shrink-0">재</span>
                  {{/isFirstVisit}}
                  <div class="font-bold text-slate-800">{{patientName}}</div>
                </div>
                <div class="text-xs text-slate-500 truncate">{{note}}</div>
              </a>
            {{/dashboard.schedulePreview}}
            {{^dashboard.schedulePreview}}
              <div class="col-span-3 p-12 text-center text-slate-500 bg-slate-50 rounded-2xl border border-dashed border-slate-300">
                오늘 예정된 진료 일정이 없습니다.
              </div>
            {{/dashboard.schedulePreview}}
          </div>
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>feather.replace();</script>
</body>
</html>
