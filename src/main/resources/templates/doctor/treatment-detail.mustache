<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>진료실 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body>
  
  {{> common/sidebar-doctor}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}
    
    <main class="content-wrapper">
      <div class="max-w-4xl mx-auto space-y-6">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center text-indigo-600">
              <i data-feather="activity" class="w-5 h-5"></i>
            </div>
            <h1 class="text-2xl font-bold text-slate-800">진료실</h1>
          </div>
          <a href="treatment-list.html" class="text-sm font-medium text-slate-500 hover:text-slate-700">
            목록으로 돌아가기
          </a>
        </div>

        <div class="grid grid-cols-3 gap-6" id="detail-container">
          <!-- Details injected by JS -->
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script src="/js/data.js"></script>
  <script>
    function handleComplete(id) {
      const notes = document.getElementById('treatment-notes').value;
      if (!notes) {
        alert('진료 기록을 입력해주세요.');
        return;
      }
      
      const btn = document.getElementById('complete-btn');
      btn.disabled = true;
      btn.innerHTML = '<div class="w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"></div> 진료 완료 중...';
      
      setTimeout(() => {
        updateReservationStatus(id, 'COMPLETED');
        alert('진료가 완료되었습니다.');
        window.location.href = 'treatment-list.html';
      }, 1000);
    }

    document.addEventListener("DOMContentLoaded", () => {
      const id = parseInt(getQueryParam('id'));
      const reservation = getReservationById(id);

      if (!reservation) {
        alert('존재하지 않는 예약입니다.');
        window.location.href = 'treatment-list.html';
        return;
      }

      const patient = {
        id: reservation.id,
        name: reservation.name,
        age: 35,
        gender: 'M',
        symptoms: reservation.symptoms || '증상 없음',
        history: '고혈압 약 복용 중',
      };

      document.getElementById('detail-container').innerHTML = \`
        <!-- Left Column: Patient Info -->
        <div class="col-span-1 space-y-6">
          <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center text-slate-500">
                <i data-feather="user" class="w-8 h-8"></i>
              </div>
              <div>
                <h2 class="text-xl font-bold text-slate-800">\${patient.name}</h2>
                <div class="text-sm text-slate-500">\${patient.age}세 / \${patient.gender}</div>
              </div>
            </div>

            <div class="space-y-4">
              <div>
                <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">환자 호소 증상</h3>
                <div class="bg-orange-50 text-orange-900 p-3 rounded-xl text-sm border border-orange-100 leading-relaxed">
                  \${patient.symptoms}
                </div>
              </div>

              <div>
                <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">과거 병력</h3>
                <div class="bg-slate-50 text-slate-700 p-3 rounded-xl text-sm border border-slate-100">
                  \${patient.history}
                </div>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
            <h3 class="text-sm font-bold text-slate-800 flex items-center gap-2 mb-4">
              <i data-feather="activity" class="w-4 h-4 text-indigo-500"></i>
              최근 진료 기록
            </h3>
            <div class="space-y-3">
              <div class="border-l-2 border-indigo-200 pl-3 pb-3">
                <div class="text-xs text-slate-400 mb-1">2023.09.15</div>
                <div class="text-sm text-slate-700">감기 몸살, 약 처방 3일치</div>
              </div>
              <div class="border-l-2 border-slate-200 pl-3">
                <div class="text-xs text-slate-400 mb-1">2023.05.02</div>
                <div class="text-sm text-slate-700">건강검진 결과 상담</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Column: Treatment Notes -->
        <div class="col-span-2 bg-white rounded-2xl shadow-sm border border-slate-200 flex flex-col">
          <div class="p-6 border-b border-slate-200 flex items-center gap-2">
            <i data-feather="file-text" class="w-5 h-5 text-indigo-600"></i>
            <h2 class="text-lg font-bold text-slate-800">진료 기록 작성</h2>
          </div>
          
          <div class="p-6 flex-1 flex flex-col">
            <textarea
              id="treatment-notes"
              class="flex-1 w-full p-4 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none resize-none text-slate-700 leading-relaxed"
              placeholder="진료 내용, 처방 내역, 특이사항 등을 상세히 기록해주세요."
            ></textarea>
          </div>

          <div class="p-6 border-t border-slate-200 bg-slate-50 rounded-b-2xl flex justify-end gap-3">
            <button class="px-6 py-3 bg-white border border-slate-300 text-slate-700 font-medium rounded-xl hover:bg-slate-100 transition-colors">
              임시 저장
            </button>
            <button 
              id="complete-btn"
              onclick="handleComplete(\${patient.id})"
              class="px-8 py-3 bg-indigo-600 text-white font-medium rounded-xl hover:bg-indigo-700 transition-colors shadow-sm flex items-center gap-2 disabled:opacity-50"
            >
              <i data-feather="check-circle" class="w-5 h-5"></i>
              진료 완료
            </button>
          </div>
        </div>
      \`;

      feather.replace();
    });
  </script>
</body>
</html>
