<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>진료실 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-doctor}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="max-w-4xl mx-auto space-y-6">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center text-indigo-600">
              <i data-feather="activity" class="w-5 h-5"></i>
            </div>
            <h1 class="text-2xl font-bold text-slate-800">진료실</h1>
          </div>
          {{#detail.canComplete}}
          <a href="/doctor/treatment-list" class="text-sm font-medium text-slate-500 hover:text-slate-700 flex items-center gap-1">
            <i data-feather="arrow-left" class="w-4 h-4"></i>
            목록으로 돌아가기
          </a>
          {{/detail.canComplete}}
          {{^detail.canComplete}}
          <a href="/doctor/treatment-list?date={{detail.reservationDate}}&tab=completed" class="text-sm font-medium text-slate-500 hover:text-slate-700 flex items-center gap-1">
            <i data-feather="arrow-left" class="w-4 h-4"></i>
            목록으로 돌아가기
          </a>
          {{/detail.canComplete}}
        </div>

        {{#errorMessage}}
          <div class="p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">{{errorMessage}}</div>
        {{/errorMessage}}
        {{#message}}
          <div class="p-4 bg-green-50 border border-green-200 rounded-xl text-green-700 text-sm">{{message}}</div>
        {{/message}}

        <div class="grid grid-cols-3 gap-6">
          <!-- 좌측: 환자 정보 -->
          <div class="col-span-1 space-y-6">
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
              <div class="flex items-center gap-4 mb-6">
                <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center text-slate-500">
                  <i data-feather="user" class="w-8 h-8"></i>
                </div>
                <div>
                  <div class="flex items-center gap-2 mb-1">
                    {{#detail.isFirstVisit}}
                    <span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-[9px] font-medium bg-slate-100 text-slate-500 shrink-0">초</span>
                    {{/detail.isFirstVisit}}
                    {{^detail.isFirstVisit}}
                    <span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-[9px] font-medium bg-slate-100 text-slate-500 shrink-0">재</span>
                    {{/detail.isFirstVisit}}
                    <h2 class="text-xl font-bold text-slate-800">
                      {{detail.patientName}}
                      <span class="text-base font-medium text-slate-400 ml-1">(F / 30세)</span>
                    </h2>
                  </div>
                  <div class="text-sm text-slate-500">{{detail.patientPhone}}</div>
                  <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-orange-100 text-orange-600 mt-1 inline-block">
                    {{detail.statusText}}
                  </span>
                </div>
              </div>

              <div class="space-y-4">
                <div>
                  <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">예약 시간</h3>
                  <div class="bg-slate-50 text-slate-700 p-3 rounded-xl text-sm border border-slate-100 mb-4">
                    {{detail.timeSlot}}
                  </div>
                </div>
                <div>
                  <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">접수 경로</h3>
                  <div class="p-3 rounded-xl text-sm border font-bold flex items-center gap-2 {{detail.sourceBadgeClass}}">
                    <i data-feather="external-link" class="w-4 h-4"></i>
                    {{detail.sourceText}}
                  </div>
                </div>
                <div>
                  <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">내원 사유</h3>
                  <div class="bg-orange-50 text-orange-900 p-3 rounded-xl text-sm border border-orange-100 leading-relaxed">
                    {{detail.note}}
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- 우측: 진료 기록 작성 or 완료된 기록 -->
          <div class="col-span-2 bg-white rounded-2xl shadow-sm border border-slate-200 flex flex-col">
            <div class="p-6 border-b border-slate-200 flex items-center justify-between">
              <div class="flex items-center gap-2">
                <i data-feather="file-text" class="w-5 h-5 text-indigo-600"></i>
                <h2 class="text-lg font-bold text-slate-800">진료 기록</h2>
              </div>
              <div class="flex items-center gap-2">
                {{#detail.canComplete}}
                  {{#detail.canStartTreatment}}
                    <form method="post" action="/doctor/treatment/start">
                      <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
                      <input type="hidden" name="id" value="{{detail.reservationId}}">
                      <button type="submit"
                              class="px-4 py-2 text-sm font-medium rounded-lg shadow-sm flex items-center gap-1.5 transition-colors hover:opacity-90"
                              style="background-color:#ea580c;color:#fff;">
                        <i data-feather="play" class="w-4 h-4"></i>
                        진료 시작
                      </button>
                    </form>
                  {{/detail.canStartTreatment}}
                  <button type="submit"
                          form="complete-form"
                          formaction="/doctor/treatment/save"
                          class="px-4 py-2 bg-slate-800 text-white text-sm font-medium rounded-lg hover:bg-slate-900 transition-colors shadow-sm flex items-center gap-1.5">
                    <i data-feather="save" class="w-4 h-4"></i>
                    저장
                  </button>
                {{/detail.canComplete}}
              </div>
            </div>

            {{#detail.canComplete}}
              <!-- 진료 기록 작성 폼 -->
              <form id="complete-form" action="/doctor/treatment/complete" method="post" class="flex-1 flex flex-col">
                <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
                <input type="hidden" name="id" value="{{detail.reservationId}}">

                <div class="p-6 flex-1 flex flex-col gap-5">
                  <div class="flex flex-col">
                    <label class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">진단명</label>
                    <textarea
                      name="diagnosis"
                      required
                      rows="2"
                      class="w-full p-4 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none resize-none text-slate-700 leading-relaxed shadow-sm"
                      placeholder="진단명을 입력해주세요."
                    >{{#detail.diagnosis}}{{detail.diagnosis}}{{/detail.diagnosis}}</textarea>
                  </div>
                  
                  <div class="flex-1 flex flex-col">
                    <label class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">진료 소견 (SOAP)</label>
                    <textarea
                      name="remark"
                      required
                      class="flex-1 w-full p-4 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none resize-none text-slate-700 leading-relaxed shadow-sm"
                      placeholder="진료 소견(SOAP)을 입력해주세요."
                    >{{#detail.remark}}{{detail.remark}}{{/detail.remark}}</textarea>
                  </div>

                  <div class="flex flex-col">
                    <label class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">처방 내역</label>
                    <textarea
                      name="prescription"
                      required
                      rows="3"
                      class="w-full p-4 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none resize-none text-slate-700 leading-relaxed shadow-sm"
                      placeholder="처방 내역을 입력해주세요."
                    >{{#detail.prescription}}{{detail.prescription}}{{/detail.prescription}}</textarea>
                  </div>
                </div>
              </form>

              <!-- 푸터: 진료 완료 버튼 -->
              <div class="p-6 border-t border-slate-200 bg-slate-50 rounded-b-2xl flex justify-end items-center">
                <button
                  type="submit"
                  form="complete-form"
                  class="px-8 py-3 bg-indigo-600 text-white font-medium rounded-xl hover:bg-indigo-700 transition-colors shadow-sm flex items-center gap-2"
                >
                  <i data-feather="check-circle" class="w-5 h-5"></i>
                  진료 완료
                </button>
              </div>
            {{/detail.canComplete}}

            {{^detail.canComplete}}
              <!-- 완료된 진료 기록 조회 -->
              <div class="p-6 flex-1 flex flex-col gap-6">
                {{#detail.diagnosis}}
                  <div class="space-y-6">
                    <div>
                      <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">진단명</h3>
                      <div class="bg-slate-50 text-slate-700 p-4 rounded-xl text-sm border border-slate-100 leading-relaxed whitespace-pre-wrap font-semibold">{{detail.diagnosis}}</div>
                    </div>
                    <div>
                      <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">진료 소견 (SOAP)</h3>
                      <div class="bg-slate-50 text-slate-700 p-4 rounded-xl text-sm border border-slate-100 leading-relaxed whitespace-pre-wrap">{{detail.remark}}</div>
                    </div>
                    <div>
                      <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">처방 내역</h3>
                      <div class="bg-indigo-50 text-indigo-900 p-4 rounded-xl text-sm border border-indigo-100 leading-relaxed whitespace-pre-wrap">{{detail.prescription}}</div>
                    </div>
                  </div>
                {{/detail.diagnosis}}
                {{^detail.diagnosis}}
                  <div class="py-12 flex flex-col items-center justify-center text-slate-400 gap-2">
                    <i data-feather="inbox" class="w-12 h-12 opacity-20"></i>
                    <p>기록된 진료 내용이 없습니다.</p>
                  </div>
                {{/detail.diagnosis}}

                <div class="space-y-3 pt-4 border-t border-slate-100">
                  <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider">사용한 물품 내역</h3>
                  <div class="bg-slate-50 rounded-xl border border-slate-100 overflow-hidden">
                    <table class="w-full text-xs">
                      <thead class="bg-slate-100 text-slate-500">
                        <tr>
                          <th class="px-3 py-2 text-left font-medium">물품명</th>
                          <th class="px-3 py-2 text-left font-medium">사용자</th>
                          <th class="px-3 py-2 text-right font-medium">수량</th>
                          <th class="px-3 py-2 text-right font-medium">시간</th>
                        </tr>
                      </thead>
                      <tbody class="divide-y divide-slate-100">
                        {{#usageLogs}}
                        <tr>
                          <td class="px-3 py-2 text-slate-700 font-medium">{{itemName}}</td>
                          <td class="px-3 py-2 text-slate-500">{{usedBy}}</td>
                          <td class="px-3 py-2 text-right text-slate-600">{{amount}}개</td>
                          <td class="px-3 py-2 text-right text-slate-400">{{usedAt}}</td>
                        </tr>
                        {{/usageLogs}}
                        {{^usageLogs}}
                        <tr><td colspan="4" class="px-3 py-2 text-xs text-slate-400 text-center">사용한 물품이 없습니다.</td></tr>
                        {{/usageLogs}}
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>

              <div class="p-6 border-t border-slate-200 bg-slate-50 rounded-b-2xl flex items-center justify-between">
                <span class="text-sm font-medium text-green-600 flex items-center gap-1">
                  <i data-feather="check-circle" class="w-4 h-4"></i>
                  진료 완료됨
                </span>
                <a href="/doctor/treatment-list?date={{detail.reservationDate}}&tab=completed" class="text-sm font-bold text-indigo-600 hover:text-indigo-800">
                  목록으로 돌아가기
                </a>
              </div>
            {{/detail.canComplete}}
          </div>
        </div>

        {{#detail.canComplete}}
        <!-- 물품 사용 섹션 -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 space-y-4">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
              <h3 class="text-base font-bold text-slate-800 flex items-center gap-2">
                <i data-feather="package" class="w-5 h-5 text-indigo-600"></i>
                물품 사용
              </h3>
              <button type="button" id="item-batch-use-btn"
                      class="px-3 py-1.5 bg-indigo-600 text-white text-xs font-bold rounded-lg hover:bg-indigo-700 transition-colors shadow-sm flex items-center gap-1.5">
                <i data-feather="plus-square" class="w-4 h-4"></i>
                선택 물품 일괄 사용
              </button>
            </div>
            <div class="flex gap-1.5" id="item-category-btns">
              <button type="button" data-cat="" class="item-cat-btn px-3 py-1.5 text-xs font-medium rounded-lg bg-indigo-600 text-white transition-colors">전체</button>
              <button type="button" data-cat="MEDICAL_SUPPLIES" class="item-cat-btn px-3 py-1.5 text-xs font-medium rounded-lg bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors">의료소모품</button>
              <button type="button" data-cat="MEDICAL_EQUIPMENT" class="item-cat-btn px-3 py-1.5 text-xs font-medium rounded-lg bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors">의료기기</button>
              <button type="button" data-cat="GENERAL_SUPPLIES" class="item-cat-btn px-3 py-1.5 text-xs font-medium rounded-lg bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors">사무/비품</button>
            </div>
          </div>

          <div class="bg-slate-50 rounded-xl border border-slate-100 overflow-hidden">
            <table class="w-full text-xs">
              <thead class="bg-slate-100 text-slate-500">
                <tr>
                  <th class="px-3 py-2 text-left font-medium">물품명</th>
                  <th class="px-3 py-2 text-left font-medium">사용자</th>
                  <th class="px-3 py-2 text-right font-medium">수량</th>
                  <th class="px-3 py-2 text-right font-medium">시간</th>
                  <th class="px-3 py-2 text-center font-medium">관리</th>
                </tr>
              </thead>
              <tbody id="usage-log-tbody" class="divide-y divide-slate-100">
                {{#usageLogs}}
                <tr>
                  <td class="px-3 py-2 text-slate-700 font-medium">{{itemName}}</td>
                  <td class="px-3 py-2 text-slate-500">{{usedBy}}</td>
                  <td class="px-3 py-2 text-right text-slate-600">{{amount}}개</td>
                  <td class="px-3 py-2 text-right text-slate-400">{{usedAt}}</td>
                  <td class="px-3 py-2 text-center">
                    <button type="button" onclick="cancelUsage({{id}})"
                            class="p-1 text-red-500 hover:bg-red-50 rounded transition-colors" title="사용 취소">
                      <i data-feather="x-circle" class="w-4 h-4"></i>
                    </button>
                  </td>
                </tr>
                {{/usageLogs}}
                <tr id="usage-log-empty" style="{{#usageLogs.size}}display:none{{/usageLogs.size}}">
                  <td colspan="5" class="px-3 py-2 text-xs text-slate-400 text-center">사용된 물품이 없습니다.</td>
                </tr>
              </tbody>
            </table>
          </div>
          <div id="usage-log-pagination" class="flex items-center justify-center pt-1" style="display:none">
            <div class="flex items-center gap-2">
              <button id="usage-log-prev" type="button" class="px-2 py-1 text-[10px] border border-slate-200 rounded">이전</button>
              <div id="usage-log-page-numbers" class="flex items-center gap-1"></div>
              <button id="usage-log-next" type="button" class="px-2 py-1 text-[10px] border border-slate-200 rounded">다음</button>
            </div>
          </div>

          <div class="relative">
            <i data-feather="search" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"></i>
            <input type="text" id="item-search" placeholder="물품명 검색 (초성·영문 가능)"
                   class="w-full pl-9 pr-4 py-2 text-sm border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-300">
          </div>
          <div class="grid grid-cols-4 gap-3" id="item-use-grid">
            {{#items}}
            <div class="item-card border border-slate-200 rounded-xl p-3 space-y-2" data-category="{{category}}" data-id="{{id}}">
              <div class="item-name text-sm font-bold text-slate-800 truncate">{{name}}</div>
              <div class="text-xs text-slate-500">{{categoryText}}</div>
              <div class="text-xs font-bold {{#lowStock}}text-red-600{{/lowStock}}{{^lowStock}}text-slate-600{{/lowStock}}">
                재고: <span class="quantity-span">{{quantity}}</span>개
              </div>
              <form action="/doctor/item/use" method="post" class="flex items-center gap-1">
                <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
                <input type="hidden" name="id" value="{{id}}">
                <input type="hidden" name="reservationId" value="{{detail.reservationId}}">
                <input type="number" name="amount" min="1" placeholder="수량"
                       class="flex-1 w-0 px-2 py-1 text-xs border border-slate-300 rounded-lg text-center focus:outline-none focus:ring-1 focus:ring-indigo-400">
                <button type="submit" class="px-2 py-1 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-bold rounded-lg transition-colors whitespace-nowrap">
                  사용
                </button>
              </form>
            </div>
            {{/items}}
          </div>
        </div>
        {{/detail.canComplete}}

        <!-- [신규] 과거 진료 이력 섹션 -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
          <div class="p-6 border-b border-slate-200 bg-slate-50 flex items-center justify-between">
            <div class="flex items-center gap-2">
              <i data-feather="clock" class="w-5 h-5 text-indigo-600"></i>
              <h2 class="text-lg font-bold text-slate-800">과거 진료 이력 (완료 기록)</h2>
            </div>
            <!-- 페이징 컨트롤 -->
            <div id="history-pagination" class="flex items-center gap-3" style="display: none;">
              <button type="button" id="history-prev" class="p-1.5 rounded-lg border border-slate-200 text-slate-400 hover:bg-white hover:text-indigo-600 disabled:opacity-30 disabled:cursor-not-allowed transition-all">
                <i data-feather="chevron-left" class="w-4 h-4"></i>
              </button>
              <span class="text-xs font-bold text-slate-500">
                <span id="history-current-page" class="text-indigo-600">1</span> / <span id="history-total-pages">1</span>
              </span>
              <button type="button" id="history-next" class="p-1.5 rounded-lg border border-slate-200 text-slate-400 hover:bg-white hover:text-indigo-600 disabled:opacity-30 disabled:cursor-not-allowed transition-all">
                <i data-feather="chevron-right" class="w-4 h-4"></i>
              </button>
            </div>
          </div>
          
          <div class="p-6">
            {{#detail.history.size}}
              <div id="history-list-container" class="space-y-8 relative before:absolute before:inset-0 before:left-4 before:w-0.5 before:bg-slate-100 before:content-['']">
                {{#detail.history}}
                  <div class="history-item relative pl-10 transition-all duration-300">
                    <!-- 타임라인 점 -->
                    <div class="absolute left-2.5 top-1.5 w-3.5 h-3.5 rounded-full bg-white border-4 border-indigo-500 shadow-sm"></div>
                    
                    <div class="bg-slate-50 rounded-2xl p-5 border border-slate-100 space-y-4 transition-all hover:border-indigo-200 hover:bg-white hover:shadow-md">
                      <div class="flex justify-between items-start">
                        <div>
                          <div class="text-sm font-bold text-slate-800 mb-0.5">{{date}}</div>
                          <div class="text-xs font-medium text-slate-500">{{deptName}} · {{doctorName}} 의사</div>
                        </div>
                        <span class="px-2 py-0.5 rounded-full text-[10px] font-bold bg-green-100 text-green-700">진료 완료</span>
                      </div>
                      
                      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="space-y-1">
                          <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">진단명</span>
                          <div class="text-sm text-slate-700 font-semibold">{{diagnosis}}</div>
                        </div>
                        <div class="space-y-1">
                          <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">처방 내역</span>
                          <div class="text-sm text-slate-600 bg-white p-2 rounded-lg border border-slate-100">{{prescription}}</div>
                        </div>
                      </div>
                      
                      {{#remark}}
                      <div class="space-y-1 pt-2 border-t border-slate-100">
                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">진료 소견</span>
                        <div class="text-sm text-slate-600 leading-relaxed italic">"{{remark}}"</div>
                      </div>
                      {{/remark}}
                    </div>
                  </div>
                {{/detail.history}}
              </div>
            {{/detail.history.size}}
            
            {{^detail.history.size}}
              <div class="py-12 flex flex-col items-center justify-center text-slate-400 gap-3">
                <div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center">
                  <i data-feather="folder" class="w-8 h-8 opacity-20"></i>
                </div>
                <p class="text-sm font-medium">과거 진료 기록이 없습니다.</p>
              </div>
            {{/detail.history.size}}
          </div>
        </div>

      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>
    (function() {
      // 1. 카테고리 필터링 및 검색 로직
      const itemSearchInput = document.getElementById('item-search');
      const itemCards = document.querySelectorAll('.item-card');
      const categoryBtns = document.querySelectorAll('.item-cat-btn');
      let currentCategory = "";

      function filterItems() {
        const query = itemSearchInput.value.toLowerCase();
        itemCards.forEach(card => {
          const name = card.querySelector('.item-name').textContent.toLowerCase();
          const category = card.getAttribute('data-category');
          const matchesCategory = !currentCategory || category === currentCategory;
          const matchesSearch = !query || itemMatches(name, query);
          
          card.style.display = (matchesCategory && matchesSearch) ? 'block' : 'none';
        });
      }

      categoryBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          categoryBtns.forEach(b => b.classList.replace('bg-indigo-600', 'bg-slate-100'));
          categoryBtns.forEach(b => b.classList.replace('text-white', 'text-slate-600'));
          btn.classList.replace('bg-slate-100', 'bg-indigo-600');
          btn.classList.replace('text-slate-600', 'text-white');
          currentCategory = btn.getAttribute('data-cat');
          filterItems();
        });
      });

      itemSearchInput.addEventListener('input', filterItems);

      // 2. 개별 물품 사용 (AJAX)
      document.querySelectorAll('form[action$="/doctor/item/use"]').forEach(function(form) {
        form.addEventListener('submit', function(e) {
          e.preventDefault();
          const input = form.querySelector('input[name="amount"]');
          const amount = input.value.trim();
          if (!amount || amount <= 0) return alert('수량을 입력해주세요.');

          const id = form.querySelector('input[name="id"]').value;
          const resId = form.querySelector('input[name="reservationId"]').value;
          const csrfToken = document.querySelector('input[name="_csrf"]').value;
          
          const params = new URLSearchParams();
          params.append('id', id);
          params.append('amount', amount);
          params.append('reservationId', resId);
          params.append('_csrf', csrfToken);

          fetch('/doctor/item/use', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: params.toString()
          }).then(res => res.json()).then(data => {
            if (data.quantity !== undefined) {
              form.closest('.item-card').querySelector('.quantity-span').textContent = data.quantity;
              input.value = '';
              refreshUsageLogs(data.logs || []);
            } else if (data.error) alert(data.error);
          });
        });
      });

      // 3. 선택 물품 일괄 사용
      const batchUseBtn = document.getElementById('item-batch-use-btn');
      if (batchUseBtn) {
        batchUseBtn.addEventListener('click', function(e) {
          e.preventDefault();
          const requests = [];
          const resId = "{{detail.reservationId}}";
          const csrfToken = document.querySelector('input[name="_csrf"]').value;

          document.querySelectorAll('.item-card').forEach(card => {
            const amountInput = card.querySelector('input[name="amount"]');
            const amount = amountInput.value.trim();
            if (amount && parseInt(amount) > 0) {
              requests.push({
                id: card.getAttribute('data-id'),
                amount: parseInt(amount)
              });
            }
          });

          if (requests.length === 0) {
            alert('사용할 물품의 수량을 하나 이상 입력해주세요.');
            return;
          }

          fetch('/doctor/item/use-batch', {
            method: 'POST',
            headers: { 
              'Content-Type': 'application/json',
              'X-CSRF-TOKEN': csrfToken 
            },
            body: JSON.stringify({
              reservationId: resId,
              requests: requests
            })
          }).then(res => {
            if (!res.ok) throw new Error('일괄 처리에 실패했습니다.');
            return res.json();
          }).then(data => {
            if (data.successes && data.successes.length > 0) {
              if (data.errors && data.errors.length > 0) {
                alert('일부 물품의 재고가 부족하여 처리되지 않았습니다.\n\n' + data.errors.join('\n'));
              }
              location.reload(); 
            } else if (data.errors && data.errors.length > 0) {
              alert('재고가 부족하여 처리에 실패했습니다:\n' + data.errors.join('\n'));
            } else if (data.error) {
              alert('오류: ' + data.error);
            }
          }).catch(err => {
            console.error(err);
            alert('서버 통신 중 오류가 발생했습니다.');
          });
        });
      }

      // ── 초성 검색 지원 로직 ──
      var CHOSUNG = ['ㄱ','ㄲ','ㄴ','ㄷ','ㄸ','ㄹ','ㅁ','ㅂ','ㅃ','ㅅ','ㅆ','ㅇ','ㅈ','ㅉ','ㅊ','ㅋ','ㅌ','ㅍ','ㅎ'];
      function getChosung(str) {
        return str.split('').map(function(ch) {
          var code = ch.charCodeAt(0);
          if (code >= 0xAC00 && code <= 0xD7A3) return CHOSUNG[Math.floor((code - 0xAC00) / 588)];
          return ch;
        }).join('');
      }
      function isChosungOnly(str) { return /^[ㄱ-ㅎ]+$/.test(str); }
      function itemMatches(name, query) {
        if (!query) return true;
        var q = query.toLowerCase();
        if (isChosungOnly(q)) return getChosung(name).includes(q);
        return name.toLowerCase().includes(q);
      }

      // (이하 사용 취소 및 페이징 로직 동일 유지)
      window.cancelUsage = function(logId) {
        if(!confirm('정말 취소하시겠습니까?')) return;
        const resId = "{{detail.reservationId}}";
        const csrfToken = document.querySelector('input[name="_csrf"]').value;
        const params = new URLSearchParams();
        params.append('logId', logId);
        params.append('reservationId', resId);
        params.append('_csrf', csrfToken);

        fetch('/doctor/item/cancel', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: params.toString()
        }).then(res => res.json()).then(data => {
          if (data.logs) {
            refreshUsageLogs(data.logs);
            // 재고 업데이트 (화면상의 해당 카드 재고 갱신)
            const card = document.querySelector(`.item-card[data-id="${data.itemId}"]`);
            if(card) card.querySelector('.quantity-span').textContent = data.quantity;
          } else if (data.error) alert(data.error);
        });
      };

      var USAGE_LOG_PAGE_SIZE = 10;
      var usageLogPage = 1;

      function renderUsageLog() {
        var rows = Array.from(document.querySelectorAll('#usage-log-tbody tr:not(#usage-log-empty)'));
        var total = rows.length;
        var totalPages = Math.max(1, Math.ceil(total / USAGE_LOG_PAGE_SIZE));
        if (usageLogPage > totalPages) usageLogPage = totalPages;
        var start = (usageLogPage - 1) * USAGE_LOG_PAGE_SIZE;
        rows.forEach(function(r, i) { r.style.display = (i >= start && i < start + USAGE_LOG_PAGE_SIZE) ? '' : 'none'; });
        var bar = document.getElementById('usage-log-pagination');
        if (bar) bar.style.display = (total === 0 || totalPages <= 1) ? 'none' : 'flex';
        buildUsageLogPageNumbers(usageLogPage, totalPages);
      }

      function buildUsageLogPageNumbers(current, total) {
        var container = document.getElementById('usage-log-page-numbers');
        if(!container) return;
        container.innerHTML = '';
        if (total <= 1) return;
        for (var i = 1; i <= total; i++) {
          (function(n) {
            var b = document.createElement('button');
            b.type = 'button'; b.textContent = n;
            b.className = 'px-2 py-1 text-xs rounded-lg border transition-colors ' +
              (n === current ? 'bg-indigo-600 text-white border-indigo-600' : 'border-slate-200 text-slate-600 hover:bg-slate-100');
            b.addEventListener('click', function() { usageLogPage = n; renderUsageLog(); });
            container.appendChild(b);
          })(i);
        }
      }

      function refreshUsageLogs(logs) {
        var tbody = document.getElementById('usage-log-tbody');
        if (!tbody) return;
        Array.from(tbody.querySelectorAll('tr:not(#usage-log-empty)')).forEach(r => r.remove());
        var emptyRow = document.getElementById('usage-log-empty');
        if (logs && logs.length > 0) {
          if (emptyRow) emptyRow.style.display = 'none';
          logs.forEach(log => {
            const tr = document.createElement('tr');
            tr.innerHTML = `<td class="px-3 py-2 text-slate-700 font-medium">${log.itemName}</td>
                            <td class="px-3 py-2 text-slate-500">${log.usedBy}</td>
                            <td class="px-3 py-2 text-right text-slate-600">${log.amount}개</td>
                            <td class="px-3 py-2 text-right text-slate-400">${log.usedAt}</td>
                            <td class="px-3 py-2 text-center">
                              <button type="button" onclick="cancelUsage(${log.id})" class="p-1 text-red-500 hover:bg-red-50 rounded"><i data-feather="x-circle" class="w-4 h-4"></i></button>
                            </td>`;
            tbody.appendChild(tr);
          });
          if (window.feather) feather.replace();
        } else {
          if (emptyRow) emptyRow.style.display = '';
        }
        renderUsageLog();
      }

      renderUsageLog();

      // ── 과거 진료 이력 페이징 ──
      (function() {
        var HISTORY_PAGE_SIZE = 3;
        var historyPage = 1;
        var items = document.querySelectorAll('.history-item');
        var total = items.length;
        var totalPages = Math.ceil(total / HISTORY_PAGE_SIZE);
        if (total > HISTORY_PAGE_SIZE) {
          document.getElementById('history-pagination').style.display = 'flex';
          document.getElementById('history-total-pages').textContent = totalPages;
        }
        function renderHistory() {
          var start = (historyPage - 1) * HISTORY_PAGE_SIZE;
          var end = start + HISTORY_PAGE_SIZE;
          items.forEach(function(item, index) {
            item.style.display = (index >= start && index < end) ? 'block' : 'none';
          });
          document.getElementById('history-current-page').textContent = historyPage;
          document.getElementById('history-prev').disabled = (historyPage <= 1);
          document.getElementById('history-next').disabled = (historyPage >= totalPages);
        }
        document.getElementById('history-prev').addEventListener('click', () => { if (historyPage > 1) { historyPage--; renderHistory(); } });
        document.getElementById('history-next').addEventListener('click', () => { if (historyPage < totalPages) { historyPage++; renderHistory(); } });
        if (total > 0) renderHistory();
      })();
    })();
  </script>
  <script>feather.replace();</script>
</body>
</html>
