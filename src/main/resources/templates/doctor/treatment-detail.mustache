<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>진료실 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-doctor}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="max-w-4xl mx-auto space-y-6">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center text-indigo-600">
              <i data-feather="activity" class="w-5 h-5"></i>
            </div>
            <h1 class="text-2xl font-bold text-slate-800">진료실</h1>
          </div>
          {{#detail.canComplete}}
          <a href="/doctor/treatment-list" class="text-sm font-medium text-slate-500 hover:text-slate-700 flex items-center gap-1">
            <i data-feather="arrow-left" class="w-4 h-4"></i>
            목록으로 돌아가기
          </a>
          {{/detail.canComplete}}
          {{^detail.canComplete}}
          <a href="/doctor/completed-list" class="text-sm font-medium text-slate-500 hover:text-slate-700 flex items-center gap-1">
            <i data-feather="arrow-left" class="w-4 h-4"></i>
            목록으로 돌아가기
          </a>
          {{/detail.canComplete}}
        </div>

        {{#errorMessage}}
          <div class="p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">{{errorMessage}}</div>
        {{/errorMessage}}

        <div class="grid grid-cols-3 gap-6">
          <!-- 좌측: 환자 정보 -->
          <div class="col-span-1 space-y-6">
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
              <div class="flex items-center gap-4 mb-6">
                <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center text-slate-500">
                  <i data-feather="user" class="w-8 h-8"></i>
                </div>
                <div>
                  <h2 class="text-xl font-bold text-slate-800">{{detail.patientName}}</h2>
                  <div class="text-sm text-slate-500">{{detail.patientPhone}}</div>
                  <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-orange-100 text-orange-600 mt-1 inline-block">
                    {{detail.statusText}}
                  </span>
                </div>
              </div>

              <div class="space-y-4">
                <div>
                  <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">예약 시간</h3>
                  <div class="bg-slate-50 text-slate-700 p-3 rounded-xl text-sm border border-slate-100">
                    {{detail.timeSlot}}
                  </div>
                </div>
                <div>
                  <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">환자 메모</h3>
                  <div class="bg-orange-50 text-orange-900 p-3 rounded-xl text-sm border border-orange-100 leading-relaxed">
                    {{detail.note}}
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- 우측: 진료 기록 작성 or 완료된 기록 -->
          <div class="col-span-2 bg-white rounded-2xl shadow-sm border border-slate-200 flex flex-col">
            <div class="p-6 border-b border-slate-200 flex items-center gap-2">
              <i data-feather="file-text" class="w-5 h-5 text-indigo-600"></i>
              <h2 class="text-lg font-bold text-slate-800">진료 기록</h2>
            </div>

            {{#detail.canComplete}}
              <!-- 진료 기록 작성 폼 (id로 푸터 버튼과 연결) -->
              <form id="complete-form" action="/doctor/treatment/complete" method="post" class="flex-1 flex flex-col">
                <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
                <input type="hidden" name="id" value="{{detail.reservationId}}">

                <div class="p-6 flex-1 flex flex-col gap-4">
                  <div class="flex-1 flex flex-col">
                    <label class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">진단 내용</label>
                    <textarea
                      name="diagnosis"
                      required
                      class="flex-1 w-full p-4 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none resize-none text-slate-700 leading-relaxed"
                      placeholder="진단 내용을 입력해주세요."
                    ></textarea>
                  </div>
                  <div class="flex-1 flex flex-col">
                    <label class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">처방 내역</label>
                    <textarea
                      name="prescription"
                      required
                      class="flex-1 w-full p-4 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none resize-none text-slate-700 leading-relaxed"
                      placeholder="처방 내역을 입력해주세요."
                    ></textarea>
                  </div>
                  <div>
                    <label class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">특이사항 (선택)</label>
                    <textarea
                      name="remark"
                      rows="2"
                      class="w-full p-4 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none resize-none text-slate-700 leading-relaxed"
                      placeholder="특이사항을 입력해주세요."
                    ></textarea>
                  </div>
                </div>
              </form>

              <!-- 푸터: 진료 시작 form + 진료 완료 버튼 (form 밖에 별도 배치) -->
              <div class="p-6 border-t border-slate-200 bg-slate-50 rounded-b-2xl flex justify-between items-center">
                <div>
                  {{#detail.canStartTreatment}}
                  <form method="post" action="/doctor/treatment/start">
                    <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
                    <input type="hidden" name="id" value="{{detail.reservationId}}">
                    <button type="submit"
                            class="px-6 py-3 font-medium rounded-xl shadow-sm flex items-center gap-2"
                            style="background-color:#ea580c;color:#fff;">
                      <i data-feather="play" class="w-5 h-5"></i>
                      진료 시작
                    </button>
                  </form>
                  {{/detail.canStartTreatment}}
                </div>
                <button
                  type="submit"
                  form="complete-form"
                  class="px-8 py-3 bg-indigo-600 text-white font-medium rounded-xl hover:bg-indigo-700 transition-colors shadow-sm flex items-center gap-2"
                >
                  <i data-feather="check-circle" class="w-5 h-5"></i>
                  진료 완료
                </button>
              </div>
            {{/detail.canComplete}}

            {{^detail.canComplete}}
              <!-- 완료된 진료 기록 조회 -->
              <div class="p-6 flex-1 flex flex-col gap-4">
                {{#detail.diagnosis}}
                  <div>
                    <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">진단 내용</h3>
                    <div class="bg-slate-50 text-slate-700 p-4 rounded-xl text-sm border border-slate-100 leading-relaxed">{{detail.diagnosis}}</div>
                  </div>
                  <div>
                    <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">처방 내역</h3>
                    <div class="bg-slate-50 text-slate-700 p-4 rounded-xl text-sm border border-slate-100 leading-relaxed">{{detail.prescription}}</div>
                  </div>
                  {{#detail.remark}}
                    <div>
                      <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">특이사항</h3>
                      <div class="bg-slate-50 text-slate-700 p-4 rounded-xl text-sm border border-slate-100 leading-relaxed">{{detail.remark}}</div>
                    </div>
                  {{/detail.remark}}
                {{/detail.diagnosis}}
                {{^detail.diagnosis}}
                  <div class="flex-1 flex items-center justify-center text-slate-400 text-sm">
                    아직 진료 기록이 없습니다.
                  </div>
                {{/detail.diagnosis}}
              </div>

              <div class="px-6 pb-4 space-y-2">
                <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">사용 물품 내역</h3>
                <div class="bg-slate-50 rounded-xl border border-slate-100 overflow-hidden">
                  <table class="w-full text-xs">
                    <thead class="bg-slate-100 text-slate-500">
                      <tr>
                        <th class="px-3 py-2 text-left font-medium">물품명</th>
                        <th class="px-3 py-2 text-right font-medium">수량</th>
                        <th class="px-3 py-2 text-right font-medium">시간</th>
                      </tr>
                    </thead>
                    <tbody id="usage-log-tbody" class="divide-y divide-slate-100">
                      {{#usageLogs}}
                      <tr>
                        <td class="px-3 py-2 text-slate-700 font-medium">{{itemName}}</td>
                        <td class="px-3 py-2 text-right text-slate-600">{{amount}}개</td>
                        <td class="px-3 py-2 text-right text-slate-400">{{usedAt}}</td>
                      </tr>
                      {{/usageLogs}}
                      {{^usageLogs}}
                      <tr id="usage-log-empty"><td colspan="3" class="px-3 py-2 text-xs text-slate-400">사용된 물품이 없습니다.</td></tr>
                      {{/usageLogs}}
                    </tbody>
                  </table>
                </div>
                <div id="usage-log-pagination" class="flex items-center justify-between pt-1" style="display:none!important">
                  <span id="usage-log-page-info" class="text-xs text-slate-500"></span>
                  <div class="flex items-center gap-2">
                    <button id="usage-log-prev" type="button"
                            class="px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-100 disabled:opacity-40 disabled:cursor-not-allowed transition-colors">
                      이전
                    </button>
                    <div id="usage-log-page-numbers" class="flex items-center gap-1"></div>
                    <button id="usage-log-next" type="button"
                            class="px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-100 disabled:opacity-40 disabled:cursor-not-allowed transition-colors">
                      다음
                    </button>
                  </div>
                </div>
              </div>

              <div class="p-6 border-t border-slate-200 bg-slate-50 rounded-b-2xl flex items-center justify-between">
                <span class="text-sm font-medium text-green-600 flex items-center gap-1">
                  <i data-feather="check-circle" class="w-4 h-4"></i>
                  진료 완료
                </span>
                <a href="/doctor/completed-list" class="text-sm text-indigo-600 hover:text-indigo-800">
                  완료 목록 보기
                </a>
              </div>
            {{/detail.canComplete}}
          </div>
        </div>

        {{#detail.canComplete}}
        <!-- 물품 사용 섹션 — 진료 기록 아래 전체 너비 -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 space-y-4">
          <div class="flex items-center justify-between">
            <h3 class="text-base font-bold text-slate-800 flex items-center gap-2">
              <i data-feather="package" class="w-5 h-5 text-indigo-600"></i>
              물품 사용
            </h3>
            <!-- 카테고리 필터 -->
            <div class="flex gap-1.5" id="item-category-btns">
              <button type="button" data-cat="" class="item-cat-btn px-3 py-1.5 text-xs font-medium rounded-lg bg-indigo-600 text-white transition-colors">전체</button>
              <button type="button" data-cat="MEDICAL_SUPPLIES" class="item-cat-btn px-3 py-1.5 text-xs font-medium rounded-lg bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors">의료소모품</button>
              <button type="button" data-cat="MEDICAL_EQUIPMENT" class="item-cat-btn px-3 py-1.5 text-xs font-medium rounded-lg bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors">의료기기</button>
              <button type="button" data-cat="GENERAL_SUPPLIES" class="item-cat-btn px-3 py-1.5 text-xs font-medium rounded-lg bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors">사무/비품</button>
            </div>
          </div>
          <!-- 검색 -->
          <div class="relative">
            <i data-feather="search" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"></i>
            <input type="text" id="item-search" placeholder="물품명 검색 (초성·영문 가능)"
                   class="w-full pl-9 pr-4 py-2 text-sm border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-300">
          </div>
          <!-- 물품 카드 목록 — 가로 배치 -->
          <div class="grid grid-cols-4 gap-3" id="item-use-grid">
            {{#items}}
            <div class="item-card border border-slate-200 rounded-xl p-3 space-y-2" data-category="{{category}}">
              <div class="item-name text-sm font-bold text-slate-800 truncate">{{name}}</div>
              <div class="text-xs text-slate-500">{{categoryText}}</div>
              <div class="text-xs font-bold {{#lowStock}}text-red-600{{/lowStock}}{{^lowStock}}text-slate-600{{/lowStock}}">
                재고: <span class="quantity-span">{{quantity}}</span>개
              </div>
              <form action="/doctor/item/use" method="post" class="flex items-center gap-1">
                <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
                <input type="hidden" name="id" value="{{id}}">
                <input type="hidden" name="reservationId" value="{{detail.reservationId}}">
                <input type="number" name="amount" min="1" placeholder="수량"
                       class="flex-1 w-0 px-2 py-1 text-xs border border-slate-300 rounded-lg text-center focus:outline-none focus:ring-1 focus:ring-indigo-400">
                <button type="submit" class="px-2 py-1 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-bold rounded-lg transition-colors whitespace-nowrap">
                  사용
                </button>
              </form>
            </div>
            {{/items}}
          </div>
          <div id="card-grid-pagination" class="flex items-center justify-center pt-2" style="display:none!important">
            <div class="flex items-center gap-2">
              <button id="card-grid-prev" type="button"
                      class="px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-100 disabled:opacity-40 disabled:cursor-not-allowed transition-colors">이전</button>
              <div id="card-grid-page-numbers" class="flex items-center gap-1"></div>
              <button id="card-grid-next" type="button"
                      class="px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-100 disabled:opacity-40 disabled:cursor-not-allowed transition-colors">다음</button>
            </div>
          </div>
        </div>
        {{/detail.canComplete}}

      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>
    // 초성 추출
    var CHOSUNG = ['ㄱ','ㄲ','ㄴ','ㄷ','ㄸ','ㄹ','ㅁ','ㅂ','ㅃ','ㅅ','ㅆ','ㅇ','ㅈ','ㅉ','ㅊ','ㅋ','ㅌ','ㅍ','ㅎ'];
    function getChosung(str) {
      return str.split('').map(function(ch) {
        var code = ch.charCodeAt(0);
        if (code >= 0xAC00 && code <= 0xD7A3) return CHOSUNG[Math.floor((code - 0xAC00) / 588)];
        return ch;
      }).join('');
    }
    function isChosungOnly(str) { return /^[ㄱ-ㅎ]+$/.test(str); }
    function itemMatches(name, query) {
      if (!query) return true;
      var q = query.toLowerCase();
      if (isChosungOnly(q)) return getChosung(name).includes(q);
      return name.toLowerCase().includes(q);
    }

    // ── usage-log 페이징 ──
    var USAGE_LOG_PAGE_SIZE = 10;
    var usageLogPage = 1;

    function buildUsageLogPageNumbers(current, total) {
      var container = document.getElementById('usage-log-page-numbers');
      container.innerHTML = '';
      if (total <= 1) return;
      var start = Math.max(1, current - 2);
      var end   = Math.min(total, start + 4);
      if (end - start < 4) start = Math.max(1, end - 4);
      function makeBtn(n) {
        var b = document.createElement('button');
        b.type = 'button'; b.textContent = n;
        b.className = 'px-2 py-1 text-xs rounded-lg border transition-colors ' +
          (n === current ? 'bg-indigo-600 text-white border-indigo-600' : 'border-slate-200 text-slate-600 hover:bg-slate-100');
        b.addEventListener('click', function() { usageLogPage = n; renderUsageLog(); });
        return b;
      }
      function makeDots() {
        var s = document.createElement('span'); s.textContent = '...';
        s.className = 'px-1 text-xs text-slate-400'; return s;
      }
      if (start > 1) { container.appendChild(makeBtn(1)); if (start > 2) container.appendChild(makeDots()); }
      for (var i = start; i <= end; i++) container.appendChild(makeBtn(i));
      if (end < total) { if (end < total - 1) container.appendChild(makeDots()); container.appendChild(makeBtn(total)); }
    }

    function renderUsageLog() {
      var rows = Array.from(document.querySelectorAll('#usage-log-tbody tr:not(#usage-log-empty)'));
      var total = rows.length;
      var totalPages = Math.max(1, Math.ceil(total / USAGE_LOG_PAGE_SIZE));
      if (usageLogPage > totalPages) usageLogPage = totalPages;
      if (usageLogPage < 1) usageLogPage = 1;
      var start = (usageLogPage - 1) * USAGE_LOG_PAGE_SIZE;
      rows.forEach(function(r, i) { r.style.display = (i >= start && i < start + USAGE_LOG_PAGE_SIZE) ? '' : 'none'; });
      var bar = document.getElementById('usage-log-pagination');
      if (total === 0 || totalPages <= 1) { bar.style.removeProperty('display'); bar.style.display = 'none'; }
      else { bar.style.removeProperty('display'); }
      buildUsageLogPageNumbers(usageLogPage, totalPages);
      document.getElementById('usage-log-prev').disabled = usageLogPage <= 1;
      document.getElementById('usage-log-next').disabled = usageLogPage >= totalPages;
    }

    var usageLogPrevBtn = document.getElementById('usage-log-prev');
    var usageLogNextBtn = document.getElementById('usage-log-next');
    if (usageLogPrevBtn) {
      usageLogPrevBtn.addEventListener('click', function() {
        if (usageLogPage > 1) { usageLogPage--; renderUsageLog(); }
      });
      usageLogNextBtn.addEventListener('click', function() {
        var rows = document.querySelectorAll('#usage-log-tbody tr:not(#usage-log-empty)');
        var totalPages = Math.max(1, Math.ceil(rows.length / USAGE_LOG_PAGE_SIZE));
        if (usageLogPage < totalPages) { usageLogPage++; renderUsageLog(); }
      });
      renderUsageLog();
    }

    // ── 카드 그리드 페이징 ──
    var CARD_PAGE_SIZE = 10;
    var cardPage = 1;
    var currentCat = '';

    function buildCardPageNumbers(current, total) {
      var container = document.getElementById('card-grid-page-numbers');
      if (!container) return;
      container.innerHTML = '';
      if (total <= 1) return;
      var start = Math.max(1, current - 2);
      var end   = Math.min(total, start + 4);
      if (end - start < 4) start = Math.max(1, end - 4);
      function makeBtn(n) {
        var b = document.createElement('button');
        b.type = 'button'; b.textContent = n;
        b.className = 'px-2 py-1 text-xs rounded-lg border transition-colors ' +
          (n === current ? 'bg-indigo-600 text-white border-indigo-600' : 'border-slate-200 text-slate-600 hover:bg-slate-100');
        b.addEventListener('click', function() { cardPage = n; applyFilter(); });
        return b;
      }
      function makeDots() {
        var s = document.createElement('span'); s.textContent = '...';
        s.className = 'px-1 text-xs text-slate-400'; return s;
      }
      if (start > 1) { container.appendChild(makeBtn(1)); if (start > 2) container.appendChild(makeDots()); }
      for (var i = start; i <= end; i++) container.appendChild(makeBtn(i));
      if (end < total) { if (end < total - 1) container.appendChild(makeDots()); container.appendChild(makeBtn(total)); }
    }

    function applyFilter() {
      var searchEl = document.getElementById('item-search');
      var query = searchEl ? searchEl.value.trim() : '';
      var allCards = Array.from(document.querySelectorAll('#item-use-grid .item-card'));
      var filtered = allCards.filter(function(card) {
        var catOk  = !currentCat || card.dataset.category === currentCat;
        var nameOk = itemMatches(card.querySelector('.item-name').textContent, query);
        return catOk && nameOk;
      });
      var totalPages = Math.max(1, Math.ceil(filtered.length / CARD_PAGE_SIZE));
      if (cardPage > totalPages) cardPage = totalPages;
      if (cardPage < 1) cardPage = 1;
      var startIdx = (cardPage - 1) * CARD_PAGE_SIZE;
      allCards.forEach(function(c) { c.style.display = 'none'; });
      filtered.forEach(function(c, i) { c.style.display = (i >= startIdx && i < startIdx + CARD_PAGE_SIZE) ? '' : 'none'; });
      var bar = document.getElementById('card-grid-pagination');
      if (bar) {
        if (filtered.length === 0 || totalPages <= 1) { bar.style.removeProperty('display'); bar.style.display = 'none'; }
        else { bar.style.removeProperty('display'); }
        buildCardPageNumbers(cardPage, totalPages);
        var prevBtn = document.getElementById('card-grid-prev');
        var nextBtn = document.getElementById('card-grid-next');
        if (prevBtn) prevBtn.disabled = cardPage <= 1;
        if (nextBtn) nextBtn.disabled = cardPage >= totalPages;
      }
    }

    // 검색 이벤트 (canComplete=true 일 때만 존재)
    var searchInput = document.getElementById('item-search');
    if (searchInput) searchInput.addEventListener('input', function() { cardPage = 1; applyFilter(); });

    // 카테고리 필터
    document.querySelectorAll('.item-cat-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        currentCat = this.dataset.cat;
        document.querySelectorAll('.item-cat-btn').forEach(function(b) {
          b.className = 'item-cat-btn px-3 py-1.5 text-xs font-medium rounded-lg bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors';
        });
        this.className = 'item-cat-btn px-3 py-1.5 text-xs font-medium rounded-lg bg-indigo-600 text-white transition-colors';
        cardPage = 1;
        applyFilter();
      });
    });

    // 카드 그리드 이전/다음 버튼
    var cardPrevBtn = document.getElementById('card-grid-prev');
    var cardNextBtn = document.getElementById('card-grid-next');
    if (cardPrevBtn) {
      cardPrevBtn.addEventListener('click', function() {
        if (cardPage > 1) { cardPage--; applyFilter(); }
      });
      cardNextBtn.addEventListener('click', function() {
        var searchEl = document.getElementById('item-search');
        var query = searchEl ? searchEl.value.trim() : '';
        var filtered = Array.from(document.querySelectorAll('#item-use-grid .item-card')).filter(function(c) {
          return (!currentCat || c.dataset.category === currentCat) && itemMatches(c.querySelector('.item-name').textContent, query);
        });
        var totalPages = Math.max(1, Math.ceil(filtered.length / CARD_PAGE_SIZE));
        if (cardPage < totalPages) { cardPage++; applyFilter(); }
      });
    }

    // 사용 물품 내역 실시간 갱신
    function refreshUsageLogs(logs) {
      var tbody = document.getElementById('usage-log-tbody');
      if (!tbody) return;
      Array.from(tbody.querySelectorAll('tr:not(#usage-log-empty)')).forEach(function(r) { r.remove(); });
      var emptyRow = document.getElementById('usage-log-empty');
      if (logs && logs.length > 0) {
        if (emptyRow) emptyRow.style.display = 'none';
        logs.forEach(function(log) {
          const tr = document.createElement('tr');
          const td1 = document.createElement('td'); td1.className = 'px-3 py-2 text-slate-700 font-medium'; td1.textContent = log.itemName;
          const td2 = document.createElement('td'); td2.className = 'px-3 py-2 text-right text-slate-600'; td2.textContent = log.amount + '개';
          const td3 = document.createElement('td'); td3.className = 'px-3 py-2 text-right text-slate-400'; td3.textContent = log.usedAt;
          tr.appendChild(td1); tr.appendChild(td2); tr.appendChild(td3);
          tbody.appendChild(tr);
        });
      } else {
        if (emptyRow) emptyRow.style.display = '';
      }
      usageLogPage = 1;
      renderUsageLog();
    }

    // 물품 사용 AJAX
    document.querySelectorAll('form[action$="/doctor/item/use"]').forEach(function(form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var input = form.querySelector('input[name="amount"]');
        var value = input.value.trim();
        var amount = Number(value);
        if (value === '' || isNaN(amount) || !Number.isInteger(amount) || amount <= 0) {
          alert('올바른 수량을 입력해주세요. (1 이상의 정수)');
          return;
        }
        var id = form.querySelector('input[name="id"]').value;
        var reservationId = form.querySelector('input[name="reservationId"]').value;
        var csrfInput = form.querySelector('input[type="hidden"]:not([name="id"]):not([name="reservationId"])');
        var params = new URLSearchParams();
        params.append('id', id);
        params.append('amount', value);
        params.append('reservationId', reservationId);
        params.append(csrfInput.name, csrfInput.value);

        fetch('/doctor/item/use', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: params.toString()
        })
        .then(function(res) { return res.json(); })
        .then(function(data) {
          if (data.quantity !== undefined) {
            var card = form.closest('.item-card');
            card.querySelector('.quantity-span').textContent = data.quantity;
            input.value = '';
            refreshUsageLogs(data.logs || []);
          } else if (data.error) {
            alert(data.error);
          }
        });
      });
    });

    // 초기 렌더
    if (document.getElementById('item-use-grid')) applyFilter();
  </script>
  <script>feather.replace();</script>
</body>
</html>
