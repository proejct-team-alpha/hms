<form method="post" action="{{formAction}}" class="space-y-5">
  <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
  {{#hasRuleId}}
    <input type="hidden" name="ruleId" value="{{ruleIdValue}}">
  {{/hasRuleId}}

  <div>
    <label class="block text-sm font-semibold text-slate-700 mb-1.5">카테고리 <span class="text-red-500">*</span></label>
    <select name="category" required
      class="w-full px-4 py-2.5 rounded-xl border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300 bg-white">
      <option value="">카테고리를 선택하세요</option>
      <option value="EMERGENCY" {{#emergencySelected}}selected{{/emergencySelected}}>응급</option>
      <option value="SUPPLY" {{#supplySelected}}selected{{/supplySelected}}>물품</option>
      <option value="DUTY" {{#dutySelected}}selected{{/dutySelected}}>근무</option>
      <option value="HYGIENE" {{#hygieneSelected}}selected{{/hygieneSelected}}>위생</option>
      <option value="OTHER" {{#otherSelected}}selected{{/otherSelected}}>기타</option>
    </select>
    {{#categoryError}}
      <p class="mt-2 text-sm font-medium text-red-600">{{categoryError}}</p>
    {{/categoryError}}
  </div>

  <div>
    <label class="block text-sm font-semibold text-slate-700 mb-1.5">제목 <span class="text-red-500">*</span></label>
    <input type="text" name="title" value="{{titleValue}}" required
      class="w-full px-4 py-2.5 rounded-xl border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
      placeholder="규칙 제목을 입력하세요">
    {{#titleError}}
      <p class="mt-2 text-sm font-medium text-red-600">{{titleError}}</p>
    {{/titleError}}
  </div>

  <div>
    <label class="block text-sm font-semibold text-slate-700 mb-1.5">내용 <span class="text-red-500">*</span></label>
    <textarea name="content" rows="6" required
      class="w-full px-4 py-2.5 rounded-xl border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300 resize-none"
      placeholder="규칙 내용을 입력하세요">{{contentValue}}</textarea>
    {{#contentError}}
      <p class="mt-2 text-sm font-medium text-red-600">{{contentError}}</p>
    {{/contentError}}
  </div>

  <div class="flex items-center gap-2">
    <input type="checkbox" name="active" id="rule-active-check" value="true" {{#activeChecked}}checked{{/activeChecked}} class="w-4 h-4 accent-indigo-600">
    <label for="rule-active-check" class="text-sm text-slate-700">활성</label>
  </div>

  <div class="flex gap-3 pt-4">
    <button type="submit"
      class="flex-1 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-xl hover:bg-indigo-700 transition-colors">
      {{submitLabel}}
    </button>
    <a href="{{cancelUrl}}"
      class="flex-1 py-2.5 bg-slate-100 text-slate-700 text-sm font-semibold rounded-xl hover:bg-slate-200 transition-colors text-center">
      취소
    </a>
  </div>
</form>
