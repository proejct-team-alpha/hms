<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{pageTitle}} - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex bg-slate-50">
  {{> common/sidebar-admin}}

  <div class="main-content flex-1 flex flex-col ml-64 min-h-screen">
    {{> common/header-staff}}

    <main class="flex-1 p-8">
      <div class="max-w-6xl mx-auto w-full space-y-6">
        <div class="flex items-center justify-between gap-4">
          <div class="flex items-center gap-4">
            <a
              href="/admin/patient/list"
              class="w-10 h-10 flex items-center justify-center text-slate-400 hover:text-slate-600 hover:bg-white rounded-xl border border-transparent hover:border-slate-200 hover:shadow-sm transition-all"
            >
              <i data-feather="arrow-left" class="w-5 h-5"></i>
            </a>

            <div>
              <h1 class="text-2xl font-bold text-slate-900 tracking-tight">{{pageTitle}}</h1>
              <p class="text-slate-500 mt-1">환자 기본 정보와 전체 예약 이력을 확인합니다.</p>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <section class="lg:col-span-1 space-y-6">
            <div
              class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden"
              data-patient-detail-card
              data-patient-id="{{model.patientId}}"
              data-patient-update-url="/admin/api/patients/{{model.patientId}}/update"
            >
              <div class="p-6 border-b border-slate-100 bg-slate-50/60 flex items-start justify-between gap-4">
                <div>
                  <h2 class="font-bold text-slate-800">기본 정보</h2>
                  <p class="text-sm text-slate-500 mt-1">환자 식별 정보와 연락처를 확인</p>
                </div>
                <button
                  type="button"
                  data-patient-edit-toggle
                  class="inline-flex items-center gap-1 px-3 py-1.5 bg-slate-100 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-200 transition-colors"
                >
                  수정
                </button>
              </div>

              <div class="p-6 space-y-5">
                <div
                  data-patient-feedback
                  class="hidden rounded-xl border px-4 py-3 text-sm font-medium"
                ></div>

                <div data-patient-view-section class="space-y-5">
                  <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide">환자 ID</p>
                    <p class="mt-2 text-lg font-semibold text-slate-900">{{model.patientId}}</p>
                  </div>

                  <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide">이름</p>
                    <p class="mt-2 text-sm font-medium text-slate-800" data-patient-name-value>{{model.name}}</p>
                  </div>

                  <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide">연락처</p>
                    <p class="mt-2 text-sm font-medium text-slate-800" data-patient-phone-value>{{model.phone}}</p>
                  </div>

                  <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide">이메일</p>
                    <p class="mt-2 text-sm text-slate-700">{{model.email}}</p>
                  </div>

                  <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide">주소</p>
                    <p class="mt-2 text-sm text-slate-700 leading-relaxed">{{model.address}}</p>
                  </div>

                  <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide">메모</p>
                    <p class="mt-2 text-sm text-slate-700 leading-relaxed whitespace-pre-wrap" data-patient-note-value>{{model.note}}</p>
                  </div>
                </div>

                <form data-patient-edit-form class="hidden space-y-5" novalidate>
                  <div>
                    <label for="patient-name" class="block text-sm font-semibold text-slate-700 mb-2">이름</label>
                    <input
                      id="patient-name"
                      name="name"
                      type="text"
                      value="{{model.name}}"
                      class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm text-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-300"
                    >
                    <p data-field-error="name" class="hidden mt-2 text-sm font-medium text-red-600"></p>
                  </div>

                  <div>
                    <label for="patient-phone" class="block text-sm font-semibold text-slate-700 mb-2">연락처</label>
                    <input
                      id="patient-phone"
                      name="phone"
                      type="text"
                      value="{{model.phone}}"
                      class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm text-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-300"
                    >
                    <p data-field-error="phone" class="hidden mt-2 text-sm font-medium text-red-600"></p>
                  </div>

                  <div>
                    <label for="patient-note" class="block text-sm font-semibold text-slate-700 mb-2">메모</label>
                    <textarea
                      id="patient-note"
                      name="note"
                      rows="4"
                      class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm text-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-300 resize-none"
                    >{{model.noteValue}}</textarea>
                  </div>

                  <div class="flex items-center justify-end gap-3 pt-2">
                    <button
                      type="button"
                      data-patient-edit-cancel
                      class="inline-flex items-center gap-2 px-4 py-2 border border-slate-200 text-slate-600 text-sm font-semibold rounded-xl hover:bg-slate-50 transition-colors"
                    >
                      취소
                    </button>
                    <button
                      type="submit"
                      class="inline-flex items-center gap-2 px-4 py-2 bg-slate-900 text-white text-sm font-semibold rounded-xl hover:bg-slate-800 transition-colors"
                    >
                      저장
                    </button>
                  </div>
                </form>
              </div>
            </div>

            <div class="bg-indigo-600 rounded-2xl p-6 text-white shadow-lg shadow-indigo-100 relative overflow-hidden">
              <div class="relative z-10">
                <i data-feather="users" class="w-8 h-8 opacity-60 mb-4"></i>
                <p class="text-sm font-medium opacity-90 leading-relaxed">
                  목록 화면은 환자를 찾기 위한 인덱스 역할에 집중하고, 상세 화면에서는 해당 환자의 전체 예약 이력을 함께 확인합니다.
                </p>
              </div>
              <i data-feather="file-text" class="absolute -bottom-4 -right-4 w-24 h-24 opacity-10"></i>
            </div>
          </section>

          <section class="lg:col-span-2">
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
              <div class="p-6 border-b border-slate-100 bg-slate-50/60">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                  <div>
                    <h2 class="font-bold text-slate-800">예약 이력</h2>
                    <p class="text-sm text-slate-500 mt-1">해당 환자의 전체 예약 및 접수 이력을 시간 순으로 확인합니다.</p>
                  </div>
                  <div class="flex items-center gap-2 flex-wrap">
                    <input type="date" id="hist-from" class="px-3 py-1.5 text-sm border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-400">
                    <span class="text-slate-400 text-xs">~</span>
                    <input type="date" id="hist-to" class="px-3 py-1.5 text-sm border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-400">
                    <button type="button" id="hist-filter-btn" class="px-3 py-1.5 text-xs font-semibold bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors">검색</button>
                    <button type="button" id="hist-reset-btn" class="px-3 py-1.5 text-xs font-semibold border border-slate-200 text-slate-600 rounded-lg hover:bg-slate-50 transition-colors">초기화</button>
                  </div>
                </div>
              </div>

              <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                  <thead>
                    <tr class="bg-slate-50 border-b border-slate-200 text-xs uppercase tracking-wider text-slate-500">
                      <th class="p-4 font-medium">예약번호</th>
                      <th class="p-4 font-medium">날짜</th>
                      <th class="p-4 font-medium">시간</th>
                      <th class="p-4 font-medium">진료과</th>
                      <th class="p-4 font-medium">의사</th>
                      <th class="p-4 font-medium">상태</th>
                    </tr>
                  </thead>
                  <tbody id="reservation-history-tbody" class="divide-y divide-slate-200">
                    {{#model.reservationHistories}}
                      <tr class="history-row hover:bg-slate-50 transition-colors"
                          data-date="{{reservationDate}}">
                        <td class="p-4 text-sm font-semibold text-slate-800">{{reservationNumber}}</td>
                        <td class="p-4 text-sm text-slate-700">{{reservationDate}}</td>
                        <td class="p-4 text-sm text-slate-700">{{timeSlot}}</td>
                        <td class="p-4 text-sm text-slate-700">{{departmentName}}</td>
                        <td class="p-4 text-sm text-slate-700">{{doctorName}}</td>
                        <td class="p-4 text-sm font-medium text-slate-800">{{statusText}}</td>
                      </tr>
                    {{/model.reservationHistories}}
                    {{^model.reservationHistories}}
                      <tr id="history-empty-row">
                        <td colspan="6" class="p-8 text-center text-slate-500">등록된 예약 이력이 없습니다.</td>
                      </tr>
                    {{/model.reservationHistories}}
                  </tbody>
                </table>
              </div>

              <div id="history-pagination-bar" class="p-4 border-t border-slate-100 flex items-center justify-center gap-2 bg-slate-50" style="display:none!important">
                <button id="hist-prev" type="button" class="px-3 py-1.5 text-sm rounded-md border border-slate-300 text-slate-600 hover:bg-white disabled:opacity-40">이전</button>
                <div id="hist-page-numbers" class="flex items-center gap-1"></div>
                <button id="hist-next" type="button" class="px-3 py-1.5 text-sm rounded-md border border-slate-300 text-slate-600 hover:bg-white disabled:opacity-40">다음</button>
              </div>
            </div>
          </section>
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>
    feather.replace();

    // ── 예약 이력 페이징 + 기간 검색 ──
    (function () {
      var HIST_PAGE_SIZE = 10;
      var histPage = 1;
      var allRows = Array.from(document.querySelectorAll('.history-row'));

      function getFilteredRows() {
        var from = document.getElementById('hist-from').value;
        var to   = document.getElementById('hist-to').value;
        return allRows.filter(function(row) {
          var d = row.getAttribute('data-date');
          if (from && d < from) return false;
          if (to   && d > to)   return false;
          return true;
        });
      }

      function renderHistPagination() {
        var filtered = getFilteredRows();
        var total = filtered.length;
        var totalPages = Math.max(1, Math.ceil(total / HIST_PAGE_SIZE));
        if (histPage > totalPages) histPage = totalPages;
        var start = (histPage - 1) * HIST_PAGE_SIZE;
        allRows.forEach(function(r) { r.style.display = 'none'; });
        filtered.slice(start, start + HIST_PAGE_SIZE).forEach(function(r) { r.style.display = ''; });
        var emptyRow = document.getElementById('history-empty-row');
        if (emptyRow) emptyRow.style.display = total === 0 ? '' : 'none';
        var bar = document.getElementById('history-pagination-bar');
        if (bar) bar.style.cssText = (total === 0 || totalPages <= 1) ? 'display:none' : 'display:flex';
        var container = document.getElementById('hist-page-numbers');
        if (container) {
          container.innerHTML = '';
          for (var i = 1; i <= totalPages; i++) {
            (function(n) {
              var b = document.createElement('a');
              b.href = '#'; b.textContent = n;
              b.className = 'px-3 py-1.5 text-sm rounded-md border transition-colors ' +
                (n === histPage ? 'bg-slate-800 border-slate-800 text-white' : 'border-slate-300 text-slate-600 hover:bg-white');
              b.addEventListener('click', function(e) { e.preventDefault(); histPage = n; renderHistPagination(); });
              container.appendChild(b);
            })(i);
          }
        }
        var prevBtn = document.getElementById('hist-prev');
        var nextBtn = document.getElementById('hist-next');
        if (prevBtn) { prevBtn.disabled = histPage <= 1; prevBtn.onclick = function() { if (histPage > 1) { histPage--; renderHistPagination(); } }; }
        if (nextBtn) { nextBtn.disabled = histPage >= totalPages; nextBtn.onclick = function() { if (histPage < totalPages) { histPage++; renderHistPagination(); } }; }
      }

      var filterBtn = document.getElementById('hist-filter-btn');
      var resetBtn  = document.getElementById('hist-reset-btn');
      if (filterBtn) filterBtn.addEventListener('click', function() { histPage = 1; renderHistPagination(); });
      if (resetBtn)  resetBtn.addEventListener('click', function() {
        document.getElementById('hist-from').value = '';
        document.getElementById('hist-to').value   = '';
        histPage = 1;
        renderHistPagination();
      });

      renderHistPagination();
    })();

    (function () {
      const detailCard = document.querySelector('[data-patient-detail-card]');

      if (!detailCard) {
        return;
      }

      const updateUrl = detailCard.dataset.patientUpdateUrl;
      const feedback = detailCard.querySelector('[data-patient-feedback]');
      const editToggleButton = detailCard.querySelector('[data-patient-edit-toggle]');
      const viewSection = detailCard.querySelector('[data-patient-view-section]');
      const editForm = detailCard.querySelector('[data-patient-edit-form]');
      const cancelButton = detailCard.querySelector('[data-patient-edit-cancel]');
      const nameInput = detailCard.querySelector('#patient-name');
      const phoneInput = detailCard.querySelector('#patient-phone');
      const noteInput = detailCard.querySelector('#patient-note');
      const nameValue = detailCard.querySelector('[data-patient-name-value]');
      const phoneValue = detailCard.querySelector('[data-patient-phone-value]');
      const noteValue = detailCard.querySelector('[data-patient-note-value]');
      const csrfToken = '{{_csrf.token}}';

      const state = {
        name: nameInput.value,
        phone: phoneInput.value,
        note: noteInput.value
      };

      function clearFieldErrors() {
        detailCard.querySelectorAll('[data-field-error]').forEach((fieldError) => {
          fieldError.textContent = '';
          fieldError.classList.add('hidden');
        });
      }

      function setFieldError(fieldName, message) {
        const target = detailCard.querySelector(`[data-field-error="${fieldName}"]`);

        if (!target) {
          return;
        }

        target.textContent = message;
        target.classList.remove('hidden');
      }

      function showFeedback(type, message) {
        feedback.className = 'rounded-xl border px-4 py-3 text-sm font-medium';

        if (type === 'success') {
          feedback.classList.add('border-green-200', 'bg-green-50', 'text-green-700');
        } else {
          feedback.classList.add('border-red-200', 'bg-red-50', 'text-red-700');
        }

        feedback.textContent = message;
        feedback.classList.remove('hidden');
      }

      function hideFeedback() {
        feedback.textContent = '';
        feedback.classList.add('hidden');
      }

      function syncFormWithState() {
        nameInput.value = state.name;
        phoneInput.value = state.phone;
        noteInput.value = state.note;
      }

      function enterEditMode() {
        hideFeedback();
        clearFieldErrors();
        syncFormWithState();
        viewSection.classList.add('hidden');
        editForm.classList.remove('hidden');
        editToggleButton.classList.add('hidden');
        nameInput.focus();
      }

      function exitEditMode() {
        clearFieldErrors();
        editForm.classList.add('hidden');
        viewSection.classList.remove('hidden');
        editToggleButton.classList.remove('hidden');
      }

      function updateViewValues(body) {
        state.name = body.name;
        state.phone = body.phone;
        state.note = body.note ?? '';

        nameValue.textContent = state.name;
        phoneValue.textContent = state.phone;
        noteValue.textContent = state.note === '' ? '-' : state.note;

        syncFormWithState();
      }

      function applyError(payload) {
        const message = payload && payload.msg ? payload.msg : '';

        if (message.includes('VALIDATION_ERROR')) {
          if (message.includes('name:')) {
            setFieldError('name', '이름을 입력해 주세요.');
          }
          if (message.includes('phone:')) {
            setFieldError('phone', '연락처를 입력해 주세요.');
          }
          showFeedback('error', '입력값을 확인해 주세요.');
          return;
        }

        if (message.includes('DUPLICATE_PATIENT_PHONE')) {
          setFieldError('phone', '이미 사용 중인 연락처입니다.');
          showFeedback('error', '연락처를 다시 확인해 주세요.');
          return;
        }

        if (message.includes('RESOURCE_NOT_FOUND')) {
          showFeedback('error', '환자 정보를 찾을 수 없습니다. 목록으로 돌아가 다시 확인해 주세요.');
          return;
        }

        showFeedback('error', '환자 정보 수정에 실패했습니다. 잠시 후 다시 시도해 주세요.');
      }

      editToggleButton.addEventListener('click', enterEditMode);
      cancelButton.addEventListener('click', exitEditMode);

      editForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        hideFeedback();
        clearFieldErrors();

        const payload = {
          name: nameInput.value.trim(),
          phone: phoneInput.value.trim(),
          note: noteInput.value
        };

        try {
          const response = await fetch(updateUrl, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'X-CSRF-TOKEN': csrfToken
            },
            body: JSON.stringify(payload)
          });

          const result = await response.json();

          if (!response.ok) {
            applyError(result);
            return;
          }

          updateViewValues(result.body);
          exitEditMode();
          showFeedback('success', result.body.message || '환자 정보가 수정되었습니다.');
        } catch (error) {
          console.error(error);
          showFeedback('error', '환자 정보 수정 중 오류가 발생했습니다.');
        }
      });
    }());
  </script>
</body>
</html>