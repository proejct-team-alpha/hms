<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{pageTitle}} - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex bg-slate-50">
  {{> common/sidebar-admin}}

  <div class="main-content flex-1 flex flex-col ml-64 min-h-screen">
    {{> common/header-staff}}

    <main class="flex-1 p-8">
      <div class="max-w-6xl mx-auto w-full space-y-6">
        <div class="flex items-center justify-between gap-4">
          <div class="flex items-center gap-4">
            <a
              href="/admin/patient/list"
              class="w-10 h-10 flex items-center justify-center text-slate-400 hover:text-slate-600 hover:bg-white rounded-xl border border-transparent hover:border-slate-200 hover:shadow-sm transition-all"
            >
              <i data-feather="arrow-left" class="w-5 h-5"></i>
            </a>

            <div>
              <h1 class="text-2xl font-bold text-slate-900 tracking-tight">{{pageTitle}}</h1>
              <p class="text-slate-500 mt-1">?섏옄 湲곕낯 ?뺣낫? ?꾩껜 ?덉빟 ?대젰???뺤씤?⑸땲??</p>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <section class="lg:col-span-1 space-y-6">
            <div
              class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden"
              data-patient-detail-card
              data-patient-id="{{model.patientId}}"
              data-patient-update-url="/admin/api/patients/{{model.patientId}}/update"
            >
              <div class="p-6 border-b border-slate-100 bg-slate-50/60 flex items-start justify-between gap-4">
                <div>
                  <h2 class="font-bold text-slate-800">湲곕낯 ?뺣낫</h2>
                  <p class="text-sm text-slate-500 mt-1">?섏옄 ?앸퀎 ?뺣낫? ?곕씫泥섎? ?뺤씤?섍퀬 ?꾩슂??寃쎌슦 諛붾줈 ?섏젙?⑸땲??</p>
                </div>
                <button
                  type="button"
                  data-patient-edit-toggle
                  class="inline-flex items-center gap-1 px-3 py-1.5 bg-slate-100 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-200 transition-colors"
                >
                  <i data-feather="edit-3" class="w-4 h-4"></i>
                  ?뺣낫 ?섏젙
                </button>
              </div>

              <div class="p-6 space-y-5">
                <div
                  data-patient-feedback
                  class="hidden rounded-xl border px-4 py-3 text-sm font-medium"
                ></div>

                <div data-patient-view-section class="space-y-5">
                  <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide">?섏옄 ID</p>
                    <p class="mt-2 text-lg font-semibold text-slate-900">{{model.patientId}}</p>
                  </div>

                  <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide">?대쫫</p>
                    <p class="mt-2 text-sm font-medium text-slate-800" data-patient-name-value>{{model.name}}</p>
                  </div>

                  <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide">?곕씫泥?/p>
                    <p class="mt-2 text-sm font-medium text-slate-800" data-patient-phone-value>{{model.phone}}</p>
                  </div>

                  <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide">?대찓??/p>
                    <p class="mt-2 text-sm text-slate-700">{{model.email}}</p>
                  </div>

                  <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide">二쇱냼</p>
                    <p class="mt-2 text-sm text-slate-700 leading-relaxed">{{model.address}}</p>
                  </div>

                  <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide">硫붾え</p>
                    <p class="mt-2 text-sm text-slate-700 leading-relaxed whitespace-pre-wrap" data-patient-note-value>{{model.note}}</p>
                  </div>
                </div>

                <form data-patient-edit-form class="hidden space-y-5" novalidate>
                  <div>
                    <label for="patient-name" class="block text-sm font-semibold text-slate-700 mb-2">?대쫫</label>
                    <input
                      id="patient-name"
                      name="name"
                      type="text"
                      value="{{model.name}}"
                      class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm text-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-300"
                    >
                    <p data-field-error="name" class="hidden mt-2 text-sm font-medium text-red-600"></p>
                  </div>

                  <div>
                    <label for="patient-phone" class="block text-sm font-semibold text-slate-700 mb-2">?곕씫泥?/label>
                    <input
                      id="patient-phone"
                      name="phone"
                      type="text"
                      value="{{model.phone}}"
                      class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm text-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-300"
                    >
                    <p data-field-error="phone" class="hidden mt-2 text-sm font-medium text-red-600"></p>
                  </div>

                  <div>
                    <label for="patient-note" class="block text-sm font-semibold text-slate-700 mb-2">硫붾え</label>
                    <textarea
                      id="patient-note"
                      name="note"
                      rows="4"
                      class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm text-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-300 resize-none"
                    >{{model.noteValue}}</textarea>
                  </div>

                  <div class="flex items-center justify-end gap-3 pt-2">
                    <button
                      type="button"
                      data-patient-edit-cancel
                      class="inline-flex items-center gap-2 px-4 py-2 border border-slate-200 text-slate-600 text-sm font-semibold rounded-xl hover:bg-slate-50 transition-colors"
                    >
                      痍⑥냼
                    </button>
                    <button
                      type="submit"
                      class="inline-flex items-center gap-1 px-3 py-1.5 bg-slate-100 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-200 transition-colors"
                    >
                      ???                    </button>
                  </div>
                </form>
              </div>
            </div>

            <div class="bg-indigo-600 rounded-2xl p-6 text-white shadow-lg shadow-indigo-100 relative overflow-hidden">
              <div class="relative z-10">
                <i data-feather="users" class="w-8 h-8 opacity-60 mb-4"></i>
                <p class="text-sm font-medium opacity-90 leading-relaxed">
                  紐⑸줉 ?붾㈃? ?섏옄瑜?李얘린 ?꾪븳 ?몃뜳????븷??吏묒쨷?섍퀬, ?곸꽭 ?붾㈃?먯꽌???대떦 ?섏옄???꾩껜 ?덉빟 ?대젰???④퍡 ?뺤씤?⑸땲??
                </p>
              </div>
              <i data-feather="file-text" class="absolute -bottom-4 -right-4 w-24 h-24 opacity-10"></i>
            </div>
          </section>

          <section class="lg:col-span-2">
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
              <div class="p-6 border-b border-slate-100 bg-slate-50/60">
                <div>
                  <h2 class="font-bold text-slate-800">?덉빟 ?대젰</h2>
                  <p class="text-sm text-slate-500 mt-1">?대떦 ?섏옄???꾩껜 ?덉빟 諛??묒닔 ?대젰???쒓컙 ?쒖쑝濡??뺤씤?⑸땲??</p>
                </div>
              </div>

              <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                  <thead>
                    <tr class="bg-slate-50 border-b border-slate-200 text-xs uppercase tracking-wider text-slate-500">
                      <th class="p-4 font-medium">?덉빟踰덊샇</th>
                      <th class="p-4 font-medium">?좎쭨</th>
                      <th class="p-4 font-medium">?쒓컙</th>
                      <th class="p-4 font-medium">吏꾨즺怨?/th>
                      <th class="p-4 font-medium">?섏궗</th>
                      <th class="p-4 font-medium">?곹깭</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-slate-200">
                    {{#model.reservationHistories}}
                      <tr class="hover:bg-slate-50 transition-colors">
                        <td class="p-4 text-sm font-semibold text-slate-800">{{reservationNumber}}</td>
                        <td class="p-4 text-sm text-slate-700">{{reservationDate}}</td>
                        <td class="p-4 text-sm text-slate-700">{{timeSlot}}</td>
                        <td class="p-4 text-sm text-slate-700">{{departmentName}}</td>
                        <td class="p-4 text-sm text-slate-700">{{doctorName}}</td>
                        <td class="p-4 text-sm font-medium text-slate-800">{{statusText}}</td>
                      </tr>
                    {{/model.reservationHistories}}
                    {{^model.reservationHistories}}
                      <tr>
                        <td colspan="6" class="p-8 text-center text-slate-500">?깅줉???덉빟 ?대젰???놁뒿?덈떎.</td>
                      </tr>
                    {{/model.reservationHistories}}
                  </tbody>
                </table>
              </div>
            </div>
          </section>
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>
    feather.replace();

    (function () {
      const detailCard = document.querySelector('[data-patient-detail-card]');

      if (!detailCard) {
        return;
      }

      const updateUrl = detailCard.dataset.patientUpdateUrl;
      const feedback = detailCard.querySelector('[data-patient-feedback]');
      const editToggleButton = detailCard.querySelector('[data-patient-edit-toggle]');
      const viewSection = detailCard.querySelector('[data-patient-view-section]');
      const editForm = detailCard.querySelector('[data-patient-edit-form]');
      const cancelButton = detailCard.querySelector('[data-patient-edit-cancel]');
      const nameInput = detailCard.querySelector('#patient-name');
      const phoneInput = detailCard.querySelector('#patient-phone');
      const noteInput = detailCard.querySelector('#patient-note');
      const nameValue = detailCard.querySelector('[data-patient-name-value]');
      const phoneValue = detailCard.querySelector('[data-patient-phone-value]');
      const noteValue = detailCard.querySelector('[data-patient-note-value]');
      const csrfToken = '{{_csrf.token}}';

      const state = {
        name: nameInput.value,
        phone: phoneInput.value,
        note: noteInput.value
      };

      function clearFieldErrors() {
        detailCard.querySelectorAll('[data-field-error]').forEach((fieldError) => {
          fieldError.textContent = '';
          fieldError.classList.add('hidden');
        });
      }

      function setFieldError(fieldName, message) {
        const target = detailCard.querySelector(`[data-field-error="${fieldName}"]`);

        if (!target) {
          return;
        }

        target.textContent = message;
        target.classList.remove('hidden');
      }

      function showFeedback(type, message) {
        feedback.className = 'rounded-xl border px-4 py-3 text-sm font-medium';

        if (type === 'success') {
          feedback.classList.add('border-green-200', 'bg-green-50', 'text-green-700');
        } else {
          feedback.classList.add('border-red-200', 'bg-red-50', 'text-red-700');
        }

        feedback.textContent = message;
        feedback.classList.remove('hidden');
      }

      function hideFeedback() {
        feedback.textContent = '';
        feedback.classList.add('hidden');
      }

      function syncFormWithState() {
        nameInput.value = state.name;
        phoneInput.value = state.phone;
        noteInput.value = state.note;
      }

      function enterEditMode() {
        hideFeedback();
        clearFieldErrors();
        syncFormWithState();
        viewSection.classList.add('hidden');
        editForm.classList.remove('hidden');
        editToggleButton.classList.add('hidden');
        nameInput.focus();
      }

      function exitEditMode() {
        clearFieldErrors();
        editForm.classList.add('hidden');
        viewSection.classList.remove('hidden');
        editToggleButton.classList.remove('hidden');
      }

      function updateViewValues(body) {
        state.name = body.name;
        state.phone = body.phone;
        state.note = body.note ?? '';

        nameValue.textContent = state.name;
        phoneValue.textContent = state.phone;
        noteValue.textContent = state.note === '' ? '-' : state.note;

        syncFormWithState();
      }

      function applyError(payload) {
        const message = payload && payload.msg ? payload.msg : '';

        if (message.includes('VALIDATION_ERROR')) {
          if (message.includes('name:')) {
            setFieldError('name', '?대쫫???낅젰??二쇱꽭??');
          }
          if (message.includes('phone:')) {
            setFieldError('phone', '?곕씫泥섎? ?낅젰??二쇱꽭??');
          }
          showFeedback('error', '?낅젰媛믪쓣 ?뺤씤??二쇱꽭??');
          return;
        }

        if (message.includes('DUPLICATE_PATIENT_PHONE')) {
          setFieldError('phone', '?대? ?ъ슜 以묒씤 ?곕씫泥섏엯?덈떎.');
          showFeedback('error', '?곕씫泥섎? ?ㅼ떆 ?뺤씤??二쇱꽭??');
          return;
        }

        if (message.includes('RESOURCE_NOT_FOUND')) {
          showFeedback('error', '?섏옄 ?뺣낫瑜?李얠쓣 ???놁뒿?덈떎. 紐⑸줉?쇰줈 ?뚯븘媛 ?ㅼ떆 ?뺤씤??二쇱꽭??');
          return;
        }

        showFeedback('error', '?섏옄 ?뺣낫 ?섏젙???ㅽ뙣?덉뒿?덈떎. ?좎떆 ???ㅼ떆 ?쒕룄??二쇱꽭??');
      }

      editToggleButton.addEventListener('click', enterEditMode);
      cancelButton.addEventListener('click', exitEditMode);

      editForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        hideFeedback();
        clearFieldErrors();

        const payload = {
          name: nameInput.value.trim(),
          phone: phoneInput.value.trim(),
          note: noteInput.value
        };

        try {
          const response = await fetch(updateUrl, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'X-CSRF-TOKEN': csrfToken
            },
            body: JSON.stringify(payload)
          });

          const result = await response.json();

          if (!response.ok) {
            applyError(result);
            return;
          }

          updateViewValues(result.body);
          exitEditMode();
          showFeedback('success', result.body.message || '?섏옄 ?뺣낫媛 ?섏젙?섏뿀?듬땲??');
        } catch (error) {
          console.error(error);
          showFeedback('error', '?섏옄 ?뺣낫 ?섏젙 以??ㅻ쪟媛 諛쒖깮?덉뒿?덈떎.');
        }
      });
    }());
  </script>
</body>
</html>
