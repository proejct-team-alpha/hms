<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{pageTitle}} - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-admin}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="space-y-6 max-w-6xl mx-auto">

        <div class="flex items-center justify-between gap-4">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600">
              <i data-feather="list" class="w-6 h-6"></i>
            </div>
            <div>
              <h1 class="text-2xl font-bold text-slate-800">{{pageTitle}}</h1>
              <p class="text-slate-500 mt-1">날짜 범위를 기준으로 물품 입출고 이력을 조회합니다.</p>
            </div>
          </div>
          <div class="text-sm text-slate-500 text-right">
            <div>총 <span class="font-semibold text-slate-700">{{totalCount}}</span>건</div>
          </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
          <form method="get" action="/admin/item/history" class="p-4 border-b border-slate-200 bg-slate-50" id="history-date-form">
            <input type="hidden" name="keyword" id="history-hidden-keyword" value="">
            <input type="hidden" name="type" id="history-hidden-type" value="">

            <div class="flex flex-wrap items-end gap-3">
              <div class="min-w-[180px]">
                <label for="history-from-date" class="block text-sm font-medium text-slate-700 mb-1.5">시작일</label>
                <input
                  type="date"
                  id="history-from-date"
                  name="fromDate"
                  value="{{fromDate}}"
                  class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none"
                >
              </div>

              <div class="min-w-[180px]">
                <label for="history-to-date" class="block text-sm font-medium text-slate-700 mb-1.5">종료일</label>
                <input
                  type="date"
                  id="history-to-date"
                  name="toDate"
                  value="{{toDate}}"
                  class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none"
                >
              </div>

              <button
                type="submit"
                class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors"
              >
                조회
              </button>
              <a
                href="/admin/item/history"
                class="px-4 py-2 bg-slate-100 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-200 transition-colors"
              >
                초기화
              </a>
            </div>
          </form>

          {{#dateError}}
          <div class="px-4 py-3 border-b border-red-200 bg-red-50 text-sm text-red-700">
            {{dateError}}
          </div>
          {{/dateError}}

          <div class="grid grid-cols-2 gap-4 p-4 border-b border-slate-200 bg-white">
            <div class="rounded-xl border border-blue-200 bg-blue-50 p-4">
              <div class="text-xs font-medium text-blue-700">총 입고 수량</div>
              <div class="mt-1 text-xl font-bold text-blue-800">{{totalIn}}<span class="ml-1 text-sm font-normal text-blue-600">개</span></div>
            </div>
            <div class="rounded-xl border border-orange-200 bg-orange-50 p-4">
              <div class="text-xs font-medium text-orange-700">총 출고 수량</div>
              <div class="mt-1 text-xl font-bold text-orange-800">{{totalOut}}<span class="ml-1 text-sm font-normal text-orange-600">개</span></div>
            </div>
          </div>

          <div class="p-4 border-b border-slate-200 bg-white">
            <div class="flex flex-wrap items-end gap-3">
              <div class="min-w-[260px] flex-1">
                <label for="history-search" class="block text-sm font-medium text-slate-700 mb-1.5">물품명 검색</label>
                <div class="relative">
                  <i data-feather="search" class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
                  <input
                    type="text"
                    id="history-search"
                    placeholder="물품명 검색"
                    class="w-full pl-9 pr-4 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none"
                  >
                </div>
              </div>

              <div class="flex items-center gap-1.5" id="type-filter-btns">
                <button type="button" data-type="" class="type-filter-btn px-3 py-2 text-xs font-medium rounded-lg bg-indigo-600 text-white transition-colors">전체</button>
                <button type="button" data-type="입고" class="type-filter-btn px-3 py-2 text-xs font-medium rounded-lg bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors">입고</button>
                <button type="button" data-type="출고" class="type-filter-btn px-3 py-2 text-xs font-medium rounded-lg bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors">출고</button>
              </div>
            </div>
          </div>

          {{#hasHistories}}
          <table class="w-full text-sm">
            <thead class="bg-slate-50 border-b border-slate-200">
              <tr>
                <th class="px-5 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide">구분</th>
                <th class="px-5 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide">물품명</th>
                <th class="px-5 py-3 text-right text-xs font-semibold text-slate-500 uppercase tracking-wide">수량</th>
                <th class="px-5 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide">담당자</th>
                <th class="px-5 py-3 text-right text-xs font-semibold text-slate-500 uppercase tracking-wide">일시</th>
              </tr>
            </thead>
            <tbody id="history-tbody" class="divide-y divide-slate-100">
              {{#histories}}
              <tr class="history-row hover:bg-slate-50 transition-colors" data-name="{{itemName}}" data-type="{{typeText}}">
                <td class="px-5 py-3">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium {{#isIn}}bg-blue-100 text-blue-700{{/isIn}}{{^isIn}}bg-orange-100 text-orange-700{{/isIn}}">
                    {{typeText}}
                  </span>
                </td>
                <td class="px-5 py-3 font-medium text-slate-800">{{itemName}}</td>
                <td class="px-5 py-3 text-right text-slate-600">{{amount}}개</td>
                <td class="px-5 py-3 text-slate-600">{{performedBy}}</td>
                <td class="px-5 py-3 text-right text-slate-400">{{createdAt}}</td>
              </tr>
              {{/histories}}
            </tbody>
          </table>
          {{/hasHistories}}
          {{^hasHistories}}
          <div class="p-8 text-center">
            <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <i data-feather="clock" class="w-8 h-8 text-slate-400"></i>
            </div>
            <p class="text-sm text-slate-500">조회된 입출고 내역이 없습니다.</p>
          </div>
          {{/hasHistories}}

          {{#hasHistories}}
          <div class="p-4 border-t border-slate-200 flex items-center justify-between bg-slate-50" id="pagination-bar">
            <span class="text-xs text-slate-500" id="page-info"></span>
            <div class="flex items-center gap-2">
              <button id="btn-prev" type="button" class="px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-100 disabled:opacity-40 disabled:cursor-not-allowed transition-colors">이전</button>
              <div id="page-numbers" class="flex items-center gap-1"></div>
              <button id="btn-next" type="button" class="px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-100 disabled:opacity-40 disabled:cursor-not-allowed transition-colors">다음</button>
            </div>
          </div>
          {{/hasHistories}}
        </div>

      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>
    const PAGE_SIZE = 10;
    let currentPage = 1;
    let totalPages = 1;
    let currentType = '';
    let currentQuery = '';

    function getStateParams() {
      return new URLSearchParams(window.location.search);
    }

    function syncStateToUrl() {
      const params = getStateParams();
      if (currentQuery) {
        params.set('keyword', currentQuery);
      } else {
        params.delete('keyword');
      }

      if (currentType) {
        params.set('type', currentType);
      } else {
        params.delete('type');
      }

      const nextUrl = `${window.location.pathname}${params.toString() ? `?${params.toString()}` : ''}`;
      window.history.replaceState({}, '', nextUrl);

      const hiddenKeyword = document.getElementById('history-hidden-keyword');
      const hiddenType = document.getElementById('history-hidden-type');
      if (hiddenKeyword) {
        hiddenKeyword.value = currentQuery;
      }
      if (hiddenType) {
        hiddenType.value = currentType;
      }
    }

    function applyInitialState() {
      const params = getStateParams();
      currentQuery = params.get('keyword') || '';
      currentType = params.get('type') || '';

      const searchInput = document.getElementById('history-search');
      if (searchInput) {
        searchInput.value = currentQuery;
      }

      const targetButton = Array.from(document.querySelectorAll('.type-filter-btn')).find((button) => button.dataset.type === currentType)
        || document.querySelector('.type-filter-btn[data-type=""]');
      if (targetButton) {
        document.querySelectorAll('.type-filter-btn').forEach((button) => {
          button.className = 'type-filter-btn px-3 py-2 text-xs font-medium rounded-lg bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors';
        });
        targetButton.className = 'type-filter-btn px-3 py-2 text-xs font-medium rounded-lg bg-indigo-600 text-white transition-colors';
      }

      syncStateToUrl();
    }

    function getFilteredRows() {
      const rows = Array.from(document.querySelectorAll('#history-tbody .history-row'));
      return rows.filter((row) => {
        const rowName = row.dataset.name || '';
        const rowType = row.dataset.type || '';
        const nameOk = !currentQuery || rowName.includes(currentQuery);
        const typeOk = !currentType || rowType === currentType;
        return nameOk && typeOk;
      });
    }

    function buildPageNumbers(totalPgs) {
      const startBase = Math.max(1, currentPage - 2);
      const end = Math.min(totalPgs, startBase + 4);
      const start = Math.max(1, end - 4);
      let html = '';

      if (start > 1) {
        html += '<button type="button" data-page="1" class="hist-page-btn px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 bg-white text-slate-600 hover:bg-slate-100 transition-colors">1</button>';
        if (start > 2) {
          html += '<span class="px-1 text-xs text-slate-400">...</span>';
        }
      }

      for (let page = start; page <= end; page += 1) {
        const active = page === currentPage
          ? 'bg-indigo-600 text-white border-indigo-600'
          : 'bg-white text-slate-600 hover:bg-slate-100 border-slate-200';
        html += `<button type="button" data-page="${page}" class="hist-page-btn px-3 py-1.5 text-xs font-medium rounded-lg border ${active} transition-colors">${page}</button>`;
      }

      if (end < totalPgs) {
        if (end < totalPgs - 1) {
          html += '<span class="px-1 text-xs text-slate-400">...</span>';
        }
        html += `<button type="button" data-page="${totalPgs}" class="hist-page-btn px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 bg-white text-slate-600 hover:bg-slate-100 transition-colors">${totalPgs}</button>`;
      }

      return html;
    }

    function render() {
      const body = document.getElementById('history-tbody');
      if (!body) {
        return;
      }

      const rows = getFilteredRows();
      const total = rows.length;
      totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
      currentPage = Math.min(Math.max(1, currentPage), totalPages);

      const start = (currentPage - 1) * PAGE_SIZE;
      const end = start + PAGE_SIZE;

      Array.from(document.querySelectorAll('#history-tbody .history-row')).forEach((row) => {
        row.style.display = 'none';
      });
      rows.forEach((row, index) => {
        row.style.display = index >= start && index < end ? '' : 'none';
      });

      const bar = document.getElementById('pagination-bar');
      const info = document.getElementById('page-info');
      const numbersEl = document.getElementById('page-numbers');
      const prevButton = document.getElementById('btn-prev');
      const nextButton = document.getElementById('btn-next');

      if (totalPages <= 1) {
        if (bar) {
          bar.style.display = 'none';
        }
        syncStateToUrl();
        return;
      }
      if (bar) {
        bar.style.display = '';
      }

      if (info) {
        info.textContent = `${total}건 / ${totalPages}페이지`;
      }

      if (numbersEl) {
        numbersEl.innerHTML = buildPageNumbers(totalPages);
        numbersEl.querySelectorAll('.hist-page-btn').forEach((button) => {
          button.addEventListener('click', () => {
            currentPage = Number(button.dataset.page);
            render();
          });
        });
      }

      if (prevButton) {
        prevButton.disabled = currentPage <= 1;
      }
      if (nextButton) {
        nextButton.disabled = currentPage >= totalPages;
      }

      syncStateToUrl();
    }

    const searchInput = document.getElementById('history-search');
    if (searchInput) {
      searchInput.addEventListener('input', () => {
        currentQuery = searchInput.value.trim();
        currentPage = 1;
        render();
      });
    }

    document.querySelectorAll('.type-filter-btn').forEach((button) => {
      button.addEventListener('click', () => {
        currentType = button.dataset.type || '';
        currentPage = 1;
        document.querySelectorAll('.type-filter-btn').forEach((target) => {
          target.className = 'type-filter-btn px-3 py-2 text-xs font-medium rounded-lg bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors';
        });
        button.className = 'type-filter-btn px-3 py-2 text-xs font-medium rounded-lg bg-indigo-600 text-white transition-colors';
        render();
      });
    });

    const prevButton = document.getElementById('btn-prev');
    if (prevButton) {
      prevButton.addEventListener('click', () => {
        if (currentPage > 1) {
          currentPage -= 1;
          render();
        }
      });
    }

    const nextButton = document.getElementById('btn-next');
    if (nextButton) {
      nextButton.addEventListener('click', () => {
        if (currentPage < totalPages) {
          currentPage += 1;
          render();
        }
      });
    }

    feather.replace();
    applyInitialState();
    render();
  </script>
</body>
</html>