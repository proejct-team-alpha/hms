<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>예약 취소 관리</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="bg-slate-50 min-h-screen p-6">
    <div class="max-w-7xl mx-auto space-y-6">
        <!-- 헤더 -->
        <div class="flex items-center gap-3 mb-8">
            <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600">
                <i data-lucide="calendar" class="w-6 h-6"></i>
            </div>
            <div>
                <h1 class="text-2xl font-bold text-slate-800">예약 취소 관리</h1>
                <p class="text-slate-500 mt-1">모든 예약을 조회하고 취소할 수 있습니다.</p>
            </div>
        </div>

        <!-- 메인 콘텐츠 -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
            <!-- 필터 및 검색 -->
            <div class="p-4 border-b border-slate-200 flex flex-col md:flex-row justify-between items-center bg-slate-50 gap-4">
                <div class="flex flex-wrap gap-2">
                    <button class="px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-slate-800 text-white">
                        전체
                    </button>
                    <button class="px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-white border border-slate-300 text-slate-600 hover:bg-slate-100">
                        예약
                    </button>
                    <button class="px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-white border border-slate-300 text-slate-600 hover:bg-slate-100">
                        접수
                    </button>
                    <button class="px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-white border border-slate-300 text-slate-600 hover:bg-slate-100">
                        완료
                    </button>
                    <button class="px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-white border border-slate-300 text-slate-600 hover:bg-slate-100">
                        취소
                    </button>
                </div>
                <div class="flex items-center gap-2">
                    <div class="relative">
                        <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
                        <input 
                            type="text" 
                            placeholder="환자명 검색..." 
                            class="pl-9 pr-4 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none w-64"
                        />
                    </div>
                </div>
            </div>

            <!-- 테이블 -->
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-200 text-xs uppercase tracking-wider text-slate-500">
                        <th class="p-4 font-medium">시간</th>
                        <th class="p-4 font-medium">환자명</th>
                        <th class="p-4 font-medium">연락처</th>
                        <th class="p-4 font-medium">진료과 / 전문의</th>
                        <th class="p-4 font-medium">상태</th>
                        <th class="p-4 font-medium text-right">액션</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200">
                    <!-- 항목 1 -->
                    <tr class="hover:bg-slate-50 transition-colors cursor-pointer" onclick="openModal('김철수', '010-1234-5678', '내과', '이의사', '10:30', 'RECEIVED', '기침, 가래, 미열')">
                        <td class="p-4 text-sm font-medium text-slate-900">10:30</td>
                        <td class="p-4 text-sm font-semibold text-slate-800">김철수</td>
                        <td class="p-4 text-sm text-slate-600">010-1234-5678</td>
                        <td class="p-4 text-sm text-slate-600">내과 / 이의사</td>
                        <td class="p-4">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-green-100 text-green-800">
                                RECEIVED
                            </span>
                        </td>
                        <td class="p-4 text-right" onclick="event.stopPropagation()">
                            <div class="flex items-center justify-end gap-2">
                                <button class="inline-flex items-center gap-1 px-3 py-1.5 bg-red-50 text-red-600 text-sm font-medium rounded-lg hover:bg-red-100 transition-colors">
                                    <i data-lucide="x-circle" class="w-4 h-4"></i>
                                    취소
                                </button>
                            </div>
                        </td>
                    </tr>

                    <!-- 항목 2 -->
                    <tr class="hover:bg-slate-50 transition-colors cursor-pointer" onclick="openModal('이영희', '010-9876-5432', '이비인후과', '박의사', '11:00', 'RESERVED', '목 통증')">
                        <td class="p-4 text-sm font-medium text-slate-900">11:00</td>
                        <td class="p-4 text-sm font-semibold text-slate-800">이영희</td>
                        <td class="p-4 text-sm text-slate-600">010-9876-5432</td>
                        <td class="p-4 text-sm text-slate-600">이비인후과 / 박의사</td>
                        <td class="p-4">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-indigo-100 text-indigo-800">
                                RESERVED
                            </span>
                        </td>
                        <td class="p-4 text-right" onclick="event.stopPropagation()">
                            <div class="flex items-center justify-end gap-2">
                                <button class="inline-flex items-center gap-1 px-3 py-1.5 bg-green-50 text-green-600 text-sm font-medium rounded-lg hover:bg-green-100 transition-colors">
                                    다시 접수
                                </button>
                                <button class="inline-flex items-center gap-1 px-3 py-1.5 bg-red-50 text-red-600 text-sm font-medium rounded-lg hover:bg-red-100 transition-colors">
                                    <i data-lucide="x-circle" class="w-4 h-4"></i>
                                    취소
                                </button>
                            </div>
                        </td>
                    </tr>

                    <!-- 항목 3 -->
                    <tr class="hover:bg-slate-50 transition-colors cursor-pointer" onclick="openModal('박지민', '010-5555-4444', '정형외과', '김의사', '09:00', 'COMPLETED', '발목 염좌')">
                        <td class="p-4 text-sm font-medium text-slate-900">09:00</td>
                        <td class="p-4 text-sm font-semibold text-slate-800">박지민</td>
                        <td class="p-4 text-sm text-slate-600">010-5555-4444</td>
                        <td class="p-4 text-sm text-slate-600">정형외과 / 김의사</td>
                        <td class="p-4">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-blue-100 text-blue-800">
                                COMPLETED
                            </span>
                        </td>
                        <td class="p-4 text-right" onclick="event.stopPropagation()">
                            <div class="flex items-center justify-end gap-2">
                                <button disabled class="inline-flex items-center gap-1 px-3 py-1.5 bg-red-50 text-red-600 text-sm font-medium rounded-lg hover:bg-red-100 transition-colors opacity-50 cursor-not-allowed">
                                    <i data-lucide="x-circle" class="w-4 h-4"></i>
                                    취소
                                </button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>

            <!-- 페이지네이션 -->
            <div class="p-4 border-t border-slate-200 bg-slate-50 flex justify-center">
                <nav class="flex items-center gap-1">
                    <button class="p-2 rounded-lg border border-slate-200 text-slate-400 hover:bg-slate-50 disabled:opacity-50" disabled>
                        <i data-lucide="chevron-left" class="w-4 h-4"></i>
                    </button>
                    <button class="w-8 h-8 flex items-center justify-center rounded-lg text-sm font-medium bg-indigo-600 text-white">
                        1
                    </button>
                    <button class="w-8 h-8 flex items-center justify-center rounded-lg text-sm font-medium text-slate-600 hover:bg-slate-50">
                        2
                    </button>
                    <button class="p-2 rounded-lg border border-slate-200 text-slate-400 hover:bg-slate-50">
                        <i data-lucide="chevron-right" class="w-4 h-4"></i>
                    </button>
                </nav>
            </div>
        </div>
    </div>

    <!-- 환자 상세 모달 -->
    <div id="patientModal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/50 backdrop-blur-sm">
        <div class="bg-white rounded-2xl shadow-xl border border-slate-200 w-full max-w-lg overflow-hidden">
            <div class="p-6 border-b border-slate-100 flex justify-between items-center bg-slate-50">
                <h2 class="text-xl font-bold text-slate-800">예약 상세 정보</h2>
                <button onclick="closeModal()" class="text-slate-400 hover:text-slate-600">
                    <i data-lucide="x" class="w-6 h-6"></i>
                </button>
            </div>
            <div class="p-8 space-y-6">
                <div class="flex items-center gap-4">
                    <div class="w-16 h-16 bg-indigo-50 rounded-2xl flex items-center justify-center text-indigo-600">
                        <i data-lucide="user" class="w-8 h-8"></i>
                    </div>
                    <div>
                        <div id="modalName" class="text-2xl font-bold text-slate-800">이름</div>
                        <div class="text-slate-500 flex items-center gap-1.5 mt-1">
                            <i data-lucide="phone" class="w-4 h-4"></i>
                            <span id="modalPhone">010-0000-0000</span>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-6">
                    <div class="space-y-1">
                        <div class="text-xs font-bold text-slate-400 uppercase tracking-wider">진료과</div>
                        <div id="modalDept" class="font-semibold text-slate-800">진료과</div>
                    </div>
                    <div class="space-y-1">
                        <div class="text-xs font-bold text-slate-400 uppercase tracking-wider">담당 의사</div>
                        <div id="modalDoctor" class="font-semibold text-slate-800">의사명</div>
                    </div>
                    <div class="space-y-1">
                        <div class="text-xs font-bold text-slate-400 uppercase tracking-wider">예약 시간</div>
                        <div class="font-semibold text-slate-800 flex items-center gap-1.5">
                            <i data-lucide="clock" class="w-4 h-4 text-slate-400"></i>
                            <span id="modalTime">00:00</span>
                        </div>
                    </div>
                    <div class="space-y-1">
                        <div class="text-xs font-bold text-slate-400 uppercase tracking-wider">현재 상태</div>
                        <div>
                            <span id="modalStatus" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-slate-100 text-slate-800">
                                STATUS
                            </span>
                        </div>
                    </div>
                </div>

                <div class="space-y-2">
                    <div class="text-xs font-bold text-slate-400 uppercase tracking-wider flex items-center gap-1.5">
                        <i data-lucide="file-text" class="w-4 h-4"></i>
                        증상 및 참고사항
                    </div>
                    <div id="modalSymptoms" class="p-4 bg-slate-50 rounded-xl border border-slate-200 text-sm text-slate-600 leading-relaxed">
                        증상 내용
                    </div>
                </div>

                <div class="pt-4">
                    <button
                        onclick="closeModal()"
                        class="w-full py-3 bg-slate-800 text-white font-bold rounded-xl hover:bg-slate-700 transition-colors"
                    >
                        확인
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // 아이콘 초기화
        lucide.createIcons();

        // 모달 관리
        const modal = document.getElementById('patientModal');

        function openModal(name, phone, dept, doctor, time, status, symptoms) {
            document.getElementById('modalName').textContent = name;
            document.getElementById('modalPhone').textContent = phone;
            document.getElementById('modalDept').textContent = dept;
            document.getElementById('modalDoctor').textContent = doctor;
            document.getElementById('modalTime').textContent = time;
            document.getElementById('modalSymptoms').textContent = symptoms || '등록된 증상 정보가 없습니다.';
            
            const statusEl = document.getElementById('modalStatus');
            statusEl.textContent = status;
            
            // 상태에 따른 색상 변경
            statusEl.className = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold';
            if (status === 'RESERVED') statusEl.classList.add('bg-indigo-100', 'text-indigo-800');
            else if (status === 'RECEIVED') statusEl.classList.add('bg-green-100', 'text-green-800');
            else if (status === 'COMPLETED') statusEl.classList.add('bg-blue-100', 'text-blue-800');
            else if (status === 'IN_PROGRESS') statusEl.classList.add('bg-purple-100', 'text-purple-800');
            else statusEl.classList.add('bg-red-100', 'text-red-800');

            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeModal() {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }
    </script>
</body>
</html>
