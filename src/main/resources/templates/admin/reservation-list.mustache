<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>전체 예약 목록 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-admin}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="space-y-4">

        <!-- 상태 필터 탭 -->
        <div class="flex gap-2 flex-wrap">
          {{#data.statusOptions}}
          <a href="{{url}}" class="px-4 py-2 rounded-lg text-sm font-medium transition-colors {{#selected}}bg-indigo-600 text-white{{/selected}}{{^selected}}bg-white border border-slate-200 text-slate-600 hover:bg-slate-50{{/selected}}">
            {{label}}
          </a>
          {{/data.statusOptions}}
        </div>

        <!-- 테이블 -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
          <div class="p-4 border-b border-slate-100 flex items-center justify-between">
            <span class="text-sm text-slate-500">총 <span class="font-bold text-slate-800">{{data.totalCount}}</span>건</span>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-slate-50 border-b border-slate-200">
                <tr>
                  <th class="text-left px-4 py-3 font-semibold text-slate-600">예약번호</th>
                  <th class="text-left px-4 py-3 font-semibold text-slate-600">예약일</th>
                  <th class="text-left px-4 py-3 font-semibold text-slate-600">시간</th>
                  <th class="text-left px-4 py-3 font-semibold text-slate-600">환자명</th>
                  <th class="text-left px-4 py-3 font-semibold text-slate-600">연락처</th>
                  <th class="text-left px-4 py-3 font-semibold text-slate-600">진료과</th>
                  <th class="text-left px-4 py-3 font-semibold text-slate-600">담당의</th>
                  <th class="text-left px-4 py-3 font-semibold text-slate-600">상태</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {{#data.reservations}}
                <tr class="hover:bg-slate-50">
                  <td class="px-4 py-3 font-mono text-xs text-slate-600">{{reservationNumber}}</td>
                  <td class="px-4 py-3 text-slate-700">{{reservationDate}}</td>
                  <td class="px-4 py-3 text-slate-700">{{timeSlot}}</td>
                  <td class="px-4 py-3 font-medium text-slate-800">{{patientName}}</td>
                  <td class="px-4 py-3 text-slate-600">{{patientPhone}}</td>
                  <td class="px-4 py-3 text-slate-600">{{departmentName}}</td>
                  <td class="px-4 py-3 text-slate-600">{{doctorName}}</td>
                  <td class="px-4 py-3">
                    {{#reserved}}<span class="px-2 py-1 text-xs font-medium rounded-full bg-blue-100 text-blue-700">예약</span>{{/reserved}}
                    {{#received}}<span class="px-2 py-1 text-xs font-medium rounded-full bg-yellow-100 text-yellow-700">접수</span>{{/received}}
                    {{#completed}}<span class="px-2 py-1 text-xs font-medium rounded-full bg-green-100 text-green-700">완료</span>{{/completed}}
                    {{#cancelled}}<span class="px-2 py-1 text-xs font-medium rounded-full bg-red-100 text-red-700">취소</span>{{/cancelled}}
                  </td>
                </tr>
                {{/data.reservations}}
                {{^data.reservations}}
                <tr>
                  <td colspan="8" class="px-4 py-12 text-center text-slate-400">예약 내역이 없습니다.</td>
                </tr>
                {{/data.reservations}}
              </tbody>
            </table>
          </div>

          <!-- 페이지네이션 -->
          {{#data.totalPages}}
          <div class="p-4 border-t border-slate-100 flex items-center justify-between">
            <div class="text-sm text-slate-500">
              {{data.currentPage}} / {{data.totalPages}} 페이지
            </div>
            <div class="flex gap-1">
              {{#data.hasPrevious}}
              <a href="{{data.previousUrl}}" class="px-3 py-1.5 text-sm rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-50">
                <i data-feather="chevron-left" class="w-4 h-4"></i>
              </a>
              {{/data.hasPrevious}}

              {{#data.pageLinks}}
              <a href="{{url}}" class="px-3 py-1.5 text-sm rounded-lg {{#active}}bg-indigo-600 text-white border border-indigo-600{{/active}}{{^active}}border border-slate-200 text-slate-600 hover:bg-slate-50{{/active}}">
                {{page}}
              </a>
              {{/data.pageLinks}}

              {{#data.hasNext}}
              <a href="{{data.nextUrl}}" class="px-3 py-1.5 text-sm rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-50">
                <i data-feather="chevron-right" class="w-4 h-4"></i>
              </a>
              {{/data.hasNext}}
            </div>
          </div>
          {{/data.totalPages}}
        </div>

      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>feather.replace();</script>
</body>
</html>
