<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>관리자 대시보드 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-admin}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}
    
    <main class="content-wrapper flex-1 p-6">
      <div class="space-y-6 max-w-6xl mx-auto">
        <h1 class="text-2xl font-bold text-slate-800">관리자 대시보드</h1>
         <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-indigo-50 rounded-xl flex items-center justify-center text-indigo-600"><i data-lucide="calendar-check-2" class="w-6 h-6"></i></div>
                    <div><div class="text-sm font-medium text-slate-500">오늘 예약</div><div class="text-2xl font-bold text-slate-800">{{model.todayReservations}}건</div></div>
                </div>
            </div>
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-green-50 rounded-xl flex items-center justify-center text-green-600"><i data-lucide="clipboard-list" class="w-6 h-6"></i></div>
                    <div><div class="text-sm font-medium text-slate-500">총 예약</div><div class="text-2xl font-bold text-slate-800">{{model.totalReservations}}건</div></div>
                </div>
            </div>
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-orange-50 rounded-xl flex items-center justify-center text-orange-600"><i data-lucide="building-2" class="w-6 h-6"></i></div>
                    <div><div class="text-sm font-medium text-slate-500">총 직원 수</div><div class="text-2xl font-bold text-slate-800">{{model.totalStaff}}명</div></div>
                </div>
            </div>
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-purple-50 rounded-xl flex items-center justify-center text-purple-600"><i data-lucide="shield-check" class="w-6 h-6"></i></div>
                    <div><div class="text-sm font-medium text-slate-500">재고 부족</div><div class="text-2xl font-bold text-slate-800">{{model.lowStockItems}}개</div></div>
                </div>
            </div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
            <div class="flex justify-between items-center mb-6">
              <h2 class="text-lg font-bold text-slate-800">일별 환자 수 추이</h2>
              <i data-feather="trending-up" class="w-5 h-5 text-indigo-500"></i>
            </div>
            <div class="h-[300px] w-full relative">
              <canvas id="daily-patient-canvas" class="w-full h-full"></canvas>
              <p id="daily-patient-error" class="hidden absolute inset-0 flex items-center justify-center text-sm text-red-500">
                데이터를 불러오지 못했습니다
              </p>
            </div>
          </div>

          <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
            <div class="flex justify-between items-center mb-6">
              <h2 class="text-lg font-bold text-slate-800">카테고리별 물품 재고 현황</h2>
              <i data-feather="package" class="w-5 h-5 text-orange-500"></i>
            </div>
            <div class="h-[300px] w-full relative">
              <canvas id="category-stock-canvas" class="w-full h-full"></canvas>
              <p id="category-stock-error" class="hidden absolute inset-0 flex items-center justify-center text-sm text-red-500">
                데이터를 불러오지 못했습니다
              </p>
            </div>
          </div>
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script src="/js/page/admin-dashboard.js"></script>
</body>
</html>
