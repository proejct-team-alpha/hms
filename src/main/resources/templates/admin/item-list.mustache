<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>물품 관리 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body>
  
  <script src="components/sidebar.js"></script>

  <div class="main-content">
    <script src="components/header.js"></script>
    
    <main class="content-wrapper">
      <div class="space-y-6 max-w-6xl mx-auto">
        <div class="flex justify-between items-center mb-8">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600">
              <i data-feather="package" class="w-6 h-6"></i>
            </div>
            <div>
              <h1 class="text-2xl font-bold text-slate-800">물품 관리</h1>
              <p class="text-slate-500 mt-1">병원 내 의료소모품 및 비품 재고를 관리합니다.</p>
            </div>
          </div>
          <a href="item-form.html" class="px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 transition-colors flex items-center gap-2">
            <i data-feather="plus" class="w-5 h-5"></i>
            물품 등록
          </a>
        </div>

        <!-- Filters and Search -->
        <div class="bg-white p-4 rounded-xl shadow-sm border border-slate-200 flex flex-col md:flex-row gap-4 items-center justify-between">
          <div class="flex items-center gap-2 overflow-x-auto pb-2 md:pb-0 w-full md:w-auto" id="category-filters">
            <!-- Injected by JS -->
          </div>
          <div class="relative w-full md:w-64">
            <i data-feather="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
            <input
              type="text"
              id="search-input"
              placeholder="물품명 검색..."
              class="w-full pl-10 pr-4 py-2 border border-slate-200 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none text-sm"
            />
          </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-200 text-xs uppercase tracking-wider text-slate-500">
                <th class="p-4 font-medium">물품명</th>
                <th class="p-4 font-medium">카테고리</th>
                <th class="p-4 font-medium text-right">현재 재고</th>
                <th class="p-4 font-medium text-right">최소 수량</th>
                <th class="p-4 font-medium text-center">상태</th>
                <th class="p-4 font-medium text-right">관리</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200" id="item-list-container">
              <!-- Injected by JS -->
            </tbody>
          </table>
        </div>
      </div>
    </main>

    <script src="components/footer.js"></script>
  </div>

  <script src="js/data.js"></script>
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      let items = getItems();
      let selectedCategory = '전체';
      let searchQuery = '';
      const categories = ['전체', '의료소모품', '의약품', '사무용품', '기타비품', '소모품', '의료기기'];

      const categoryContainer = document.getElementById('category-filters');
      const searchInput = document.getElementById('search-input');
      const listContainer = document.getElementById('item-list-container');

      function renderCategories() {
        categoryContainer.innerHTML = categories.map(cat => `
          <button
            class="category-btn px-4 py-2 rounded-lg text-sm font-medium transition-colors whitespace-nowrap ${
              selectedCategory === cat
                ? 'bg-indigo-600 text-white'
                : 'bg-slate-100 text-slate-600 hover:bg-slate-200'
            }"
            data-category="${cat}"
          >
            ${cat}
          </button>
        `).join('');

        document.querySelectorAll('.category-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            selectedCategory = e.target.dataset.category;
            renderCategories();
            renderList();
          });
        });
      }

      function renderList() {
        const filtered = items.filter(item => {
          const matchesCategory = selectedCategory === '전체' || item.category === selectedCategory;
          const matchesQuery = item.name.toLowerCase().includes(searchQuery.toLowerCase());
          return matchesCategory && matchesQuery;
        });

        if (filtered.length > 0) {
          listContainer.innerHTML = filtered.map(item => {
            const isLowStock = item.stock <= item.minStock;
            const stockClass = isLowStock ? 'text-red-600' : 'text-slate-800';
            const statusBadge = isLowStock 
              ? `<span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-bold bg-red-100 text-red-800"><i data-feather="alert-triangle" class="w-3.5 h-3.5"></i>재고 부족</span>`
              : `<span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-green-100 text-green-800">정상</span>`;

            return `
              <tr class="hover:bg-slate-50 transition-colors">
                <td class="p-4 text-sm font-bold text-slate-800">${item.name}</td>
                <td class="p-4 text-sm text-slate-600">
                  <span class="px-2.5 py-1 rounded-md bg-slate-100 text-slate-600 text-xs font-medium">
                    ${item.category}
                  </span>
                </td>
                <td class="p-4 text-sm font-bold text-right ${stockClass}">
                  ${item.stock.toLocaleString()} ${item.unit}
                </td>
                <td class="p-4 text-sm text-slate-500 text-right">
                  ${item.minStock.toLocaleString()} ${item.unit}
                </td>
                <td class="p-4 text-center">
                  ${statusBadge}
                </td>
                <td class="p-4 text-right">
                  <div class="flex items-center justify-end gap-2">
                    <button 
                      onclick="window.location.href='item-form.html?id=${item.id}'"
                      class="p-1.5 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-md transition-colors"
                    >
                      <i data-feather="edit-2" class="w-4 h-4"></i>
                    </button>
                    <button 
                      onclick="handleDelete(${item.id})"
                      class="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-md transition-colors"
                    >
                      <i data-feather="trash-2" class="w-4 h-4"></i>
                    </button>
                  </div>
                </td>
              </tr>
            `;
          }).join('');
        } else {
          listContainer.innerHTML = `
            <tr>
              <td colspan="6" class="p-8 text-center text-slate-500 text-sm">
                검색 결과가 없습니다.
              </td>
            </tr>
          `;
        }
        feather.replace();
      }

      searchInput.addEventListener('input', (e) => {
        searchQuery = e.target.value;
        renderList();
      });

      window.handleDelete = function(id) {
        if (window.confirm('정말 이 물품을 삭제하시겠습니까?')) {
          deleteItem(id);
          items = getItems();
          renderList();
        }
      };

      renderCategories();
      renderList();
    });
  </script>
</body>
</html>
