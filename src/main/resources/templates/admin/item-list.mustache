<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>물품 목록 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-admin}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="space-y-6 max-w-6xl mx-auto">
        <div class="flex items-center justify-between gap-4">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600">
              <i data-feather="package" class="w-6 h-6"></i>
            </div>
            <div>
              <h1 class="text-2xl font-bold text-slate-800">{{pageTitle}}</h1>
              <p class="text-slate-500 mt-1">병원 내 의료소모품 및 비품 재고를 관리합니다.</p>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="text-sm text-slate-500 text-right">
              <div>총 <span class="font-semibold text-slate-700">{{totalCount}}</span>건</div>
            </div>
            <a href="/admin/item/form" class="flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors">
              <i data-feather="plus" class="w-4 h-4"></i>
              물품 등록
            </a>
            <a href="/admin/item/use" class="flex items-center gap-2 px-4 py-2 bg-red-500 text-white text-sm font-medium rounded-lg hover:bg-red-600 transition-colors">
              <i data-feather="arrow-up-circle" class="w-4 h-4"></i>
              물품 출고
            </a>
          </div>
        </div>

        {{#message}}
        <div class="p-4 bg-green-50 border border-green-200 rounded-xl text-sm text-green-700">{{message}}</div>
        {{/message}}
        {{#errorMessage}}
        <div class="p-4 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700">{{errorMessage}}</div>
        {{/errorMessage}}

        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden" id="item-list-table-wrap">
          <form id="item-search-form" method="get" action="/admin/item/list" class="p-4 border-b border-slate-200 bg-slate-50">
            <div class="flex flex-wrap items-end gap-3">
              <div class="min-w-[280px] flex-1">
                <label for="item-search" class="block text-sm font-medium text-slate-700 mb-1.5">검색</label>
                <div class="relative">
                  <i data-feather="search" class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
                  <input
                    type="text"
                    id="item-search"
                    name="keyword"
                    value="{{keyword}}"
                    placeholder="물품명 검색 (초성·영문 가능)"
                    class="w-full pl-9 pr-4 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none"
                  >
                </div>
              </div>

              <div class="min-w-[180px]">
                <label for="item-category" class="block text-sm font-medium text-slate-700 mb-1.5">카테고리</label>
                <select
                  id="item-category"
                  name="category"
                  class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none"
                >
                  {{#categoryFilters}}
                  <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                  {{/categoryFilters}}
                </select>
              </div>

              <button
                type="submit"
                class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors"
              >
                조회
              </button>
              <a
                href="/admin/item/list"
                class="px-4 py-2 bg-slate-100 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-200 transition-colors"
              >
                초기화
              </a>
            </div>
          </form>

          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-200 text-xs uppercase tracking-wider text-slate-500">
                <th class="p-4 font-medium">물품명</th>
                <th class="p-4 font-medium">카테고리</th>
                <th class="p-4 font-medium text-right">현재 재고</th>
                <th class="p-4 font-medium text-center">입고</th>
                <th class="p-4 font-medium text-right">최소 수량</th>
                <th class="p-4 font-medium text-center">상태</th>
                <th class="p-4 font-medium text-right">관리</th>
              </tr>
            </thead>
            <tbody id="item-list-tbody" class="divide-y divide-slate-200">
              {{#items}}
              <tr class="hover:bg-slate-50 transition-colors">
                <td class="p-4 text-sm font-bold text-slate-800">{{name}}</td>
                <td class="p-4 text-sm text-slate-600">
                  <span class="px-2.5 py-1 rounded-md bg-slate-100 text-slate-600 text-xs font-medium">{{categoryText}}</span>
                </td>
                <td class="p-4 text-sm text-right">
                  <span class="font-bold {{#lowStock}}text-red-600{{/lowStock}}{{^lowStock}}text-slate-800{{/lowStock}}">{{quantity}}개</span>
                </td>
                <td class="p-4 text-sm text-center">
                  <form method="post" action="/admin/item/restock" class="flex items-center justify-center gap-1">
                    <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
                    <input type="hidden" name="id" value="{{id}}">
                    <input
                      type="number"
                      name="amount"
                      min="1"
                      placeholder="수량"
                      class="w-16 px-2 py-1 text-xs border border-slate-300 rounded-md focus:outline-none focus:ring-1 focus:ring-indigo-400 text-center"
                    >
                    <button
                      type="submit"
                      class="px-2 py-1 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-bold rounded-md transition-colors whitespace-nowrap"
                    >
                      입고
                    </button>
                  </form>
                </td>
                <td class="p-4 text-sm text-slate-500 text-right">{{minQuantity}}개</td>
                <td class="p-4 text-center">
                  {{#lowStock}}
                  <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-bold bg-red-100 text-red-800">
                    <i data-feather="alert-triangle" class="w-3.5 h-3.5"></i>
                    재고 부족
                  </span>
                  {{/lowStock}}
                  {{^lowStock}}
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-green-100 text-green-800">
                    정상
                  </span>
                  {{/lowStock}}
                </td>
                <td class="p-4 text-right">
                  <div class="flex items-center justify-end gap-2">
                    <a href="/admin/item/form?id={{id}}" class="p-1.5 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-md transition-colors inline-block">
                      <i data-feather="edit-2" class="w-4 h-4"></i>
                    </a>
                    <form method="post" action="/admin/item/delete" style="display:inline;">
                      <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
                      <input type="hidden" name="id" value="{{id}}">
                      <button type="submit" class="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-md transition-colors">
                        <i data-feather="trash-2" class="w-4 h-4"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
              {{/items}}
              {{^items}}
              <tr id="empty-row">
                <td colspan="7" class="p-8 text-center text-slate-500 text-sm">조회된 물품이 없습니다.</td>
              </tr>
              {{/items}}
            </tbody>
          </table>

          <div id="item-list-pagination" class="flex items-center justify-between px-4 py-3 border-t border-slate-200" style="display:none!important">
            <span id="item-list-page-info" class="text-xs text-slate-500"></span>
            <div class="flex items-center gap-2">
              <button
                id="item-list-prev"
                type="button"
                class="px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-100 disabled:opacity-40 disabled:cursor-not-allowed transition-colors"
              >
                이전
              </button>
              <div id="item-list-page-numbers" class="flex items-center gap-1"></div>
              <button
                id="item-list-next"
                type="button"
                class="px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-100 disabled:opacity-40 disabled:cursor-not-allowed transition-colors"
              >
                다음
              </button>
            </div>
          </div>
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>
    const CHOSUNG = ['ㄱ', 'ㄲ', 'ㄴ', 'ㄷ', 'ㄸ', 'ㄹ', 'ㅁ', 'ㅂ', 'ㅃ', 'ㅅ', 'ㅆ', 'ㅇ', 'ㅈ', 'ㅉ', 'ㅊ', 'ㅋ', 'ㅌ', 'ㅍ', 'ㅎ'];

    function getChosung(value) {
      return value.split('').map(function (char) {
        const code = char.charCodeAt(0);
        if (code >= 0xac00 && code <= 0xd7a3) {
          return CHOSUNG[Math.floor((code - 0xac00) / 588)];
        }
        return char;
      }).join('');
    }

    function isChosungOnly(value) {
      return /^[ㄱ-ㅎ]+$/.test(value);
    }

    function itemMatches(name, query) {
      if (!query) {
        return true;
      }

      const lowerCaseQuery = query.toLowerCase();
      if (isChosungOnly(lowerCaseQuery)) {
        return getChosung(name).includes(lowerCaseQuery);
      }

      return name.toLowerCase().includes(lowerCaseQuery);
    }

    const ITEM_LIST_PAGE_SIZE = 10;
    const itemSearchInput = document.getElementById('item-search');
    const itemListPageInfo = document.getElementById('item-list-page-info');
    const itemListPrevButton = document.getElementById('item-list-prev');
    const itemListNextButton = document.getElementById('item-list-next');
    const itemListPageNumbers = document.getElementById('item-list-page-numbers');
    const itemListPagination = document.getElementById('item-list-pagination');
    let itemListPage = 1;

    function getFilteredRows() {
      const query = itemSearchInput.value.trim();
      return Array.from(document.querySelectorAll('#item-list-tbody tr:not(#empty-row)')).filter(function (row) {
        const nameCell = row.querySelector('td:first-child');
        const name = nameCell ? nameCell.textContent.trim() : '';
        return itemMatches(name, query);
      });
    }

    function buildItemListPageNumbers(current, total) {
      itemListPageNumbers.innerHTML = '';
      if (total <= 1) {
        return;
      }

      let start = Math.max(1, current - 2);
      const end = Math.min(total, start + 4);
      if (end - start < 4) {
        start = Math.max(1, end - 4);
      }

      function makeButton(page) {
        const button = document.createElement('button');
        button.type = 'button';
        button.textContent = page;
        button.className = 'px-2 py-1 text-xs rounded-lg border transition-colors ' +
          (page === current
            ? 'bg-indigo-600 text-white border-indigo-600'
            : 'border-slate-200 text-slate-600 hover:bg-slate-100');
        button.addEventListener('click', function () {
          itemListPage = page;
          renderItemList();
        });
        return button;
      }

      function makeDots() {
        const dots = document.createElement('span');
        dots.textContent = '...';
        dots.className = 'px-1 text-xs text-slate-400';
        return dots;
      }

      if (start > 1) {
        itemListPageNumbers.appendChild(makeButton(1));
        if (start > 2) {
          itemListPageNumbers.appendChild(makeDots());
        }
      }

      for (let page = start; page <= end; page += 1) {
        itemListPageNumbers.appendChild(makeButton(page));
      }

      if (end < total) {
        if (end < total - 1) {
          itemListPageNumbers.appendChild(makeDots());
        }
        itemListPageNumbers.appendChild(makeButton(total));
      }
    }

    function renderItemList() {
      const filteredRows = getFilteredRows();
      const total = filteredRows.length;
      const totalPages = Math.max(1, Math.ceil(total / ITEM_LIST_PAGE_SIZE));

      if (itemListPage > totalPages) {
        itemListPage = totalPages;
      }
      if (itemListPage < 1) {
        itemListPage = 1;
      }

      const startIndex = (itemListPage - 1) * ITEM_LIST_PAGE_SIZE;
      document.querySelectorAll('#item-list-tbody tr:not(#empty-row)').forEach(function (row) {
        row.style.display = 'none';
      });

      filteredRows.forEach(function (row, index) {
        row.style.display = (index >= startIndex && index < startIndex + ITEM_LIST_PAGE_SIZE) ? '' : 'none';
      });

      if (total === 0 || totalPages <= 1) {
        itemListPagination.style.removeProperty('display');
        itemListPagination.style.display = 'none';
      } else {
        itemListPagination.style.removeProperty('display');
      }

      itemListPageInfo.textContent = total + '건 / ' + totalPages + '페이지';
      buildItemListPageNumbers(itemListPage, totalPages);
      itemListPrevButton.disabled = itemListPage <= 1;
      itemListNextButton.disabled = itemListPage >= totalPages;
    }

    itemSearchInput.addEventListener('input', function () {
      itemListPage = 1;
      renderItemList();
    });

    itemListPrevButton.addEventListener('click', function () {
      if (itemListPage > 1) {
        itemListPage -= 1;
        renderItemList();
      }
    });

    itemListNextButton.addEventListener('click', function () {
      const totalPages = Math.max(1, Math.ceil(getFilteredRows().length / ITEM_LIST_PAGE_SIZE));
      if (itemListPage < totalPages) {
        itemListPage += 1;
        renderItemList();
      }
    });

    renderItemList();
  </script>
  <script>
    feather.replace();
  </script>
</body>
</html>
