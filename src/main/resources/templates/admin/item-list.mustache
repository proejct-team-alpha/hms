<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>물품 관리 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-admin}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="space-y-4">

        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-2xl font-bold text-slate-800">물품 관리</h1>
            <p class="text-slate-500 mt-1">물품 재고 현황을 조회하고 관리합니다.</p>
          </div>
          <a href="/admin/item/form"
            class="flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors">
            <i data-feather="plus" class="w-4 h-4"></i>
            물품 등록
          </a>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-slate-50 border-b border-slate-200">
                <tr>
                  <th class="text-left px-4 py-3 font-semibold text-slate-600">물품명</th>
                  <th class="text-left px-4 py-3 font-semibold text-slate-600">카테고리</th>
                  <th class="text-left px-4 py-3 font-semibold text-slate-600">현재 수량</th>
                  <th class="text-left px-4 py-3 font-semibold text-slate-600">최소 수량</th>
                  <th class="text-left px-4 py-3 font-semibold text-slate-600">재고 상태</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {{#items}}
                <tr class="hover:bg-slate-50">
                  <td class="px-4 py-3 font-medium text-slate-800">{{name}}</td>
                  <td class="px-4 py-3 text-slate-600">{{categoryText}}</td>
                  <td class="px-4 py-3 text-slate-700">{{quantity}}</td>
                  <td class="px-4 py-3 text-slate-500">{{minQuantity}}</td>
                  <td class="px-4 py-3">
                    <span class="{{stockBadgeClass}}">{{#lowStock}}부족{{/lowStock}}{{^lowStock}}정상{{/lowStock}}</span>
                  </td>
                </tr>
                {{/items}}
                {{^hasItems}}
                <tr>
                  <td colspan="5" class="px-4 py-12 text-center text-slate-400">등록된 물품이 없습니다.</td>
                </tr>
                {{/hasItems}}
              </tbody>
            </table>
          </div>
        </div>

      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>feather.replace();</script>
</body>
</html>
