<tbody class="divide-y divide-slate-200">
  {{#staffList}}
  <tr class="hover:bg-slate-50 transition-colors">
    <td class="p-4 text-sm font-bold text-slate-800 flex items-center gap-3">
      <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500">
        <i data-feather="user" class="w-4 h-4"></i>
      </div>
      {{name}}
    </td>
    <td class="p-4">
      <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold {{roleBadgeColor}}">
        <i data-feather="shield" class="w-3.5 h-3.5"></i>{{roleLabel}}
      </span>
    </td>
    <td class="p-4 text-sm text-slate-600">{{dept}}</td>
    <td class="p-4 text-sm text-slate-600">{{phone}}</td>
    <td class="p-4 text-right">
      <div class="flex items-center justify-end gap-2">
        <a href="/staff/{{id}}/edit" class="p-1.5 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-md">
          <i data-feather="edit-2" class="w-4 h-4"></i>
        </a>
        <form action="/staff/{{id}}/delete" method="POST" class="inline" onsubmit="return confirm('정말 이 직원을 삭제하시겠습니까?');">
          <button type="submit" class="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-md">
            <i data-feather="trash-2" class="w-4 h-4"></i>
          </button>
        </form>
      </div>
    </td>
  </tr>
  {{/staffList}}
</tbody>