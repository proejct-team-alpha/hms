<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>직원 관리 - MediCare+</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/feather-icons"></script>
  <link rel="stylesheet" href="css/style.css">
</head>
<body>
  
  <script src="components/sidebar.js"></script>

  <div class="main-content">
    <script src="components/header.js"></script>
    
    <main class="content-wrapper">
      <div class="space-y-6 max-w-6xl mx-auto">
        <div class="flex justify-between items-center mb-8">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600">
              <i data-feather="users" class="w-6 h-6"></i>
            </div>
            <div>
              <h1 class="text-2xl font-bold text-slate-800">직원 관리</h1>
              <p class="text-slate-500 mt-1">병원 시스템 접속 권한을 가진 직원을 관리합니다.</p>
            </div>
          </div>
          <a href="staff-form.html" class="px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 transition-colors flex items-center gap-2">
            <i data-feather="plus" class="w-5 h-5"></i>
            직원 등록
          </a>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
          <div class="p-4 border-b border-slate-200 bg-slate-50">
            <div class="relative w-64">
              <i data-feather="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
              <input 
                type="text" 
                id="search-input"
                placeholder="이름, 부서, 권한 검색..." 
                class="w-full pl-9 pr-4 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none"
              />
            </div>
          </div>

          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-200 text-xs uppercase tracking-wider text-slate-500">
                <th class="p-4 font-medium">이름</th>
                <th class="p-4 font-medium">권한 (Role)</th>
                <th class="p-4 font-medium">부서/진료과</th>
                <th class="p-4 font-medium">연락처</th>
                <th class="p-4 font-medium text-right">관리</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200" id="staff-list-container">
              <!-- Injected by JS -->
            </tbody>
          </table>
        </div>
      </div>
    </main>

    <script src="components/footer.js"></script>
  </div>

  <script src="js/data.js"></script>
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      let staffList = getStaff();
      let searchQuery = '';

      const listContainer = document.getElementById('staff-list-container');
      const searchInput = document.getElementById('search-input');

      function renderList() {
        const filtered = staffList.filter(s => {
          const roleLabel = getRoleLabel(s.role);
          const matchSearch = s.name.toLowerCase().includes(searchQuery.toLowerCase()) || 
                              s.dept.toLowerCase().includes(searchQuery.toLowerCase()) ||
                              roleLabel.toLowerCase().includes(searchQuery.toLowerCase());
          return matchSearch;
        });

        if (filtered.length > 0) {
          listContainer.innerHTML = filtered.map(staff => {
            let roleBadge = '';
            if (staff.role === 'ADMIN') roleBadge = 'bg-red-100 text-red-800';
            else if (staff.role === 'DOCTOR') roleBadge = 'bg-blue-100 text-blue-800';
            else if (staff.role === 'NURSE') roleBadge = 'bg-green-100 text-green-800';
            else roleBadge = 'bg-purple-100 text-purple-800';

            return `
              <tr class="hover:bg-slate-50 transition-colors">
                <td class="p-4 text-sm font-bold text-slate-800 flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500">
                    <i data-feather="user" class="w-4 h-4"></i>
                  </div>
                  ${staff.name}
                </td>
                <td class="p-4">
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold ${roleBadge}">
                    <i data-feather="shield" class="w-3.5 h-3.5"></i>
                    ${getRoleLabel(staff.role)}
                  </span>
                </td>
                <td class="p-4 text-sm text-slate-600">${staff.dept}</td>
                <td class="p-4 text-sm text-slate-600">${staff.phone}</td>
                <td class="p-4 text-right">
                  <div class="flex items-center justify-end gap-2">
                    <button 
                      onclick="window.location.href='staff-form.html?id=${staff.id}'"
                      class="p-1.5 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-md transition-colors"
                    >
                      <i data-feather="edit-2" class="w-4 h-4"></i>
                    </button>
                    <button 
                      onclick="handleDelete(${staff.id})"
                      class="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-md transition-colors"
                    >
                      <i data-feather="trash-2" class="w-4 h-4"></i>
                    </button>
                  </div>
                </td>
              </tr>
            `;
          }).join('');
        } else {
          listContainer.innerHTML = `
            <tr>
              <td colspan="5" class="p-8 text-center text-slate-500">
                검색 결과가 없습니다.
              </td>
            </tr>
          `;
        }
        feather.replace();
      }

      searchInput.addEventListener('input', (e) => {
        searchQuery = e.target.value;
        renderList();
      });

      window.handleDelete = function(id) {
        if (window.confirm('정말 이 직원을 삭제하시겠습니까?')) {
          deleteStaff(id);
          staffList = getStaff();
          renderList();
        }
      };

      renderList();
    });
  </script>
</body>
</html>
