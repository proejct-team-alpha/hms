<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>직원 관리 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body>
  {{> common/sidebar-admin}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper">
      <div class="space-y-6 max-w-6xl mx-auto">
        <div class="flex items-center justify-between mb-6">
          <div>
            <h1 class="text-2xl font-bold text-slate-800">직원 목록</h1>
            <p class="text-slate-500 mt-1">이름, 로그인 아이디, 역할, 재직 상태 기준으로 직원을 조회합니다.</p>
          </div>
          <div class="flex items-center gap-4">
            <div class="text-sm text-slate-500">
              총 <span class="font-semibold text-slate-700">{{model.totalCount}}</span>명
            </div>
            <a
              href="/admin/staff/new"
              class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors"
            >
              직원 등록
            </a>
          </div>
        </div>

        {{#successMessage}}
          <div class="px-4 py-3 rounded-lg border border-green-200 bg-green-50 text-green-700 text-sm">{{successMessage}}</div>
        {{/successMessage}}

        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
          <form method="get" action="/admin/staff/list" class="p-4 border-b border-slate-200 bg-slate-50">
            <input type="hidden" name="page" value="1">
            <input type="hidden" name="size" value="{{model.size}}">

            <div class="flex flex-wrap items-end gap-3">
              <div class="relative min-w-[240px] flex-1">
                <label for="staff-keyword" class="block text-sm font-medium text-slate-700 mb-1.5">검색</label>
                <i data-feather="search" class="absolute left-3 top-[42px] -translate-y-1/2 w-4 h-4 text-slate-400"></i>
                <input
                  type="text"
                  id="staff-keyword"
                  name="keyword"
                  value="{{model.keyword}}"
                  placeholder="이름 또는 로그인 아이디 검색"
                  class="w-full pl-9 pr-4 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none"
                />
              </div>

              <div class="min-w-[180px]">
                <label for="staff-role" class="block text-sm font-medium text-slate-700 mb-1.5">역할</label>
                <select
                  id="staff-role"
                  name="role"
                  class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none"
                >
                  {{#model.roleOptions}}
                    <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                  {{/model.roleOptions}}
                </select>
              </div>

              <div class="min-w-[180px]">
                <label for="staff-employment-status" class="block text-sm font-medium text-slate-700 mb-1.5">재직 상태</label>
                <select
                  id="staff-employment-status"
                  name="employmentStatus"
                  class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none"
                >
                  {{#model.employmentStatusOptions}}
                    <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                  {{/model.employmentStatusOptions}}
                </select>
              </div>

              <button
                type="submit"
                class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors"
              >
                조회
              </button>
            </div>
          </form>

          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-200 text-xs uppercase tracking-wider text-slate-500">
                <th class="p-4 font-medium">이름</th>
                <th class="p-4 font-medium">로그인 아이디</th>
                <th class="p-4 font-medium">사번</th>
                <th class="p-4 font-medium">역할</th>
                <th class="p-4 font-medium">부서</th>
                <th class="p-4 font-medium">재직 상태</th>
                <th class="p-4 font-medium text-right">관리</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200">
              {{#model.staffs}}
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="p-4 text-sm font-semibold text-slate-800">{{name}}</td>
                  <td class="p-4 text-sm text-slate-700">{{username}}</td>
                  <td class="p-4 text-sm text-slate-700">{{employeeNumber}}</td>
                  <td class="p-4">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold {{roleBadgeClass}}">
                      {{roleLabel}}
                    </span>
                  </td>
                  <td class="p-4 text-sm text-slate-700">{{departmentName}}</td>
                  <td class="p-4">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold {{employmentStatusBadgeClass}}">
                      {{employmentStatusLabel}}
                    </span>
                  </td>
                  <td class="p-4 text-right">
                    <a
                      href="/admin/staff/form"
                      class="inline-flex items-center gap-1 px-3 py-1.5 bg-slate-100 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-200 transition-colors"
                    >
                      수정
                    </a>
                  </td>
                </tr>
              {{/model.staffs}}
              {{^model.staffs}}
                <tr>
                  <td colspan="7" class="p-8 text-center text-slate-500">조회된 직원이 없습니다.</td>
                </tr>
              {{/model.staffs}}
            </tbody>
          </table>

          <div class="p-4 border-t border-slate-200 flex items-center justify-center gap-2 bg-slate-50">
            {{#model.hasPrevious}}
              <a href="{{model.previousUrl}}" class="px-3 py-1.5 text-sm rounded-md border border-slate-300 text-slate-600 hover:bg-white">이전</a>
            {{/model.hasPrevious}}

            {{#model.pageLinks}}
              <a href="{{url}}" class="px-3 py-1.5 text-sm rounded-md border transition-colors {{#active}}bg-slate-800 border-slate-800 text-white{{/active}}{{^active}}border-slate-300 text-slate-600 hover:bg-white{{/active}}">{{page}}</a>
            {{/model.pageLinks}}

            {{#model.hasNext}}
              <a href="{{model.nextUrl}}" class="px-3 py-1.5 text-sm rounded-md border border-slate-300 text-slate-600 hover:bg-white">다음</a>
            {{/model.hasNext}}
          </div>
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>
    feather.replace();
  </script>
</body>
</html>
