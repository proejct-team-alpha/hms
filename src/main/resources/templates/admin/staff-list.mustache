<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>직원 관리</title>
    <link rel="stylesheet" href="/css/tailwind.min.css">
    <script src="/js/lucide.min.js"></script>
</head>
<body class="bg-slate-50 min-h-screen p-6">
    <div class="max-w-7xl mx-auto space-y-6">
        <!-- 헤더 -->
        <div class="flex justify-between items-center mb-8">
            <div class="flex items-center gap-3">
                <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600">
                    <i data-lucide="users" class="w-6 h-6"></i>
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-slate-800">직원 관리</h1>
                    <p class="text-slate-500 mt-1">병원 시스템 접속 권한을 가진 직원을 관리합니다.</p>
                </div>
            </div>
            <a href="staff-form.html" class="px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 transition-colors flex items-center gap-2">
                <i data-lucide="plus" class="w-5 h-5"></i>
                직원 등록
            </a>
        </div>

        <!-- 메인 콘텐츠 -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
            <!-- 검색바 -->
            <div class="p-4 border-b border-slate-200 bg-slate-50">
                <div class="relative w-64">
                    <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
                    <input 
                        type="text" 
                        placeholder="이름, 부서, 권한 검색..." 
                        class="w-full pl-9 pr-4 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none"
                    />
                </div>
            </div>

            <!-- 테이블 -->
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-200 text-xs uppercase tracking-wider text-slate-500">
                        <th class="p-4 font-medium">이름</th>
                        <th class="p-4 font-medium">권한 (Role)</th>
                        <th class="p-4 font-medium">부서/진료과</th>
                        <th class="p-4 font-medium">연락처</th>
                        <th class="p-4 font-medium text-right">관리</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200">
                    <!-- 항목 1 -->
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="p-4 text-sm font-bold text-slate-800 flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500">
                                <i data-lucide="user" class="w-4 h-4"></i>
                            </div>
                            김관리
                        </td>
                        <td class="p-4">
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-red-100 text-red-800">
                                <i data-lucide="shield-check" class="w-3.5 h-3.5"></i>
                                시스템 관리자
                            </span>
                        </td>
                        <td class="p-4 text-sm text-slate-600">행정부</td>
                        <td class="p-4 text-sm text-slate-600">010-1111-2222</td>
                        <td class="p-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <a href="staff-form.html?id=1" class="p-1.5 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-md transition-colors">
                                    <i data-lucide="edit-2" class="w-4 h-4"></i>
                                </a>
                                <button class="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-md transition-colors">
                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                </button>
                            </div>
                        </td>
                    </tr>

                    <!-- 항목 2 -->
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="p-4 text-sm font-bold text-slate-800 flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500">
                                <i data-lucide="user" class="w-4 h-4"></i>
                            </div>
                            이의사
                        </td>
                        <td class="p-4">
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-blue-100 text-blue-800">
                                <i data-lucide="shield-check" class="w-3.5 h-3.5"></i>
                                의사
                            </span>
                        </td>
                        <td class="p-4 text-sm text-slate-600">내과</td>
                        <td class="p-4 text-sm text-slate-600">010-3333-4444</td>
                        <td class="p-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <a href="staff-form.html?id=2" class="p-1.5 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-md transition-colors">
                                    <i data-lucide="edit-2" class="w-4 h-4"></i>
                                </a>
                                <button class="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-md transition-colors">
                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                </button>
                            </div>
                        </td>
                    </tr>

                    <!-- 항목 3 -->
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="p-4 text-sm font-bold text-slate-800 flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500">
                                <i data-lucide="user" class="w-4 h-4"></i>
                            </div>
                            박간호
                        </td>
                        <td class="p-4">
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-green-100 text-green-800">
                                <i data-lucide="shield-check" class="w-3.5 h-3.5"></i>
                                간호사
                            </span>
                        </td>
                        <td class="p-4 text-sm text-slate-600">외래간호팀</td>
                        <td class="p-4 text-sm text-slate-600">010-5555-6666</td>
                        <td class="p-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <a href="staff-form.html?id=3" class="p-1.5 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-md transition-colors">
                                    <i data-lucide="edit-2" class="w-4 h-4"></i>
                                </a>
                                <button class="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-md transition-colors">
                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                </button>
                            </div>
                        </td>
                    </tr>

                    <!-- 항목 4 -->
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="p-4 text-sm font-bold text-slate-800 flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500">
                                <i data-lucide="user" class="w-4 h-4"></i>
                            </div>
                            최원무
                        </td>
                        <td class="p-4">
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold bg-purple-100 text-purple-800">
                                <i data-lucide="shield-check" class="w-3.5 h-3.5"></i>
                                일반 직원
                            </span>
                        </td>
                        <td class="p-4 text-sm text-slate-600">원무과</td>
                        <td class="p-4 text-sm text-slate-600">010-7777-8888</td>
                        <td class="p-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <a href="staff-form.html?id=4" class="p-1.5 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-md transition-colors">
                                    <i data-lucide="edit-2" class="w-4 h-4"></i>
                                </a>
                                <button class="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-md transition-colors">
                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>

            <!-- 페이지네이션 -->
            <div class="p-4 border-t border-slate-200 bg-slate-50 flex justify-center">
                <nav class="flex items-center gap-1">
                    <button class="p-2 rounded-lg border border-slate-200 text-slate-400 hover:bg-slate-50 disabled:opacity-50" disabled>
                        <i data-lucide="chevron-left" class="w-4 h-4"></i>
                    </button>
                    <button class="w-8 h-8 flex items-center justify-center rounded-lg text-sm font-medium bg-indigo-600 text-white">
                        1
                    </button>
                    <button class="w-8 h-8 flex items-center justify-center rounded-lg text-sm font-medium text-slate-600 hover:bg-slate-50">
                        2
                    </button>
                    <button class="p-2 rounded-lg border border-slate-200 text-slate-400 hover:bg-slate-50">
                        <i data-lucide="chevron-right" class="w-4 h-4"></i>
                    </button>
                </nav>
            </div>
        </div>
    </div>

    <script src="/js/app.js"></script>
</body>
</html>
