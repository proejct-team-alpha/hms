<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>직원 관리 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-admin}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="space-y-4">

        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-2xl font-bold text-slate-800">직원 관리</h1>
            <p class="text-slate-500 mt-1">직원 정보를 조회하고 관리합니다.</p>
          </div>
          <a href="/admin/staff/form" class="flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors">
            <i data-feather="user-plus" class="w-4 h-4"></i>
            직원 등록
          </a>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-slate-50 border-b border-slate-200">
                <tr>
                  <th class="text-left px-4 py-3 font-semibold text-slate-600">사번</th>
                  <th class="text-left px-4 py-3 font-semibold text-slate-600">이름</th>
                  <th class="text-left px-4 py-3 font-semibold text-slate-600">아이디</th>
                  <th class="text-left px-4 py-3 font-semibold text-slate-600">직책</th>
                  <th class="text-left px-4 py-3 font-semibold text-slate-600">진료과</th>
                  <th class="text-left px-4 py-3 font-semibold text-slate-600">상태</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {{#staffList}}
                <tr class="hover:bg-slate-50">
                  <td class="px-4 py-3 font-mono text-xs text-slate-600">{{employeeNumber}}</td>
                  <td class="px-4 py-3 font-medium text-slate-800">{{name}}</td>
                  <td class="px-4 py-3 text-slate-600">{{username}}</td>
                  <td class="px-4 py-3 text-slate-600">{{roleText}}</td>
                  <td class="px-4 py-3 text-slate-600">{{departmentName}}</td>
                  <td class="px-4 py-3">
                    <span class="{{activeBadgeClass}}">{{activeText}}</span>
                  </td>
                </tr>
                {{/staffList}}
                {{^hasStaff}}
                <tr>
                  <td colspan="6" class="px-4 py-12 text-center text-slate-400">등록된 직원이 없습니다.</td>
                </tr>
                {{/hasStaff}}
              </tbody>
            </table>
          </div>
        </div>

      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>feather.replace();</script>
</body>
</html>
