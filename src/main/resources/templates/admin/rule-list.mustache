<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>병원 규칙 관리 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-admin}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="space-y-4">

        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-2xl font-bold text-slate-800">병원 규칙 관리</h1>
            <p class="text-slate-500 mt-1">병원 규칙을 조회하고 관리합니다.</p>
          </div>
          <a href="/admin/rule/form"
            class="flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors">
            <i data-feather="plus" class="w-4 h-4"></i>
            규칙 등록
          </a>
        </div>

        <div class="space-y-3">
          {{#rules}}
          <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-2">
                  <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-indigo-100 text-indigo-700">{{categoryText}}</span>
                  <span class="{{activeBadgeClass}}">{{activeText}}</span>
                </div>
                <h3 class="text-base font-bold text-slate-800 mb-1">{{title}}</h3>
                <p class="text-sm text-slate-500 line-clamp-2">{{content}}</p>
              </div>
            </div>
          </div>
          {{/rules}}
          {{^hasRules}}
          <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-12 text-center text-slate-400">
            등록된 규칙이 없습니다.
          </div>
          {{/hasRules}}
        </div>

      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>feather.replace();</script>
</body>
</html>
