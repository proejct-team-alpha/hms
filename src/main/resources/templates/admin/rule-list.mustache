<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>병원 규칙 관리</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="bg-slate-50 min-h-screen p-6">
    <div class="max-w-7xl mx-auto space-y-6">
        <!-- 헤더 -->
        <div class="flex justify-between items-center mb-8">
            <div class="flex items-center gap-3">
                <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600">
                    <i data-lucide="file-text" class="w-6 h-6"></i>
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-slate-800">병원 규칙 관리</h1>
                    <p class="text-slate-500 mt-1">챗봇이 참고할 병원 규칙을 관리합니다.</p>
                </div>
            </div>
            <a href="rule-form.html" class="px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 transition-colors flex items-center gap-2">
                <i data-lucide="plus" class="w-5 h-5"></i>
                규칙 등록
            </a>
        </div>

        <!-- 카테고리 탭 및 검색 -->
        <div class="flex flex-col md:flex-row gap-4 items-center justify-between mb-6">
            <div class="flex flex-wrap gap-2">
                <button class="px-4 py-2 rounded-xl text-sm font-bold transition-all bg-indigo-600 text-white shadow-md shadow-indigo-200">전체</button>
                <button class="px-4 py-2 rounded-xl text-sm font-bold transition-all bg-white text-slate-600 border border-slate-200 hover:bg-slate-50">일반안내</button>
                <button class="px-4 py-2 rounded-xl text-sm font-bold transition-all bg-white text-slate-600 border border-slate-200 hover:bg-slate-50">주차/시설</button>
                <button class="px-4 py-2 rounded-xl text-sm font-bold transition-all bg-white text-slate-600 border border-slate-200 hover:bg-slate-50">방역지침</button>
                <button class="px-4 py-2 rounded-xl text-sm font-bold transition-all bg-white text-slate-600 border border-slate-200 hover:bg-slate-50">기타</button>
            </div>
            <div class="relative w-full md:w-64">
                <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
                <input
                    type="text"
                    placeholder="규칙 제목, 내용 검색..."
                    class="w-full pl-10 pr-4 py-2 border border-slate-200 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none text-sm"
                />
            </div>
        </div>

        <!-- 규칙 목록 -->
        <div class="grid grid-cols-1 gap-4">
            <!-- 항목 1 -->
            <div onclick="openModal('면회 시간 안내', '일반안내', '평일: 18:00~20:00, 주말: 10:00~12:00, 18:00~20:00', true)" class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 flex items-start justify-between hover:shadow-md transition-shadow cursor-pointer">
                <div class="space-y-3 flex-1">
                    <div class="flex flex-wrap items-center gap-3">
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-lg bg-slate-100 text-slate-600 text-[10px] font-bold uppercase tracking-wider">
                            <i data-lucide="tag" class="w-3 h-3"></i>
                            일반안내
                        </span>
                        <h3 class="text-lg font-bold text-slate-800">면회 시간 안내</h3>
                        <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                            <i data-lucide="check-circle-2" class="w-3.5 h-3.5"></i>
                            활성 (챗봇 반영)
                        </span>
                    </div>
                    <p class="text-slate-600 text-sm leading-relaxed max-w-3xl">
                        평일: 18:00~20:00, 주말: 10:00~12:00, 18:00~20:00
                    </p>
                </div>
                <div class="flex items-center gap-2 ml-4">
                    <a href="rule-form.html?id=1" onclick="event.stopPropagation()" class="p-2 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors">
                        <i data-lucide="edit-2" class="w-5 h-5"></i>
                    </a>
                    <button onclick="event.stopPropagation()" class="p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors">
                        <i data-lucide="trash-2" class="w-5 h-5"></i>
                    </button>
                </div>
            </div>

            <!-- 항목 2 -->
            <div onclick="openModal('주차 요금 안내', '주차/시설', '외래 진료 환자 4시간 무료, 입원 환자 보호자 1대 무료', true)" class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 flex items-start justify-between hover:shadow-md transition-shadow cursor-pointer">
                <div class="space-y-3 flex-1">
                    <div class="flex flex-wrap items-center gap-3">
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-lg bg-slate-100 text-slate-600 text-[10px] font-bold uppercase tracking-wider">
                            <i data-lucide="tag" class="w-3 h-3"></i>
                            주차/시설
                        </span>
                        <h3 class="text-lg font-bold text-slate-800">주차 요금 안내</h3>
                        <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                            <i data-lucide="check-circle-2" class="w-3.5 h-3.5"></i>
                            활성 (챗봇 반영)
                        </span>
                    </div>
                    <p class="text-slate-600 text-sm leading-relaxed max-w-3xl">
                        외래 진료 환자 4시간 무료, 입원 환자 보호자 1대 무료
                    </p>
                </div>
                <div class="flex items-center gap-2 ml-4">
                    <a href="rule-form.html?id=2" onclick="event.stopPropagation()" class="p-2 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors">
                        <i data-lucide="edit-2" class="w-5 h-5"></i>
                    </a>
                    <button onclick="event.stopPropagation()" class="p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors">
                        <i data-lucide="trash-2" class="w-5 h-5"></i>
                    </button>
                </div>
            </div>

            <!-- 항목 3 -->
            <div onclick="openModal('코로나19 관련 지침 (구버전)', '방역지침', '모든 내원객 마스크 착용 의무화', false)" class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 flex items-start justify-between hover:shadow-md transition-shadow cursor-pointer">
                <div class="space-y-3 flex-1">
                    <div class="flex flex-wrap items-center gap-3">
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-lg bg-slate-100 text-slate-600 text-[10px] font-bold uppercase tracking-wider">
                            <i data-lucide="tag" class="w-3 h-3"></i>
                            방역지침
                        </span>
                        <h3 class="text-lg font-bold text-slate-800">코로나19 관련 지침 (구버전)</h3>
                        <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-600">
                            <i data-lucide="x-circle" class="w-3.5 h-3.5"></i>
                            비활성
                        </span>
                    </div>
                    <p class="text-slate-600 text-sm leading-relaxed max-w-3xl">
                        모든 내원객 마스크 착용 의무화
                    </p>
                </div>
                <div class="flex items-center gap-2 ml-4">
                    <a href="rule-form.html?id=3" onclick="event.stopPropagation()" class="p-2 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors">
                        <i data-lucide="edit-2" class="w-5 h-5"></i>
                    </a>
                    <button onclick="event.stopPropagation()" class="p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors">
                        <i data-lucide="trash-2" class="w-5 h-5"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- 페이지네이션 -->
        <div class="flex justify-center mt-6">
            <nav class="flex items-center gap-1">
                <button class="p-2 rounded-lg border border-slate-200 text-slate-400 hover:bg-slate-50 disabled:opacity-50" disabled>
                    <i data-lucide="chevron-left" class="w-4 h-4"></i>
                </button>
                <button class="w-8 h-8 flex items-center justify-center rounded-lg text-sm font-medium bg-indigo-600 text-white">
                    1
                </button>
                <button class="w-8 h-8 flex items-center justify-center rounded-lg text-sm font-medium text-slate-600 hover:bg-slate-50">
                    2
                </button>
                <button class="p-2 rounded-lg border border-slate-200 text-slate-400 hover:bg-slate-50">
                    <i data-lucide="chevron-right" class="w-4 h-4"></i>
                </button>
            </nav>
        </div>

        <!-- 규칙 상세 모달 -->
        <div id="ruleModal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50 p-4">
            <div class="bg-white rounded-2xl shadow-xl w-full max-w-2xl overflow-hidden animate-in fade-in zoom-in duration-200">
                <div class="p-6 border-b border-slate-100 flex justify-between items-center bg-slate-50">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600">
                            <i data-lucide="file-text" class="w-5 h-5"></i>
                        </div>
                        <div>
                            <h3 class="text-lg font-bold text-slate-800">병원 규칙 상세보기</h3>
                            <div class="flex items-center gap-2 mt-0.5">
                                <span id="modalCategory" class="text-xs font-medium text-slate-500">카테고리</span>
                                <span class="w-1 h-1 bg-slate-300 rounded-full"></span>
                                <span id="modalStatus" class="text-xs font-bold">상태</span>
                            </div>
                        </div>
                    </div>
                    <button onclick="closeModal()" class="p-2 hover:bg-slate-200 rounded-full transition-colors text-slate-400 hover:text-slate-600">
                        <i data-lucide="x" class="w-6 h-6"></i>
                    </button>
                </div>
                <div class="p-8 space-y-6">
                    <div>
                        <h4 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-2">규칙 제목</h4>
                        <p id="modalTitle" class="text-xl font-bold text-slate-800">제목</p>
                    </div>
                    <div>
                        <h4 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-2">상세 내용</h4>
                        <div class="bg-slate-50 rounded-xl p-6 border border-slate-100">
                            <p id="modalContent" class="text-slate-700 leading-relaxed whitespace-pre-wrap">내용</p>
                        </div>
                    </div>
                    <div class="flex justify-end pt-4">
                        <button onclick="closeModal()" class="px-6 py-2.5 bg-slate-800 text-white font-bold rounded-xl hover:bg-slate-700 transition-all shadow-lg shadow-slate-200">
                            닫기
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // 아이콘 초기화
        lucide.createIcons();

        // 모달 관리
        const modal = document.getElementById('ruleModal');

        function openModal(title, category, content, isActive) {
            document.getElementById('modalTitle').textContent = title;
            document.getElementById('modalCategory').textContent = category;
            document.getElementById('modalContent').textContent = content;
            
            const statusEl = document.getElementById('modalStatus');
            statusEl.textContent = isActive ? '활성 상태' : '비활성 상태';
            statusEl.className = `text-xs font-bold ${isActive ? 'text-green-600' : 'text-slate-400'}`;

            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeModal() {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }
    </script>
</body>
</html>
