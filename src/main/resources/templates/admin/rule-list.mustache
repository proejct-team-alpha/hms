<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{pageTitle}} - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body>
  {{> common/sidebar-admin}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper">
      <div
        class="space-y-6 max-w-6xl mx-auto"
        data-rule-list-page
      >
        <div class="flex items-center justify-between mb-6">
          <div>
            <h1 class="text-2xl font-bold text-slate-800">{{pageTitle}}</h1>
            <p class="text-slate-500 mt-1">제목, 카테고리, 활성 여부 기준으로 병원 규칙을 조회하고 관리합니다.</p>
          </div>
          <div class="flex items-center gap-4">
            <div class="text-sm text-slate-500 text-right">
              <div>총 <span class="font-semibold text-slate-700">{{model.totalCount}}</span>건</div>
              {{#model.hasPages}}
                <div>{{model.currentPage}} / {{model.totalPages}} 페이지</div>
              {{/model.hasPages}}
              {{^model.hasPages}}
                <div>0 / 0 페이지</div>
              {{/model.hasPages}}
            </div>
            <a
              href="/admin/rule/new"
              class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors"
            >
              규칙 등록
            </a>
          </div>
        </div>

        {{#successMessage}}
          <div class="rounded-xl border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">
            {{successMessage}}
          </div>
        {{/successMessage}}
        {{#errorMessage}}
          <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
            {{errorMessage}}
          </div>
        {{/errorMessage}}

        <div
          data-rule-list-toast
          class="hidden fixed top-6 right-6 z-50 max-w-sm rounded-xl border px-4 py-3 text-sm font-medium shadow-lg"
          aria-live="polite"
        ></div>

        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
          <form method="get" action="/admin/rule/list" class="p-4 border-b border-slate-200 bg-slate-50">
            <input type="hidden" name="page" value="1">
            <input type="hidden" name="size" value="{{model.size}}">

            <div class="flex flex-wrap items-end gap-3">
              <div class="min-w-[260px] flex-1">
                <label for="rule-keyword" class="block text-sm font-medium text-slate-700 mb-1.5">제목 검색</label>
                <div class="relative">
                  <i data-feather="search" class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
                  <input
                    type="text"
                    id="rule-keyword"
                    name="keyword"
                    value="{{model.keyword}}"
                    placeholder="규칙 제목 검색"
                    class="w-full pl-9 pr-4 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none"
                  >
                </div>
              </div>

              <div class="min-w-[180px]">
                <label for="rule-category" class="block text-sm font-medium text-slate-700 mb-1.5">카테고리</label>
                <select
                  id="rule-category"
                  name="category"
                  class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none"
                >
                  {{#model.categoryOptions}}
                    <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                  {{/model.categoryOptions}}
                </select>
              </div>

              <div class="min-w-[180px]">
                <label for="rule-active" class="block text-sm font-medium text-slate-700 mb-1.5">활성 여부</label>
                <select
                  id="rule-active"
                  name="active"
                  class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none"
                >
                  {{#model.activeOptions}}
                    <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                  {{/model.activeOptions}}
                </select>
              </div>

              <button
                type="submit"
                class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors"
              >
                조회
              </button>
              <a
                href="/admin/rule/list"
                class="px-4 py-2 bg-slate-100 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-200 transition-colors"
              >
                초기화
              </a>
            </div>
          </form>

          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-200 text-xs uppercase tracking-wider text-slate-500">
                <th class="p-4 font-medium">제목</th>
                <th class="p-4 font-medium">카테고리</th>
                <th class="p-4 font-medium">상태</th>
                <th class="p-4 font-medium text-right">관리</th>
              </tr>
            </thead>
            <tbody
              class="divide-y divide-slate-200"
              data-rule-table-body
              data-empty-message="조회된 규칙이 없습니다."
            >
              {{#model.rules}}
                <tr
                  class="hover:bg-slate-50 transition-colors cursor-pointer focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:ring-inset"
                  data-rule-row
                  data-rule-detail-url="/admin/rule/detail?ruleId={{id}}"
                  tabindex="0"
                >
                  <td class="p-4 text-sm font-semibold text-slate-800">
                    {{title}}
                  </td>
                  <td class="p-4">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-indigo-100 text-indigo-700">
                      {{categoryText}}
                    </span>
                  </td>
                  <td class="p-4">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold {{activeBadgeClass}}">
                      {{activeText}}
                    </span>
                  </td>
                  <td class="p-4 text-right">
                    <button
                      type="button"
                      class="inline-flex items-center justify-center gap-2 px-3 py-1.5 rounded-lg border border-red-200 bg-red-50 text-sm font-medium text-red-600 hover:bg-red-100 transition-colors"
                      data-rule-delete-button
                      data-rule-delete-url="/admin/api/rules/{{id}}"
                    >
                      <i data-feather="trash-2" class="w-4 h-4"></i>
                      삭제
                    </button>
                  </td>
                </tr>
              {{/model.rules}}
              {{^model.rules}}
                <tr data-rule-empty-row>
                  <td colspan="4" class="p-8 text-center text-slate-500">조회된 규칙이 없습니다.</td>
                </tr>
              {{/model.rules}}
            </tbody>
          </table>

          <div class="p-4 border-t border-slate-200 flex items-center justify-center gap-2 bg-slate-50">
            {{#model.hasPrevious}}
              <a href="{{model.previousUrl}}" class="px-3 py-1.5 text-sm rounded-md border border-slate-300 text-slate-600 hover:bg-white">이전</a>
            {{/model.hasPrevious}}

            {{#model.pageLinks}}
              <a href="{{url}}" class="px-3 py-1.5 text-sm rounded-md border transition-colors {{#active}}bg-slate-800 border-slate-800 text-white{{/active}}{{^active}}border-slate-300 text-slate-600 hover:bg-white{{/active}}">{{page}}</a>
            {{/model.pageLinks}}

            {{#model.hasNext}}
              <a href="{{model.nextUrl}}" class="px-3 py-1.5 text-sm rounded-md border border-slate-300 text-slate-600 hover:bg-white">다음</a>
            {{/model.hasNext}}
          </div>
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>
    feather.replace();

    (function () {
      const page = document.querySelector('[data-rule-list-page]');

      if (!page) {
        return;
      }

      const toast = page.querySelector('[data-rule-list-toast]');
      const tableBody = page.querySelector('[data-rule-table-body]');
      const csrfToken = '{{_csrf.token}}';
      const emptyMessage = tableBody ? tableBody.dataset.emptyMessage : '';
      let toastTimerId;

      function showToast(type, message) {
        if (!toast) {
          return;
        }

        if (toastTimerId) {
          window.clearTimeout(toastTimerId);
        }

        toast.className = 'fixed top-6 right-6 z-50 max-w-sm rounded-xl border px-4 py-3 text-sm font-medium shadow-lg';

        if (type === 'success') {
          toast.classList.add('border-green-200', 'bg-green-50', 'text-green-700');
        } else {
          toast.classList.add('border-red-200', 'bg-red-50', 'text-red-700');
        }

        toast.textContent = message;
        toast.classList.remove('hidden');

        toastTimerId = window.setTimeout(function () {
          toast.classList.add('hidden');
        }, 2500);
      }

      function ensureEmptyStateRow() {
        if (!tableBody) {
          return;
        }

        const remainingRows = tableBody.querySelectorAll('[data-rule-row]');
        const existingEmptyRow = tableBody.querySelector('[data-rule-empty-row]');

        if (remainingRows.length > 0) {
          if (existingEmptyRow) {
            existingEmptyRow.remove();
          }
          return;
        }

        if (existingEmptyRow) {
          return;
        }

        const emptyRow = document.createElement('tr');
        emptyRow.setAttribute('data-rule-empty-row', '');

        const emptyCell = document.createElement('td');
        emptyCell.colSpan = 4;
        emptyCell.className = 'p-8 text-center text-slate-500';
        emptyCell.textContent = emptyMessage || '조회된 규칙이 없습니다.';

        emptyRow.appendChild(emptyCell);
        tableBody.appendChild(emptyRow);
      }

      function resolveErrorMessage(payload) {
        const message = payload && payload.msg ? payload.msg : '';

        if (message.indexOf('RESOURCE_NOT_FOUND') !== -1) {
          return '이미 삭제되었거나 존재하지 않는 규칙입니다.';
        }

        if (message.indexOf('ACCESS_DENIED') !== -1) {
          return '규칙 삭제 권한이 없습니다.';
        }

        return '규칙 삭제에 실패했습니다. 잠시 후 다시 시도해 주세요.';
      }

      async function parseResponse(response) {
        const contentType = response.headers.get('content-type') || '';

        if (contentType.indexOf('application/json') !== -1) {
          return response.json();
        }

        const text = await response.text();

        try {
          return JSON.parse(text);
        } catch (error) {
          return { msg: text };
        }
      }

      function bindRowNavigation(row) {
        const detailUrl = row.dataset.ruleDetailUrl;

        if (!detailUrl) {
          return;
        }

        row.addEventListener('click', function (event) {
          if (event.target.closest('[data-rule-delete-button]')) {
            return;
          }

          window.location.href = detailUrl;
        });

        row.addEventListener('keydown', function (event) {
          if (event.key !== 'Enter') {
            return;
          }

          if (event.target.closest('[data-rule-delete-button]')) {
            return;
          }

          event.preventDefault();
          window.location.href = detailUrl;
        });
      }

      function bindDeleteButton(button) {
        button.addEventListener('click', async function (event) {
          event.preventDefault();
          event.stopPropagation();

          const deleteUrl = button.dataset.ruleDeleteUrl;
          const row = button.closest('[data-rule-row]');

          if (!deleteUrl || !row) {
            return;
          }

          if (!window.confirm('정말 삭제하시겠습니까?')) {
            return;
          }

          button.disabled = true;
          button.classList.add('opacity-60', 'cursor-not-allowed');

          try {
            const response = await fetch(deleteUrl, {
              method: 'POST',
              headers: {
                'X-CSRF-TOKEN': csrfToken
              }
            });

            const result = await parseResponse(response);

            if (!response.ok) {
              showToast('error', resolveErrorMessage(result));
              return;
            }

            row.remove();
            ensureEmptyStateRow();
            showToast(
              'success',
              result && result.body && result.body.message
                ? result.body.message
                : '규칙이 삭제되었습니다.'
            );
          } catch (error) {
            console.error(error);
            showToast('error', '규칙 삭제 중 오류가 발생했습니다. 다시 시도해 주세요.');
          } finally {
            button.disabled = false;
            button.classList.remove('opacity-60', 'cursor-not-allowed');
          }
        });
      }

      page.querySelectorAll('[data-rule-row]').forEach(bindRowNavigation);
      page.querySelectorAll('[data-rule-delete-button]').forEach(bindDeleteButton);
    }());
  </script>
</body>
</html>
