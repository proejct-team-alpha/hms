<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>병원 규칙 등록/수정 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body>
  
  {{> common/sidebar-admin}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}
    
    <main class="content-wrapper">
      <div class="max-w-2xl mx-auto space-y-6">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600">
              <i data-feather="file-text" class="w-6 h-6"></i>
            </div>
            <div>
              <h1 class="text-2xl font-bold text-slate-800" id="page-title">병원 규칙 등록</h1>
              <p class="text-slate-500 mt-1">챗봇이 참고할 병원 규칙을 작성합니다.</p>
            </div>
          </div>
          <a href="rule-list.html" class="text-sm font-medium text-slate-500 hover:text-slate-700">
            목록으로 돌아가기
          </a>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
          <form id="rule-form" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">규칙 제목</label>
                <input
                  type="text"
                  id="rule-title"
                  required
                  class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none"
                  placeholder="예: 면회 시간 안내"
                />
              </div>

              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">카테고리</label>
                <select
                  id="rule-category"
                  class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none"
                >
                  <option value="일반안내">일반안내</option>
                  <option value="주차/시설">주차/시설</option>
                  <option value="방역지침">방역지침</option>
                  <option value="기타">기타</option>
                </select>
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-slate-700 mb-2">규칙 내용 (챗봇 프롬프트 반영)</label>
              <textarea
                id="rule-content"
                required
                class="w-full p-4 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none h-48 resize-none leading-relaxed"
                placeholder="상세한 규칙 내용을 작성해주세요. 이 내용은 챗봇이 답변할 때 참고합니다."
              ></textarea>
            </div>

            <div class="flex items-center gap-3 p-4 bg-slate-50 rounded-xl border border-slate-200">
              <label class="flex items-center gap-3 cursor-pointer">
                <input
                  type="checkbox"
                  id="rule-active"
                  checked
                  class="w-5 h-5 text-indigo-600 rounded focus:ring-indigo-500 border-slate-300"
                />
                <span class="text-sm font-medium text-slate-700">활성화 (챗봇 응답에 즉시 반영)</span>
              </label>
              <i data-feather="check-circle" id="active-icon" class="w-5 h-5 text-green-500 ml-auto"></i>
            </div>

            <div class="pt-6 border-t border-slate-200 flex justify-end gap-3">
              <a href="rule-list.html" class="px-6 py-3 bg-white border border-slate-300 text-slate-700 font-medium rounded-xl hover:bg-slate-50 transition-colors">
                취소
              </a>
              <button type="submit" class="px-8 py-3 bg-indigo-600 text-white font-medium rounded-xl hover:bg-indigo-700 transition-colors shadow-sm flex items-center gap-2">
                <i data-feather="save" class="w-5 h-5"></i>
                저장하기
              </button>
            </div>
          </form>
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script src="/js/data.js"></script>
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const urlParams = new URLSearchParams(window.location.search);
      const id = urlParams.get('id');
      
      const form = document.getElementById('rule-form');
      const titleInput = document.getElementById('rule-title');
      const categoryInput = document.getElementById('rule-category');
      const contentInput = document.getElementById('rule-content');
      const activeInput = document.getElementById('rule-active');
      const activeIcon = document.getElementById('active-icon');
      const pageTitle = document.getElementById('page-title');

      if (id) {
        pageTitle.textContent = '병원 규칙 수정';
        const rule = getRuleById(id);
        if (rule) {
          titleInput.value = rule.title;
          categoryInput.value = rule.category;
          contentInput.value = rule.content;
          activeInput.checked = rule.isActive;
          updateActiveIcon(rule.isActive);
        }
      }

      function updateActiveIcon(isActive) {
        if (isActive) {
          activeIcon.setAttribute('data-feather', 'check-circle');
          activeIcon.className = 'w-5 h-5 text-green-500 ml-auto';
        } else {
          activeIcon.setAttribute('data-feather', 'x-circle');
          activeIcon.className = 'w-5 h-5 text-slate-400 ml-auto';
        }
        feather.replace();
      }

      activeInput.addEventListener('change', (e) => {
        updateActiveIcon(e.target.checked);
      });

      form.addEventListener('submit', (e) => {
        e.preventDefault();
        
        const data = {
          title: titleInput.value,
          category: categoryInput.value,
          content: contentInput.value,
          isActive: activeInput.checked
        };

        if (id) {
          updateRule(id, data);
        } else {
          addRule(data);
        }

        alert('규칙이 저장되었습니다.');
        window.location.href = 'rule-list.html';
      });

      feather.replace();
    });
  </script>
</body>
</html>
