<form action="{{#staff}}/staff/{{id}}/update{{/staff}}{{^staff}}/staff/create{{/staff}}" method="POST" class="space-y-6">
  <input type="text" name="name" value="{{#staff}}{{name}}{{/staff}}" required class="w-full..." placeholder="예: 김의사"/>
  <input type="tel" name="phone" value="{{#staff}}{{phone}}{{/staff}}" required class="w-full..." placeholder="010-1234-5678"/>
  <input type="text" name="dept" value="{{#staff}}{{dept}}{{/staff}}" required class="w-full..."/>

  <div class="pt-6 border-t border-slate-200">
    <h3 class="text-sm font-bold text-slate-800 mb-4 flex items-center gap-2">
      <i data-feather="lock" class="w-4 h-4 text-indigo-500"></i>
      접속 비밀번호 설정
    </h3>
    <div class="grid grid-cols-2 gap-6">
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-2">새 비밀번호</label>
        <input type="password" name="password" {{^staff}}required{{/staff}} class="w-full..." placeholder="{{#staff}}변경할 경우에만 입력{{/staff}}{{^staff}}비밀번호 입력{{/staff}}"/>
      </div>
      </div>
  </div>
  </form>