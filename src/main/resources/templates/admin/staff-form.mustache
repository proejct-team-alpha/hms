<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>직원 등록 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body>
  {{> common/sidebar-admin}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper">
      <div class="max-w-3xl mx-auto space-y-6">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-2xl font-bold text-slate-800">{{model.title}}</h1>
            <p class="text-slate-500 mt-1">직원 계정 정보를 입력하고 시스템 접근 권한을 설정합니다.</p>
          </div>
          <a href="/admin/staff/list" class="text-sm font-medium text-slate-500 hover:text-slate-700">
            목록으로 돌아가기
          </a>
        </div>

        {{#errorMessage}}
          <div class="px-4 py-3 rounded-lg border border-red-200 bg-red-50 text-red-700 text-sm">{{errorMessage}}</div>
        {{/errorMessage}}

        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
          <form method="post" action="{{model.formAction}}" class="space-y-6">
            <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="staff-username" class="block text-sm font-medium text-slate-700 mb-2">로그인 아이디</label>
                <input
                  type="text"
                  id="staff-username"
                  name="username"
                  value="{{model.username}}"
                  required
                  class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none"
                  placeholder="예: staff02"
                />
              </div>
              <div>
                <label for="staff-password" class="block text-sm font-medium text-slate-700 mb-2">비밀번호</label>
                <input
                  type="password"
                  id="staff-password"
                  name="password"
                  required
                  class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none"
                  placeholder="8자 이상 입력"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="staff-name" class="block text-sm font-medium text-slate-700 mb-2">이름</label>
                <input
                  type="text"
                  id="staff-name"
                  name="name"
                  value="{{model.name}}"
                  required
                  class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none"
                  placeholder="예: 김직원"
                />
              </div>
              <div>
                <label for="staff-employee-number" class="block text-sm font-medium text-slate-700 mb-2">사번</label>
                <input
                  type="text"
                  id="staff-employee-number"
                  name="employeeNumber"
                  value="{{model.employeeNumber}}"
                  required
                  class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none"
                  placeholder="예: S-20260301"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="staff-role" class="block text-sm font-medium text-slate-700 mb-2">역할</label>
                <select
                  id="staff-role"
                  name="role"
                  class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none bg-white"
                >
                  {{#model.roleOptions}}
                    <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                  {{/model.roleOptions}}
                </select>
              </div>
              <div>
                <label for="staff-department" class="block text-sm font-medium text-slate-700 mb-2">부서</label>
                <select
                  id="staff-department"
                  name="departmentId"
                  class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none bg-white"
                >
                  <option value="">부서 선택 안함</option>
                  {{#model.departmentOptions}}
                    <option value="{{id}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                  {{/model.departmentOptions}}
                </select>
              </div>
            </div>

            <div>
              <label for="staff-active" class="block text-sm font-medium text-slate-700 mb-2">재직 상태</label>
              <select
                id="staff-active"
                name="active"
                class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none bg-white"
              >
                {{#model.employmentStatusOptions}}
                  <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                {{/model.employmentStatusOptions}}
              </select>
            </div>

            <div class="pt-6 border-t border-slate-200 flex justify-end gap-3">
              <a href="/admin/staff/list" class="px-6 py-3 bg-white border border-slate-300 text-slate-700 font-medium rounded-xl hover:bg-slate-50 transition-colors">
                취소
              </a>
              <button type="submit" class="px-8 py-3 bg-indigo-600 text-white font-medium rounded-xl hover:bg-indigo-700 transition-colors shadow-sm flex items-center gap-2">
                <i data-feather="save" class="w-5 h-5"></i>
                {{model.submitLabel}}
              </button>
            </div>
          </form>
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>
    feather.replace();
  </script>
</body>
</html>
