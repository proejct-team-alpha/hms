<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{model.title}} - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-admin}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="max-w-3xl mx-auto space-y-6">
        <div class="flex items-center gap-3">
          <a href="/admin/staff/list" class="p-2 text-slate-400 hover:text-slate-600 hover:bg-slate-100 rounded-lg transition-colors">
            <i data-feather="arrow-left" class="w-5 h-5"></i>
          </a>
          <div>
            <h1 class="text-2xl font-bold text-slate-800">{{model.title}}</h1>
            {{^model.editMode}}
              <p class="text-slate-500 mt-1">직원 정보를 입력하고 부서에 맞는 설정을 함께 관리합니다.</p>
            {{/model.editMode}}
            {{#model.editMode}}
              <p class="text-slate-500 mt-1">직원 정보를 확인하고 필요한 항목만 수정합니다.</p>
            {{/model.editMode}}
          </div>
        </div>

        {{#errorMessage}}
          <div class="px-4 py-3 rounded-lg border border-red-200 bg-red-50 text-red-700 text-sm">{{errorMessage}}</div>
        {{/errorMessage}}

        {{#model.selfEdit}}
          <div class="px-4 py-3 rounded-lg border border-amber-200 bg-amber-50 text-amber-800 text-sm">
            본인 계정은 재직 상태와 퇴사 일시를 직접 변경할 수 없습니다.
          </div>
        {{/model.selfEdit}}

        {{#model.readOnly}}
          <div class="px-4 py-3 rounded-lg border border-slate-200 bg-slate-50 text-slate-700 text-sm">
            비활성화된 직원입니다. 조회만 가능합니다.
          </div>
        {{/model.readOnly}}

        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
          <form method="post" action="{{model.formAction}}" class="space-y-6">
            <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
            {{#model.editMode}}
              <input type="hidden" name="staffId" value="{{model.staffId}}">
            {{/model.editMode}}

            {{^model.editMode}}
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label for="staff-username" class="block text-sm font-medium text-slate-700 mb-2">로그인 아이디</label>
                  <input
                    type="text"
                    id="staff-username"
                    name="username"
                    value="{{model.username}}"
                    required
                    class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none"
                    placeholder="예: staff02"
                  />
                  {{#usernameError}}
                    <p class="mt-2 text-sm text-red-600">{{usernameError}}</p>
                  {{/usernameError}}
                </div>
                <div>
                  <label for="staff-password" class="block text-sm font-medium text-slate-700 mb-2">비밀번호</label>
                  <input
                    type="password"
                    id="staff-password"
                    name="password"
                    required
                    class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none"
                    placeholder="8자 이상 입력"
                  />
                  {{#passwordError}}
                    <p class="mt-2 text-sm text-red-600">{{passwordError}}</p>
                  {{/passwordError}}
                </div>
              </div>
            {{/model.editMode}}

            {{#model.editMode}}
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2">로그인 아이디</label>
                  <div class="w-full px-4 py-3 border border-slate-200 rounded-xl bg-slate-50 text-slate-700">{{model.username}}</div>
                </div>
                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2">사번</label>
                  <div class="w-full px-4 py-3 border border-slate-200 rounded-xl bg-slate-50 text-slate-700">{{model.employeeNumber}}</div>
                </div>
              </div>

              <div>
                <label for="staff-password" class="block text-sm font-medium text-slate-700 mb-2">비밀번호</label>
                <input
                  type="password"
                  id="staff-password"
                  name="password"
                  class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none disabled:bg-slate-50 disabled:text-slate-500"
                  {{#model.readOnly}}disabled{{/model.readOnly}}
                  placeholder="변경할 때만 입력하세요"
                />
                {{#passwordError}}
                  <p class="mt-2 text-sm text-red-600">{{passwordError}}</p>
                {{/passwordError}}
                <p class="text-xs text-slate-500 mt-2">비워두면 기존 비밀번호를 유지합니다.</p>
              </div>
            {{/model.editMode}}

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="staff-name" class="block text-sm font-medium text-slate-700 mb-2">이름</label>
                <input
                  type="text"
                  id="staff-name"
                  name="name"
                  value="{{model.name}}"
                  required
                  class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none disabled:bg-slate-50 disabled:text-slate-500"
                  {{#model.readOnly}}disabled{{/model.readOnly}}
                  placeholder="예: 김직원"
                />
                {{#nameError}}
                  <p class="mt-2 text-sm text-red-600">{{nameError}}</p>
                {{/nameError}}
              </div>

              {{^model.editMode}}
                <div>
                  <label for="staff-employee-number" class="block text-sm font-medium text-slate-700 mb-2">사번</label>
                  <input
                    type="text"
                    id="staff-employee-number"
                    name="employeeNumber"
                    value="{{model.employeeNumber}}"
                    required
                    class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none"
                    placeholder="예: S-20260301"
                  />
                  {{#employeeNumberError}}
                    <p class="mt-2 text-sm text-red-600">{{employeeNumberError}}</p>
                  {{/employeeNumberError}}
                </div>
              {{/model.editMode}}

              {{#model.editMode}}
                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2">부서</label>
                  <div class="w-full px-4 py-3 border border-slate-200 rounded-xl bg-slate-50 text-slate-700">{{model.selectedRoleLabel}}</div>
                </div>
              {{/model.editMode}}
            </div>

            {{^model.editMode}}
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label for="staff-role" class="block text-sm font-medium text-slate-700 mb-2">부서</label>
                  <select
                    id="staff-role"
                    name="role"
                    required
                    class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none bg-white"
                  >
                    {{#model.roleOptions}}
                      <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                    {{/model.roleOptions}}
                  </select>
                  {{#roleError}}
                    <p class="mt-2 text-sm text-red-600">{{roleError}}</p>
                  {{/roleError}}
                </div>

                <div>
                  <label for="staff-active" class="block text-sm font-medium text-slate-700 mb-2">재직 상태</label>
                  <select
                    id="staff-active"
                    name="active"
                    class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none bg-white disabled:bg-slate-50 disabled:text-slate-500"
                    {{#model.employmentStatusLocked}}disabled{{/model.employmentStatusLocked}}
                  >
                    {{#model.employmentStatusOptions}}
                      <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                    {{/model.employmentStatusOptions}}
                  </select>
                  {{#model.employmentStatusLocked}}
                    <input type="hidden" name="active" value="{{#model.active}}true{{/model.active}}{{^model.active}}false{{/model.active}}">
                  {{/model.employmentStatusLocked}}
                  {{#activeError}}
                    <p class="mt-2 text-sm text-red-600">{{activeError}}</p>
                  {{/activeError}}
                </div>
              </div>

              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">퇴사 일시</label>
                <input type="hidden" id="staff-retired-at-hidden" name="retiredAt" value="{{model.retiredAt}}">
                <div class="grid grid-cols-[minmax(0,1fr)_120px] gap-3">
                  <input
                    type="date"
                    id="staff-retired-at-date"
                    name="retiredAtDate"
                    value="{{model.retiredAtDate}}"
                    class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none disabled:bg-slate-50 disabled:text-slate-500"
                    {{#model.retiredAtLocked}}disabled{{/model.retiredAtLocked}}
                  />
                  <select
                    id="staff-retired-at-hour"
                    name="retiredAtHour"
                    class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none bg-white disabled:bg-slate-50 disabled:text-slate-500"
                    {{#model.retiredAtLocked}}disabled{{/model.retiredAtLocked}}
                  >
                    <option value="">시간</option>
                    {{#model.retiredAtHourOptions}}
                      <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                    {{/model.retiredAtHourOptions}}
                  </select>
                </div>
                {{#retiredAtError}}
                  <p class="mt-2 text-sm text-red-600">{{retiredAtError}}</p>
                {{/retiredAtError}}
                {{^model.retiredAtLocked}}
                  <p class="text-xs text-slate-500 mt-2">날짜와 시간을 모두 선택하면 분은 자동으로 00으로 고정됩니다.</p>
                {{/model.retiredAtLocked}}
              </div>
            {{/model.editMode}}

            {{#model.editMode}}
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">
                <div>
                  <label for="staff-active" class="block text-sm font-medium text-slate-700 mb-2">재직 상태</label>
                  <select
                    id="staff-active"
                    name="active"
                    class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none bg-white disabled:bg-slate-50 disabled:text-slate-500"
                    {{#model.employmentStatusLocked}}disabled{{/model.employmentStatusLocked}}
                  >
                    {{#model.employmentStatusOptions}}
                      <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                    {{/model.employmentStatusOptions}}
                  </select>
                  {{#model.employmentStatusLocked}}
                    <input type="hidden" name="active" value="{{#model.active}}true{{/model.active}}{{^model.active}}false{{/model.active}}">
                  {{/model.employmentStatusLocked}}
                  {{#activeError}}
                    <p class="mt-2 text-sm text-red-600">{{activeError}}</p>
                  {{/activeError}}
                </div>

                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2">퇴사 일시</label>
                  <input type="hidden" id="staff-retired-at-hidden" name="retiredAt" value="{{model.retiredAt}}">
                  <div class="grid grid-cols-[minmax(0,1fr)_120px] gap-3">
                    <input
                      type="date"
                      id="staff-retired-at-date"
                      name="retiredAtDate"
                      value="{{model.retiredAtDate}}"
                      class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none disabled:bg-slate-50 disabled:text-slate-500"
                      {{#model.retiredAtLocked}}disabled{{/model.retiredAtLocked}}
                    />
                    <select
                      id="staff-retired-at-hour"
                      name="retiredAtHour"
                      class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none bg-white disabled:bg-slate-50 disabled:text-slate-500"
                      {{#model.retiredAtLocked}}disabled{{/model.retiredAtLocked}}
                    >
                      <option value="">시간</option>
                      {{#model.retiredAtHourOptions}}
                        <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                      {{/model.retiredAtHourOptions}}
                    </select>
                  </div>
                  {{#retiredAtError}}
                    <p class="mt-2 text-sm text-red-600">{{retiredAtError}}</p>
                  {{/retiredAtError}}
                  {{^model.retiredAtLocked}}
                    <p class="text-xs text-slate-500 mt-2">날짜와 시간을 모두 선택하면 분은 자동으로 00으로 고정됩니다.</p>
                  {{/model.retiredAtLocked}}
                </div>
              </div>
            {{/model.editMode}}

            <div id="doctor-fields" class="border-t border-slate-200 pt-6 space-y-6 {{^model.doctorRole}}hidden{{/model.doctorRole}}">
              <div>
                <h2 class="text-lg font-semibold text-slate-800">의사 전용 정보</h2>
                <p class="text-sm text-slate-500 mt-1">의사 부서일 때만 진료과와 진료 가능 요일을 함께 관리합니다.</p>
              </div>


              <div>
                <label for="doctor-department" class="block text-sm font-medium text-slate-700 mb-2">진료과</label>
                <select
                  id="doctor-department"
                  name="departmentId"
                  class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none bg-white disabled:bg-slate-50 disabled:text-slate-500"
                  {{#model.readOnly}}disabled{{/model.readOnly}}
                >
                  <option value="">진료과를 선택하세요</option>
                  {{#model.departmentOptions}}
                    <option value="{{id}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                  {{/model.departmentOptions}}
                </select>
                {{#departmentIdError}}
                  <p class="mt-2 text-sm text-red-600">{{departmentIdError}}</p>
                {{/departmentIdError}}
              </div>

              <div>
                <span class="block text-sm font-medium text-slate-700 mb-3">진료 가능 요일</span>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                  {{#model.availableDayOptions}}
                    <label class="flex items-center gap-2 px-3 py-2 border border-slate-300 rounded-lg bg-white text-sm text-slate-700 disabled:bg-slate-50">
                      <input type="checkbox" name="availableDays" value="{{value}}" {{#selected}}checked{{/selected}} {{#model.readOnly}}disabled{{/model.readOnly}}>
                      <span>{{label}}</span>
                    </label>
                  {{/model.availableDayOptions}}
                </div>
              </div>
            </div>

            <div class="pt-6 border-t border-slate-200 flex justify-end gap-3">
              <a href="/admin/staff/list" class="px-6 py-3 bg-white border border-slate-300 text-slate-700 font-medium rounded-xl hover:bg-slate-50 transition-colors">
                취소
              </a>
              {{^model.readOnly}}
                <button type="submit" class="px-8 py-3 bg-indigo-600 text-white font-medium rounded-xl hover:bg-indigo-700 transition-colors shadow-sm flex items-center gap-2">
                  <i data-feather="save" class="w-5 h-5"></i>
                  {{model.submitLabel}}
                </button>
              {{/model.readOnly}}
            </div>
          </form>
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>
    const staffForm = document.querySelector("form");
    const roleSelect = document.getElementById("staff-role");
    const doctorFields = document.getElementById("doctor-fields");
    const doctorDepartmentSelect = doctorFields ? doctorFields.querySelector('select[name="departmentId"]') : null;
    const retiredAtDateInput = document.getElementById("staff-retired-at-date");
    const retiredAtHourSelect = document.getElementById("staff-retired-at-hour");
    const retiredAtHiddenInput = document.getElementById("staff-retired-at-hidden");

    if (roleSelect && doctorFields) {
      const toggleDoctorFields = () => {
        const doctorRole = roleSelect.value === "DOCTOR";
        doctorFields.classList.toggle("hidden", !doctorRole);
        if (doctorDepartmentSelect && !doctorDepartmentSelect.disabled) {
          doctorDepartmentSelect.required = doctorRole;
        }
      };

      roleSelect.addEventListener("change", toggleDoctorFields);
      toggleDoctorFields();
    } else if (doctorDepartmentSelect && doctorFields && !doctorFields.classList.contains("hidden") && !doctorDepartmentSelect.disabled) {
      doctorDepartmentSelect.required = true;
    }

    if (retiredAtDateInput && retiredAtHourSelect && retiredAtHiddenInput) {
      const retiredAtValidationMessage = "퇴사 일시는 날짜와 시간을 모두 선택해야 합니다.";

      const syncRetiredAtHidden = () => {
        const dateValue = retiredAtDateInput.value;
        const hourValue = retiredAtHourSelect.value;

        retiredAtDateInput.setCustomValidity("");
        retiredAtHourSelect.setCustomValidity("");

        if (!dateValue && !hourValue) {
          retiredAtHiddenInput.value = "";
          return true;
        }

        if (!dateValue || !hourValue) {
          retiredAtHiddenInput.value = "";
          retiredAtDateInput.setCustomValidity(retiredAtValidationMessage);
          retiredAtHourSelect.setCustomValidity(retiredAtValidationMessage);
          return false;
        }

        retiredAtHiddenInput.value = `${dateValue}T${hourValue}:00`;
        return true;
      };

      retiredAtDateInput.addEventListener("change", syncRetiredAtHidden);
      retiredAtHourSelect.addEventListener("change", syncRetiredAtHidden);

      if (staffForm) {
        staffForm.addEventListener("submit", (event) => {
          if (!syncRetiredAtHidden()) {
            event.preventDefault();
            retiredAtDateInput.reportValidity();
          }
        });
      }

      syncRetiredAtHidden();
    }

    feather.replace();
  </script>
</body>
</html>
