<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>진료과 관리 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body>
  
  {{> components/sidebar}}

  <div class="main-content">
    {{> components/header}}
    
    <main class="content-wrapper">
      <div class="space-y-6 max-w-6xl mx-auto">
        
        <div class="flex justify-between items-center">
          <h1 class="text-2xl font-bold text-slate-800">진료과 관리</h1>
          <a href="/admin/departments/create" class="flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 transition-colors">
            <i data-feather="plus" class="w-5 h-5"></i>
            진료과 등록
          </a>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
          
          <div class="p-4 border-b border-slate-200 flex justify-between items-center bg-slate-50">
            <div class="relative w-64">
              <form action="/admin/departments" method="GET">
                <i data-feather="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
                <input 
                  type="text" 
                  name="search"
                  value="{{searchQuery}}"
                  placeholder="진료과명 또는 코드 검색..." 
                  class="w-full pl-9 pr-4 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none"
                />
              </form>
            </div>
          </div>

          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-200 text-xs uppercase tracking-wider text-slate-500">
                <th class="p-4 font-medium">진료과명</th>
                <th class="p-4 font-medium">코드</th>
                <th class="p-4 font-medium">소속 의사 수</th>
                <th class="p-4 font-medium">상태</th>
                <th class="p-4 font-medium text-right">관리</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200">
              {{#departments}}
              <tr class="hover:bg-slate-50 transition-colors">
                <td class="p-4">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg bg-indigo-50 text-indigo-600 flex items-center justify-center">
                      <i data-feather="building-2" class="w-4 h-4"></i>
                    </div>
                    <span class="font-semibold text-slate-800">{{name}}</span>
                  </div>
                </td>
                <td class="p-4 text-sm text-slate-600 font-mono">{{code}}</td>
                <td class="p-4 text-sm text-slate-600">{{doctorCount}}명</td>
                
                <td class="p-4">
                  <form action="/admin/departments/{{id}}/toggle" method="POST" class="m-0 inline-block">
                    <button type="submit" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium transition-colors {{#isActive}}bg-green-100 text-green-800 hover:bg-green-200{{/isActive}}{{^isActive}}bg-slate-100 text-slate-800 hover:bg-slate-200{{/isActive}}">
                      {{#isActive}}운영 중{{/isActive}}
                      {{^isActive}}운영 중지{{/isActive}}
                    </button>
                  </form>
                </td>
                
                <td class="p-4 text-right">
                  <div class="flex items-center justify-end gap-2">
                    <a href="/admin/departments/{{id}}/edit" class="p-1.5 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors">
                      <i data-feather="edit-2