<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{pageTitle}} - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-admin}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="space-y-6 max-w-6xl mx-auto">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-2xl font-bold text-slate-800">{{pageTitle}}</h1>
            <p class="text-slate-500 mt-1">진료과 정보를 조회하고 관리합니다.</p>
          </div>
          <div class="flex items-center gap-4">
            <div class="text-sm text-slate-500 text-right">
              <div>총 <span class="font-semibold text-slate-700">{{model.totalCount}}</span>개</div>
              {{#model.hasPages}}
                <div>{{model.currentPage}} / {{model.totalPages}}페이지</div>
              {{/model.hasPages}}
              {{^model.hasPages}}
                <div>0 / 0페이지</div>
              {{/model.hasPages}}
            </div>
            <button
              type="button"
              onclick="document.getElementById('addModal').classList.remove('hidden')"
              class="flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors"
            >
              <i data-feather="plus" class="w-4 h-4"></i>
              진료과 등록
            </button>
          </div>
        </div>

        {{#successMessage}}
          <div class="rounded-xl border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">
            {{successMessage}}
          </div>
        {{/successMessage}}
        {{#errorMessage}}
          <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
            {{errorMessage}}
          </div>
        {{/errorMessage}}

        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-slate-50 border-b border-slate-200">
                <tr>
                  <th class="text-left px-4 py-3 font-semibold text-slate-600">ID</th>
                  <th class="text-left px-4 py-3 font-semibold text-slate-600">진료과명</th>
                  <th class="text-left px-4 py-3 font-semibold text-slate-600">상태</th>
                  <th class="text-left px-4 py-3 font-semibold text-slate-600">관리</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {{#model.departments}}
                <tr class="hover:bg-slate-50">
                  <td class="px-4 py-3 text-slate-400 text-xs">{{id}}</td>
                  <td class="px-4 py-3 font-medium text-slate-800">{{name}}</td>
                  <td class="px-4 py-3">
                    <span class="{{activeBadgeClass}}">{{activeText}}</span>
                  </td>
                  <td class="px-4 py-3">
                    <a href="/admin/department/detail?departmentId={{id}}" class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-300 text-slate-600 hover:bg-white">
                      <i data-feather="external-link" class="w-3.5 h-3.5"></i>
                      상세
                    </a>
                  </td>
                </tr>
                {{/model.departments}}
                {{^model.departments}}
                <tr>
                  <td colspan="4" class="px-4 py-12 text-center text-slate-400">등록된 진료과가 없습니다.</td>
                </tr>
                {{/model.departments}}
              </tbody>
            </table>
          </div>

          <div class="p-4 border-t border-slate-200 flex items-center justify-center gap-2 bg-slate-50">
            {{#model.hasPrevious}}
              <a href="{{model.previousUrl}}" class="px-3 py-1.5 text-sm rounded-md border border-slate-300 text-slate-600 hover:bg-white">이전</a>
            {{/model.hasPrevious}}

            {{#model.pageLinks}}
              <a href="{{url}}" class="px-3 py-1.5 text-sm rounded-md border transition-colors {{#active}}bg-slate-800 border-slate-800 text-white{{/active}}{{^active}}border-slate-300 text-slate-600 hover:bg-white{{/active}}">{{page}}</a>
            {{/model.pageLinks}}

            {{#model.hasNext}}
              <a href="{{model.nextUrl}}" class="px-3 py-1.5 text-sm rounded-md border border-slate-300 text-slate-600 hover:bg-white">다음</a>
            {{/model.hasNext}}
          </div>
        </div>
      </div>
    </main>

    <div id="addModal" class="hidden fixed inset-0 bg-black/40 flex items-center justify-center z-50">
      <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-8">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-lg font-bold text-slate-800">진료과 등록</h2>
          <button
            type="button"
            onclick="document.getElementById('addModal').classList.add('hidden')"
            class="p-2 text-slate-400 hover:text-slate-600 hover:bg-slate-100 rounded-lg"
          >
            <i data-feather="x" class="w-4 h-4"></i>
          </button>
        </div>

        <form method="post" action="/admin/department/create" class="space-y-4">
          <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">
              진료과명 <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              name="name"
              required
              class="w-full px-4 py-2.5 rounded-xl border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
            >
          </div>
          <div class="flex items-center gap-2">
            <input type="checkbox" name="active" id="activeCheck" value="true" checked class="w-4 h-4 accent-indigo-600">
            <label for="activeCheck" class="text-sm text-slate-700">운영 중</label>
          </div>
          <div class="flex gap-3 pt-2">
            <button type="submit" class="flex-1 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-xl hover:bg-indigo-700">
              등록
            </button>
            <button
              type="button"
              onclick="document.getElementById('addModal').classList.add('hidden')"
              class="flex-1 py-2.5 bg-slate-100 text-slate-700 text-sm font-semibold rounded-xl hover:bg-slate-200"
            >
              취소
            </button>
          </div>
        </form>
      </div>
    </div>

    {{> common/footer-staff}}
  </div>

  <script>
    feather.replace();
  </script>
</body>
</html>