<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>규칙 수정 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-admin}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="max-w-2xl mx-auto space-y-6">

        <div class="flex items-center gap-3">
          <a href="/admin/rule/detail?ruleId={{ruleIdValue}}" class="p-2 text-slate-400 hover:text-slate-600 hover:bg-slate-100 rounded-lg transition-colors">
            <i data-feather="arrow-left" class="w-5 h-5"></i>
          </a>
          <div>
            <h1 class="text-2xl font-bold text-slate-800">규칙 수정</h1>
            <p class="text-slate-500 mt-1">규칙 내용을 수정합니다.</p>
          </div>
        </div>

        {{#errorMessage}}
          <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
            {{errorMessage}}
          </div>
        {{/errorMessage}}

        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
          {{> admin/_rule-form}}
        </div>

      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>feather.replace();</script>
</body>
</html>
