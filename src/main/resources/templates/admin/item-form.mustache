<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>물품 등록 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-admin}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="max-w-2xl mx-auto space-y-6">

        <div class="flex items-center gap-3">
          <a href="/admin/item/list" class="p-2 text-slate-400 hover:text-slate-600 hover:bg-slate-100 rounded-lg transition-colors">
            <i data-feather="arrow-left" class="w-5 h-5"></i>
          </a>
          <div>
            <h1 class="text-2xl font-bold text-slate-800">물품 등록</h1>
            <p class="text-slate-500 mt-1">새 물품 정보를 입력하세요.</p>
          </div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
          <form method="post" action="/admin/item" class="space-y-5">
            <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">

            <div>
              <label class="block text-sm font-semibold text-slate-700 mb-1.5">물품명 <span class="text-red-500">*</span></label>
              <input type="text" name="name" required
                class="w-full px-4 py-2.5 rounded-xl border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                placeholder="물품명을 입력하세요">
            </div>

            <div>
              <label class="block text-sm font-semibold text-slate-700 mb-1.5">카테고리 <span class="text-red-500">*</span></label>
              <select name="category" required
                class="w-full px-4 py-2.5 rounded-xl border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300 bg-white">
                <option value="">카테고리를 선택하세요</option>
                <option value="MEDICAL_SUPPLIES">의료 소모품</option>
                <option value="MEDICAL_EQUIPMENT">의료 장비</option>
                <option value="GENERAL_SUPPLIES">일반 소모품</option>
              </select>
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1.5">현재 수량 <span class="text-red-500">*</span></label>
                <input type="number" name="quantity" min="0" required
                  class="w-full px-4 py-2.5 rounded-xl border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                  placeholder="0">
              </div>
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1.5">최소 수량 <span class="text-red-500">*</span></label>
                <input type="number" name="minQuantity" min="0" required
                  class="w-full px-4 py-2.5 rounded-xl border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                  placeholder="0">
              </div>
            </div>

            <div class="flex gap-3 pt-4">
              <button type="submit"
                class="flex-1 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-xl hover:bg-indigo-700 transition-colors">
                등록
              </button>
              <a href="/admin/item/list"
                class="flex-1 py-2.5 bg-slate-100 text-slate-700 text-sm font-semibold rounded-xl hover:bg-slate-200 transition-colors text-center">
                취소
              </a>
            </div>
          </form>
        </div>

      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>feather.replace();</script>
</body>
</html>
