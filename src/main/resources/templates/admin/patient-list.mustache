<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{pageTitle}} - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body>
  {{> common/sidebar-admin}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper">
      <div class="space-y-6 max-w-6xl mx-auto">
        <div class="flex items-center justify-between mb-6">
          <div>
            <h1 class="text-2xl font-bold text-slate-800">{{pageTitle}}</h1>
            <p class="text-slate-500 mt-1">환자명 또는 연락처로 환자를 빠르게 조회하고 관리합니다.</p>
          </div>
          <div class="text-sm text-slate-500 text-right">
            <div>총 <span class="font-semibold text-slate-700">{{model.totalCount}}</span>명</div>
            <div>{{model.currentPage}} 페이지</div>
          </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
          <form method="get" action="/admin/patient/list" class="p-4 border-b border-slate-200 bg-slate-50">
            <input type="hidden" name="page" value="1">
            <input type="hidden" name="size" value="{{model.size}}">

            <div class="flex flex-wrap items-end gap-3">
              <div class="min-w-[280px] flex-1">
                <label for="patient-keyword" class="block text-sm font-medium text-slate-700 mb-1.5">검색</label>
                <div class="relative">
                  <i data-feather="search" class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
                  <input
                    type="text"
                    id="patient-keyword"
                    name="keyword"
                    value="{{model.keyword}}"
                    placeholder="환자명 또는 연락처 검색"
                    class="w-full pl-9 pr-4 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none"
                  >
                </div>
              </div>

              <button
                type="submit"
                class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors"
              >
                조회
              </button>
              <a
                href="/admin/patient/list"
                class="px-4 py-2 bg-slate-100 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-200 transition-colors"
              >
                초기화
              </a>
            </div>
          </form>

          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-200 text-xs uppercase tracking-wider text-slate-500">
                <th class="p-4 font-medium">환자명</th>
                <th class="p-4 font-medium">연락처</th>
                <th class="p-4 font-medium">등록일</th>
                <th class="p-4 font-medium text-right">관리</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200">
              {{#model.patients}}
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="p-4 text-sm font-semibold text-slate-800">{{name}}</td>
                  <td class="p-4 text-sm text-slate-700">{{phone}}</td>
                  <td class="p-4 text-sm text-slate-700">{{registeredDate}}</td>
                  <td class="p-4 text-right">
                    <a
                      href="{{detailUrl}}"
                      class="inline-flex items-center gap-1 px-3 py-1.5 bg-slate-100 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-200 transition-colors"
                    >
                      상세보기
                    </a>
                  </td>
                </tr>
              {{/model.patients}}
              {{^model.patients}}
                <tr>
                  <td colspan="4" class="p-8 text-center text-slate-500">조회된 환자가 없습니다.</td>
                </tr>
              {{/model.patients}}
            </tbody>
          </table>

          <div class="p-4 border-t border-slate-200 flex items-center justify-center gap-2 bg-slate-50">
            {{#model.hasPrevious}}
              <a href="{{model.previousUrl}}" class="px-3 py-1.5 text-sm rounded-md border border-slate-300 text-slate-600 hover:bg-white">이전</a>
            {{/model.hasPrevious}}

            {{#model.pageLinks}}
              <a href="{{url}}" class="px-3 py-1.5 text-sm rounded-md border transition-colors {{#active}}bg-slate-800 border-slate-800 text-white{{/active}}{{^active}}border-slate-300 text-slate-600 hover:bg-white{{/active}}">{{page}}</a>
            {{/model.pageLinks}}

            {{#model.hasNext}}
              <a href="{{model.nextUrl}}" class="px-3 py-1.5 text-sm rounded-md border border-slate-300 text-slate-600 hover:bg-white">다음</a>
            {{/model.hasNext}}
          </div>
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>
    feather.replace();
  </script>
</body>
</html>