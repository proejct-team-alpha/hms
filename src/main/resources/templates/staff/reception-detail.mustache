<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>환자 정보 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
  <!-- 카카오 주소 API -->
  <script src="//t1.daumcdn.net/mapjsapi/bundle/postcode/prod/postcode.v2.js"></script>
  <style>
    .info-input {
      width: 100%;
      padding: 0.65rem 0.9rem;
      background-color: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 0.85rem;
      font-size: 0.9rem;
      font-weight: 600;
      color: #1e293b;
      transition: all 0.2s;
    }
    .info-input:focus {
      background-color: white;
      border-color: #4f46e5;
      box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
      outline: none;
    }
    .info-label {
      display: block;
      font-size: 0.7rem;
      font-weight: 800;
      color: #94a3b8;
      margin-bottom: 0.4rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .read-only-text {
      font-size: 0.9rem;
      font-weight: 700;
      color: #334155;
    }
    .detail-grid {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 4rem;
    }
    .birth-input-date { width: 100px !important; text-align: center; }
    .birth-input-gender { width: 45px !important; text-align: center; }
  </style>
</head>
<body class="min-h-screen flex bg-[#f8fafc]">
  {{> common/sidebar-staff}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-8">
      <div class="max-w-6xl mx-auto space-y-6">
        
        <!-- 상단 헤더 -->
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <a href="/staff/reception/list?date={{currentDate}}&tab={{currentTab}}&page={{currentPage}}&query={{query}}{{#deptIds}}&deptIds={{.}}{{/deptIds}}{{#doctorIds}}&doctorIds={{.}}{{/doctorIds}}&source={{source}}" class="p-2 bg-white border border-slate-200 rounded-xl hover:bg-slate-50 transition-colors text-slate-400 shadow-sm">
              <i data-feather="arrow-left" class="w-5 h-5"></i>
            </a>
            <h1 class="text-2xl font-black text-slate-800 tracking-tight">환자 정보</h1>
          </div>
        </div>

        <div id="detailCard" class="bg-white rounded-[2rem] border border-slate-200 shadow-sm overflow-hidden">
          <!-- 환자 헤더 고정 영역 -->
          <div class="bg-indigo-50 border-b border-indigo-100 p-8 flex items-center justify-between">
            <div class="flex items-center gap-6">
              <div class="w-20 h-20 bg-white rounded-3xl flex items-center justify-center text-indigo-600 shadow-sm border border-indigo-100">
                <i data-feather="user" class="w-10 h-10"></i>
              </div>
              <div class="space-y-2">
                <div>
                  <span class="text-[10px] font-black text-indigo-400 uppercase tracking-widest">환자등록번호: {{detail.patientId}}</span>
                </div>
                <div class="flex items-center gap-3">
                  {{#detail.isFirstVisit}}
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded bg-slate-100 text-slate-500 text-[9px] font-black shrink-0">초</span>
                  {{/detail.isFirstVisit}}
                  {{^detail.isFirstVisit}}
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded bg-indigo-600 text-white text-[9px] font-black shrink-0">재</span>
                  {{/detail.isFirstVisit}}
                  <div class="flex items-baseline gap-2">
                    <h2 class="text-2xl font-black text-slate-800">{{detail.patientName}}</h2>
                    <span class="text-sm font-bold text-slate-500">({{detail.ageGender}})</span>
                  </div>
                </div>
                <div class="flex items-center gap-1.5 text-sm text-slate-500 font-bold">
                  <i data-feather="phone" class="w-3.5 h-3.5 opacity-50"></i>
                  {{detail.patientPhone}}
                </div>
              </div>
            </div>
            <div class="text-right">
              <span class="inline-flex items-center gap-1.5 px-4 py-2 rounded-2xl text-xs font-black shadow-sm {{detail.statusBadgeClass}}">
                <i data-feather="activity" class="w-3.5 h-3.5"></i>
                {{detail.statusText}}
              </span>
            </div>
          </div>

          <div class="p-10">
            <div class="detail-grid">
              
              <!-- 좌측: 예약 내역 (참조용) -->
              <div class="space-y-8 py-4">
                <div class="space-y-6">
                  <div class="space-y-1">
                    <label class="info-label">예약번호</label>
                    <div class="read-only-text text-indigo-600">{{detail.reservationNumber}}</div>
                  </div>
                  <div class="space-y-1">
                    <label class="info-label">예약 구분</label>
                    <div class="read-only-text">{{detail.sourceText}}</div>
                  </div>
                  <div class="grid grid-cols-2 gap-2">
                    <div class="space-y-1">
                      <label class="info-label">날짜</label>
                      <div class="read-only-text">{{detail.reservationDate}}</div>
                    </div>
                    <div class="space-y-1">
                      <label class="info-label">시간</label>
                      <div class="read-only-text">{{detail.timeSlot}}</div>
                    </div>
                  </div>
                  <div class="space-y-1">
                    <label class="info-label">최초 예약 정보</label>
                    <div class="read-only-text leading-relaxed">
                      {{detail.departmentName}}<br>
                      {{detail.doctorName}} 전문의
                    </div>
                  </div>
                </div>

                {{#detail.cancellationReason}}
                <div class="bg-red-50 p-5 rounded-2xl border border-red-100 space-y-2">
                  <label class="text-[10px] font-black text-red-400 uppercase tracking-widest">취소 사유</label>
                  <p class="text-xs font-bold text-red-600 leading-relaxed">{{detail.cancellationReason}}</p>
                </div>
                {{/detail.cancellationReason}}
              </div>

              <!-- 우측: 접수 및 인적 사항 (상시 수정) -->
              <div class="space-y-8 py-4">
                <div class="space-y-6">
                  <!-- [주석] 접수 정보: 실제 시스템에 기록된 접수 시각 데이터를 표시 -->
                  <div class="grid grid-cols-2 gap-6">
                    <div>
                      <label class="info-label">접수 날짜</label>
                      <div class="read-only-text py-2 border-b border-slate-100">
                        {{#detail.actualReceptionDate}}{{detail.actualReceptionDate}}{{/detail.actualReceptionDate}}
                        {{^detail.actualReceptionDate}}-{{/detail.actualReceptionDate}}
                      </div>
                    </div>
                    <div>
                      <label class="info-label">접수 시간</label>
                      <div class="read-only-text py-2 border-b border-slate-100 text-indigo-600">
                        {{#detail.receptionTime}}{{detail.receptionTime}}{{/detail.receptionTime}}
                        {{^detail.receptionTime}}-{{/detail.receptionTime}}
                      </div>
                    </div>
                  </div>

                  <!-- [기능 구현] 최종 진료과/의사: 수정 가능 상태(예약/대기)일 때만 드롭다운 표시, 그 외엔 텍스트 표시 -->
                  <div class="grid grid-cols-2 gap-6">
                    <div>
                      <label class="info-label">최종 진료과</label>
                      {{#detail.canEditReceptionInfo}}
                      <select id="receptionDept" class="info-input" onchange="filterDoctors(this.value)">
                        {{#departments}}
                        <option value="{{id}}" {{#selected}}selected{{/selected}}>{{name}}</option>
                        {{/departments}}
                      </select>
                      {{/detail.canEditReceptionInfo}}
                      {{^detail.canEditReceptionInfo}}
                      <div class="read-only-text py-2 border-b border-slate-100">{{detail.departmentName}}</div>
                      <input type="hidden" id="receptionDept" value="{{detail.departmentId}}">
                      {{/detail.canEditReceptionInfo}}
                    </div>
                    <div>
                      <label class="info-label">담당 의사</label>
                      {{#detail.canEditReceptionInfo}}
                      <select id="receptionDoctor" class="info-input">
                        {{#doctors}}
                        <option value="{{id}}" data-dept-id="{{deptId}}" {{#selected}}selected{{/selected}}>{{name}}</option>
                        {{/doctors}}
                      </select>
                      {{/detail.canEditReceptionInfo}}
                      {{^detail.canEditReceptionInfo}}
                      <div class="read-only-text py-2 border-b border-slate-100">{{detail.doctorName}} 전문의</div>
                      <input type="hidden" id="receptionDoctor" value="{{detail.doctorId}}">
                      {{/detail.canEditReceptionInfo}}
                    </div>
                  </div>

                  <div class="grid grid-cols-2 gap-6">
                    <div>
                      <label class="info-label">주민번호</label>
                      <div class="flex items-center gap-2">
                        <input type="text" id="birthDate" value="{{detail.birthDatePart}}" maxlength="6" class="info-input birth-input-date" placeholder="YYMMDD">
                        <span class="text-slate-300">-</span>
                        <div class="flex items-center gap-1">
                          <input type="text" id="genderDigit" value="{{detail.genderDigitPart}}" maxlength="1" class="info-input birth-input-gender" placeholder="G">
                          <span class="text-slate-400 font-bold tracking-widest ml-1">******</span>
                        </div>
                      </div>
                    </div>
                    <div>
                      <label class="info-label">이메일</label>
                      <input type="email" id="patientEmail" value="{{detail.patientEmail}}" class="info-input">
                    </div>
                  </div>

                  <!-- [주석] 주소 입력 영역: 우편번호, 기본주소, 상세주소 3줄 구조로 최적화 -->
                  <div class="space-y-3">
                    <label class="info-label">주소</label>
                    
                    <!-- [주석] 1행: 우편번호 입력 및 주소 검색 버튼 -->
                    <div class="flex gap-2">
                      <input type="text" id="postcode" class="info-input w-32" placeholder="우편번호" readonly>
                      <button type="button" onclick="execDaumPostcode()" class="px-4 py-2 bg-slate-800 text-white text-xs font-black rounded-xl hover:bg-slate-900 transition-all flex-shrink-0">주소 찾기</button>
                    </div>
                    
                    <!-- [주석] 2행: 검색된 기본 주소 표시 (전체 너비) -->
                    <input type="text" id="basicAddress" value="{{detail.patientAddress}}" class="info-input w-full" placeholder="기본 주소" readonly>
                    
                    <!-- [주석] 3행: 상세 주소 직접 입력 (전체 너비) -->
                    <input type="text" id="detailAddress" class="info-input w-full" placeholder="상세 주소 입력">
                  </div>

                  <div>
                    <label class="info-label">내원 사유</label>
                    {{#detail.canEditReceptionInfo}}
                    <textarea id="visitReason" rows="2" class="info-input resize-none">{{detail.visitReason}}</textarea>
                    {{/detail.canEditReceptionInfo}}
                    {{^detail.canEditReceptionInfo}}
                    <div class="read-only-text py-2 border-b border-slate-100 leading-relaxed">{{detail.visitReason}}</div>
                    <input type="hidden" id="visitReason" value="{{detail.visitReason}}">
                    {{/detail.canEditReceptionInfo}}
                  </div>

                  <div>
                    <label class="info-label">특이사항</label>
                    <textarea id="noteInput" rows="3" class="info-input resize-none">{{detail.patientNote}}</textarea>
                  </div>

                  <div class="pt-2">
                    <button type="button" onclick="saveAllInfo()" class="w-full py-4 bg-indigo-600 text-white font-black rounded-2xl hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-100 flex items-center justify-center gap-2">
                      <i data-feather="save" class="w-4 h-4"></i>
                      저장
                    </button>
                  </div>
                </div>
              </div>

            </div>
          </div>
        </div>

        <div class="flex justify-center pt-4">
          <a href="/staff/reception/list?date={{currentDate}}&tab={{currentTab}}&page={{currentPage}}&query={{query}}{{#deptIds}}&deptIds={{.}}{{/deptIds}}{{#doctorIds}}&doctorIds={{.}}{{/doctorIds}}&source={{source}}" class="text-sm font-bold text-slate-400 hover:text-indigo-600 transition-colors flex items-center gap-2">
            <i data-feather="list" class="w-4 h-4"></i>
            목록으로 돌아가기
          </a>
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>
    feather.replace();

    // [주석] 주민번호 앞자리 6자 입력 시 뒷자리로 자동 포커스 이동
    document.getElementById('birthDate').addEventListener('input', function() {
      if (this.value.length >= 6) {
        document.getElementById('genderDigit').focus();
      }
    });

    function filterDoctors(deptId) {
      const doctorSelect = document.getElementById('receptionDoctor');
      const options = doctorSelect.querySelectorAll('option');
      let firstVisible = null;
      options.forEach(opt => {
        if (opt.getAttribute('data-dept-id') === deptId) {
          opt.style.display = 'block';
          if (!firstVisible) firstVisible = opt.value;
        } else {
          opt.style.display = 'none';
        }
      });
      if (firstVisible) doctorSelect.value = firstVisible;
    }

    document.addEventListener('DOMContentLoaded', () => {
      filterDoctors(document.getElementById('receptionDept').value);
      const fullAddr = document.getElementById('basicAddress').value;
      if (fullAddr.startsWith('[')) {
        const match = fullAddr.match(/\[(\d+)\]\s*(.*)/);
        if (match) {
          document.getElementById('postcode').value = match[1];
          document.getElementById('basicAddress').value = match[2];
        }
      }
    });

    function execDaumPostcode() {
      new daum.Postcode({
        oncomplete: function(data) {
          let addr = data.userSelectedType === 'R' ? data.roadAddress : data.jibunAddress;
          if (data.userSelectedType === 'R' && data.bname !== '' && /[동|로|가]$/g.test(data.bname)) addr += ' (' + data.bname + ')';
          document.getElementById('postcode').value = data.zonecode;
          document.getElementById('basicAddress').value = addr;
          document.getElementById('detailAddress').focus();
        }
      }).open();
    }

    async function saveAllInfo() {
      const reservationId = "{{detail.id}}";
      const birthDate = document.getElementById('birthDate').value;
      const genderDigit = document.getElementById('genderDigit').value;

      // [주석] 주민번호 필수 입력 검증 (앞 6자리, 뒤 1자리)
      if (!birthDate || birthDate.length < 6 || !genderDigit) {
        alert('주민번호를 정확히 입력해 주세요. (앞 6자리 및 뒤 1자리 필수)');
        return;
      }

      const birthInfo = birthDate + '-' + genderDigit;
      const postcode = document.getElementById('postcode').value;
      const basicAddr = document.getElementById('basicAddress').value;
      const detailAddr = document.getElementById('detailAddress').value;
      const fullAddress = postcode ? `[${postcode}] ${basicAddr} ${detailAddr}`.trim() : basicAddr;

      const payload = {
        reservationId: reservationId,
        deptId: document.getElementById('receptionDept').value,
        doctorId: document.getElementById('receptionDoctor').value,
        birthInfo: birthInfo,
        email: document.getElementById('patientEmail').value,
        address: fullAddress,
        visitReason: document.getElementById('visitReason').value,
        note: document.getElementById('noteInput').value
      };

      try {
        const response = await fetch('/staff/reception/update-patient-info', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': '{{_csrf.token}}' },
          body: JSON.stringify(payload)
        });
        const result = await response.json();
        if (result.success) {
          // [주석] 저장 성공 시 모든 필터링 상태를 유지하며 목록으로 이동
          const params = new URLSearchParams();
          params.set('date', '{{currentDate}}');
          params.set('tab', '{{currentTab}}');
          params.set('page', '{{currentPage}}');
          
          const queryValue = '{{query}}';
          if (queryValue) params.set('query', queryValue);
          
          const sourceValue = '{{source}}';
          if (sourceValue) params.set('source', sourceValue);
          
          // [주석] Mustache 리스트 반복을 통해 여러 개의 deptIds와 doctorIds를 추가
          {{#deptIds}}params.append('deptIds', '{{.}}');{{/deptIds}}
          {{#doctorIds}}params.append('doctorIds', '{{.}}');{{/doctorIds}}
          
          location.href = `/staff/reception/list?${params.toString()}`;
        } else {
          alert('저장 실패: ' + (result.message || ''));
        }
      } catch (e) {
        console.error(e);
        alert('서버와 통신 중 오류가 발생했습니다.');
      }
    }
  </script>
</body>
</html>
