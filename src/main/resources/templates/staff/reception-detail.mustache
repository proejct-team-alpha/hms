<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>환자 정보 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
  <!-- 카카오 주소 API -->
  <script src="https://t1.daumcdn.net/mapjsapi/bundle/postcode/prod/postcode.v2.js"></script>
  <style>
    .info-input { width: 100%; padding: 0.5rem 0.8rem; background-color: #f8fafc; border: 1px solid #e2e8f0; border-radius: 0.75rem; font-size: 0.85rem; font-weight: 600; color: #1e293b; transition: all 0.2s; }
    .info-input:focus { background-color: white; border-color: #4f46e5; box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1); outline: none; }
    .info-label { display: block; font-size: 0.65rem; font-weight: 800; color: #94a3b8; margin-bottom: 0.3rem; text-transform: uppercase; letter-spacing: 0.05em; }
    .read-only-text { font-size: 0.85rem; font-weight: 700; color: #334155; }
    .detail-grid { display: grid; grid-template-columns: 1fr 2fr; gap: 3rem; }
    /* [반응형 대응] 주민번호 입력칸 너비 최적화 */
    .birth-input-date { width: 85px !important; text-align: center; flex-shrink: 0; }
    .birth-input-gender { width: 38px !important; text-align: center; flex-shrink: 0; }
    
    @media (max-width: 1024px) {
      .detail-grid { grid-template-columns: 1fr; gap: 2rem; }
    }
  </style>
</head>
<body class="min-h-screen flex bg-[#f8fafc]">
  {{> common/sidebar-staff}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-5">
      <div class="max-w-6xl mx-auto space-y-4">
        
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <a href="/staff/reception/list?date={{currentDate}}&tab={{currentTab}}&query={{query}}{{#deptIds}}&deptIds={{.}}{{/deptIds}}{{#doctorIds}}&doctorIds={{.}}{{/doctorIds}}&source={{source}}" class="p-1.5 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors text-slate-400 shadow-sm">
              <i data-feather="arrow-left" class="w-4 h-4"></i>
            </a>
            <h1 class="text-xl font-black text-slate-800 tracking-tight">환자 상세 정보</h1>
          </div>
        </div>

        <div id="detailCard" class="bg-white rounded-[1.5rem] border border-slate-200 shadow-sm overflow-hidden">
          <div class="bg-indigo-50 border-b border-indigo-100 p-5 flex items-center justify-between">
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center text-indigo-600 shadow-sm border border-indigo-100">
                <i data-feather="user" class="w-7 h-7"></i>
              </div>
              <div class="space-y-1">
                <div><span class="text-[9px] font-black text-indigo-400 uppercase tracking-widest">환자등록번호: {{detail.patientId}}</span></div>
                <div class="flex items-center gap-2">
                  {{#detail.isFirstVisit}}<span class="inline-flex items-center px-1.5 py-0.5 rounded bg-indigo-50 text-indigo-500 text-[9px] font-black shrink-0">초</span>{{/detail.isFirstVisit}}
                  {{^detail.isFirstVisit}}<span class="inline-flex items-center px-1.5 py-0.5 rounded bg-slate-100 text-slate-500 text-[9px] font-black shrink-0">재</span>{{/detail.isFirstVisit}}
                  <div class="flex items-center gap-2">
                    <h2 class="text-xl font-black text-slate-800">{{detail.patientName}}</h2>
                    <span class="text-xs font-bold text-slate-500">({{detail.ageGender}})</span>
                  </div>
                </div>
                <div class="flex items-center gap-1.5 text-xs text-slate-500 font-bold"><i data-feather="phone" class="w-3 h-3 opacity-50"></i>{{detail.patientPhone}}</div>
              </div>
            </div>
            <div class="text-right">
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-[10px] font-black shadow-sm {{detail.statusBadgeClass}}">
                <i data-feather="activity" class="w-3 h-3"></i>{{detail.statusText}}
              </span>
            </div>
          </div>

          <div class="p-6">
            <div class="detail-grid">
              <div class="space-y-5">
                <div class="space-y-4">
                  <div class="space-y-0.5"><label class="info-label">예약번호</label><div class="read-only-text text-indigo-600">{{detail.reservationNumber}}</div></div>
                  <div class="space-y-0.5"><label class="info-label">예약 구분</label><div class="read-only-text">{{detail.sourceText}}</div></div>
                  <div class="grid grid-cols-2 gap-2">
                    <div class="space-y-0.5"><label class="info-label">날짜</label><div class="read-only-text">{{detail.reservationDate}}</div></div>
                    <div class="space-y-0.5"><label class="info-label">시간</label><div class="read-only-text">{{detail.timeSlot}}</div></div>
                  </div>
                  <div class="space-y-0.5"><label class="info-label">최초 예약 정보</label><div class="read-only-text leading-tight">{{detail.departmentName}} / {{detail.doctorName}} 전문의</div></div>
                </div>
                {{#detail.cancellationReason}}
                <div class="bg-red-50 p-4 rounded-xl border border-red-100 space-y-1">
                  <label class="text-[9px] font-black text-red-400 uppercase tracking-widest">취소 사유</label>
                  <p class="text-[11px] font-bold text-red-600 leading-snug">{{detail.cancellationReason}}</p>
                </div>
                {{/detail.cancellationReason}}
              </div>

              <div class="space-y-5">
                <div class="space-y-4">
                  <div class="grid grid-cols-2 gap-4">
                    <div><label class="info-label">접수 날짜</label><div class="read-only-text py-1 border-b border-slate-100">{{#detail.actualReceptionDate}}{{detail.actualReceptionDate}}{{/detail.actualReceptionDate}}{{^detail.actualReceptionDate}}-{{/detail.actualReceptionDate}}</div></div>
                    <div><label class="info-label">접수 시간</label><div class="read-only-text py-1 border-b border-slate-100 text-indigo-600">{{#detail.receptionTime}}{{detail.receptionTime}}{{/detail.receptionTime}}{{^detail.receptionTime}}-{{/detail.receptionTime}}</div></div>
                  </div>

                  <div class="grid grid-cols-2 gap-4">
                    <div>
                      <label class="info-label">최종 진료과</label>
                      {{#detail.canEditReceptionInfo}}
                      <select id="receptionDept" class="info-input" onchange="filterDoctors(this.value)">
                        {{#departments}}<option value="{{id}}" {{#selected}}selected{{/selected}}>{{name}}</option>{{/departments}}
                      </select>
                      {{/detail.canEditReceptionInfo}}
                      {{^detail.canEditReceptionInfo}}
                      <div class="read-only-text py-1 border-b border-slate-100">{{detail.departmentName}}</div>
                      <input type="hidden" id="receptionDept" value="{{detail.departmentId}}">
                      {{/detail.canEditReceptionInfo}}
                    </div>
                    <div>
                      <label class="info-label">담당 의사</label>
                      {{#detail.canEditReceptionInfo}}
                      <select id="receptionDoctor" class="info-input">
                        {{#doctors}}<option value="{{id}}" data-dept-id="{{deptId}}" {{#selected}}selected{{/selected}}>{{name}}</option>{{/doctors}}
                      </select>
                      {{/detail.canEditReceptionInfo}}
                      {{^detail.canEditReceptionInfo}}
                      <div class="read-only-text py-1 border-b border-slate-100">{{detail.doctorName}} 전문의</div>
                      <input type="hidden" id="receptionDoctor" value="{{detail.doctorId}}">
                      {{/detail.canEditReceptionInfo}}
                    </div>
                  </div>

                  <!-- [레이아웃 수정] 주민번호와 이메일을 항상 한 줄에 배치 -->
                  <div class="grid grid-cols-2 gap-4">
                    <div>
                      <label class="info-label">주민번호</label>
                      <div class="flex items-center gap-1 flex-nowrap">
                        <input type="text" id="birthDate" value="{{detail.birthDatePart}}" maxlength="6" class="info-input birth-input-date" style="width: 80px !important;" placeholder="940101">
                        <span class="text-slate-300">-</span>
                        <div class="flex items-center gap-1 flex-nowrap">
                          <input type="text" id="genderDigit" value="{{detail.genderDigitPart}}" maxlength="1" class="info-input birth-input-gender" style="width: 35px !important;" placeholder="1">
                          <span class="text-slate-400 font-bold ml-0.5 text-[10px] whitespace-nowrap">******</span>
                        </div>
                      </div>
                    </div>
                    <div><label class="info-label">이메일</label><input type="email" id="patientEmail" value="{{detail.patientEmail}}" class="info-input"></div>
                  </div>

                  <div class="space-y-2">
                    <label class="info-label">주소</label>
                    <div class="flex gap-2">
                      <input type="text" id="postcode" class="info-input w-28" placeholder="우편번호" readonly>
                      <button type="button" onclick="execDaumPostcode()" class="px-3 py-1.5 bg-slate-800 text-white text-[10px] font-black rounded-lg hover:bg-slate-900 transition-all flex-shrink-0">주소 찾기</button>
                    </div>
                    <input type="text" id="basicAddress" value="{{detail.patientAddress}}" class="info-input w-full bg-white" placeholder="주소를 입력하세요 (상세주소 포함)">
                  </div>

                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div><label class="info-label">내원 사유</label><textarea id="visitReason" rows="2" class="info-input resize-none">{{detail.visitReason}}</textarea></div>
                    <div><label class="info-label">특이사항</label><textarea id="noteInput" rows="2" class="info-input resize-none">{{detail.patientNote}}</textarea></div>
                  </div>

                  <div class="pt-1">
                    <button type="button" onclick="saveAllInfo()" class="w-full py-3 bg-indigo-600 text-white font-black rounded-xl hover:bg-indigo-700 transition-all shadow-md flex items-center justify-center gap-2 text-sm">
                      <i data-feather="save" class="w-4 h-4"></i>저장
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="flex justify-center pt-2">
          <a href="/staff/reception/list?date={{currentDate}}&tab={{currentTab}}&query={{query}}{{#deptIds}}&deptIds={{.}}{{/deptIds}}{{#doctorIds}}&doctorIds={{.}}{{/doctorIds}}&source={{source}}" class="text-xs font-bold text-slate-400 hover:text-indigo-600 transition-colors flex items-center gap-1.5">
            <i data-feather="list" class="w-3.5 h-3.5"></i>목록으로 돌아가기
          </a>
        </div>
      </div>
    </main>
    {{> common/footer-staff}}
  </div>

  <script>
    feather.replace();
    document.getElementById('birthDate').addEventListener('input', function() { if (this.value.length >= 6) document.getElementById('genderDigit').focus(); });
    function filterDoctors(deptId) {
      const doctorSelect = document.getElementById('receptionDoctor');
      const options = doctorSelect.querySelectorAll('option');
      let firstVisible = null;
      options.forEach(opt => {
        if (opt.getAttribute('data-dept-id') === deptId) {
          opt.style.display = 'block';
          if (!firstVisible) firstVisible = opt.value;
        } else opt.style.display = 'none';
      });
      if (firstVisible) doctorSelect.value = firstVisible;
    }
    document.addEventListener('DOMContentLoaded', () => {
      const deptEl = document.getElementById('receptionDept');
      if (deptEl) filterDoctors(deptEl.value);
      const basicAddrEl = document.getElementById('basicAddress');
      if (basicAddrEl && basicAddrEl.value.startsWith('[')) {
        const match = basicAddrEl.value.match(/\[(\d+)\]\s*(.*)/);
        if (match) { document.getElementById('postcode').value = match[1]; basicAddrEl.value = match[2]; }
      }
    });
    function execDaumPostcode() {
      if (typeof daum === 'undefined') {
        const script = document.createElement('script');
        script.src = 'https://t1.daumcdn.net/mapjsapi/bundle/postcode/prod/postcode.v2.js';
        script.onload = () => { openDaumPostcode(); };
        document.head.appendChild(script);
      } else { openDaumPostcode(); }
    }
    function openDaumPostcode() {
      new daum.Postcode({
        oncomplete: function(data) {
          let addr = (data.userSelectedType === 'R') ? data.roadAddress : data.jibunAddress;
          let extraAddr = '';
          if(data.userSelectedType === 'R'){
            if(data.bname !== '' && /[동|로|가]$/g.test(data.bname)) extraAddr += data.bname;
            if(data.buildingName !== '' && data.apartment === 'Y') extraAddr += (extraAddr !== '' ? ', ' + data.buildingName : data.buildingName);
            if(extraAddr !== '') addr += ' (' + extraAddr + ')';
          }
          document.getElementById('postcode').value = data.zonecode;
          const addrInput = document.getElementById('basicAddress');
          addrInput.value = addr;
          addrInput.focus();
        }
      }).open();
    }
    async function saveAllInfo() {
      const birthDate = document.getElementById('birthDate').value;
      const genderDigit = document.getElementById('genderDigit').value;
      if (!birthDate || birthDate.length < 6 || !genderDigit) { alert('주민번호를 정확히 입력해 주세요.'); return; }
      const postcode = document.getElementById('postcode').value;
      const basicAddr = document.getElementById('basicAddress').value;
      const payload = {
        reservationId: "{{detail.id}}",
        deptId: document.getElementById('receptionDept').value,
        doctorId: document.getElementById('receptionDoctor').value,
        birthInfo: birthDate + '-' + genderDigit,
        email: document.getElementById('patientEmail').value,
        address: postcode ? `[${postcode}] ${basicAddr}`.trim() : basicAddr,
        visitReason: document.getElementById('visitReason').value,
        note: document.getElementById('noteInput').value
      };
      try {
        const response = await fetch('/staff/reception/update-patient-info', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': '{{_csrf.token}}' },
          body: JSON.stringify(payload)
        });
        const result = await response.json();
        if (result.success) {
          location.href = `/staff/reception/list?date={{currentDate}}&tab={{currentTab}}&query={{query}}{{#deptIds}}&deptIds={{.}}{{/deptIds}}{{#doctorIds}}&doctorIds={{.}}{{/doctorIds}}&source={{source}}`;
        } else alert('저장 실패: ' + result.message);
      } catch (e) { alert('서버 오류 발생'); }
    }
  </script>
</body>
</html>
