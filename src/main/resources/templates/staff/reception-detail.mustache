</head>
<body>
  
  {{> components/sidebar}}

  <div class="main-content">
    {{> components/header}}
    
    <main class="content-wrapper">
      <div class="max-w-3xl mx-auto space-y-6">
        <div class="flex items-center justify-between">
          <h1 class="text-2xl font-bold text-slate-800">예약 환자 접수</h1>
          <a href="/receptions" class="text-sm font-medium text-slate-500 hover:text-slate-700">
            목록으로 돌아가기
          </a>
        </div>

        {{^patient}}
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 text-center">
          <h2 class="text-xl font-bold text-slate-800 mb-4">예약 정보를 찾을 수 없습니다.</h2>
          <a href="/receptions" class="text-indigo-600 hover:underline">돌아가기</a>
        </div>
        {{/patient}}

        {{#patient}}
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
          <div class="bg-indigo-50 border-b border-indigo-100 p-6 flex items-center justify-between">
            <div class="flex items-center gap-4">
              <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center text-indigo-600 shadow-sm border border-indigo-100">
                <i data-feather="user" class="w-8 h-8"></i>
              </div>
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <h2 class="text-xl font-bold text-slate-800">{{name}}</h2>
                  <span class="px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                    {{type}} 예약
                  </span>
                </div>
                <div class="flex items-center gap-2 text-sm text-slate-600">
                  <i data-feather="phone" class="w-4 h-4"></i>
                  {{phone}}
                </div>
              </div>
            </div>
            <div class="text-right">
              <div class="text-sm text-slate-500 mb-1">현재 상태</div>
              <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-indigo-100 text-indigo-700 font-semibold text-sm">
                <i data-feather="clock" class="w-4 h-4"></i>
                접수 대기 (RESERVED)
              </div>
            </div>
          </div>

          <form action="/receptions/{{id}}/receive" method="POST">
            <div class="p-8 space-y-8">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="space-y-6">
                  <h3 class="text-sm font-bold text-slate-400 uppercase tracking-wider border-b border-slate-100 pb-2">예약 정보</h3>
                  
                  <div class="flex items-start gap-3">
                    <i data-feather="calendar" class="w-5 h-5 text-slate-400 shrink-0 mt-0.5"></i>
                    <div>
                      <div class="text-sm text-slate-500 mb-1">예약 일시</div>
                      <div class="font-medium text-slate-800">오늘 {{time}}</div>
                    </div>
                  </div>
                  
                  <div class="flex items-start gap-3">
                    <i data-feather="map-pin" class="w-5 h-5 text-slate-400 shrink-0 mt-0.5"></i>
                    <div>
                      <div class="text-sm text-slate-500 mb-1">진료과 / 전문의</div>
                      <div class="font-medium text-slate-800">{{dept}} / {{doctor}}</div>
                    </div>
                  </div>
                  
                  <div class="flex items-start gap-3">
                    <i data-feather="file-text" class="w-5 h-5 text-slate-400 shrink-0 mt-0.5"></i>
                    <div class="w-full">
                      <div class="text-sm text-slate-500 mb-1">증상 및 메모</div>
                      <div class="text-slate-800 bg-slate-50 p-4 rounded-xl border border-slate-100 text-sm leading-relaxed">
                        {{symptoms}}
                      </div>
                    </div>
                  </div>
                </div>

                <div class="space-y-6">
                  <h3 class="text-sm font-bold text-slate-400 uppercase tracking-wider border-b border-slate-100 pb-2">추가 정보 입력</h3>
                  
                  <div class="space-y-4">
                    <div>
                      <label class="block text-sm font-medium text-slate-700 mb-2 flex items-center gap-2">
                        <i data-feather="home" class="w-4 h-4 text-slate-400"></i> 주소
                      </label>
                      <input type="text" name="address" value="{{address}}" placeholder="환자 주소를 입력하세요" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none text-sm"/>
                    </div>
                    
                    <div>
                      <label class="block text-sm font-medium text-slate-700 mb-2 flex items-center gap-2">
                        <i data-feather="alert-circle" class="w-4 h-4 text-slate-400"></i> 특이사항 (알레르기, 과거 병력 등)
                      </label>
                      <textarea name="notes" placeholder="접수 시 참고할 특이사항을 입력하세요" rows="4" class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none text-sm resize-none">{{notes}}</textarea>
                    </div>
                  </div>
                </div>
              </div>

              <div class="pt-8 border-t border-slate-200 flex justify-end gap-3">
                <button type="submit" class="px-8 py-3 bg-indigo-600 text-white font-medium rounded-xl hover:bg-indigo-700 transition-colors shadow-sm flex items-center gap-2">
                  <i data-feather="check-circle" class="w-5 h-5"></i>
                  접수 완료 처리 (RECEIVED)
                </button>
              </div>
            </div>
          </form>
        </div>
        {{/patient}}
      </div>
    </main>

    {{> components/footer}}
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      feather.replace();
    });
  </script>
</body>
</html>