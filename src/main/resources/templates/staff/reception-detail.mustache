<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>예약 환자 접수 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-staff}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="max-w-3xl mx-auto space-y-6">
        <div class="flex items-center justify-between">
          <h1 class="text-2xl font-bold text-slate-800">예약 환자 접수</h1>
          <a href="/staff/reception/list?date={{currentDate}}&status={{currentStatus}}&page={{currentPage}}" class="text-sm font-medium text-slate-500 hover:text-slate-700">
            목록으로 돌아가기
          </a>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
          <!-- 환자 헤더 -->
          <div class="bg-indigo-50 border-b border-indigo-100 p-6 flex items-center justify-between">
            <div class="flex items-center gap-4">
              <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center text-indigo-600 shadow-sm border border-indigo-100">
                <i data-feather="user" class="w-8 h-8"></i>
              </div>
              <div>
                <div class="flex items-center gap-2 mb-1">
                  {{#detail.isFirstVisit}}
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-slate-100 text-slate-500 shrink-0">초</span>
                  {{/detail.isFirstVisit}}
                  {{^detail.isFirstVisit}}
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-slate-100 text-slate-500 shrink-0">재</span>
                  {{/detail.isFirstVisit}}
                  <h2 class="text-xl font-bold text-slate-800">{{detail.patientName}}</h2>
                  <span class="px-2.5 py-0.5 rounded-full text-xs font-medium {{detail.sourceBadgeClass}} ml-1">
                    {{detail.sourceText}} 예약
                  </span>
                </div>
                <div class="flex items-center gap-2 text-sm text-slate-600">
                  <i data-feather="phone" class="w-4 h-4"></i>
                  {{detail.patientPhone}}
                </div>
              </div>
            </div>
            <div class="text-right">
              <div class="text-sm text-slate-500 mb-1">현재 상태</div>
              <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-semibold {{detail.statusBadgeClass}}">
                <i data-feather="clock" class="w-4 h-4"></i>
                {{detail.statusText}}
              </span>
            </div>
          </div>

          <div class="p-8 space-y-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <!-- 예약 정보 -->
              <div class="space-y-6">
                <h3 class="text-sm font-bold text-slate-400 uppercase tracking-wider border-b border-slate-100 pb-2">예약 정보</h3>

                <div class="flex items-start gap-3">
                  <i data-feather="hash" class="w-5 h-5 text-slate-400 shrink-0 mt-0.5"></i>
                  <div>
                    <div class="text-sm text-slate-500 mb-1">예약번호</div>
                    <div class="font-medium text-slate-800">{{detail.reservationNumber}}</div>
                  </div>
                </div>

                <div class="flex items-start gap-3">
                  <i data-feather="calendar" class="w-5 h-5 text-slate-400 shrink-0 mt-0.5"></i>
                  <div>
                    <div class="text-sm text-slate-500 mb-1">예약 일시</div>
                    <div class="font-medium text-slate-800">{{detail.reservationDate}} {{detail.timeSlot}}</div>
                  </div>
                </div>

                <div class="flex items-start gap-3">
                  <i data-feather="map-pin" class="w-5 h-5 text-slate-400 shrink-0 mt-0.5"></i>
                  <div>
                    <div class="text-sm text-slate-500 mb-1">진료과 / 전문의</div>
                    <div class="font-medium text-slate-800">{{detail.departmentName}} / {{detail.doctorName}}</div>
                  </div>
                </div>

                <div class="flex items-start gap-3">
                  <i data-feather="mail" class="w-5 h-5 text-slate-400 shrink-0 mt-0.5"></i>
                  <div>
                    <div class="text-sm text-slate-500 mb-1">이메일</div>
                    <div class="font-medium text-slate-800">{{detail.patientEmail}}</div>
                  </div>
                </div>
              </div>

              <!-- 환자 추가 정보 -->
              <div class="space-y-6">
                <div class="flex items-center justify-between border-b border-slate-100 pb-2">
                  <h3 class="text-sm font-bold text-slate-400 uppercase tracking-wider">환자 정보</h3>
                  <button type="button" id="editBtn" onclick="toggleEdit(true)" class="text-xs font-medium text-indigo-600 hover:text-indigo-700 flex items-center gap-1">
                    <i data-feather="edit-2" class="w-3 h-3"></i>
                    수정하기
                  </button>
                  <div id="editActions" class="hidden flex items-center gap-2">
                    <button type="button" onclick="saveInfo()" class="text-xs font-bold text-green-600 hover:text-green-700">저장</button>
                    <button type="button" onclick="toggleEdit(false)" class="text-xs font-medium text-slate-400 hover:text-slate-500">취소</button>
                  </div>
                </div>

                <div class="flex items-start gap-3">
                  <i data-feather="home" class="w-5 h-5 text-slate-400 shrink-0 mt-0.5"></i>
                  <div class="w-full">
                    <div class="text-sm text-slate-500 mb-1">주소</div>
                    <div id="addressDisplay" class="font-medium text-slate-800">
                      {{#detail.patientAddress}}{{detail.patientAddress}}{{/detail.patientAddress}}
                      {{^detail.patientAddress}}<span class="text-slate-400">미등록</span>{{/detail.patientAddress}}
                    </div>
                    <input type="text" id="addressInput" class="hidden w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" value="{{detail.patientAddress}}">
                  </div>
                </div>

                <div class="flex items-start gap-3">
                  <i data-feather="alert-circle" class="w-5 h-5 text-slate-400 shrink-0 mt-0.5"></i>
                  <div class="w-full">
                    <div class="text-sm text-slate-500 mb-1">특이사항</div>
                    <div id="noteDisplay" class="text-slate-800 bg-slate-50 p-3 rounded-xl border border-slate-100 text-sm leading-relaxed">
                      {{#detail.patientNote}}{{detail.patientNote}}{{/detail.patientNote}}
                      {{^detail.patientNote}}<span class="text-slate-400">입력된 특이사항이 없습니다.</span>{{/detail.patientNote}}
                    </div>
                    <textarea id="noteInput" rows="3" class="hidden w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">{{detail.patientNote}}</textarea>
                  </div>
                </div>
              </div>
            </div>

            <!-- 액션 버튼 -->
            <div class="pt-8 border-t border-slate-200 flex justify-end gap-3">
              <a href="/staff/reception/list?date={{currentDate}}&status={{currentStatus}}&page={{currentPage}}" class="px-6 py-3 bg-white border border-slate-300 text-slate-700 font-medium rounded-xl hover:bg-slate-50 transition-colors">
                목록으로
              </a>
              {{#detail.canReceive}}
              <form method="post" action="/staff/reception/receive" class="inline">
                <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
                <input type="hidden" name="reservationId" value="{{detail.id}}">
                <input type="hidden" name="date" value="{{currentDate}}">
                <input type="hidden" name="status" value="{{currentStatus}}">
                <input type="hidden" name="page" value="{{currentPage}}">
                <button type="submit" class="px-8 py-3 bg-indigo-600 text-white font-medium rounded-xl hover:bg-indigo-700 transition-colors shadow-sm flex items-center gap-2">
                  <i data-feather="check-circle" class="w-5 h-5"></i>
                  접수 완료 처리
                </button>
              </form>
              {{/detail.canReceive}}
              {{#detail.canCancel}}
              <form method="post" action="/staff/reception/cancel" class="inline" onsubmit="return handleCancel(this)">
                <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
                <input type="hidden" name="id" value="{{detail.id}}">
                <input type="hidden" name="reason" id="cancelReasonInput">
                <input type="hidden" name="date" value="{{currentDate}}">
                <input type="hidden" name="status" value="{{currentStatus}}">
                <input type="hidden" name="page" value="{{currentPage}}">
                <button type="submit" class="px-6 py-3 bg-red-50 text-red-600 font-medium rounded-xl hover:bg-red-100 transition-colors flex items-center gap-2">
                  <i data-feather="x-circle" class="w-5 h-5"></i>
                  예약 취소
                </button>
              </form>

              <script>
                function handleCancel(form) {
                  const reason = window.prompt('예약을 취소하시겠습니까? 취소 사유를 입력해주세요:');
                  if (reason === null) {
                    return false;
                  }
                  form.querySelector('#cancelReasonInput').value = reason;
                  return true;
                }
              </script>
              {{/detail.canCancel}}
            </div>
          </div>
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>
    feather.replace();

    function toggleEdit(isEdit) {
      document.getElementById('editBtn').classList.toggle('hidden', isEdit);
      document.getElementById('editActions').classList.toggle('hidden', !isEdit);
      
      document.getElementById('addressDisplay').classList.toggle('hidden', isEdit);
      document.getElementById('addressInput').classList.toggle('hidden', !isEdit);
      
      document.getElementById('noteDisplay').classList.toggle('hidden', isEdit);
      document.getElementById('noteInput').classList.toggle('hidden', !isEdit);
    }

    async function saveInfo() {
      const address = document.getElementById('addressInput').value;
      const note = document.getElementById('noteInput').value;
      const reservationId = {{detail.id}};

      try {
        const response = await fetch('/staff/reception/update-patient-info', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-TOKEN': '{{_csrf.token}}'
          },
          body: JSON.stringify({
            reservationId: reservationId,
            address: address,
            note: note
          })
        });

        if (response.ok) {
          const result = await response.json();
          alert(result.message);
          
          // UI 업데이트
          document.getElementById('addressDisplay').innerText = address || '미등록';
          document.getElementById('addressDisplay').classList.remove('text-slate-400');
          if (!address) document.getElementById('addressDisplay').classList.add('text-slate-400');
          
          document.getElementById('noteDisplay').innerText = note || '입력된 특이사항이 없습니다.';
          document.getElementById('noteDisplay').classList.remove('text-slate-400');
          if (!note) document.getElementById('noteDisplay').classList.add('text-slate-400');
          
          toggleEdit(false);
        } else {
          alert('정보 수정에 실패했습니다.');
        }
      } catch (error) {
        console.error('Error:', error);
        alert('오류가 발생했습니다.');
      }
    }
  </script>
</body>
</html>
