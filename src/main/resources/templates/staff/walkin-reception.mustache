<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>접수 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
  <style>
    /* MediCare+ 스타일 유지하며 박스형 입력 및 단 구분 최적화 */
    .split-input { text-align: center; padding: 0.75rem 0.5rem !important; }
    .split-input:focus { border-color: #4f46e5; ring: 2px; ring-color: #4f46e5; }
    /* 단 사이 수직 구분선 (데스크탑 전용) */
    @media (min-width: 768px) {
      .vertical-divider {
        position: relative;
      }
      .vertical-divider::after {
        content: '';
        position: absolute;
        right: -3rem; /* gap-24의 절반인 3rem 위치 */
        top: 0;
        height: 100%;
        width: 1px;
        background-color: #f1f5f9;
      }
    }
  </style>
</head>
<body class="min-h-screen flex bg-[#f8fafc]">
  {{> common/sidebar-staff}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="max-w-5xl mx-auto">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-10">
          
          <!-- 헤더 섹션: 제목 및 목록가기 추가 -->
          <div class="flex items-center justify-between mb-10 pb-6 border-b border-slate-100">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600">
                <i data-feather="user-plus" class="w-6 h-6"></i>
              </div>
              <div>
                <h1 class="text-2xl font-bold text-slate-800">접수</h1>
                <p class="text-slate-500 mt-1 text-sm">환자 접수 등록하는 화면입니다.</p>
              </div>
            </div>
            <!-- 우측 상단 목록가기 링크 -->
            <a href="/staff/reception/list" class="text-sm font-medium text-slate-500 hover:text-slate-700 flex items-center gap-1 transition-colors">
              <i data-feather="arrow-left" class="w-4 h-4"></i>
              목록으로 돌아가기
            </a>
          </div>

          <form id="walkinForm" method="post" action="/staff/walkin" class="space-y-10">
            <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
            <input type="hidden" name="birthInfo" id="hiddenBirthInfo">
            <input type="hidden" name="phone" id="hiddenPhone">
            <input type="hidden" name="date" value="{{today}}">
            <input type="hidden" name="time" id="hiddenTime">

            <!-- 5:5 단 배치 - 여백을 gap-24로 넉넉하게 조정 -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-24">
              
              <!-- 왼쪽 단: 환자 기본 정보 -->
              <div class="space-y-6 vertical-divider">
                <div class="flex items-center gap-2 mb-4 text-indigo-600">
                  <i data-feather="user" class="w-4 h-4"></i>
                  <h3 class="text-xs font-bold uppercase tracking-widest">환자 기본 정보</h3>
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2 ml-1">환자 성함</label>
                  <input type="text" name="name" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none" placeholder="성함을 입력하세요" />
                </div>

                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2 ml-1">주민등록번호</label>
                  <div class="flex items-center gap-2">
                    <!-- 주민번호 필수 입력 설정 -->
                    <input type="text" id="ssn1" maxlength="6" required class="split-input w-28 border border-slate-300 rounded-xl outline-none focus:ring-2 focus:ring-indigo-500" placeholder="앞 6자리" />
                    <span class="text-slate-400 font-bold">-</span>
                    <input type="text" id="ssn2" maxlength="1" required class="split-input w-12 border border-slate-300 rounded-xl outline-none focus:ring-2 focus:ring-indigo-500" placeholder="뒤 1자" />
                    <span class="text-slate-400 font-medium tracking-widest ml-1 text-lg">******</span>
                  </div>
                </div>

                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2 ml-1">연락처</label>
                  <div class="flex items-center gap-2">
                    <input type="text" id="p1" maxlength="3" class="split-input w-20 border border-slate-300 rounded-xl outline-none focus:ring-2 focus:ring-indigo-500" placeholder="010" />
                    <span class="text-slate-400 font-bold">-</span>
                    <input type="text" id="p2" maxlength="4" class="split-input w-24 border border-slate-300 rounded-xl outline-none focus:ring-2 focus:ring-indigo-500" placeholder="1234" />
                    <span class="text-slate-400 font-bold">-</span>
                    <input type="text" id="p3" maxlength="4" class="split-input w-24 border border-slate-300 rounded-xl outline-none focus:ring-2 focus:ring-indigo-500" placeholder="5678" />
                  </div>
                </div>
              </div>

              <!-- 오른쪽 단: 진료 정보 설정 -->
              <div class="space-y-6">
                <div class="flex items-center gap-2 mb-4 text-indigo-600">
                  <i data-feather="activity" class="w-4 h-4"></i>
                  <h3 class="text-xs font-bold uppercase tracking-widest">진료 정보 설정</h3>
                </div>

                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2 ml-1">진료과</label>
                  <select name="departmentId" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none bg-white">
                    <option value="">진료과를 선택하세요</option>
                    {{#departments}}
                    <option value="{{id}}">{{name}}</option>
                    {{/departments}}
                  </select>
                </div>

                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2 ml-1">전문의</label>
                  <select name="doctorId" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none bg-white">
                    <option value="">의사를 선택하세요</option>
                    {{#doctors}}
                    <option value="{{id}}" data-dept-id="{{departmentId}}">{{displayName}}</option>
                    {{/doctors}}
                  </select>
                </div>

                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2 ml-1">내원 사유</label>
                  <input type="text" name="visitReason" class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none" placeholder="증상을 간단히 입력하세요" />
                </div>
              </div>
            </div>

            <!-- 하단: 메모 및 특이사항 (Full Width) - 상단 선 제거 -->
            <div class="pt-6">
              <label class="block text-sm font-medium text-slate-700 mb-2 ml-1">메모 및 특이사항</label>
              <textarea name="notes" class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none h-32 resize-none" placeholder="특이사항이나 과거 이력 등을 기록하세요."></textarea>
            </div>

            <!-- 등록 버튼 -->
            <div class="pt-8 flex justify-end">
              <button type="submit" class="w-full md:w-72 py-4 bg-indigo-600 text-white rounded-xl font-bold text-lg hover:bg-indigo-700 transition-all shadow-lg active:scale-[0.98]">
                등록
              </button>
            </div>
          </form>
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>feather.replace();</script>
  
  <script>
    (function () {
      const form = document.getElementById('walkinForm');
      const hiddenTime = document.getElementById('hiddenTime');
      const ssn1 = document.getElementById('ssn1'), ssn2 = document.getElementById('ssn2');
      const p1 = document.getElementById('p1'), p2 = document.getElementById('p2'), p3 = document.getElementById('p3');
      const hiddenBirth = document.getElementById('hiddenBirthInfo'), hiddenPhone = document.getElementById('hiddenPhone');

      function updateHiddenTime() {
        const now = new Date();
        hiddenTime.value = String(now.getHours()).padStart(2, '0') + ':' + String(now.getMinutes()).padStart(2, '0');
      }
      updateHiddenTime();

      function setupSplitInput(curr, next, prev) {
        curr.addEventListener('input', () => {
          curr.value = curr.value.replace(/\D/g, '');
          if (curr.value.length >= curr.maxLength && next) next.focus();
          hiddenBirth.value = (ssn1.value || ssn2.value) ? `${ssn1.value}-${ssn2.value}` : '';
          hiddenPhone.value = (p1.value || p2.value || p3.value) ? `${p1.value}-${p2.value}-${p3.value}` : '';
        });
        curr.addEventListener('keydown', (e) => {
          if (e.key === 'Backspace' && curr.value.length === 0 && prev) prev.focus();
        });
      }

      setupSplitInput(ssn1, ssn2, null);
      setupSplitInput(ssn2, p1, ssn1);
      setupSplitInput(p1, p2, ssn2);
      setupSplitInput(p2, p3, p1);
      setupSplitInput(p3, null, p2);

      const deptSelect = document.querySelector('select[name="departmentId"]');
      const docSelect = document.querySelector('select[name="doctorId"]');
      const docOptions = Array.from(docSelect.querySelectorAll('option[data-dept-id]'));

      deptSelect.addEventListener('change', () => {
        const id = deptSelect.value;
        docOptions.forEach(opt => opt.style.display = (!id || opt.dataset.deptId === id) ? '' : 'none');
        docSelect.value = '';
      });

      form.addEventListener('submit', updateHiddenTime);
    })();
  </script>
</body>
</html>