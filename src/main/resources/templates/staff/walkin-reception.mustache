<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>방문 접수 - MediCare+</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/feather-icons"></script>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  
  {{> components/sidebar}}

  <div class="main-content">
    {{> components/header}}
    
    <main class="content-wrapper">
      <div class="max-w-2xl mx-auto">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
          <div class="flex items-center gap-3 mb-8">
            <div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center text-orange-600">
              <i data-feather="user-plus" class="w-6 h-6"></i>
            </div>
            <div>
              <h1 class="text-2xl font-bold text-slate-800">방문 접수 (Walk-in)</h1>
              <p class="text-slate-500 mt-1">예약 없이 방문한 환자를 즉시 접수합니다.</p>
            </div>
          </div>

          <form action="/receptions/walkin" method="POST" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">환자 성함</label>
                <div class="relative">
                  <i data-feather="user" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                  <input type="text" name="name" required class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-orange-500 outline-none" placeholder="홍길동" />
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">연락처</label>
                <div class="relative">
                  <i data-feather="phone" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                  <input type="tel" name="phone" required class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-orange-500 outline-none" placeholder="010-1234-5678" />
                </div>
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-slate-700 mb-2">이메일 (선택)</label>
              <div class="relative">
                <i data-feather="mail" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                <input type="email" name="email" class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-orange-500 outline-none" placeholder="example@email.com" />
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">진료과</label>
                <select name="department" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-orange-500 outline-none bg-white">
                  <option value="">선택해주세요</option>
                  <option value="내과">내과</option>
                  <option value="외과">외과</option>
                  <option value="소아과">소아과</option>
                  <option value="이비인후과">이비인후과</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">전문의</label>
                <select name="doctor" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-orange-500 outline-none bg-white">
                  <option value="">선택해주세요</option>
                  <option value="김의사 원장">김의사 원장</option>
                  <option value="이의사 과장">이의사 과장</option>
                  <option value="박의사 과장">박의사 과장</option>
                </select>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">접수 날짜</label>
                <div class="relative">
                  <i data-feather="calendar" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                  <input type="date" name="date" value="{{todayDate}}" required class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-orange-500 outline-none" />
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">접수 시간</label>
                <div class="relative">
                  <i data-feather="clock" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                  <input type="time" name="time" value="{{currentTime}}" required class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-orange-500 outline-none" />
                </div>
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-slate-700 mb-2">증상 및 메모</label>
              <div class="relative">
                <i data-feather="file-text" class="absolute left-3 top-4 w-5 h-5 text-slate-400"></i>
                <textarea name="notes" class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-orange-500 outline-none h-24 resize-none" placeholder="환자의 증상이나 특이사항을 입력하세요."></textarea>
              </div>
            </div>

            <div class="pt-6 border-t border-slate-200">
              <button type="submit" class="w-full py-4 bg-orange-600 text-white rounded-xl font-medium text-lg hover:bg-orange-700 transition-colors shadow-sm">
                즉시 접수하기
              </button>
            </div>
          </form>
        </div>
      </div>
    </main>

    {{> components/footer}}
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      feather.replace();
    });
  </script>
</body>
</html>