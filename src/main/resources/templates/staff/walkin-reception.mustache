<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>방문 접수 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/flatpickr.min.css">
  <script src="/js/feather.min.js"></script>
  <script src="/js/flatpickr.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-staff}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="max-w-2xl mx-auto">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
          <div class="flex items-center gap-3 mb-8">
            <div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center text-orange-600">
              <i data-feather="user-plus" class="w-6 h-6"></i>
            </div>
            <div>
              <h1 class="text-2xl font-bold text-slate-800">방문 접수 (Walk-in)</h1>
              <p class="text-slate-500 mt-1">예약 없이 방문한 환자를 즉시 접수합니다.</p>
            </div>
          </div>

          <form id="walkinForm" method="post" action="/staff/walkin" class="space-y-6">
            <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">환자 성함</label>
                <div class="relative">
                  <i data-feather="user" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                  <input type="text" name="name" required class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none" placeholder="홍길동" value="{{#form}}{{name}}{{/form}}" />
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">연락처</label>
                <div class="relative">
                  <i data-feather="phone" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                  <input 
                    type="tel" 
                    id="phoneInput"
                    name="phone" 
                    pattern="\d{3}-\d{4}-\d{4}" 
                    maxlength="13" 
                    required 
                    class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none" 
                    placeholder="010-1234-5678" 
                    value="{{#form}}{{phone}}{{/form}}" 
                  />
                </div>
                <p class="mt-2 text-xs text-slate-500 flex items-center gap-1.5 ml-1">
                  <i data-feather="info" class="w-3.5 h-3.5"></i>
                  숫자만 입력하시면 하이픈(-)이 자동으로 추가됩니다.
                </p>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">진료과</label>
                <select name="departmentId" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none bg-white">
                  <option value="">선택해주세요</option>
                  {{#departments}}
                  <option value="{{id}}">{{name}}</option>
                  {{/departments}}
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">전문의</label>
                <select name="doctorId" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none bg-white">
                  <option value="">선택해주세요</option>
                  {{#doctors}}
                  <option value="{{id}}" data-dept-id="{{departmentId}}" data-available-days="{{availableDays}}">{{displayName}}</option>
                  {{/doctors}}
                </select>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">접수 날짜</label>
                <div class="relative">
                  <i data-feather="calendar" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                  <input type="text" name="date" id="dateInput" required class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none" value="{{today}}" />
                </div>
                <p id="dateWarning" class="text-xs text-red-500 mt-1 hidden">선택하신 의사의 진료일이 아닙니다.</p>
              </div>
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">접수 시간</label>
                <div class="relative">
                  <i data-feather="clock" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                  <input type="text" name="time" id="timeInput" required maxlength="5" class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none" placeholder="HH:mm" />
                </div>
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-slate-700 mb-2">증상 및 메모</label>
              <div class="relative">
                <i data-feather="file-text" class="absolute left-3 top-4 w-5 h-5 text-slate-400"></i>
                <textarea name="notes" class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none h-24 resize-none" placeholder="환자의 증상이나 특이사항을 입력하세요.">{{#form}}{{notes}}{{/form}}</textarea>
              </div>
            </div>

            <div class="pt-6 border-t border-slate-200">
              <button type="submit" class="w-full py-4 bg-orange-600 text-white rounded-xl font-medium text-lg hover:bg-orange-700 transition-colors shadow-sm">
                즉시 접수하기
              </button>
            </div>
          </form>
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>feather.replace();</script>
  {{#message}}
  <script>alert("{{message}}");</script>
  {{/message}}
  <script>
    (function () {
      const form       = document.getElementById('walkinForm');
      const deptSelect = document.querySelector('select[name="departmentId"]');
      const docSelect  = document.querySelector('select[name="doctorId"]');
      const dateInput  = document.getElementById('dateInput');
      const timeInput  = document.getElementById('timeInput');
      const dateWarning = document.getElementById('dateWarning');
      const docOptions = Array.from(docSelect.querySelectorAll('option[data-dept-id]'));

      const DAY_MAP = { SUN: 0, MON: 1, TUE: 2, WED: 3, THU: 4, FRI: 5, SAT: 6 };

      // Flatpickr 초기화
      const datePicker = flatpickr(dateInput, {
        dateFormat: 'Y-m-d',
        minDate: 'today',
        onChange: function() { validateDoctorAvailability(); }
      });

      // 현재 시간 설정 (HH:mm)
      function setCurrentTime() {
        const now = new Date();
        const hours = String(now.getHours()).padStart(2, '0');
        const minutes = String(now.getMinutes()).padStart(2, '0');
        timeInput.value = `${hours}:${minutes}`;
      }

      // 진료과 → 의사 필터
      function filterDoctorsOnly() {
        const deptId = deptSelect.value;
        docOptions.forEach(function(opt) {
          opt.style.display = (!deptId || opt.dataset.deptId === deptId) ? '' : 'none';
        });
        if (docSelect.options[docSelect.selectedIndex] &&
            docSelect.options[docSelect.selectedIndex].style.display === 'none') {
          docSelect.value = '';
        }
      }

      // 의사 선택 시 진료 가능 요일 적용
      function validateDoctorAvailability() {
        const selectedDoc = docSelect.options[docSelect.selectedIndex];
        const availableDaysStr = (selectedDoc && selectedDoc.dataset.availableDays) || '';
        const selectedDateStr = dateInput.value;

        if (!availableDaysStr || !selectedDateStr) {
          dateWarning.classList.add('hidden');
          return true;
        }

        const availableDayNums = availableDaysStr
          .split(',')
          .map(d => DAY_MAP[d.trim()]);

        const selectedDate = new Date(selectedDateStr);
        const selectedDayNum = selectedDate.getDay();

        if (availableDayNums.includes(selectedDayNum)) {
          dateWarning.classList.add('hidden');
          // 다시 진료 가능일이 되면, 비어있을 경우에만 현재 시간으로 채워줌
          if (!timeInput.value) {
            setCurrentTime();
          }
          return true;
        } else {
          dateWarning.classList.remove('hidden');
          timeInput.value = ''; // 진료 불가능일이면 시간 비움
          return false;
        }
      }

      // 의사 변경 시 달력 제한 업데이트 및 날짜/시간 리셋
      function updateDatePickerLimits() {
        const selectedDoc = docSelect.options[docSelect.selectedIndex];
        const availableDaysStr = (selectedDoc && selectedDoc.dataset.availableDays) || '';

        // 1. 먼저 날짜 제한을 일시적으로 해제 (오늘 날짜 설정을 보장하기 위함)
        datePicker.set('enable', [function() { return true; }]);

        // 2. 날짜와 시간을 현재 시점으로 초기화
        const now = new Date();
        const todayStr = now.getFullYear() + '-' + 
                         String(now.getMonth() + 1).padStart(2, '0') + '-' + 
                         String(now.getDate()).padStart(2, '0');

        datePicker.setDate(todayStr);
        setCurrentTime();

        // 3. 새 의사의 진료 요일에 맞춰 다시 제한 설정
        if (availableDaysStr) {
          const availableDayNums = availableDaysStr.split(',').map(d => DAY_MAP[d.trim()]);
          datePicker.set('enable', [
            function(date) { return availableDayNums.includes(date.getDay()); }
          ]);
        }
        
        // 4. 경고 메시지 및 시간 필드 상태 동기화
        validateDoctorAvailability();
      }

      deptSelect.addEventListener('change', function() { filterDoctorsOnly(); });
      docSelect.addEventListener('change', function() { updateDatePickerLimits(); });

      // 폼 제출 전 최종 확인
      form.addEventListener('submit', function(e) {
        if (!validateDoctorAvailability()) {
          e.preventDefault();
          alert('선택하신 의사의 진료일이 아닙니다. 날짜를 확인해주세요.');
        }
      });

      // 초기 설정
      setCurrentTime();
      
      // 폼 오류 복원 시 처리
      const restoreDeptId = '{{#form}}{{departmentId}}{{/form}}';
      const restoreDocId  = '{{#form}}{{doctorId}}{{/form}}';
      const restoreDate   = '{{#form}}{{date}}{{/form}}';
      const restoreTime   = '{{#form}}{{time}}{{/form}}';

      if (restoreDeptId) {
        deptSelect.value = restoreDeptId;
        filterDoctorsOnly();
      }
      if (restoreDocId) {
        docSelect.value = restoreDocId;
        updateDatePickerLimits();
      }
      if (restoreDate) {
        datePicker.setDate(restoreDate);
      }
      if (restoreTime) {
        timeInput.value = restoreTime;
      }
    })();
  </script>
  <script>
const phoneInput = document.getElementById('phoneInput');

// 자동 하이픈
phoneInput.addEventListener('input', function (e) {
  let value = e.target.value.replace(/\D/g, '');

  if (value.length <= 3) {
    value = value;
  } else if (value.length <= 7) {
    value = value.slice(0, 3) + '-' + value.slice(3);
  } else {
    value = value.slice(0, 3) + '-' + value.slice(3, 7) + '-' + value.slice(7, 11);
  }

  e.target.value = value;
});

// 시간 입력 자동 콜론 (HH:mm)
const timeInput = document.getElementById('timeInput');
timeInput.addEventListener('input', function (e) {
  let value = e.target.value.replace(/\D/g, ''); // 숫자만 남김
  
  if (value.length > 2) {
    value = value.slice(0, 2) + ':' + value.slice(2, 4);
  }
  
  e.target.value = value;
});

// 시간 유효성 체크 (포커스 아웃 시)
timeInput.addEventListener('blur', function (e) {
  const value = e.target.value;
  if (value.length > 0 && value.length < 5) {
    alert('시간 형식이 올바르지 않습니다. (예: 14:30)');
    setTimeout(() => timeInput.focus(), 10);
  } else if (value.length === 5) {
    const [h, m] = value.split(':').map(Number);
    if (h < 0 || h > 23 || m < 0 || m > 59) {
      alert('유효하지 않은 시간입니다. (00:00 ~ 23:59)');
      setTimeout(() => timeInput.focus(), 10);
    }
  }
});
</script>
</body>
</html>
