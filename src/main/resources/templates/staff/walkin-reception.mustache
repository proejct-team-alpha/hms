<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>방문 접수 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-staff}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="max-w-2xl mx-auto">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
          <div class="flex items-center gap-3 mb-8">
            <div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center text-orange-600">
              <i data-feather="user-plus" class="w-6 h-6"></i>
            </div>
            <div>
              <h1 class="text-2xl font-bold text-slate-800">방문 접수 (Walk-in)</h1>
              <p class="text-slate-500 mt-1">예약 없이 방문한 환자를 즉시 접수합니다.</p>
            </div>
          </div>

          <form method="post" action="/staff/walkin" class="space-y-6">
            <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">환자 성함</label>
                <div class="relative">
                  <i data-feather="user" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                  <input type="text" name="name" required class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none" placeholder="홍길동" value="{{#form}}{{name}}{{/form}}" />
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">연락처</label>
                <div class="relative">
                  <i data-feather="phone" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                  <input type="tel" name="phone" pattern="\d{3}-\d{4}-\d{4}" maxlength="13" required class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none" placeholder="010-1234-5678" value="{{#form}}{{phone}}{{/form}}" />
                </div>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">진료과</label>
                <select name="departmentId" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none bg-white">
                  <option value="">선택해주세요</option>
                  {{#departments}}
                  <option value="{{id}}">{{name}}</option>
                  {{/departments}}
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">전문의</label>
                <select name="doctorId" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none bg-white">
                  <option value="">선택해주세요</option>
                  {{#doctors}}
                  <option value="{{id}}" data-dept-id="{{departmentId}}">{{displayName}}</option>
                  {{/doctors}}
                </select>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">접수 날짜</label>
                <div class="relative">
                  <i data-feather="calendar" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                  <input type="date" name="date" id="dateInput" required value="{{#form}}{{date}}{{/form}}{{^form}}{{today}}{{/form}}" class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none" />
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">접수 시간</label>
                <div class="relative">
                  <i data-feather="clock" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                  <select name="time" id="timeSelect" required
                          class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none bg-white">
                    <option value="">선택해주세요</option>
                    <optgroup label="오전">
                      <option value="09:00">09:00</option>
                      <option value="09:30">09:30</option>
                      <option value="10:00">10:00</option>
                      <option value="10:30">10:30</option>
                      <option value="11:00">11:00</option>
                      <option value="11:30">11:30</option>
                    </optgroup>
                    <optgroup label="오후">
                      <option value="14:00">14:00</option>
                      <option value="14:30">14:30</option>
                      <option value="15:00">15:00</option>
                      <option value="15:30">15:30</option>
                      <option value="16:00">16:00</option>
                      <option value="16:30">16:30</option>
                      <option value="17:00">17:00</option>
                      <option value="17:30">17:30</option>
                    </optgroup>
                  </select>
                </div>
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-slate-700 mb-2">증상 및 메모</label>
              <div class="relative">
                <i data-feather="file-text" class="absolute left-3 top-4 w-5 h-5 text-slate-400"></i>
                <textarea name="notes" class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none h-24 resize-none" placeholder="환자의 증상이나 특이사항을 입력하세요.">{{#form}}{{notes}}{{/form}}</textarea>
              </div>
            </div>

            <div class="pt-6 border-t border-slate-200">
              <button type="submit" class="w-full py-4 bg-orange-600 text-white rounded-xl font-medium text-lg hover:bg-orange-700 transition-colors shadow-sm">
                즉시 접수하기
              </button>
            </div>
          </form>
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>feather.replace();</script>
  {{#message}}
  <script>alert("{{message}}");</script>
  {{/message}}
  <script>
    (async function () {
      const deptSelect  = document.querySelector('select[name="departmentId"]');
      const docSelect   = document.querySelector('select[name="doctorId"]');
      const dateInput   = document.getElementById('dateInput');
      const timeSelect  = document.getElementById('timeSelect');
      const docOptions  = Array.from(docSelect.querySelectorAll('option[data-dept-id]'));

      // 과거 날짜 선택 불가
      dateInput.min = new Date().toISOString().split('T')[0];

      // 진료과 → 의사 필터 (select 값 변경 없이 DOM만 조작)
      function filterDoctorsOnly() {
        const deptId = deptSelect.value;
        docOptions.forEach(function(opt) {
          opt.style.display = (!deptId || opt.dataset.deptId === deptId) ? '' : 'none';
        });
        if (docSelect.options[docSelect.selectedIndex] &&
            docSelect.options[docSelect.selectedIndex].style.display === 'none') {
          docSelect.value = '';
        }
      }

      // booked-slots API 호출 → 예약 불가 시간 비활성화
      async function refreshTimeSlots() {
        const doctorId = docSelect.value;
        const date     = dateInput.value;
        const opts     = Array.from(timeSelect.querySelectorAll('option[value]'));

        // 전체 초기화
        opts.forEach(function(opt) {
          opt.disabled = false;
          opt.textContent = opt.value;
        });
        if (!doctorId || !date) return;

        try {
          const res    = await fetch('/api/reservation/booked-slots?doctorId=' + doctorId + '&date=' + date);
          const booked = await res.json();
          opts.forEach(function(opt) {
            if (booked.includes(opt.value)) {
              opt.disabled = true;
              opt.textContent = opt.value + ' (예약불가)';
              if (timeSelect.value === opt.value) timeSelect.value = '';
            }
          });
        } catch (e) {}
      }

      deptSelect.addEventListener('change', function() { filterDoctorsOnly(); refreshTimeSlots(); });
      docSelect.addEventListener('change', refreshTimeSlots);
      dateInput.addEventListener('change', refreshTimeSlots);

      // 폼 오류 복원
      const restoreDeptId = '{{#form}}{{departmentId}}{{/form}}';
      const restoreDocId  = '{{#form}}{{doctorId}}{{/form}}';
      const restoreTime   = '{{#form}}{{time}}{{/form}}';

      if (restoreDeptId) deptSelect.value = restoreDeptId;
      filterDoctorsOnly();
      if (restoreDocId) docSelect.value = restoreDocId;
      await refreshTimeSlots();
      if (restoreTime) timeSelect.value = restoreTime;
    })();
  </script>
</body>
</html>
