<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>접수 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
  <style>
    .split-input { text-align: center; padding: 0.75rem 0.5rem !important; }
    .split-input:focus { border-color: #4f46e5; ring: 2px; ring-color: #4f46e5; }
    /* 불필요한 세로선 스타일 삭제됨 */
  </style>
</head>
<body class="min-h-screen flex bg-[#f8fafc]">
  {{> common/sidebar-staff}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="max-w-5xl mx-auto">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-10">
          
          <div class="flex items-center justify-between mb-10 pb-6 border-b border-slate-100">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600">
                <i data-feather="user-plus" class="w-6 h-6"></i>
              </div>
              <div>
                <h1 class="text-2xl font-bold text-slate-800">접수</h1>
                <p class="text-slate-500 mt-1 text-sm">환자 접수 등록하는 화면입니다.</p>
              </div>
            </div>
            <a href="/staff/reception/list" class="text-sm font-medium text-slate-500 hover:text-slate-700 flex items-center gap-1 transition-colors">
              <i data-feather="arrow-left" class="w-4 h-4"></i>
              목록으로 돌아가기
            </a>
          </div>

          <form id="walkinForm" method="post" action="/staff/walkin" class="space-y-10">
            <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
            <input type="hidden" name="reservationId" value="{{#reservationId}}{{reservationId}}{{/reservationId}}">
            <input type="hidden" name="birthInfo" id="hiddenBirthInfo">
            <input type="hidden" name="phone" id="hiddenPhone">
            <input type="hidden" name="date" value="{{today}}">
            <input type="hidden" name="time" id="hiddenTime">

            <!-- [디자인 수정] 단 사이 간격을 60px로 조정하여 적절한 여백 확보 -->
            <div class="flex flex-col md:flex-row" style="column-gap: 60px;">
              
              <!-- 왼쪽 단: 환자 기본 정보 -->
              <div class="flex-1 space-y-6">
                <div class="flex items-center gap-2 mb-4 text-indigo-600">
                  <i data-feather="user" class="w-4 h-4"></i>
                  <h3 class="text-xs font-bold uppercase tracking-widest">환자 기본 정보</h3>
                </div>
                
                <div>
                  <div class="flex justify-between items-end mb-2 ml-1">
                    <label class="block text-sm font-medium text-slate-700">환자 성함</label>
                    {{#patientId}}
                    <span class="text-[11px] font-bold text-slate-400 bg-slate-50 px-2 py-0.5 rounded-md border border-slate-100">환자번호: {{patientId}}</span>
                    {{/patientId}}
                  </div>
                  <input type="text" name="name" value="{{#name}}{{name}}{{/name}}" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none text-sm" placeholder="홍길동" />
                </div>

                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2 ml-1">주민등록번호</label>
                  <div class="flex items-center gap-2">
                    <input type="text" id="ssn1" maxlength="6" required class="split-input w-20 border border-slate-300 rounded-xl outline-none focus:ring-2 focus:ring-indigo-500 text-sm" placeholder="940101" />
                    <span class="text-slate-400 font-bold">-</span>
                    <input type="text" id="ssn2" maxlength="1" required class="split-input w-10 border border-slate-300 rounded-xl outline-none focus:ring-2 focus:ring-indigo-500 text-sm" placeholder="1" />
                    <span class="text-slate-400 font-medium tracking-widest ml-1 text-sm">******</span>
                  </div>
                </div>

                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2 ml-1">연락처</label>
                  <div class="flex items-center gap-2">
                    <input type="text" id="p1" maxlength="3" value="{{#p1}}{{p1}}{{/p1}}" class="split-input w-16 border border-slate-300 rounded-xl outline-none focus:ring-2 focus:ring-indigo-500 text-sm" placeholder="010" />
                    <span class="text-slate-400 font-bold">-</span>
                    <input type="text" id="p2" maxlength="4" value="{{#p2}}{{p2}}{{/p2}}" class="split-input w-20 border border-slate-300 rounded-xl outline-none focus:ring-2 focus:ring-indigo-500 text-sm" placeholder="1234" />
                    <span class="text-slate-400 font-bold">-</span>
                    <input type="text" id="p3" maxlength="4" value="{{#p3}}{{p3}}{{/p3}}" class="split-input w-20 border border-slate-300 rounded-xl outline-none focus:ring-2 focus:ring-indigo-500 text-sm" placeholder="5678" />
                  </div>
                </div>
              </div>

              <!-- 오른쪽 단: 진료 정보 설정 -->
              <div class="flex-1 space-y-6">
                <div class="flex items-center gap-2 mb-4 text-indigo-600">
                  <i data-feather="activity" class="w-4 h-4"></i>
                  <h3 class="text-xs font-bold uppercase tracking-widest">진료 정보 설정</h3>
                </div>

                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2 ml-1">진료과</label>
                  <select name="departmentId" data-selected="{{#selectedDeptId}}{{selectedDeptId}}{{/selectedDeptId}}" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none bg-white text-sm">
                    <option value="">진료과를 선택하세요</option>
                    {{#departments}}
                    <option value="{{id}}">{{name}}</option>
                    {{/departments}}
                  </select>
                </div>

                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2 ml-1">전문의</label>
                  <select name="doctorId" data-selected="{{#selectedDoctorId}}{{selectedDoctorId}}{{/selectedDoctorId}}" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none bg-white text-sm">
                    <option value="">의사를 선택하세요</option>
                    {{#doctors}}
                    <option value="{{id}}" data-dept-id="{{departmentId}}">{{displayName}}</option>
                    {{/doctors}}
                  </select>
                </div>

                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2 ml-1">내원 사유</label>
                  <input type="text" name="visitReason" class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none text-sm" placeholder="감기, 건강검진 등" />
                </div>
              </div>
            </div>

            <div class="pt-6">
              <label class="block text-sm font-medium text-slate-700 mb-2 ml-1">특이사항 및 메모</label>
              <textarea name="notes" class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none h-32 resize-none text-sm" placeholder="환자의 특이사항이나 메모를 입력하세요."></textarea>
            </div>

            <div class="pt-8 flex justify-end">
              <button type="submit" class="w-full md:w-72 py-4 bg-indigo-600 text-white rounded-xl font-bold text-lg hover:bg-indigo-700 transition-all shadow-lg active:scale-[0.98]">
                등록
              </button>
            </div>
          </form>
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>feather.replace();</script>
  
  <script>
    (function () {
      const form = document.getElementById('walkinForm');
      const hiddenTime = document.getElementById('hiddenTime');
      const ssn1 = document.getElementById('ssn1'), ssn2 = document.getElementById('ssn2');
      const p1 = document.getElementById('p1'), p2 = document.getElementById('p2'), p3 = document.getElementById('p3');
      const hiddenBirth = document.getElementById('hiddenBirthInfo'), hiddenPhone = document.getElementById('hiddenPhone');

      function updateHiddenTime() {
        const now = new Date();
        hiddenTime.value = String(now.getHours()).padStart(2, '0') + ':' + String(now.getMinutes()).padStart(2, '0');
      }
      updateHiddenTime();

      function setupSplitInput(curr, next, prev) {
        curr.addEventListener('input', () => {
          curr.value = curr.value.replace(/\D/g, '');
          if (curr.value.length >= curr.maxLength && next) next.focus();
          hiddenBirth.value = (ssn1.value || ssn2.value) ? `${ssn1.value}-${ssn2.value}` : '';
          hiddenPhone.value = (p1.value || p2.value || p3.value) ? `${p1.value}-${p2.value}-${p3.value}` : '';
        });
        curr.addEventListener('keydown', (e) => {
          if (e.key === 'Backspace' && curr.value.length === 0 && prev) prev.focus();
        });
      }

      setupSplitInput(ssn1, ssn2, null);
      setupSplitInput(ssn2, p1, ssn1);
      setupSplitInput(p1, p2, ssn2);
      setupSplitInput(p2, p3, p1);
      setupSplitInput(p3, null, p2);

      const deptSelect = document.querySelector('select[name="departmentId"]');
      const docSelect = document.querySelector('select[name="doctorId"]');
      const docOptions = Array.from(docSelect.querySelectorAll('option[data-dept-id]'));

      deptSelect.addEventListener('change', () => {
        const id = deptSelect.value;
        docOptions.forEach(opt => opt.style.display = (!id || opt.dataset.deptId === id) ? '' : 'none');
        docSelect.value = '';
      });

      function initSelectedValues() {
        const selectedDeptId = deptSelect.getAttribute('data-selected');
        const selectedDocId = docSelect.getAttribute('data-selected');
        if (selectedDeptId) {
          deptSelect.value = selectedDeptId;
          const id = selectedDeptId;
          docOptions.forEach(opt => opt.style.display = (!id || opt.dataset.deptId === id) ? '' : 'none');
          if (selectedDocId) docSelect.value = selectedDocId;
        }
        hiddenBirth.value = (ssn1.value || ssn2.value) ? `${ssn1.value}-${ssn2.value}` : '';
        hiddenPhone.value = (p1.value || p2.value || p3.value) ? `${p1.value}-${p2.value}-${p3.value}` : '';
      }
      initSelectedValues();
      form.addEventListener('submit', updateHiddenTime);
    })();
  </script>
</body>
</html>