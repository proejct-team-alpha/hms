<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>물품 출고 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-staff}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="max-w-5xl mx-auto space-y-6">

        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center text-indigo-600">
            <i data-feather="package" class="w-5 h-5"></i>
          </div>
          <h1 class="text-2xl font-bold text-slate-800">물품 출고</h1>
        </div>

        <!-- 오늘 출고 내역 -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 space-y-3">
          <h3 class="text-base font-bold text-slate-800 flex items-center gap-2">
            <i data-feather="list" class="w-5 h-5 text-indigo-600"></i>
            오늘 출고 내역
          </h3>
          <div class="bg-slate-50 rounded-xl border border-slate-100 overflow-hidden">
            <table class="w-full text-xs">
              <thead class="bg-slate-100 text-slate-500">
                <tr>
                  <th class="px-3 py-2 text-left font-medium">물품명</th>
                  <th class="px-3 py-2 text-right font-medium">수량</th>
                  <th class="px-3 py-2 text-right font-medium">시간</th>
                </tr>
              </thead>
              <tbody id="today-log-tbody" class="divide-y divide-slate-100">
                {{#todayLogs}}
                <tr>
                  <td class="px-3 py-2 text-slate-700 font-medium">{{itemName}}</td>
                  <td class="px-3 py-2 text-right text-slate-600">{{amount}}개</td>
                  <td class="px-3 py-2 text-right text-slate-400">{{usedAt}}</td>
                </tr>
                {{/todayLogs}}
                {{^todayLogs}}
                <tr id="today-log-empty"><td colspan="3" class="px-3 py-2 text-xs text-slate-400">오늘 출고된 물품이 없습니다.</td></tr>
                {{/todayLogs}}
              </tbody>
            </table>
          </div>
          <div id="today-log-pagination" class="flex items-center justify-between pt-2" style="display:none!important">
            <span id="today-log-page-info" class="text-xs text-slate-500"></span>
            <div class="flex items-center gap-2">
              <button id="today-log-prev" type="button"
                      class="px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-100 disabled:opacity-40 disabled:cursor-not-allowed transition-colors">
                이전
              </button>
              <div id="today-log-page-numbers" class="flex items-center gap-1"></div>
              <button id="today-log-next" type="button"
                      class="px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-100 disabled:opacity-40 disabled:cursor-not-allowed transition-colors">
                다음
              </button>
            </div>
          </div>
        </div>

        <!-- 물품 출고 섹션 -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 space-y-4">
          <div class="flex items-center justify-between">
            <h3 class="text-base font-bold text-slate-800 flex items-center gap-2">
              <i data-feather="package" class="w-5 h-5 text-indigo-600"></i>
              물품 선택
            </h3>
            <div class="flex gap-1.5" id="item-category-btns">
              <button type="button" data-cat="" class="item-cat-btn px-3 py-1.5 text-xs font-medium rounded-lg bg-indigo-600 text-white transition-colors">전체</button>
              <button type="button" data-cat="MEDICAL_SUPPLIES" class="item-cat-btn px-3 py-1.5 text-xs font-medium rounded-lg bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors">의료소모품</button>
              <button type="button" data-cat="MEDICAL_EQUIPMENT" class="item-cat-btn px-3 py-1.5 text-xs font-medium rounded-lg bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors">의료기기</button>
              <button type="button" data-cat="GENERAL_SUPPLIES" class="item-cat-btn px-3 py-1.5 text-xs font-medium rounded-lg bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors">사무/비품</button>
            </div>
          </div>
          <div class="relative">
            <i data-feather="search" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"></i>
            <input type="text" id="item-search" placeholder="물품명 검색 (초성·영문 가능)"
                   class="w-full pl-9 pr-4 py-2 text-sm border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-300">
          </div>
          <div class="grid grid-cols-4 gap-3" id="item-use-grid">
            {{#items}}
            <div class="item-card border border-slate-200 rounded-xl p-3 space-y-2" data-category="{{category}}">
              <div class="item-name text-sm font-bold text-slate-800 truncate">{{name}}</div>
              <div class="text-xs text-slate-500">{{categoryText}}</div>
              <div class="text-xs font-bold {{#lowStock}}text-red-600{{/lowStock}}{{^lowStock}}text-slate-600{{/lowStock}}">
                재고: <span class="quantity-span">{{quantity}}</span>개
              </div>
              <form action="/staff/item/use" method="post" class="flex items-center gap-1">
                <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
                <input type="hidden" name="id" value="{{id}}">
                <input type="number" name="amount" min="1" placeholder="수량"
                       class="flex-1 w-0 px-2 py-1 text-xs border border-slate-300 rounded-lg text-center focus:outline-none focus:ring-1 focus:ring-indigo-400">
                <button type="submit" class="px-2 py-1 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-bold rounded-lg transition-colors whitespace-nowrap">
                  출고
                </button>
              </form>
              <form action="/staff/item/restock" method="post" class="flex items-center gap-1">
                <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
                <input type="hidden" name="id" value="{{id}}">
                <input type="number" name="amount" min="1" placeholder="수량"
                       class="flex-1 w-0 px-2 py-1 text-xs border border-slate-300 rounded-lg text-center focus:outline-none focus:ring-1 focus:ring-green-400">
                <button type="submit" style="background-color:#16a34a;color:#fff;" class="px-2 py-1 text-xs font-bold rounded-lg transition-colors whitespace-nowrap hover:opacity-90">
                  입고
                </button>
              </form>
            </div>
            {{/items}}
          </div>
          <!-- 카드 그리드 페이징 바 -->
          <div id="card-grid-pagination" class="flex items-center justify-between" style="display:none!important">
            <span id="card-grid-page-info" class="text-xs text-slate-500"></span>
            <div class="flex items-center gap-2">
              <button id="card-grid-prev" type="button"
                      class="px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-100 disabled:opacity-40 disabled:cursor-not-allowed transition-colors">
                이전
              </button>
              <div id="card-grid-page-numbers" class="flex items-center gap-1"></div>
              <button id="card-grid-next" type="button"
                      class="px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-100 disabled:opacity-40 disabled:cursor-not-allowed transition-colors">
                다음
              </button>
            </div>
          </div>
        </div>

      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>
    // ===== 오늘 출고 내역 페이징 =====
    var TODAY_LOG_PAGE_SIZE = 10;
    var todayLogPage = 1;

    function buildTodayLogPageNumbers(totalPages) {
      var half = 2;
      var start = Math.max(1, todayLogPage - half);
      var end = Math.min(totalPages, start + 4);
      start = Math.max(1, end - 4);
      var html = '';
      if (start > 1) {
        html += '<button type="button" data-page="1" class="tl-page-btn px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 bg-white text-slate-600 hover:bg-slate-100 transition-colors">1</button>';
        if (start > 2) html += '<span class="px-1 text-xs text-slate-400">...</span>';
      }
      for (var p = start; p <= end; p++) {
        var active = p === todayLogPage ? 'bg-indigo-600 text-white' : 'bg-white text-slate-600 hover:bg-slate-100';
        html += '<button type="button" data-page="' + p + '" class="tl-page-btn px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 ' + active + ' transition-colors">' + p + '</button>';
      }
      if (end < totalPages) {
        if (end < totalPages - 1) html += '<span class="px-1 text-xs text-slate-400">...</span>';
        html += '<button type="button" data-page="' + totalPages + '" class="tl-page-btn px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 bg-white text-slate-600 hover:bg-slate-100 transition-colors">' + totalPages + '</button>';
      }
      return html;
    }

    function renderTodayLog() {
      var tbody = document.getElementById('today-log-tbody');
      if (!tbody) return;
      var emptyRow = document.getElementById('today-log-empty');
      if (emptyRow) emptyRow.style.display = 'none';
      var rows = Array.from(tbody.querySelectorAll('tr:not(#today-log-empty)'));
      var total = rows.length;
      var totalPages = Math.max(1, Math.ceil(total / TODAY_LOG_PAGE_SIZE));
      if (todayLogPage > totalPages) todayLogPage = totalPages;

      var start = (todayLogPage - 1) * TODAY_LOG_PAGE_SIZE;
      var end = start + TODAY_LOG_PAGE_SIZE;
      rows.forEach(function(r, i) { r.style.display = (i >= start && i < end) ? '' : 'none'; });

      var bar = document.getElementById('today-log-pagination');
      if (!bar) return;
      if (totalPages <= 1) { bar.style.removeProperty('display'); bar.style.display = 'none'; return; }
      bar.style.removeProperty('display');

      var numbersEl = document.getElementById('today-log-page-numbers');
      if (numbersEl) {
        numbersEl.innerHTML = buildTodayLogPageNumbers(totalPages);
        numbersEl.querySelectorAll('.tl-page-btn').forEach(function(btn) {
          btn.addEventListener('click', function() { todayLogPage = parseInt(this.dataset.page); renderTodayLog(); });
        });
      }

      var info = document.getElementById('today-log-page-info');
      if (info) info.textContent = total + '건 / ' + totalPages + '페이지';

      var prev = document.getElementById('today-log-prev');
      var next = document.getElementById('today-log-next');
      if (prev) prev.disabled = todayLogPage <= 1;
      if (next) next.disabled = todayLogPage >= totalPages;
    }

    var tlPrev = document.getElementById('today-log-prev');
    var tlNext = document.getElementById('today-log-next');
    if (tlPrev) tlPrev.addEventListener('click', function() { todayLogPage--; if (todayLogPage < 1) todayLogPage = 1; renderTodayLog(); });
    if (tlNext) tlNext.addEventListener('click', function() { todayLogPage++; renderTodayLog(); });

    renderTodayLog();
    // ===== END 오늘 출고 내역 페이징 =====

    var CHOSUNG = ['ㄱ','ㄲ','ㄴ','ㄷ','ㄸ','ㄹ','ㅁ','ㅂ','ㅃ','ㅅ','ㅆ','ㅇ','ㅈ','ㅉ','ㅊ','ㅋ','ㅌ','ㅍ','ㅎ'];
    function getChosung(str) {
      return str.split('').map(function(ch) {
        var code = ch.charCodeAt(0);
        if (code >= 0xAC00 && code <= 0xD7A3) return CHOSUNG[Math.floor((code - 0xAC00) / 588)];
        return ch;
      }).join('');
    }
    function isChosungOnly(str) { return /^[ㄱ-ㅎ]+$/.test(str); }
    function itemMatches(name, query) {
      if (!query) return true;
      var q = query.toLowerCase();
      if (isChosungOnly(q)) return getChosung(name).includes(q);
      return name.toLowerCase().includes(q);
    }

    var currentCat = '';
    var CARD_PAGE_SIZE = 10;
    var cardPage = 1;

    function buildCardPageNumbers(totalPages) {
      var half = 2;
      var start = Math.max(1, cardPage - half);
      var end = Math.min(totalPages, start + 4);
      start = Math.max(1, end - 4);
      var html = '';
      if (start > 1) {
        html += '<button type="button" data-page="1" class="cg-page-btn px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 bg-white text-slate-600 hover:bg-slate-100 transition-colors">1</button>';
        if (start > 2) html += '<span class="px-1 text-xs text-slate-400">...</span>';
      }
      for (var p = start; p <= end; p++) {
        var active = p === cardPage ? 'bg-indigo-600 text-white' : 'bg-white text-slate-600 hover:bg-slate-100';
        html += '<button type="button" data-page="' + p + '" class="cg-page-btn px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 ' + active + ' transition-colors">' + p + '</button>';
      }
      if (end < totalPages) {
        if (end < totalPages - 1) html += '<span class="px-1 text-xs text-slate-400">...</span>';
        html += '<button type="button" data-page="' + totalPages + '" class="cg-page-btn px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 bg-white text-slate-600 hover:bg-slate-100 transition-colors">' + totalPages + '</button>';
      }
      return html;
    }

    function applyFilter() {
      var query = document.getElementById('item-search').value.trim();
      var allCards = Array.from(document.querySelectorAll('#item-use-grid .item-card'));
      var filtered = allCards.filter(function(card) {
        var catOk = !currentCat || card.dataset.category === currentCat;
        var nameOk = itemMatches(card.querySelector('.item-name').textContent, query);
        return catOk && nameOk;
      });

      var total = filtered.length;
      var totalPages = Math.max(1, Math.ceil(total / CARD_PAGE_SIZE));
      if (cardPage < 1) cardPage = 1;
      if (cardPage > totalPages) cardPage = totalPages;
      var start = (cardPage - 1) * CARD_PAGE_SIZE;
      var end = start + CARD_PAGE_SIZE;

      allCards.forEach(function(card) { card.style.display = 'none'; });
      filtered.forEach(function(card, i) { card.style.display = (i >= start && i < end) ? '' : 'none'; });

      var bar = document.getElementById('card-grid-pagination');
      if (!bar) return;
      if (totalPages <= 1) { bar.style.removeProperty('display'); bar.style.display = 'none'; return; }
      bar.style.removeProperty('display');

      var numbersEl = document.getElementById('card-grid-page-numbers');
      if (numbersEl) {
        numbersEl.innerHTML = buildCardPageNumbers(totalPages);
        numbersEl.querySelectorAll('.cg-page-btn').forEach(function(btn) {
          btn.addEventListener('click', function() { cardPage = parseInt(this.dataset.page); applyFilter(); });
        });
      }

      var info = document.getElementById('card-grid-page-info');
      if (info) info.textContent = total + '건 / ' + totalPages + '페이지';

      var prev = document.getElementById('card-grid-prev');
      var next = document.getElementById('card-grid-next');
      if (prev) prev.disabled = cardPage <= 1;
      if (next) next.disabled = cardPage >= totalPages;
    }

    document.getElementById('item-search').addEventListener('input', function() {
      cardPage = 1; applyFilter();
    });

    document.querySelectorAll('.item-cat-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        currentCat = this.dataset.cat;
        document.querySelectorAll('.item-cat-btn').forEach(function(b) {
          b.className = 'item-cat-btn px-3 py-1.5 text-xs font-medium rounded-lg bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors';
        });
        this.className = 'item-cat-btn px-3 py-1.5 text-xs font-medium rounded-lg bg-indigo-600 text-white transition-colors';
        cardPage = 1; applyFilter();
      });
    });

    var cgPrev = document.getElementById('card-grid-prev');
    var cgNext = document.getElementById('card-grid-next');
    if (cgPrev) cgPrev.addEventListener('click', function() { cardPage--; if (cardPage < 1) cardPage = 1; applyFilter(); });
    if (cgNext) cgNext.addEventListener('click', function() { cardPage++; applyFilter(); });

    function refreshTodayLog(logs) {
      var tbody = document.getElementById('today-log-tbody');
      if (!tbody) return;
      Array.from(tbody.querySelectorAll('tr:not(#today-log-empty)')).forEach(function(r) { r.remove(); });
      var emptyRow = document.getElementById('today-log-empty');
      if (logs && logs.length > 0) {
        if (emptyRow) emptyRow.style.display = 'none';
        logs.forEach(function(log) {
          const tr = document.createElement('tr');
          const td1 = document.createElement('td'); td1.className = 'px-3 py-2 text-slate-700 font-medium'; td1.textContent = log.itemName;
          const td2 = document.createElement('td'); td2.className = 'px-3 py-2 text-right text-slate-600'; td2.textContent = log.amount + '개';
          const td3 = document.createElement('td'); td3.className = 'px-3 py-2 text-right text-slate-400'; td3.textContent = log.usedAt;
          tr.appendChild(td1); tr.appendChild(td2); tr.appendChild(td3);
          tbody.appendChild(tr);
        });
      } else {
        if (emptyRow) emptyRow.style.display = '';
      }
      todayLogPage = 1;
      renderTodayLog();
    }

    document.querySelectorAll('form[action$="/staff/item/use"]').forEach(function(form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var input = form.querySelector('input[name="amount"]');
        var value = input.value.trim();
        var amount = Number(value);
        if (value === '' || isNaN(amount) || !Number.isInteger(amount) || amount <= 0) {
          alert('올바른 수량을 입력해주세요. (1 이상의 정수)');
          return;
        }
        var id = form.querySelector('input[name="id"]').value;
        var csrfInput = form.querySelector('input[type="hidden"]:not([name="id"])');
        var params = new URLSearchParams();
        params.append('id', id);
        params.append('amount', value);
        params.append(csrfInput.name, csrfInput.value);

        fetch('/staff/item/use', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: params.toString()
        })
        .then(function(res) {
          if (!res.ok) { return res.json().then(function(d) { alert(d.error || '서버 오류가 발생했습니다.'); throw new Error('server error'); }); }
          return res.json();
        })
        .then(function(data) {
          if (data.quantity !== undefined) {
            form.closest('.item-card').querySelector('.quantity-span').textContent = data.quantity;
            input.value = '';
            refreshTodayLog(data.logs || []);
          } else if (data.error) {
            alert(data.error);
          }
        })
        .catch(function(err) { if (err.message !== 'server error') alert('오류가 발생했습니다. 다시 시도해주세요.'); });
      });
    });

    document.querySelectorAll('form[action$="/staff/item/restock"]').forEach(function(form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var input = form.querySelector('input[name="amount"]');
        var value = input.value.trim();
        var amount = Number(value);
        if (value === '' || isNaN(amount) || !Number.isInteger(amount) || amount <= 0) {
          alert('올바른 수량을 입력해주세요. (1 이상의 정수)');
          return;
        }
        var id = form.querySelector('input[name="id"]').value;
        var csrfInput = form.querySelector('input[type="hidden"]:not([name="id"])');
        var params = new URLSearchParams();
        params.append('id', id);
        params.append('amount', value);
        params.append(csrfInput.name, csrfInput.value);

        fetch('/staff/item/restock', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: params.toString()
        })
        .then(function(res) {
          if (!res.ok) { return res.json().then(function(d) { alert(d.error || '서버 오류가 발생했습니다.'); throw new Error('server error'); }); }
          return res.json();
        })
        .then(function(data) {
          if (data.quantity !== undefined) {
            form.closest('.item-card').querySelector('.quantity-span').textContent = data.quantity;
            input.value = '';
          } else if (data.error) {
            alert(data.error);
          }
        })
        .catch(function(err) { if (err.message !== 'server error') alert('오류가 발생했습니다. 다시 시도해주세요.'); });
      });
    });

    applyFilter();
  </script>
  <script>feather.replace();</script>
</body>
</html>
