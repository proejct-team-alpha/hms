<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>원무과 대시보드 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-staff}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="space-y-6 max-w-5xl mx-auto">
        <h1 class="text-2xl font-bold text-slate-800">원무과 대시보드</h1>

        <!-- Stats -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-indigo-50 rounded-xl flex items-center justify-center text-indigo-600">
                <i data-feather="users" class="w-6 h-6"></i>
              </div>
              <div>
                <div class="text-sm font-medium text-slate-500">오늘 총 예약</div>
                <div class="text-2xl font-bold text-slate-800">{{dashboard.totalToday}}명</div>
              </div>
            </div>
          </div>
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-orange-50 rounded-xl flex items-center justify-center text-orange-600">
                <i data-feather="calendar" class="w-6 h-6"></i>
              </div>
              <div>
                <div class="text-sm font-medium text-slate-500">접수 대기</div>
                <div class="text-2xl font-bold text-slate-800">{{dashboard.waitingCount}}명</div>
              </div>
            </div>
          </div>
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-green-50 rounded-xl flex items-center justify-center text-green-600">
                <i data-feather="check-circle" class="w-6 h-6"></i>
              </div>
              <div>
                <div class="text-sm font-medium text-slate-500">접수 완료</div>
                <div class="text-2xl font-bold text-slate-800">{{dashboard.receivedCount}}명</div>
              </div>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <!-- 시간대별 예약 현황 차트 -->
          <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
            <h2 class="text-lg font-bold text-slate-800 mb-6">시간대별 예약 및 접수 현황</h2>
            <div class="relative" style="height: 200px;">
              <svg viewBox="0 0 560 180" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
                <defs>
                  <linearGradient id="staffChartGrad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#6366f1" stop-opacity="0.3"/>
                    <stop offset="100%" stop-color="#6366f1" stop-opacity="0.02"/>
                  </linearGradient>
                </defs>
                <line x1="40" y1="20" x2="540" y2="20" stroke="#e2e8f0" stroke-width="1" stroke-dasharray="4,4"/>
                <line x1="40" y1="55" x2="540" y2="55" stroke="#e2e8f0" stroke-width="1" stroke-dasharray="4,4"/>
                <line x1="40" y1="90" x2="540" y2="90" stroke="#e2e8f0" stroke-width="1" stroke-dasharray="4,4"/>
                <line x1="40" y1="125" x2="540" y2="125" stroke="#e2e8f0" stroke-width="1" stroke-dasharray="4,4"/>
                <text x="30" y="24" text-anchor="end" fill="#94a3b8" font-size="10">16</text>
                <text x="30" y="59" text-anchor="end" fill="#94a3b8" font-size="10">12</text>
                <text x="30" y="94" text-anchor="end" fill="#94a3b8" font-size="10">8</text>
                <text x="30" y="129" text-anchor="end" fill="#94a3b8" font-size="10">4</text>
                <text x="30" y="160" text-anchor="end" fill="#94a3b8" font-size="10">0</text>
                <path d="M40,155 C80,145 120,60 180,45 C230,32 260,100 310,105 C360,110 390,35 440,30 C480,26 510,90 540,95 L540,155 L40,155 Z"
                      fill="url(#staffChartGrad)"/>
                <path d="M40,155 C80,145 120,60 180,45 C230,32 260,100 310,105 C360,110 390,35 440,30 C480,26 510,90 540,95"
                      fill="none" stroke="#6366f1" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                <text x="40"  y="172" text-anchor="middle" fill="#94a3b8" font-size="10">09:00</text>
                <text x="140" y="172" text-anchor="middle" fill="#94a3b8" font-size="10">10:00</text>
                <text x="240" y="172" text-anchor="middle" fill="#94a3b8" font-size="10">11:00</text>
                <text x="340" y="172" text-anchor="middle" fill="#94a3b8" font-size="10">13:00</text>
                <text x="440" y="172" text-anchor="middle" fill="#94a3b8" font-size="10">14:00</text>
                <text x="540" y="172" text-anchor="middle" fill="#94a3b8" font-size="10">16:00</text>
              </svg>
            </div>
          </div>

          <!-- 최근 예약 현황 -->
          <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
            <div class="flex justify-between items-center mb-4">
              <h2 class="text-lg font-bold text-slate-800">최근 예약 현황 미리보기</h2>
              <a href="/staff/reception/list" class="text-sm text-indigo-600 font-medium flex items-center gap-1 hover:text-indigo-800">
                전체보기 <i data-feather="arrow-right" class="w-4 h-4"></i>
              </a>
            </div>
            <div class="space-y-3">
              {{#dashboard.recentList}}
<a href="/staff/reception/detail?id={{id}}" class="flex items-center justify-between p-3 bg-slate-50 rounded-lg border border-slate-100 hover:bg-indigo-50 hover:border-indigo-200 transition-all cursor-pointer group">
  <div class="flex items-center gap-3">
    <div class="w-2 h-2 rounded-full bg-indigo-500"></div>
    <span class="font-medium text-slate-800 group-hover:text-indigo-700">{{patientName}}</span>
    <span class="text-sm text-slate-500">{{departmentName}} / {{timeSlot}}</span>
  </div>
  <span class="text-xs font-medium px-2 py-1 rounded-full {{statusBadgeClass}}">{{statusText}}</span>
</a>
{{/dashboard.recentList}}

{{^dashboard.recentList}}
<div class="p-4 text-center text-slate-500 bg-slate-50 rounded-xl border border-dashed border-slate-200">
  오늘 예약된 환자가 없습니다.
</div>
{{/dashboard.recentList}}
            </div>
          </div>
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>feather.replace();</script>
</body>
</html>
