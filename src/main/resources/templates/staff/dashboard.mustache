<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>원무과 대시보드</title>
    <link rel="stylesheet" href="/css/tailwind.min.css">
    <script src="/js/lucide.min.js"></script>
    <script src="/js/chart.min.js"></script>
</head>
<body class="bg-slate-50 min-h-screen p-6">
    <div class="max-w-7xl mx-auto space-y-6">
        <h1 class="text-2xl font-bold text-slate-800">원무과 대시보드</h1>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-indigo-50 rounded-xl flex items-center justify-center text-indigo-600">
                        <i data-lucide="users" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <div class="text-sm font-medium text-slate-500">오늘 총 예약</div>
                        <div class="text-2xl font-bold text-slate-800">15명</div>
                    </div>
                </div>
            </div>
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-orange-50 rounded-xl flex items-center justify-center text-orange-600">
                        <i data-lucide="calendar" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <div class="text-sm font-medium text-slate-500">접수 대기</div>
                        <div class="text-2xl font-bold text-slate-800">5명</div>
                    </div>
                </div>
            </div>
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-green-50 rounded-xl flex items-center justify-center text-green-600">
                        <i data-lucide="check-circle-2" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <div class="text-sm font-medium text-slate-500">접수 완료</div>
                        <div class="text-2xl font-bold text-slate-800">8명</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
                <h2 class="text-lg font-bold text-slate-800 mb-6">시간대별 예약 및 접수 현황</h2>
                <div class="h-64 relative w-full">
                    <canvas id="timeChart"></canvas>
                </div>
            </div>

            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
                <div class="flex justify-between items-center mb-4">
                    <h2 class="text-lg font-bold text-slate-800">최근 예약 현황 미리보기</h2>
                    <a href="reception-list.html" class="text-sm text-indigo-600 font-medium flex items-center gap-1 hover:text-indigo-800">
                        전체보기 <i data-lucide="arrow-right" class="w-4 h-4"></i>
                    </a>
                </div>
                <div class="space-y-3">
                    <div class="flex items-center justify-between p-3 bg-slate-50 rounded-lg border border-slate-100">
                        <div class="flex items-center gap-3">
                            <div class="w-2 h-2 rounded-full bg-indigo-500"></div>
                            <span class="font-medium text-slate-800">홍길동</span>
                            <span class="text-sm text-slate-500">내과 / 09:00</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="text-xs font-medium px-2 py-1 rounded-full bg-indigo-100 text-indigo-800">
                                예약
                            </span>
                            <form action="/staff/reception/process" method="POST" class="inline">
                                <input type="hidden" name="reservationId" value="1">
                                <button type="submit" class="text-xs font-medium px-3 py-1 bg-indigo-600 text-white rounded-full hover:bg-indigo-700 transition-colors">
                                    접수하기
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        lucide.createIcons();

        // 차트 초기화 (서버에서 데이터 주입)
        const ctx = document.getElementById('timeChart').getContext('2d');
        const labels = ["09:00","10:00","11:00","14:00","15:00"];
        const reservationData = [5, 8, 6, 4, 3];
        const receptionData = [4, 7, 5, 3, 2];

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: '예약',
                        data: reservationData,
                        backgroundColor: '#818cf8',
                        borderRadius: 4,
                        barPercentage: 0.6,
                        categoryPercentage: 0.8
                    },
                    {
                        label: '접수',
                        data: receptionData,
                        backgroundColor: '#34d399',
                        borderRadius: 4,
                        barPercentage: 0.6,
                        categoryPercentage: 0.8
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'top', labels: { usePointStyle: true, boxWidth: 8 } }
                },
                scales: {
                    x: { grid: { display: false, drawBorder: false }, ticks: { color: '#64748b', font: { size: 12 } } },
                    y: { grid: { color: '#e2e8f0', drawBorder: false, borderDash: [3, 3] }, ticks: { color: '#64748b', font: { size: 12 } } }
                }
            }
        });
    </script>
</body>
</html>