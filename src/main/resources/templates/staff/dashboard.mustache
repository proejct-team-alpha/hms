</head>
<body>
  
  {{> components/sidebar}}

  <div class="main-content">
    {{> components/header}}
    
    <main class="content-wrapper">
      <div class="space-y-6 max-w-5xl mx-auto">
        <h1 class="text-2xl font-bold text-slate-800">원무과 대시보드</h1>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-indigo-50 rounded-xl flex items-center justify-center text-indigo-600">
                <i data-feather="users" class="w-6 h-6"></i>
              </div>
              <div>
                <div class="text-sm font-medium text-slate-500">오늘 총 예약</div>
                <div class="text-2xl font-bold text-slate-800">{{totalReservations}}명</div>
              </div>
            </div>
          </div>
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-orange-50 rounded-xl flex items-center justify-center text-orange-600">
                <i data-feather="calendar" class="w-6 h-6"></i>
              </div>
              <div>
                <div class="text-sm font-medium text-slate-500">접수 대기</div>
                <div class="text-2xl font-bold text-slate-800">{{waitingReservations}}명</div>
              </div>
            </div>
          </div>
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-green-50 rounded-xl flex items-center justify-center text-green-600">
                <i data-feather="check-circle" class="w-6 h-6"></i>
              </div>
              <div>
                <div class="text-sm font-medium text-slate-500">접수 완료</div>
                <div class="text-2xl font-bold text-slate-800">{{completedReservations}}명</div>
              </div>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
            <h2 class="text-lg font-bold text-slate-800 mb-6">시간대별 예약 및 접수 현황</h2>
            <div class="h-64 flex items-center justify-center bg-slate-50 border border-slate-100 rounded-xl">
              <span class="text-slate-400 text-sm">차트 영역</span>
            </div>
          </div>

          <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
            <div class="flex justify-between items-center mb-4">
              <h2 class="text-lg font-bold text-slate-800">최근 예약 현황 미리보기</h2>
              <a href="/receptions" class="text-sm text-indigo-600 font-medium flex items-center gap-1 hover:text-indigo-800">
                전체보기 <i data-feather="arrow-right" class="w-4 h-4"></i>
              </a>
            </div>
            
            <div class="space-y-3">
              {{#recentReservations}}
              <div class="flex items-center justify-between p-3 bg-slate-50 rounded-lg border border-slate-100">
                <div class="flex items-center gap-3">
                  <div class="w-2 h-2 rounded-full {{#isReserved}}bg-orange-500{{/isReserved}}{{#isReceived}}bg-green-500{{/isReceived}}{{#isInProgress}}bg-purple-500{{/isInProgress}}{{#isCompleted}}bg-blue-500{{/isCompleted}}"></div>
                  <span class="font-medium text-slate-800">{{name}}</span>
                  <span class="text-sm text-slate-500">{{dept}} / {{time}}</span>
                </div>
                <div class="flex items-center gap-2">
                  <span class="text-xs font-medium px-2 py-1 rounded-full {{#isReserved}}bg-orange-100 text-orange-700{{/isReserved}}{{#isReceived}}bg-green-100 text-green-700{{/isReceived}}{{#isInProgress}}bg-purple-100 text-purple-700{{/isInProgress}}{{#isCompleted}}bg-blue-100 text-blue-700{{/isCompleted}}">
                    {{statusText}}
                  </span>
                  {{#isReserved}}
                  <form action="/receptions/{{id}}/receive" method="POST" class="inline m-0">
                    <button type="submit" class="text-xs font-medium px-3 py-1 bg-indigo-600 text-white rounded-full hover:bg-indigo-700 transition-colors">접수하기</button>
                  </form>
                  {{/isReserved}}
                </div>
              </div>
              {{/recentReservations}}
              
              {{^recentReservations}}
              <div class="p-4 text-center text-slate-500">최근 예약이 없습니다.</div>
              {{/recentReservations}}
            </div>
          </div>
        </div>
      </div>
    </main>

    {{> components/footer}}
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      feather.replace();
    });
  </script>
</body>
</html>