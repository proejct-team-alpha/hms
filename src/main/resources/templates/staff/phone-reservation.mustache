<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>전화 예약 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/flatpickr.min.css">
  <script src="/js/feather.min.js"></script>
  <script src="/js/flatpickr.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-staff}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="max-w-2xl mx-auto">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
          <div class="flex items-center gap-3 mb-8">
            <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center text-purple-600">
              <i data-feather="phone-call" class="w-6 h-6"></i>
            </div>
            <div>
              <h1 class="text-2xl font-bold text-slate-800">전화 예약 등록</h1>
              <p class="text-slate-500 mt-1">전화로 인입된 환자의 예약을 등록합니다.</p>
            </div>
          </div>



          <form method="post" action="/staff/reservation/create" class="space-y-6">
            <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">환자 성함</label>
                <div class="relative">
                  <i data-feather="user" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                  <input type="text" name="name" required class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none" placeholder="홍길동" value="{{#form}}{{name}}{{/form}}" />
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">연락처</label>
                <div class="relative">
                  <i data-feather="phone" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                  <input type="tel" name="phone" pattern="\d{3}-\d{4}-\d{4}" maxlength="13" required class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none" placeholder="010-1234-5678" value="{{#form}}{{phone}}{{/form}}" />
                </div>
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-slate-700 mb-2">이메일 (선택)</label>
              <div class="relative">
                <i data-feather="mail" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                <input type="email" name="email" class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none" placeholder="example@email.com" value="{{#form}}{{email}}{{/form}}" />
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">진료과</label>
                <select name="departmentId" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none bg-white">
                  <option value="">선택해주세요</option>
                  {{#departments}}
                  <option value="{{id}}">{{name}}</option>
                  {{/departments}}
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">전문의</label>
                <select name="doctorId" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none bg-white">
                  <option value="">선택해주세요</option>
                  {{#doctors}}
                  <option value="{{id}}" data-dept-id="{{departmentId}}" data-available-days="{{availableDays}}">{{displayName}}</option>
                  {{/doctors}}
                </select>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">예약 날짜</label>
                <div class="relative">
                  <i data-feather="calendar" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                  <input type="text" name="date" id="dateInput" required readonly placeholder="날짜 선택 (의사 선택 후)" class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none" />
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">예약 시간</label>
                <div class="relative">
                  <i data-feather="clock" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                  <select name="time" id="timeSelect" required class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none bg-white">
                    <option value="">선택해주세요</option>
                    <optgroup label="오전">
                      <option value="09:00">09:00</option>
                      <option value="09:30">09:30</option>
                      <option value="10:00">10:00</option>
                      <option value="10:30">10:30</option>
                      <option value="11:00">11:00</option>
                      <option value="11:30">11:30</option>
                    </optgroup>
                    <optgroup label="오후">
                      <option value="14:00">14:00</option>
                      <option value="14:30">14:30</option>
                      <option value="15:00">15:00</option>
                      <option value="15:30">15:30</option>
                      <option value="16:00">16:00</option>
                      <option value="16:30">16:30</option>
                      <option value="17:00">17:00</option>
                      <option value="17:30">17:30</option>
                    </optgroup>
                  </select>
                </div>
              </div>
            </div>

            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">증상</label>
                <textarea name="symptoms" class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none min-h-24 resize-none" placeholder="환자가 호소하는 주요 증상을 입력하세요.">{{#form}}{{symptoms}}{{/form}}</textarea>
              </div>
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">메모 (특이사항)</label>
                <textarea name="notes" class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none min-h-20 resize-none" placeholder="기타 참고할 메모 사항을 입력하세요.">{{#form}}{{notes}}{{/form}}</textarea>
              </div>
            </div>

            <div class="pt-6 border-t border-slate-200">
              <button type="submit" class="w-full py-4 bg-purple-600 text-white rounded-xl font-medium text-lg hover:bg-purple-700 transition-colors shadow-sm">
                예약 등록하기
              </button>
            </div>
          </form>
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>feather.replace();</script>
  {{#message}}
  <script>alert("{{message}}");</script>
  {{/message}}
  <script>
    (async function () {
      const deptSelect = document.querySelector('select[name="departmentId"]');
      const docSelect  = document.querySelector('select[name="doctorId"]');
      const dateInput  = document.getElementById('dateInput');
      const timeSelect = document.getElementById('timeSelect');
      const docOptions = Array.from(docSelect.querySelectorAll('option[data-dept-id]'));

      const DAY_MAP = { SUN: 0, MON: 1, TUE: 2, WED: 3, THU: 4, FRI: 5, SAT: 6 };

      // 진료과 → 의사 필터
      function filterDoctorsOnly() {
        const deptId = deptSelect.value;
        docOptions.forEach(function(opt) {
          opt.style.display = (!deptId || opt.dataset.deptId === deptId) ? '' : 'none';
        });
        if (docSelect.options[docSelect.selectedIndex] &&
            docSelect.options[docSelect.selectedIndex].style.display === 'none') {
          docSelect.value = '';
        }
      }

      // booked-slots API 호출 → 예약 불가 시간 비활성화
      async function refreshTimeSlots() {
        const doctorId = docSelect.value;
        const date     = dateInput.value;
        const opts     = Array.from(timeSelect.querySelectorAll('option[value]'));
        opts.forEach(function(opt) {
          opt.disabled = false;
          opt.textContent = opt.value;
        });
        if (!doctorId || !date) return;
        try {
          const res    = await fetch('/api/reservation/booked-slots?doctorId=' + doctorId + '&date=' + date);
          const booked = await res.json();
          opts.forEach(function(opt) {
            if (booked.includes(opt.value)) {
              opt.disabled = true;
              opt.textContent = opt.value + ' (예약불가)';
              if (timeSelect.value === opt.value) timeSelect.value = '';
            }
          });
        } catch (e) {}
      }

      // Flatpickr 초기화 (의사 선택 전: 전체 날짜 비활성)
      const datePicker = flatpickr(dateInput, {
        dateFormat: 'Y-m-d',
        minDate: 'today',
        animate: false,
        disable: [function() { return true; }],
        onChange: function() { refreshTimeSlots(); }
      });

      // 의사 availableDays → Flatpickr 갱신
      function applyDoctorAvailableDays() {
        const selectedOption   = docSelect.options[docSelect.selectedIndex];
        const availableDaysStr = (selectedOption && selectedOption.dataset.availableDays) || '';
        const availableDayNums = availableDaysStr
          .split(',')
          .map(function(d) { return DAY_MAP[d.trim()]; })
          .filter(function(n) { return n !== undefined; });

        datePicker.clear();
        if (availableDayNums.length > 0) {
          datePicker.set('disable', [
            function(date) { return !availableDayNums.includes(date.getDay()); }
          ]);
        } else {
          datePicker.set('disable', [function() { return true; }]);
        }
        // 시간 슬롯 초기화
        Array.from(timeSelect.querySelectorAll('option[value]')).forEach(function(opt) {
          opt.disabled = false;
          opt.textContent = opt.value;
        });
        timeSelect.value = '';
      }

      deptSelect.addEventListener('change', function() { filterDoctorsOnly(); applyDoctorAvailableDays(); });
      docSelect.addEventListener('change', function() { applyDoctorAvailableDays(); refreshTimeSlots(); });

      // 폼 오류 복원
      const restoreDeptId = '{{#form}}{{departmentId}}{{/form}}';
      const restoreDocId  = '{{#form}}{{doctorId}}{{/form}}';
      const restoreDate   = '{{#form}}{{date}}{{/form}}';
      const restoreTime   = '{{#form}}{{time}}{{/form}}';

      if (restoreDeptId) deptSelect.value = restoreDeptId;
      filterDoctorsOnly();
      if (restoreDocId) docSelect.value = restoreDocId;
      applyDoctorAvailableDays();
      if (restoreDate) datePicker.setDate(restoreDate);
      await refreshTimeSlots();
      if (restoreTime) timeSelect.value = restoreTime;
    })();
  </script>
</body>
</html>
