<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>전화 예약 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/flatpickr.min.css">
  <script src="/js/feather.min.js"></script>
  <script src="/js/flatpickr.min.js"></script>
  <style>
    .split-input { text-align: center; padding: 0.75rem 0.5rem !important; }
  </style>
</head>
<body class="min-h-screen flex bg-[#f8fafc]">
  {{> common/sidebar-staff}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="max-w-5xl mx-auto">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-10">
          
          <div class="flex items-center justify-between mb-10 pb-6 border-b border-slate-100">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center text-purple-600">
                <i data-feather="phone-call" class="w-6 h-6"></i>
              </div>
              <div>
                <h1 class="text-2xl font-bold text-slate-800">예약</h1>
                <p class="text-slate-500 mt-1 text-sm">환자의 예약 정보를 등록합니다.</p>
              </div>
            </div>
            <a href="/staff/reception/list" class="text-sm font-medium text-slate-500 hover:text-slate-700 flex items-center gap-1 transition-colors">
              <i data-feather="arrow-left" class="w-4 h-4"></i>
              목록으로 돌아가기
            </a>
          </div>

          <form method="post" action="/staff/reservation/create" class="space-y-10">
            <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">

            <!-- [디자인 수정] 단 사이 간격을 60px로 조정하여 적절한 여백 확보 -->
            <div class="flex flex-col md:flex-row" style="column-gap: 60px;">
              
              <!-- 왼쪽 단: 환자 기본 정보 -->
              <div class="flex-1 space-y-6">
                <div class="flex items-center gap-2 mb-4 text-purple-600">
                  <i data-feather="user" class="w-4 h-4"></i>
                  <h3 class="text-xs font-bold uppercase tracking-widest">환자 기본 정보</h3>
                </div>

                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2 ml-1">이름</label>
                  <div class="relative">
                    <i data-feather="user" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
                    <input type="text" name="name" required class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-purple-500 outline-none text-sm" placeholder="홍길동" value="{{#form}}{{name}}{{/form}}" />
                  </div>
                </div>

                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2 ml-1">연락처</label>
                  <div class="flex items-center gap-1.5">
                    <input type="text" id="phone1" maxlength="3" class="split-input w-16 border border-slate-300 rounded-xl outline-none focus:ring-2 focus:ring-purple-500 text-sm" placeholder="010" required />
                    <span class="text-slate-400 font-bold">-</span>
                    <input type="text" id="phone2" maxlength="4" class="split-input w-20 border border-slate-300 rounded-xl outline-none focus:ring-2 focus:ring-purple-500 text-sm" placeholder="1234" required />
                    <span class="text-slate-400 font-bold">-</span>
                    <input type="text" id="phone3" maxlength="4" class="split-input w-20 border border-slate-300 rounded-xl outline-none focus:ring-2 focus:ring-purple-500 text-sm" placeholder="5678" required />
                    <input type="hidden" name="phone" id="finalPhone" value="{{#form}}{{phone}}{{/form}}">
                  </div>
                </div>

                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2 ml-1">주민번호 (선택)</label>
                  <div class="flex items-center gap-1.5">
                    <input type="text" id="birthDate" maxlength="6" class="split-input w-20 border border-slate-300 rounded-xl outline-none focus:ring-2 focus:ring-purple-500 text-sm" placeholder="940101" />
                    <span class="text-slate-400 font-bold">-</span>
                    <div class="flex items-center gap-1">
                      <input type="text" id="genderDigit" maxlength="1" class="split-input w-10 border border-slate-300 rounded-xl outline-none focus:ring-2 focus:ring-purple-500 text-sm" placeholder="1" />
                      <span class="text-slate-400 font-bold tracking-widest ml-1 text-sm">******</span>
                    </div>
                    <input type="hidden" name="birthInfo" id="finalBirthInfo">
                  </div>
                </div>
              </div>

              <!-- 오른쪽 단: 예약 정보 설정 -->
              <div class="flex-1 space-y-6">
                <div class="flex items-center gap-2 mb-4 text-purple-600">
                  <i data-feather="calendar" class="w-4 h-4"></i>
                  <h3 class="text-xs font-bold uppercase tracking-widest">예약 정보 설정</h3>
                </div>

                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2 ml-1">진료과</label>
                    <select name="departmentId" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-purple-500 outline-none bg-white text-sm">
                      <option value="">선택해주세요</option>
                      {{#departments}}
                      <option value="{{id}}">{{name}}</option>
                      {{/departments}}
                    </select>
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2 ml-1">전문의</label>
                    <select name="doctorId" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-purple-500 outline-none bg-white text-sm">
                      <option value="">선택해주세요</option>
                      {{#doctors}}
                      <option value="{{id}}" data-dept-id="{{departmentId}}" data-available-days="{{availableDays}}">{{displayName}}</option>
                      {{/doctors}}
                    </select>
                  </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2 ml-1">예약 날짜</label>
                    <div class="relative">
                      <i data-feather="calendar" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
                      <input type="text" name="date" id="dateInput" required readonly placeholder="날짜 선택" class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-purple-500 outline-none text-sm" />
                    </div>
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2 ml-1">예약 시간</label>
                    <div class="relative">
                      <i data-feather="clock" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
                      <select name="time" id="timeSelect" required class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-purple-500 outline-none bg-white text-sm">
                        <option value="">선택해주세요</option>
                        <optgroup label="오전">
                          <option value="09:00">09:00</option><option value="09:30">09:30</option><option value="10:00">10:00</option>
                          <option value="10:30">10:30</option><option value="11:00">11:00</option><option value="11:30">11:30</option>
                        </optgroup>
                        <optgroup label="오후">
                          <option value="14:00">14:00</option><option value="14:30">14:30</option><option value="15:00">15:00</option>
                          <option value="15:30">15:30</option><option value="16:00">16:00</option><option value="16:30">16:30</option>
                          <option value="17:00">17:00</option><option value="17:30">17:30</option>
                        </optgroup>
                      </select>
                    </div>
                  </div>
                </div>

                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2 ml-1">예약 사유</label>
                  <input type="text" name="visitReason" class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-purple-500 outline-none text-sm" placeholder="감기, 건강검진 등" value="{{#form}}{{visitReason}}{{/form}}" />
                </div>
              </div>
            </div>

            <div class="pt-6">
              <label class="block text-sm font-medium text-slate-700 mb-2 ml-1">특이사항 및 메모</label>
              <textarea name="notes" class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-purple-500 outline-none h-32 resize-none text-sm" placeholder="환자의 특이사항이나 메모를 입력하세요.">{{#form}}{{notes}}{{/form}}</textarea>
            </div>

            <div class="pt-8 flex justify-end">
              <button type="submit" class="w-full md:w-72 py-4 bg-purple-600 text-white rounded-xl font-bold text-lg hover:bg-purple-700 transition-all shadow-lg active:scale-[0.98]">
                등록
              </button>
            </div>
          </form>
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>feather.replace();</script>
  {{#message}}<script>alert("{{message}}");</script>{{/message}}
  
  <script>
    (async function () {
      const deptSelect = document.querySelector('select[name="departmentId"]');
      const docSelect  = document.querySelector('select[name="doctorId"]');
      const dateInput  = document.getElementById('dateInput');
      const timeSelect = document.getElementById('timeSelect');
      const docOptions = Array.from(docSelect.querySelectorAll('option[data-dept-id]'));
      const DAY_MAP = { SUN: 0, MON: 1, TUE: 2, WED: 3, THU: 4, FRI: 5, SAT: 6 };

      function filterDoctorsOnly() {
        const deptId = deptSelect.value;
        docOptions.forEach(opt => opt.style.display = (!deptId || opt.dataset.deptId === deptId) ? '' : 'none');
        if (docSelect.options[docSelect.selectedIndex] && docSelect.options[docSelect.selectedIndex].style.display === 'none') docSelect.value = '';
      }

      async function refreshTimeSlots() {
        const doctorId = docSelect.value;
        const date = dateInput.value;
        const opts = Array.from(timeSelect.querySelectorAll('option[value]'));
        opts.forEach(opt => { opt.disabled = false; opt.textContent = opt.value; });
        if (!doctorId || !date) return;
        try {
          const res = await fetch('/api/reservation/booked-slots?doctorId=' + doctorId + '&date=' + date);
          if (!res.ok) throw new Error();
          const booked = await res.json();
          opts.forEach(opt => { if (booked.includes(opt.value)) { opt.disabled = true; opt.textContent = opt.value + ' (불가)'; } });
          const today = new Date().toISOString().slice(0, 10);
          if (date === today) {
            const now = new Date();
            const currentTime = now.getHours() * 60 + now.getMinutes();
            opts.forEach(opt => {
              const [h, m] = opt.value.split(':').map(Number);
              if (h * 60 + m <= currentTime) { opt.disabled = true; opt.textContent = opt.value + ' (마감)'; }
            });
          }
          timeSelect.value = '';
          const first = opts.find(opt => !opt.disabled && opt.value);
          if (first) timeSelect.value = first.value;
        } catch (e) { console.error('슬롯 조회 실패'); }
      }

      const datePicker = flatpickr(dateInput, {
        dateFormat: 'Y-m-d', minDate: 'today', animate: false,
        disable: [function() { return true; }],
        onChange: function() { refreshTimeSlots(); }
      });

      async function applyDoctorAvailableDays(autoSelect = false) {
        const selected = docSelect.options[docSelect.selectedIndex];
        if (!selected || !selected.value) { datePicker.set('disable', [() => true]); datePicker.clear(); return; }
        const days = (selected.dataset.availableDays || '').split(',').map(d => DAY_MAP[d.trim()]).filter(n => n !== undefined);
        if (days.length > 0) {
          datePicker.set('disable', [d => !days.includes(d.getDay())]);
          if (autoSelect) {
            let d = new Date();
            for (let i = 0; i < 30; i++) {
              if (days.includes(d.getDay())) { datePicker.setDate(new Date(d), true); break; }
              d.setDate(d.getDate() + 1);
            }
          }
        }
      }

      deptSelect.addEventListener('change', () => { filterDoctorsOnly(); applyDoctorAvailableDays(true); });
      docSelect.addEventListener('change', () => applyDoctorAvailableDays(true));

      const restoreDeptId = '{{#form}}{{departmentId}}{{/form}}', restoreDocId = '{{#form}}{{doctorId}}{{/form}}';
      const restoreDate = '{{#form}}{{date}}{{/form}}', restoreTime = '{{#form}}{{time}}{{/form}}';
      if (restoreDeptId) { deptSelect.value = restoreDeptId; filterDoctorsOnly(); }
      if (restoreDocId) { docSelect.value = restoreDocId; applyDoctorAvailableDays(); }
      if (restoreDate) datePicker.setDate(restoreDate);
      await refreshTimeSlots();
      if (restoreTime) timeSelect.value = restoreTime;
    })();

    (function() {
      const p1 = document.getElementById('phone1'), p2 = document.getElementById('phone2'), p3 = document.getElementById('phone3'), final = document.getElementById('finalPhone');
      const bDate = document.getElementById('birthDate'), gDigit = document.getElementById('genderDigit'), finalBirth = document.getElementById('finalBirthInfo');
      const initVal = final.value.replace(/-/g, '');
      if (initVal.length >= 3) p1.value = initVal.slice(0, 3);
      if (initVal.length >= 7) p2.value = initVal.slice(3, 7);
      if (initVal.length >= 11) p3.value = initVal.slice(7, 11);
      function update() {
        final.value = (p1.value && p2.value && p3.value) ? `${p1.value}-${p2.value}-${p3.value}` : '';
        finalBirth.value = (bDate.value && gDigit.value) ? `${bDate.value}-${gDigit.value}` : '';
      }
      [p1,p2,p3,bDate,gDigit].forEach(el => el.addEventListener('input', update));
      p1.addEventListener('input', () => { if (p1.value.length >= 3) p2.focus(); });
      p2.addEventListener('input', () => { if (p2.value.length >= 4) p3.focus(); });
      bDate.addEventListener('input', () => { if (bDate.value.length >= 6) gDigit.focus(); });
    })();
  </script>
</body>
</html>
