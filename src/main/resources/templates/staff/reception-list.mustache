<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>예약 환자 목록 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-staff}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="space-y-5 max-w-6xl mx-auto">

        {{! 헤더 }}
        <div class="flex justify-between items-center">
          <div>
            <h1 class="text-2xl font-bold text-slate-800">예약 환자 목록</h1>
            <p class="text-sm text-slate-500 mt-0.5">총 {{totalCount}}건</p>
          </div>
          <div class="flex gap-3">
            <a href="/staff/walkin-reception" class="px-4 py-2 bg-indigo-50 text-indigo-700 font-medium rounded-lg hover:bg-indigo-100 transition-colors">
              방문 접수
            </a>
            <a href="/staff/reservation/phone-reservation" class="px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 transition-colors">
              전화 예약
            </a>
          </div>
        </div>

        {{! 상단 검색/날짜 툴바 }}
        <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-200">
          <form id="filter-form" action="/staff/reception/list" method="get" class="space-y-5">
            <input type="hidden" name="status" value="{{currentStatus}}">
            
            <div class="flex flex-col lg:flex-row lg:items-center gap-5">
              {{! 날짜 컨트롤 영역: 고정 크기 유지하여 정렬 안정성 확보 }}
              <div class="flex items-center bg-slate-50 border border-slate-200 rounded-xl p-1.5 shadow-sm shrink-0 w-fit">
                {{#hasDate}}
                <a href="/staff/reception/list?date={{prevDate}}&status={{currentStatus}}&query={{query}}&deptId={{#deptId}}{{deptId}}{{/deptId}}&doctorId={{#doctorId}}{{doctorId}}{{/doctorId}}&source={{#source}}{{source}}{{/source}}" 
                   class="p-1.5 text-slate-400 hover:text-indigo-600 hover:bg-white rounded-lg transition-all">
                  <i data-feather="chevron-left" class="w-4 h-4"></i>
                </a>
                {{/hasDate}}
                
                <input type="date" id="date" name="date" value="{{currentDate}}" 
                       onchange="this.form.submit()"
                       class="bg-transparent border-none text-sm font-bold text-slate-700 focus:ring-0 cursor-pointer px-3 py-1 w-40">

                {{#hasDate}}
                <a href="/staff/reception/list?date={{nextDate}}&status={{currentStatus}}&query={{query}}&deptId={{#deptId}}{{deptId}}{{/deptId}}&doctorId={{#doctorId}}{{doctorId}}{{/doctorId}}&source={{#source}}{{source}}{{/source}}" 
                   class="p-1.5 text-slate-400 hover:text-indigo-600 hover:bg-white rounded-lg transition-all">
                  <i data-feather="chevron-right" class="w-4 h-4"></i>
                </a>
                {{/hasDate}}

                <div class="w-px h-4 bg-slate-200 mx-2"></div>
                
                <div class="flex">
                  {{#hasDate}}
                  <a href="/staff/reception/list?status={{currentStatus}}&query={{query}}&deptId={{#deptId}}{{deptId}}{{/deptId}}&doctorId={{#doctorId}}{{doctorId}}{{/doctorId}}&source={{#source}}{{source}}{{/source}}" 
                     class="px-4 py-1.5 text-xs font-bold text-slate-500 hover:text-indigo-600 hover:bg-white rounded-lg transition-all">전체</a>
                  {{/hasDate}}
                  {{^hasDate}}
                  <a href="/staff/reception/list?date={{todayDate}}&status={{currentStatus}}&query={{query}}&deptId={{#deptId}}{{deptId}}{{/deptId}}&doctorId={{#doctorId}}{{doctorId}}{{/doctorId}}&source={{#source}}{{source}}{{/source}}" 
                     class="px-4 py-1.5 text-xs font-bold text-indigo-600 bg-white rounded-lg shadow-sm">오늘</a>
                  {{/hasDate}}
                </div>
              </div>

              {{! 검색 컨트롤 영역: 유연하게 늘어나되 너무 벌어지지 않게 제한 }}
              <div class="flex-1 flex items-center gap-3">
                <div class="relative flex-1 group min-w-[200px]">
                  <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                    <i data-feather="search" class="w-4 h-4 text-slate-400 group-focus-within:text-indigo-500 transition-colors"></i>
                  </div>
                  <input type="text" name="query" value="{{query}}" placeholder="  환자명, 연락처 검색" 
                         class="w-full pl-14 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all shadow-sm">
                </div>
                <div class="flex items-center gap-2 shrink-0">
                  <button type="submit" class="px-6 py-3 bg-indigo-600 text-white text-sm font-bold rounded-xl hover:bg-indigo-700 transition-all shadow-sm hover:shadow-md">
                    검색
                  </button>
                  <button type="button" id="btn-toggle-filter" class="p-3 bg-white border border-slate-200 text-slate-600 rounded-xl hover:bg-slate-50 transition-all shadow-sm flex items-center gap-2">
                    <i data-feather="sliders" class="w-4 h-4"></i>
                    <span class="text-xs font-bold hidden sm:inline">필터</span>
                  </button>
                  <a href="/staff/reception/list" class="p-3 text-slate-400 hover:text-slate-600 hover:bg-slate-100 rounded-xl transition-all" title="초기화">
                    <i data-feather="refresh-cw" class="w-4 h-4"></i>
                  </a>
                </div>
              </div>
            </div>

            {{! 상세 필터 패널 (기본 숨김) }}
            <div id="filter-panel" class="hidden grid grid-cols-1 md:grid-cols-3 gap-4 p-4 bg-slate-50 rounded-xl border border-slate-100 shadow-inner">
              <div class="space-y-1.5">
                <label class="text-xs font-bold text-slate-500 ml-1">진료과</label>
                <select name="deptId" onchange="this.form.submit()" class="w-full bg-white border border-slate-200 rounded-lg text-sm px-3 py-2 outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all">
                  <option value="">전체 진료과</option>
                  {{#departments}}
                  <option value="{{id}}" {{#selected}}selected{{/selected}}>{{name}}</option>
                  {{/departments}}
                </select>
              </div>
              <div class="space-y-1.5">
                <label class="text-xs font-bold text-slate-500 ml-1">전문의</label>
                <select name="doctorId" onchange="this.form.submit()" class="w-full bg-white border border-slate-200 rounded-lg text-sm px-3 py-2 outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all">
                  <option value="">전체 전문의</option>
                  {{#doctors}}
                  <option value="{{id}}" {{#selected}}selected{{/selected}}>{{name}}</option>
                  {{/doctors}}
                </select>
              </div>
              <div class="space-y-1.5">
                <label class="text-xs font-bold text-slate-500 ml-1">예약 구분</label>
                <select name="source" onchange="this.form.submit()" class="w-full bg-white border border-slate-200 rounded-lg text-sm px-3 py-2 outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all">
                  <option value="">전체 구분</option>
                  {{#sources}}
                  <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                  {{/sources}}
                </select>
              </div>
            </div>
          </form>
        </div>

        {{#message}}
        <div class="p-4 bg-green-50 border border-green-200 text-green-800 rounded-xl text-sm">{{message}}</div>
        {{/message}}

        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
          {{! 상태 필터 탭 (원래대로 복구) }}
          <div class="p-4 border-b border-slate-200 flex gap-2 bg-slate-50">
            {{#filters}}
            <a href="{{href}}" class="{{cssClass}} transition-colors">{{label}}</a>
            {{/filters}}
          </div>
          
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-200 text-xs uppercase tracking-wider text-slate-500">
                <th class="p-4 font-medium">날짜</th>
                <th class="p-4 font-medium">시간</th>
                <th class="p-4 font-medium">환자명</th>
                <th class="p-4 font-medium">연락처</th>
                <th class="p-4 font-medium">예약 구분</th>
                <th class="p-4 font-medium">진료과</th>
                <th class="p-4 font-medium">전문의</th>
                <th class="p-4 font-medium text-center">상태</th>
                <th class="p-4 font-medium text-center">비고</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200">
              {{#reservations}}
              <tr class="hover:bg-slate-50 transition-colors cursor-pointer" onclick="location.href='/staff/reception/detail?id={{id}}&date={{#hasDate}}{{currentDate}}{{/hasDate}}&status={{currentStatus}}&page={{currentPage}}'">
                <td class="p-4 text-sm text-slate-600">{{reservationDate}}</td>
                <td class="p-4 text-sm font-medium text-slate-900">{{timeSlot}}</td>
                <td class="p-4 text-sm font-semibold text-slate-800">
                  <div class="flex items-center gap-2">
                    {{#isFirstVisit}}
                    <span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-[10px] font-medium bg-slate-100 text-slate-500 shrink-0">초</span>
                    {{/isFirstVisit}}
                    {{^isFirstVisit}}
                    <span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-[10px] font-medium bg-slate-100 text-slate-500 shrink-0">재</span>
                    {{/isFirstVisit}}
                    {{patientName}}
                  </div>
                </td>
                <td class="p-4 text-sm text-slate-600">{{patientPhone}}</td>
                <td class="p-4">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium {{sourceBadgeClass}}">
                    {{sourceText}}
                  </span>
                </td>
                <td class="p-4 text-sm text-slate-600">{{departmentName}}</td>
                <td class="p-4 text-sm text-slate-600">{{doctorName}}</td>
                <td class="p-4">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium {{statusBadgeClass}}">
                    {{statusText}}
                  </span>
                </td>
                <td class="p-4 text-right">
                  <div class="flex justify-end gap-2" onclick="event.stopPropagation()">
                    {{#cancellationReason}}
                    <span class="text-xs text-red-500 italic bg-red-50 px-2 py-1 rounded-md border border-red-100 max-w-[150px] truncate" title="{{cancellationReason}}">
                      사유: {{cancellationReason}}
                    </span>
                    {{/cancellationReason}}
                    
                    {{#canReceive}}
                    
                    <a href="/staff/walkin-reception?reservationId={{id}}&name={{patientName}}&phone={{patientPhone}}&deptId={{departmentId}}&doctorId={{doctorId}}"
                       class="inline-flex items-center gap-1 px-3 py-1.5 bg-green-50 text-green-600 hover:bg-green-100 text-sm font-medium rounded-lg transition">
                      <i data-feather="check-circle" class="w-3.5 h-3.5"></i> 접수
                    </a>

                    {{/canReceive}}

                    {{#canCancel}}
                    
                    <button 
  type="button"
  onclick="cancelAjax({{id}}, this, '{{currentStatus}}')"
  class="inline-flex items-center gap-1 px-3 py-1.5 bg-red-50 text-red-600 hover:bg-red-100 text-sm font-medium rounded-lg transition">
  <i data-feather="x-circle" class="w-3.5 h-3.5"></i> 취소
</button>

                    {{/canCancel}}
                  </div>
                </td>
              </tr>
              {{/reservations}}
              {{^reservations}}
              <tr>
                <td colspan="9" class="p-8 text-center text-slate-500">
                  {{selectedDate}} 예약된 환자가 없습니다.
                </td>
              </tr>
              {{/reservations}}
            </tbody>
          </table>

          {{! 페이징 }}
          <div class="px-4 py-3 border-t border-slate-200 bg-slate-50 flex items-center justify-between">
            <span class="text-sm text-slate-500">{{pageInfo}} 페이지</span>
            <div class="flex gap-2">
              {{#hasPrev}}
              <a href="{{prevPageUrl}}" class="inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-slate-600 bg-white border border-slate-300 rounded-lg hover:bg-slate-100 transition-colors">
                <i data-feather="chevron-left" class="w-4 h-4"></i> 이전
              </a>
              {{/hasPrev}}
              {{^hasPrev}}
              <span class="inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-slate-300 bg-white border border-slate-200 rounded-lg cursor-not-allowed">
                <i data-feather="chevron-left" class="w-4 h-4"></i> 이전
              </span>
              {{/hasPrev}}
              {{#hasNext}}
              <a href="{{nextPageUrl}}" class="inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-slate-600 bg-white border border-slate-300 rounded-lg hover:bg-slate-100 transition-colors">
                다음 <i data-feather="chevron-right" class="w-4 h-4"></i>
              </a>
              {{/hasNext}}
              {{^hasNext}}
              <span class="inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-slate-300 bg-white border border-slate-200 rounded-lg cursor-not-allowed">
                다음 <i data-feather="chevron-right" class="w-4 h-4"></i>
              </span>
              {{/hasNext}}
            </div>
          </div>
        </div>

      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>
feather.replace();

async function receiveAjax(reservationId, button, currentStatus) {
  try {
    const response = await fetch('/staff/reception/receive-ajax', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-TOKEN': '{{_csrf.token}}'
      },
      body: JSON.stringify({
        reservationId: reservationId
      })
    });

    const data = await response.json();
if (data.success) {
  const row = button.closest('tr');

  // 핵심: 접수대기 탭이면 삭제
  if (currentStatus === 'RESERVED') {
    row.remove();
  } else {
    // 다른 탭이면 상태만 변경
    // index 7 (0:날짜, 1:시간, 2:이름, 3:연락처, 4:구분, 5:진료과, 6:전문의, 7:상태)
    const statusCell = row.children[7];

    statusCell.innerHTML = `
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-orange-100 text-orange-700">
        진료 대기
      </span>
    `;

    button.remove();
  }
}
     else {
      alert('실패: ' + data.message);
    }

  } catch (e) {
    console.error(e);
    alert('에러 발생');
  }
}

async function cancelAjax(id, button, currentStatus) {

  const reason = window.prompt('예약을 취소하시겠습니까? 취소 사유를 입력해주세요:');
  
  if (reason === null) {
    return; // 취소 클릭
  }

  try {
    const response = await fetch('/staff/reception/cancel-ajax', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-TOKEN': '{{_csrf.token}}'
      },
      body: JSON.stringify({
        id: id,
        reason: reason
      })
    });

    const data = await response.json();

    if (data.success) {
      const row = button.closest('tr');

      // 현재 탭 필터가 변경된 상태와 맞지 않으면 행 삭제
      // 예: '진료 대기' 탭인데 '접수 대기'로 바뀌었거나, '접수 대기' 탭인데 '취소'로 바뀐 경우
      if (currentStatus === 'RECEIVED' && data.newStatus === 'RESERVED') {
        row.remove();
        return;
      }
      if (currentStatus === 'RESERVED' && data.newStatus === 'CANCELLED') {
        row.remove();
        return;
      }

      // '전체' 탭이거나 필터에 여전히 해당되는 경우 UI만 업데이트
      const statusCell = row.children[7];
      statusCell.innerHTML = `
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${data.statusClass}">
          ${data.statusText}
        </span>
      `;

      if (data.newStatus === 'CANCELLED') {
        // 최종 취소인 경우 버튼 영역 전체 제거
        const actionCell = row.children[8];
        actionCell.innerHTML = '';
      } else if (data.newStatus === 'RESERVED') {
        // 접수 대기로 돌아온 경우, '접수' 버튼을 다시 표시해야 함 (필요시 새로고침 권장)
        // 일단은 버튼 영역을 비우거나 페이지 새로고침을 유도할 수 있음
        location.reload(); 
      }
    } else {
      alert('취소 실패');
    }

  } catch (e) {
    console.error(e);
    alert('에러 발생');
  }
}


</script>

<script>
  // 상세 필터 토글
  const btnToggleFilter = document.getElementById('btn-toggle-filter');
  const filterPanel = document.getElementById('filter-panel');
  
  if (btnToggleFilter && filterPanel) {
    btnToggleFilter.addEventListener('click', () => {
      filterPanel.classList.toggle('hidden');
    });

    // 필터가 설정되어 있으면 자동으로 열어둠
    const hasActiveFilters = {{#deptId}}true{{/deptId}}{{^deptId}}false{{/deptId}} || 
                             {{#doctorId}}true{{/doctorId}}{{^doctorId}}false{{/doctorId}} || 
                             {{#source}}true{{/source}}{{^source}}false{{/source}};
    if (hasActiveFilters) {
      filterPanel.classList.remove('hidden');
    }
  }
</script>

</body>
</html>
