<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>예약 환자 목록 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-staff}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="space-y-5 max-w-6xl mx-auto">

        {{! 헤더 }}
        <div class="flex justify-between items-center">
          <div>
            <h1 class="text-2xl font-bold text-slate-800">예약 환자 목록</h1>
            <p class="text-sm text-slate-500 mt-0.5">총 {{totalCount}}건</p>
          </div>
          <div class="flex gap-3">
            <a href="/staff/walkin-reception" class="px-4 py-2 bg-indigo-50 text-indigo-700 font-medium rounded-lg hover:bg-indigo-100 transition-colors">
              방문 접수
            </a>
            <a href="/staff/reservation/phone-reservation" class="px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 transition-colors">
              전화 예약
            </a>
          </div>
        </div>

        {{! 날짜 네비게이션 }}
        <div class="flex items-center justify-center gap-3">
          {{#hasDate}}
          <a href="/staff/reception/list?date={{prevDate}}&status={{currentStatus}}" class="w-9 h-9 flex items-center justify-center rounded-lg border border-slate-300 hover:bg-slate-100 text-slate-600 transition-colors">
            <i data-feather="chevron-left" class="w-5 h-5"></i>
          </a>
          {{/hasDate}}
          <span class="text-base font-semibold text-slate-800 px-2">{{selectedDate}}</span>
          {{#hasDate}}
          <a href="/staff/reception/list?date={{nextDate}}&status={{currentStatus}}" class="w-9 h-9 flex items-center justify-center rounded-lg border border-slate-300 hover:bg-slate-100 text-slate-600 transition-colors">
            <i data-feather="chevron-right" class="w-5 h-5"></i>
          </a>
          <a href="/staff/reception/list?status={{currentStatus}}" class="ml-1 px-3 py-1.5 text-xs font-medium text-slate-500 border border-slate-300 rounded-lg hover:bg-slate-100 transition-colors">전체 보기</a>
          {{/hasDate}}
          {{^hasDate}}
          <a href="/staff/reception/list?date={{todayDate}}&status={{currentStatus}}" class="ml-1 px-3 py-1.5 text-xs font-medium text-indigo-600 border border-indigo-200 rounded-lg hover:bg-indigo-50 transition-colors">오늘만 보기</a>
          {{/hasDate}}
        </div>

        {{#message}}
        <div class="p-4 bg-green-50 border border-green-200 text-green-800 rounded-xl text-sm">{{message}}</div>
        {{/message}}

        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
          {{! 상태 필터 탭 }}
          <div class="p-4 border-b border-slate-200 flex gap-2 bg-slate-50">
            {{#filters}}
            <a href="{{href}}" class="{{cssClass}} transition-colors">{{label}}</a>
            {{/filters}}
          </div>

          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-200 text-xs uppercase tracking-wider text-slate-500">
                <th class="p-4 font-medium">날짜</th>
                <th class="p-4 font-medium">시간</th>
                <th class="p-4 font-medium">환자명</th>
                <th class="p-4 font-medium">연락처</th>
                <th class="p-4 font-medium">예약 구분</th>
                <th class="p-4 font-medium">진료과 / 전문의</th>
                <th class="p-4 font-medium text-center">상태</th>
                <th class="p-4 font-medium text-center">비고</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200">
              {{#reservations}}
              <tr class="hover:bg-slate-50 transition-colors cursor-pointer" onclick="location.href='/staff/reception/detail?id={{id}}'">
                <td class="p-4 text-sm text-slate-600">{{reservationDate}}</td>
                <td class="p-4 text-sm font-medium text-slate-900">{{timeSlot}}</td>
                <td class="p-4 text-sm font-semibold text-slate-800">{{patientName}}</td>
                <td class="p-4 text-sm text-slate-600">{{patientPhone}}</td>
                <td class="p-4">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium {{sourceBadgeClass}}">
                    {{sourceText}}
                  </span>
                </td>
                <td class="p-4 text-sm text-slate-600">{{departmentName}} / {{doctorName}}</td>
                <td class="p-4">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium {{statusBadgeClass}}">
                    {{statusText}}
                  </span>
                </td>
                <td class="p-4 text-right">
                  <div class="flex justify-end gap-2" onclick="event.stopPropagation()">
                    {{#canReceive}}
                    
                    <button 
  type="button"
  onclick="receiveAjax({{id}}, this, '{{currentStatus}}')"
  class="inline-flex items-center gap-1 px-3 py-1.5 bg-green-50 text-green-600 hover:bg-green-100 text-sm font-medium rounded-lg transition">
  <i data-feather="check-circle" class="w-3.5 h-3.5"></i> 접수
</button>


                    {{/canReceive}}

                    {{#canCancel}}
                    
                    <button 
  type="button"
  onclick="cancelAjax({{id}}, this, '{{currentStatus}}')"
  class="inline-flex items-center gap-1 px-3 py-1.5 bg-red-50 text-red-600 hover:bg-red-100 text-sm font-medium rounded-lg transition">
  <i data-feather="x-circle" class="w-3.5 h-3.5"></i> 취소
</button>

                    {{/canCancel}}
                  </div>
                </td>
              </tr>
              {{/reservations}}
              {{^reservations}}
              <tr>
                <td colspan="8" class="p-8 text-center text-slate-500">
                  {{selectedDate}} 예약된 환자가 없습니다.
                </td>
              </tr>
              {{/reservations}}
            </tbody>
          </table>

          {{! 페이징 }}
          <div class="px-4 py-3 border-t border-slate-200 bg-slate-50 flex items-center justify-between">
            <span class="text-sm text-slate-500">{{pageInfo}} 페이지</span>
            <div class="flex gap-2">
              {{#hasPrev}}
              <a href="{{prevPageUrl}}" class="inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-slate-600 bg-white border border-slate-300 rounded-lg hover:bg-slate-100 transition-colors">
                <i data-feather="chevron-left" class="w-4 h-4"></i> 이전
              </a>
              {{/hasPrev}}
              {{^hasPrev}}
              <span class="inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-slate-300 bg-white border border-slate-200 rounded-lg cursor-not-allowed">
                <i data-feather="chevron-left" class="w-4 h-4"></i> 이전
              </span>
              {{/hasPrev}}
              {{#hasNext}}
              <a href="{{nextPageUrl}}" class="inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-slate-600 bg-white border border-slate-300 rounded-lg hover:bg-slate-100 transition-colors">
                다음 <i data-feather="chevron-right" class="w-4 h-4"></i>
              </a>
              {{/hasNext}}
              {{^hasNext}}
              <span class="inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-slate-300 bg-white border border-slate-200 rounded-lg cursor-not-allowed">
                다음 <i data-feather="chevron-right" class="w-4 h-4"></i>
              </span>
              {{/hasNext}}
            </div>
          </div>
        </div>

      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>
feather.replace();

async function receiveAjax(reservationId, button, currentStatus) {
  try {
    const response = await fetch('/staff/reception/receive-ajax', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-TOKEN': '{{_csrf.token}}'
      },
      body: JSON.stringify({
        reservationId: reservationId
      })
    });

    const data = await response.json();
if (data.success) {
  const row = button.closest('tr');

  // 핵심: 접수대기 탭이면 삭제
  if (currentStatus === 'RESERVED') {
    row.remove();
  } else {
    // 다른 탭이면 상태만 변경
    const statusCell = row.children[6];

    statusCell.innerHTML = `
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-orange-100 text-orange-700">
        진료 대기
      </span>
    `;

    button.remove();
  }
}
     else {
      alert('실패: ' + data.message);
    }

  } catch (e) {
    console.error(e);
    alert('에러 발생');
  }
}

async function cancelAjax(id, button, currentStatus) {

  // confirm 추가
  if (!confirm('예약을 취소하시겠습니까?')) {
    return;
  }

  try {
    const response = await fetch('/staff/reception/cancel-ajax', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-TOKEN': '{{_csrf.token}}'
      },
      body: JSON.stringify({
        id: id
      })
    });

    const data = await response.json();

    if (data.success) {
      const row = button.closest('tr');

      // 진료대기 탭이면 사라짐
      if (currentStatus === 'RESERVED') {
        row.remove();
      } else {
        // 다른 탭이면 상태만 변경
        const statusCell = row.children[6];

        statusCell.innerHTML = `
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">
            취소
          </span>
        `;

        button.remove();
      }

    } else {
      alert('취소 실패');
    }

  } catch (e) {
    console.error(e);
    alert('에러 발생');
  }
}

</script>

</body>
</html>
