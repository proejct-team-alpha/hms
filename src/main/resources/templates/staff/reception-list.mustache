<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>예약 환자 목록</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="bg-slate-50 min-h-screen p-6">
    <div class="max-w-7xl mx-auto space-y-6">
        <div class="flex justify-between items-center">
            <h1 class="text-2xl font-bold text-slate-800">예약 환자 목록</h1>
            <div class="flex gap-3">
                <a href="walkin-reception.html" class="px-4 py-2 bg-indigo-50 text-indigo-700 font-medium rounded-lg hover:bg-indigo-100 transition-colors">
                    방문 접수
                </a>
                <a href="phone-reservation.html" class="px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 transition-colors">
                    전화 예약
                </a>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
            <form action="{{searchUrl}}" method="GET" class="p-4 border-b border-slate-200 flex flex-col md:flex-row justify-between items-start md:items-center gap-4 bg-slate-50">
                <div class="flex flex-wrap gap-2">
                    <button type="submit" name="status" value="ALL" class="px-4 py-1.5 rounded-full text-sm font-medium transition-colors {{#isStatusAll}}bg-slate-800 text-white{{/isStatusAll}}{{^isStatusAll}}bg-white border border-slate-300 text-slate-600 hover:bg-slate-100{{/isStatusAll}}">
                        전체
                    </button>
                    <button type="submit" name="status" value="RESERVED" class="px-4 py-1.5 rounded-full text-sm font-medium transition-colors {{#isStatusReserved}}bg-slate-800 text-white{{/isStatusReserved}}{{^isStatusReserved}}bg-white border border-slate-300 text-slate-600 hover:bg-slate-100{{/isStatusReserved}}">
                        예약 (접수 대기)
                    </button>
                    <button type="submit" name="status" value="WAITING" class="px-4 py-1.5 rounded-full text-sm font-medium transition-colors {{#isStatusWaiting}}bg-slate-800 text-white{{/isStatusWaiting}}{{^isStatusWaiting}}bg-white border border-slate-300 text-slate-600 hover:bg-slate-100{{/isStatusWaiting}}">
                        진료 대기
                    </button>
                    <button type="submit" name="status" value="COMPLETED" class="px-4 py-1.5 rounded-full text-sm font-medium transition-colors {{#isStatusCompleted}}bg-slate-800 text-white{{/isStatusCompleted}}{{^isStatusCompleted}}bg-white border border-slate-300 text-slate-600 hover:bg-slate-100{{/isStatusCompleted}}">
                        진료 완료
                    </button>
                </div>
                <div class="flex items-center gap-2 w-full md:w-auto">
                    <div class="relative w-full md:w-64">
                        <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
                        <input 
                            type="text" 
                            name="keyword"
                            value="{{searchKeyword}}"
                            placeholder="환자명 또는 연락처 검색..." 
                            class="pl-9 pr-4 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none w-full"
                        />
                    </div>
                </div>
            </form>

            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse min-w-[800px]">
                    <thead>
                        <tr class="bg-slate-50 border-b border-slate-200 text-xs uppercase tracking-wider text-slate-500">
                            <th class="p-4 font-medium">시간</th>
                            <th class="p-4 font-medium">환자명</th>
                            <th class="p-4 font-medium">연락처</th>
                            <th class="p-4 font-medium">예약 구분</th>
                            <th class="p-4 font-medium">진료과 / 전문의</th>
                            <th class="p-4 font-medium">상태</th>
                            <th class="p-4 font-medium text-right">비고</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200">
                        {{#receptions}}
                        <tr class="hover:bg-slate-50 transition-colors cursor-pointer" onclick="location.href='{{detailUrl}}'">
                            <td class="p-4 text-sm font-medium text-slate-900">{{time}}</td>
                            <td class="p-4 text-sm font-semibold text-slate-800">{{patientName}}</td>
                            <td class="p-4 text-sm text-slate-600">{{phone}}</td>
                            <td class="p-4">
                                {{#isOnline}}<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">ONLINE</span>{{/isOnline}}
                                {{#isWalkin}}<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-orange-100 text-orange-800">WALKIN</span>{{/isWalkin}}
                                {{#isPhone}}<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">PHONE</span>{{/isPhone}}
                            </td>
                            <td class="p-4 text-sm text-slate-600">{{department}} / {{doctorName}}</td>
                            <td class="p-4">
                                {{#isReserved}}
                                <span class="inline-flex items-center gap-1.5 text-sm font-medium text-indigo-600">
                                    <i data-lucide="clock" class="w-4 h-4"></i> 예약
                                </span>
                                {{/isReserved}}
                                {{#isWaiting}}
                                <span class="inline-flex items-center gap-1.5 text-sm font-medium text-green-600">
                                    <i data-lucide="check-circle" class="w-4 h-4"></i> 진료 대기
                                </span>
                                {{/isWaiting}}
                                {{#isTreating}}
                                <span class="inline-flex items-center gap-1.5 text-sm font-medium text-purple-600">
                                    <i data-lucide="activity" class="w-4 h-4"></i> 진료 중
                                </span>
                                {{/isTreating}}
                                {{#isCompleted}}
                                <span class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-600">
                                    <i data-lucide="check-circle" class="w-4 h-4"></i> 진료 완료
                                </span>
                                {{/isCompleted}}
                            </td>
                            <td class="p-4 text-right">
                                <div class="flex justify-end gap-2">
                                    {{#isReserved}}
                                    <form action="{{processReceptionUrl}}" method="POST" class="inline" onclick="event.stopPropagation();">
                                        <input type="hidden" name="id" value="{{id}}">
                                        <button type="submit" class="inline-flex items-center gap-1 px-3 py-1.5 bg-green-50 text-green-600 text-sm font-medium rounded-lg hover:bg-green-100 transition-colors">
                                            <i data-lucide="check-circle" class="w-4 h-4"></i> 접수
                                        </button>
                                    </form>
                                    {{/isReserved}}
                                    
                                    {{^isCompleted}}
                                    <form action="{{cancelUrl}}" method="POST" class="inline" onclick="event.stopPropagation(); return confirm('예약을 취소하시겠습니까?');">
                                        <input type="hidden" name="id" value="{{id}}">
                                        <button type="submit" class="inline-flex items-center gap-1 px-3 py-1.5 bg-red-50 text-red-600 text-sm font-medium rounded-lg hover:bg-red-100 transition-colors">
                                            <i data-lucide="x-circle" class="w-4 h-4"></i> 취소
                                        </button>
                                    </form>
                                    {{/isCompleted}}
                                </div>
                            </td>
                        </tr>
                        {{/receptions}}

                        {{^receptions}}
                        <tr>
                            <td colspan="7" class="p-8 text-center text-slate-500">조건에 맞는 내역이 없습니다.</td>
                        </tr>
                        {{/receptions}}
                    </tbody>
                </table>
            </div>
            
            <div class="p-4 border-t border-slate-200">
                {{> partials/pagination}}
            </div>
        </div>
    </div>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>