<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>예약 환자 목록 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body>
  
  {{> components/sidebar}}

  <div class="main-content">
    {{> components/header}}
    
    <main class="content-wrapper">
      <div class="space-y-6 max-w-5xl mx-auto">
        <div class="flex justify-between items-center">
          <h1 class="text-2xl font-bold text-slate-800">예약 환자 목록</h1>
          <div class="flex gap-3">
            <a href="/receptions/walkin" class="px-4 py-2 bg-indigo-50 text-indigo-700 font-medium rounded-lg hover:bg-indigo-100 transition-colors">방문 접수</a>
            <a href="/receptions/phone" class="px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 transition-colors">전화 예약</a>
          </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
          <div class="p-4 border-b border-slate-200 flex justify-between items-center bg-slate-50">
            <div class="flex gap-2">
              <a href="/receptions?filter=ALL" class="px-4 py-1.5 rounded-full text-sm font-medium transition-colors {{#filterAll}}bg-slate-800 text-white{{/filterAll}}{{^filterAll}}bg-white border border-slate-300 text-slate-600{{/filterAll}}">전체</a>
              <a href="/receptions?filter=RESERVED" class="px-4 py-1.5 rounded-full text-sm font-medium transition-colors {{#filterReserved}}bg-indigo-600 text-white{{/filterReserved}}{{^filterReserved}}bg-white border border-slate-300 text-slate-600{{/filterReserved}}">예약 (접수 대기)</a>
              <a href="/receptions?filter=RECEIVED" class="px-4 py-1.5 rounded-full text-sm font-medium transition-colors {{#filterReceived}}bg-green-600 text-white{{/filterReceived}}{{^filterReceived}}bg-white border border-slate-300 text-slate-600{{/filterReceived}}">진료 대기</a>
            </div>
            <div class="flex items-center gap-2">
              <form action="/receptions" method="GET" class="relative">
                <input type="hidden" name="filter" value="{{currentFilter}}">
                <i data-feather="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
                <input type="text" name="search" value="{{searchQuery}}" placeholder="환자명 검색..." class="pl-9 pr-4 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none w-64"/>
              </form>
            </div>
          </div>

          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-200 text-xs uppercase tracking-wider text-slate-500">
                <th class="p-4 font-medium">시간</th>
                <th class="p-4 font-medium">환자명</th>
                <th class="p-4 font-medium">연락처</th>
                <th class="p-4 font-medium">예약 구분</th>
                <th class="p-4 font-medium">진료과 / 전문의</th>
                <th class="p-4 font-medium text-right">비고</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200">
              {{#reservations}}
              <tr class="hover:bg-slate-50 transition-colors">
                <td class="p-4 text-sm font-medium text-slate-900 cursor-pointer" onclick="location.href='/receptions/{{id}}'">{{time}}</td>
                <td class="p-4 text-sm font-semibold text-slate-800 cursor-pointer" onclick="location.href='/receptions/{{id}}'">{{name}}</td>
                <td class="p-4 text-sm text-slate-600">{{phone}}</td>
                <td class="p-4">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium {{#isOnline}}bg-blue-100 text-blue-800{{/isOnline}}{{#isPhone}}bg-purple-100 text-purple-800{{/isPhone}}{{#isWalkin}}bg-orange-100 text-orange-800{{/isWalkin}}">{{type}}</span>
                </td>
                <td class="p-4 text-sm text-slate-600">{{dept}} / {{doctor}}</td>
                <td class="p-4 text-right">
                  <div class="flex justify-end gap-2">
                    {{#isReserved}}
                    <form action="/receptions/{{id}}/receive" method="POST" class="inline m-0">
                      <button type="submit" class="inline-flex items-center gap-1 px-3 py-1.5 bg-green-50 text-green-600 text-sm font-medium rounded-lg hover:bg-green-100">
                        <i data-feather="check-circle" class="w-4 h-4"></i> 접수
                      </button>
                    </form>
                    {{/isReserved}}
                    {{^isCompleted}}
                    <form action="/receptions/{{id}}/cancel" method="POST" class="inline m-0" onsubmit="return confirm('취소하시겠습니까?');">
                      <button type="submit" class="inline-flex items-center gap-1 px-3 py-1.5 bg-red-50 text-red-600 text-sm font-medium rounded-lg hover:bg-red-100">
                        <i data-feather="x-circle" class="w-4 h-4"></i> 취소
                      </button>
                    </form>
                    {{/isCompleted}}
                  </div>
                </td>
              </tr>
              {{/reservations}}
            </tbody>
          </table>
          
          <div class="p-4 border-t border-slate-200 flex justify-center gap-2">
            {{#pages}}
            <a href="/receptions?page={{page}}&filter={{currentFilter}}&search={{searchQuery}}" class="px-3 py-1 rounded {{#isActive}}bg-indigo-600 text-white{{/isActive}}{{^isActive}}bg-slate-100 text-slate-600{{/isActive}}">{{page}}</a>
            {{/pages}}
          </div>
        </div>
      </div>
    </main>

    {{> components/footer}}
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      feather.replace();
    });
  </script>
</body>
</html>