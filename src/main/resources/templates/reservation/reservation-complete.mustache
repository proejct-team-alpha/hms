<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>예약 완료</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="bg-slate-50 min-h-screen flex flex-col">
    <!-- Header (PatientLayout) -->
    <header class="bg-white border-b border-slate-200 h-16 flex items-center px-8 justify-between shrink-0 sticky top-0 z-10">
        <a href="/" class="text-xl font-bold text-slate-800 flex items-center gap-2">
            <i data-lucide="stethoscope" class="text-indigo-600 w-6 h-6"></i>
            MediCare+
        </a>
        <a href="/" class="flex items-center gap-2 text-sm font-medium text-slate-600 hover:text-indigo-600 transition-colors">
            <i data-lucide="home" class="w-4 h-4"></i>
            처음으로
        </a>
    </header>

    <!-- Main Content -->
    <main class="flex-1 overflow-y-auto p-8 flex items-center justify-center">
        <div class="max-w-2xl w-full mx-auto">
        <div id="noDataMessage" class="hidden text-center py-20">
            <h2 class="text-2xl font-bold text-slate-800">예약 정보가 없습니다.</h2>
            <a href="/reservation/index" class="inline-block mt-4 px-6 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors">
                처음으로 돌아가기
            </a>
        </div>

        <div id="successContent" class="bg-white rounded-2xl shadow-sm border border-slate-200 p-10 text-center">
            <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
                <i data-lucide="check-circle-2" class="w-10 h-10 text-green-600"></i>
            </div>
            
            <h1 class="text-3xl font-bold text-slate-800 mb-2">예약이 완료되었습니다!</h1>
            <p class="text-slate-500 mb-10">
                <span id="patientName1" class="font-semibold text-slate-700"></span>님의 진료 예약이 성공적으로 접수되었습니다.<br/>
                예약 당일 원무과에서 접수를 진행해주세요.
            </p>

            <div class="bg-slate-50 rounded-2xl p-8 text-left space-y-6 border border-slate-100 mb-10">
                <h3 class="text-lg font-semibold text-slate-800 border-b border-slate-200 pb-4 mb-4">예약 상세 정보</h3>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-y-6 gap-x-12">
                    <div class="flex items-start gap-3">
                        <i data-lucide="user" class="w-5 h-5 text-indigo-500 shrink-0 mt-0.5"></i>
                        <div>
                            <div class="text-sm text-slate-500 mb-1">환자명</div>
                            <div id="patientName2" class="font-medium text-slate-800"></div>
                        </div>
                    </div>
                    
                    <div class="flex items-start gap-3">
                        <i data-lucide="map-pin" class="w-5 h-5 text-indigo-500 shrink-0 mt-0.5"></i>
                        <div>
                            <div class="text-sm text-slate-500 mb-1">진료과 / 전문의</div>
                            <div id="deptDoctor" class="font-medium text-slate-800"></div>
                        </div>
                    </div>

                    <div class="flex items-start gap-3">
                        <i data-lucide="calendar" class="w-5 h-5 text-indigo-500 shrink-0 mt-0.5"></i>
                        <div>
                            <div class="text-sm text-slate-500 mb-1">예약 일자</div>
                            <div id="resDate" class="font-medium text-slate-800"></div>
                        </div>
                    </div>

                    <div class="flex items-start gap-3">
                        <i data-lucide="clock" class="w-5 h-5 text-indigo-500 shrink-0 mt-0.5"></i>
                        <div>
                            <div class="text-sm text-slate-500 mb-1">예약 시간</div>
                            <div id="resTime" class="font-medium text-slate-800"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="flex gap-4 justify-center">
                <a href="/" class="px-8 py-3 bg-indigo-600 text-white font-medium rounded-xl hover:bg-indigo-700 transition-colors shadow-sm">
                    메인으로 가기
                </a>
            </div>
        </div>
    </main>

    <script>
        // 아이콘 초기화
        lucide.createIcons();

        // URL 파라미터에서 예약 정보 가져오기
        const urlParams = new URLSearchParams(window.location.search);
        const name = urlParams.get('name');
        const dept = urlParams.get('dept');
        const doctor = urlParams.get('doctor');
        const date = urlParams.get('date');
        const time = urlParams.get('time');

        // 정보가 없으면 에러 메시지 표시
        if (!name || !dept || !date) {
            document.getElementById('successContent').classList.add('hidden');
            document.getElementById('noDataMessage').classList.remove('hidden');
        } else {
            // 데이터 바인딩
            document.getElementById('patientName1').textContent = name;
            document.getElementById('patientName2').textContent = name;
            document.getElementById('deptDoctor').textContent = `${dept} / ${doctor}`;
            document.getElementById('resDate').textContent = date;
            document.getElementById('resTime').textContent = time;
        }
    </script>
</body>
</html>
