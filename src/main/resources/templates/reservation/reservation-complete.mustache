<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>예약 완료 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex flex-col">
  {{> common/header-public}}
  
  <main class="flex-1 overflow-y-auto p-8">
    <div class="max-w-5xl mx-auto">
      <div id="error-view" class="hidden text-center py-20">
        <h2 class="text-2xl font-bold text-slate-800">예약 정보가 없습니다.</h2>
        <button 
          onclick="location.href='symptom-reservation.html'"
          class="mt-4 px-6 py-2 bg-indigo-600 text-white rounded-lg"
        >
          처음으로 돌아가기
        </button>
      </div>

      <div id="success-view" class="hidden max-w-2xl mx-auto">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-10 text-center">
          <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <i data-feather="check-circle" class="w-10 h-10 text-green-600"></i>
          </div>
          
          <h1 class="text-3xl font-bold text-slate-800 mb-2">예약이 완료되었습니다!</h1>
          <p class="text-slate-500 mb-10">
            <span id="res-name-title" class="font-semibold"></span>님의 진료 예약이 성공적으로 접수되었습니다.<br/>
            예약 당일 원무과에서 접수를 진행해주세요.
          </p>

          <div class="bg-slate-50 rounded-2xl p-8 text-left space-y-6 border border-slate-100 mb-10">
            <h3 class="text-lg font-semibold text-slate-800 border-b border-slate-200 pb-4 mb-4">예약 상세 정보</h3>
            
            <div class="grid grid-cols-2 gap-y-6 gap-x-12">
              <div class="flex items-start gap-3">
                <i data-feather="user" class="w-5 h-5 text-indigo-500 shrink-0 mt-0.5"></i>
                <div>
                  <div class="text-sm text-slate-500 mb-1">환자명</div>
                  <div id="res-name" class="font-medium text-slate-800"></div>
                </div>
              </div>
              
              <div class="flex items-start gap-3">
                <i data-feather="map-pin" class="w-5 h-5 text-indigo-500 shrink-0 mt-0.5"></i>
                <div>
                  <div class="text-sm text-slate-500 mb-1">진료과 / 전문의</div>
                  <div id="res-dept-doctor" class="font-medium text-slate-800"></div>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <i data-feather="calendar" class="w-5 h-5 text-indigo-500 shrink-0 mt-0.5"></i>
                <div>
                  <div class="text-sm text-slate-500 mb-1">예약 일자</div>
                  <div id="res-date" class="font-medium text-slate-800"></div>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <i data-feather="clock" class="w-5 h-5 text-indigo-500 shrink-0 mt-0.5"></i>
                <div>
                  <div class="text-sm text-slate-500 mb-1">예약 시간</div>
                  <div id="res-time" class="font-medium text-slate-800"></div>
                </div>
              </div>
            </div>
          </div>

          <div class="flex gap-4 justify-center">
            <button 
              onclick="location.href='../index.html'"
              class="px-8 py-3 bg-indigo-600 text-white font-medium rounded-xl hover:bg-indigo-700 transition-colors shadow-sm"
            >
              메인으로 가기
            </button>
          </div>
        </div>
      </div>
    </div>
  </main>

  {{> common/footer-public}}
  <script>
    feather.replace();

    const urlParams = new URLSearchParams(window.location.search);
    const name = urlParams.get('name');
    const department = urlParams.get('department');
    const doctor = urlParams.get('doctor');
    const date = urlParams.get('date');
    const time = urlParams.get('time');

    if (name && department && doctor && date && time) {
      document.getElementById('success-view').classList.remove('hidden');
      document.getElementById('res-name-title').innerText = name;
      document.getElementById('res-name').innerText = name;
      document.getElementById('res-dept-doctor').innerText = \`\${department} / \${doctor}\`;
      document.getElementById('res-date').innerText = date;
      document.getElementById('res-time').innerText = time;
    } else {
      document.getElementById('error-view').classList.remove('hidden');
    }
  </script>
</body>
</html>
