<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>예약 취소 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex flex-col">
  {{> common/header-public}}

  <main class="flex-1 overflow-y-auto p-8">
    <div class="max-w-2xl mx-auto">

      {{! 예약번호 검색 폼 }}
      <div id="search-section" class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 mb-6">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-12 h-12 bg-red-100 rounded-xl flex items-center justify-center text-red-600">
            <i data-feather="x-circle" class="w-6 h-6"></i>
          </div>
          <div>
            <h1 class="text-2xl font-bold text-slate-800">예약 취소</h1>
            <p class="text-slate-500 mt-1">예약번호를 입력하여 예약을 조회하세요.</p>
          </div>
        </div>
        <form method="get" action="/reservation/cancel" class="flex gap-3">
          <input type="text" name="reservationNumber" placeholder="예약번호 입력 (예: RES-20260310-001)"
                 class="flex-1 border border-slate-300 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" required />
          <button type="submit"
                  class="px-6 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700 transition-colors">
            조회
          </button>
        </form>
        {{#errorMessage}}
        <p class="mt-3 text-sm text-red-500">{{errorMessage}}</p>
        {{/errorMessage}}
      </div>

      {{! 예약 상세 + 취소 확인 }}
      {{#reservation}}
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
        <h2 class="text-lg font-semibold text-slate-800 mb-6">예약 정보 확인</h2>
        <div class="space-y-4 text-sm mb-8">
          <div class="flex justify-between py-2 border-b border-slate-100">
            <span class="text-slate-500">예약번호</span>
            <span class="font-medium text-slate-800">{{reservationNumber}}</span>
          </div>
          <div class="flex justify-between py-2 border-b border-slate-100">
            <span class="text-slate-500">환자명</span>
            <span class="font-medium text-slate-800">{{patientName}}</span>
          </div>
          <div class="flex justify-between py-2 border-b border-slate-100">
            <span class="text-slate-500">진료과</span>
            <span class="font-medium text-slate-800">{{departmentName}}</span>
          </div>
          <div class="flex justify-between py-2 border-b border-slate-100">
            <span class="text-slate-500">전문의</span>
            <span class="font-medium text-slate-800">{{doctorName}}</span>
          </div>
          <div class="flex justify-between py-2 border-b border-slate-100">
            <span class="text-slate-500">예약 일자</span>
            <span class="font-medium text-slate-800">{{reservationDate}}</span>
          </div>
          <div class="flex justify-between py-2 border-b border-slate-100">
            <span class="text-slate-500">예약 시간</span>
            <span class="font-medium text-slate-800">{{timeSlot}}</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-slate-500">상태</span>
            <span class="font-medium text-slate-800">{{status}}</span>
          </div>
        </div>
        <div class="flex gap-3">
          <button onclick="history.back()"
                  class="flex-1 py-3 bg-white border border-slate-300 text-slate-600 font-medium rounded-xl hover:bg-slate-50 transition-colors">
            취소 안 함
          </button>
          <form method="post" action="/reservation/cancel/{{id}}" class="flex-1">
            {{! CSRF 토큰 }}
            <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
            <button type="submit"
                    class="w-full py-3 bg-red-500 text-white font-medium rounded-xl hover:bg-red-600 transition-colors shadow-sm">
              예약 취소
            </button>
          </form>
        </div>
      </div>
      {{/reservation}}

    </div>
  </main>

  {{> common/footer-public}}
  <script>
    feather.replace();
    if (new URLSearchParams(window.location.search).has('reservationNumber')) {
      document.getElementById('search-section').classList.add('hidden');
    }
  </script>
</body>
</html>
