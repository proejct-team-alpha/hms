<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>예약 조회 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex flex-col">
  {{> common/header-public}}

  <main class="flex-1 overflow-y-auto p-8">
    <div class="max-w-2xl mx-auto">

      <div class="flex items-center gap-3 mb-8">
        <button onclick="location.href='/reservation'" class="flex items-center gap-2 text-slate-500 hover:text-slate-800 font-medium">
          <i data-feather="arrow-left" class="w-5 h-5"></i>
          돌아가기
        </button>
      </div>

      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 mb-6">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-12 h-12 bg-emerald-100 rounded-xl flex items-center justify-center text-emerald-600">
            <i data-feather="search" class="w-6 h-6"></i>
          </div>
          <div>
            <h1 class="text-2xl font-bold text-slate-800">예약 조회</h1>
            <p class="text-slate-500 mt-1">예약 번호 또는 환자 정보로 예약 내역을 조회합니다.</p>
          </div>
        </div>

        {{! 탭 메뉴 }}
        <div class="flex border-b border-slate-200 mb-6">
          <button id="tab-number" onclick="switchTab('number')"
                  class="flex-1 py-3 text-center border-b-2 border-emerald-600 font-medium text-emerald-600 transition-colors">
            예약 번호로 조회
          </button>
          <button id="tab-name" onclick="switchTab('name')"
                  class="flex-1 py-3 text-center border-b-2 border-transparent font-medium text-slate-500 hover:text-slate-700 transition-colors">
            이름/연락처로 조회
          </button>
        </div>

        {{! 예약번호 조회 폼 }}
        <form id="form-number" method="get" action="/reservation/lookup" class="space-y-6">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-2">예약 번호</label>
            <div class="relative">
              <i data-feather="hash" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
              <input type="text" name="reservationNumber" required
                     placeholder="RES-20260310-001"
                     class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none" />
            </div>
          </div>
          <button type="submit"
                  class="w-full py-4 bg-emerald-600 text-white rounded-xl font-medium text-lg hover:bg-emerald-700 transition-colors shadow-sm">
            조회하기
          </button>
        </form>

        {{! 이름/연락처 조회 폼 }}
        <form id="form-name" method="get" action="/reservation/lookup" class="space-y-6 hidden">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-2">환자 성함</label>
            <div class="relative">
              <i data-feather="user" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
              <input type="text" name="name" required
                     placeholder="홍길동"
                     class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none" />
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-2">연락처</label>
            <div class="relative">
              <i data-feather="phone" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
              <input type="tel" name="phone" required
                     placeholder="010-1234-5678"
                     class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none" />
            </div>
          </div>
          <button type="submit"
                  class="w-full py-4 bg-emerald-600 text-white rounded-xl font-medium text-lg hover:bg-emerald-700 transition-colors shadow-sm">
            조회하기
          </button>
        </form>

        {{! 오류 메시지 }}
        {{#errorMessage}}
        <div class="mt-8 pt-8 border-t border-slate-200">
          <div class="flex flex-col items-center gap-2 py-8 bg-slate-50 rounded-xl border border-slate-200">
            <i data-feather="alert-circle" class="w-8 h-8 text-slate-400"></i>
            <p class="text-slate-600">{{errorMessage}}</p>
          </div>
        </div>
        {{/errorMessage}}
      </div>

      {{! 단건 조회 결과 }}
      {{#reservation}}
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 mb-4">
        <div class="flex justify-between items-start mb-4">
          <div>
            <span class="inline-block px-2 py-1 bg-slate-100 text-slate-600 text-xs font-bold rounded mb-2">{{status}}</span>
            <p class="font-bold text-slate-800 text-lg font-mono">{{reservationNumber}}</p>
          </div>
          <div class="text-right">
            <div class="text-sm text-slate-500">환자명</div>
            <div class="font-medium text-slate-800">{{patientName}}</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4 text-sm mb-6">
          <div>
            <div class="text-slate-500 mb-1">진료과 / 전문의</div>
            <div class="font-medium text-slate-800">{{departmentName}} / {{doctorName}}</div>
          </div>
          <div>
            <div class="text-slate-500 mb-1">예약 일시</div>
            <div class="font-medium text-slate-800">{{reservationDate}} {{timeSlot}}</div>
          </div>
        </div>
        {{#canModify}}
        <div class="flex gap-3 pt-4 border-t border-slate-200">
          <button data-href="/reservation/modify?reservationNumber={{reservationNumber}}"
                  class="res-btn flex-1 py-2.5 bg-white border border-emerald-600 text-emerald-600 rounded-lg font-medium hover:bg-emerald-50 transition-colors">
            예약 변경
          </button>
          <button data-href="/reservation/cancel?reservationNumber={{reservationNumber}}"
                  class="res-btn flex-1 py-2.5 bg-red-50 border border-red-200 text-red-600 rounded-lg font-medium hover:bg-red-100 transition-colors">
            예약 취소
          </button>
        </div>
        {{/canModify}}
      </div>
      {{/reservation}}

      {{! 목록 조회 결과 }}
      {{#reservations}}
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 mb-4">
        <div class="flex justify-between items-start mb-4">
          <div>
            <span class="inline-block px-2 py-1 bg-slate-100 text-slate-600 text-xs font-bold rounded mb-2">{{status}}</span>
            <p class="font-bold text-slate-800 text-lg font-mono">{{reservationNumber}}</p>
          </div>
          <div class="text-right">
            <div class="text-sm text-slate-500">환자명</div>
            <div class="font-medium text-slate-800">{{patientName}}</div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4 text-sm mb-6">
          <div>
            <div class="text-slate-500 mb-1">진료과 / 전문의</div>
            <div class="font-medium text-slate-800">{{departmentName}} / {{doctorName}}</div>
          </div>
          <div>
            <div class="text-slate-500 mb-1">예약 일시</div>
            <div class="font-medium text-slate-800">{{reservationDate}} {{timeSlot}}</div>
          </div>
        </div>
        {{#canModify}}
        <div class="flex gap-3 pt-4 border-t border-slate-200">
          <button data-href="/reservation/modify?reservationNumber={{reservationNumber}}"
                  class="res-btn flex-1 py-2.5 bg-white border border-emerald-600 text-emerald-600 rounded-lg font-medium hover:bg-emerald-50 transition-colors">
            예약 변경
          </button>
          <button data-href="/reservation/cancel?reservationNumber={{reservationNumber}}"
                  class="res-btn flex-1 py-2.5 bg-red-50 border border-red-200 text-red-600 rounded-lg font-medium hover:bg-red-100 transition-colors">
            예약 취소
          </button>
        </div>
        {{/canModify}}
      </div>
      {{/reservations}}

    </div>
  </main>

  {{> common/footer-public}}
  <script>
    feather.replace();

    // data-href 버튼 클릭 이벤트
    document.addEventListener('click', function (e) {
      const btn = e.target.closest('.res-btn');
      if (btn && btn.dataset.href) {
        location.href = btn.dataset.href;
      }
    });

    function switchTab(tab) {
      const isNumber = tab === 'number';
      document.getElementById('form-number').classList.toggle('hidden', !isNumber);
      document.getElementById('form-name').classList.toggle('hidden', isNumber);
      document.getElementById('tab-number').className = isNumber
        ? 'flex-1 py-3 text-center border-b-2 border-emerald-600 font-medium text-emerald-600 transition-colors'
        : 'flex-1 py-3 text-center border-b-2 border-transparent font-medium text-slate-500 hover:text-slate-700 transition-colors';
      document.getElementById('tab-name').className = isNumber
        ? 'flex-1 py-3 text-center border-b-2 border-transparent font-medium text-slate-500 hover:text-slate-700 transition-colors'
        : 'flex-1 py-3 text-center border-b-2 border-emerald-600 font-medium text-emerald-600 transition-colors';
    }

    // URL 파라미터로 활성 탭 결정
    const params = new URLSearchParams(window.location.search);
    if (params.has('name') || params.has('phone')) {
      switchTab('name');
    }
  </script>
</body>
</html>
