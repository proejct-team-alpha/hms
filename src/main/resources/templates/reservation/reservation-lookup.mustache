<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>예약 조회 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex flex-col">
  {{> common/header-public}}

  <main class="flex-1 overflow-y-auto p-8">
    <div class="max-w-2xl mx-auto">

      <div class="flex items-center gap-3 mb-8">
        <button onclick="location.href='/reservation'" class="flex items-center gap-2 text-slate-500 hover:text-slate-800 font-medium">
          <i data-feather="arrow-left" class="w-5 h-5"></i>
          돌아가기
        </button>
      </div>

      {{! 탭 헤더 }}
      <div class="flex gap-2 mb-6">
        <button id="tab-number" onclick="switchTab('number')"
                class="px-5 py-2 rounded-lg text-sm font-medium bg-indigo-600 text-white transition-colors">
          예약번호 조회
        </button>
        <button id="tab-name" onclick="switchTab('name')"
                class="px-5 py-2 rounded-lg text-sm font-medium bg-white border border-slate-300 text-slate-600 hover:bg-slate-50 transition-colors">
          이름 + 전화번호 조회
        </button>
      </div>

      {{! 예약번호 조회 폼 }}
      <div id="form-number" class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 mb-6">
        <h2 class="text-lg font-semibold text-slate-800 mb-4">예약번호로 조회</h2>
        <form method="get" action="/reservation/lookup" class="flex gap-3">
          <input type="text" name="reservationNumber" placeholder="예약번호 입력 (예: RES-20260310-001)"
                 class="flex-1 border border-slate-300 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" required />
          <button type="submit"
                  class="px-6 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700 transition-colors">
            조회
          </button>
        </form>
      </div>

      {{! 이름 + 전화번호 조회 폼 }}
      <div id="form-name" class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 mb-6 hidden">
        <h2 class="text-lg font-semibold text-slate-800 mb-4">이름 + 전화번호로 조회</h2>
        <form method="get" action="/reservation/lookup" class="space-y-3">
          <input type="text" name="name" placeholder="예약자 이름"
                 class="w-full border border-slate-300 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" required />
          <input type="text" name="phone" placeholder="전화번호 (예: 010-1234-5678)"
                 class="w-full border border-slate-300 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" required />
          <button type="submit"
                  class="w-full py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700 transition-colors">
            조회
          </button>
        </form>
      </div>

      {{! 오류 메시지 }}
      {{#errorMessage}}
      <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-6 text-sm text-red-600">
        {{errorMessage}}
      </div>
      {{/errorMessage}}

      {{! 단건 조회 결과 }}
      {{#reservation}}
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 mb-4">
        <h2 class="text-lg font-semibold text-slate-800 mb-6">예약 상세 정보</h2>
        <div class="space-y-4 text-sm mb-8">
          <div class="flex justify-between py-2 border-b border-slate-100">
            <span class="text-slate-500">예약번호</span>
            <span class="font-medium text-slate-800 font-mono">{{reservationNumber}}</span>
          </div>
          <div class="flex justify-between py-2 border-b border-slate-100">
            <span class="text-slate-500">환자명</span>
            <span class="font-medium text-slate-800">{{patientName}}</span>
          </div>
          <div class="flex justify-between py-2 border-b border-slate-100">
            <span class="text-slate-500">진료과</span>
            <span class="font-medium text-slate-800">{{departmentName}}</span>
          </div>
          <div class="flex justify-between py-2 border-b border-slate-100">
            <span class="text-slate-500">전문의</span>
            <span class="font-medium text-slate-800">{{doctorName}}</span>
          </div>
          <div class="flex justify-between py-2 border-b border-slate-100">
            <span class="text-slate-500">예약 일자</span>
            <span class="font-medium text-slate-800">{{reservationDate}}</span>
          </div>
          <div class="flex justify-between py-2 border-b border-slate-100">
            <span class="text-slate-500">예약 시간</span>
            <span class="font-medium text-slate-800">{{timeSlot}}</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-slate-500">상태</span>
            <span class="font-medium text-slate-800">{{status}}</span>
          </div>
        </div>
        <div class="flex gap-3">
          <button data-href="/reservation/modify?reservationNumber={{reservationNumber}}"
                  class="res-btn flex-1 py-3 bg-indigo-600 text-white font-medium rounded-xl hover:bg-indigo-700 transition-colors">
            예약 변경
          </button>
          <button data-href="/reservation/cancel?reservationNumber={{reservationNumber}}"
                  class="res-btn flex-1 py-3 bg-red-500 text-white font-medium rounded-xl hover:bg-red-600 transition-colors">
            예약 취소
          </button>
        </div>
      </div>
      {{/reservation}}

      {{! 목록 조회 결과 }}
      {{#reservations}}
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 mb-4">
        <div class="flex justify-between items-start mb-4">
          <div>
            <p class="font-mono text-sm text-indigo-600 font-medium">{{reservationNumber}}</p>
            <p class="text-base font-semibold text-slate-800 mt-1">{{departmentName}} / {{doctorName}}</p>
            <p class="text-sm text-slate-500 mt-1">{{reservationDate}} {{timeSlot}}</p>
          </div>
          <span class="text-xs px-3 py-1 bg-slate-100 text-slate-600 rounded-full">{{status}}</span>
        </div>
        <div class="flex gap-2">
          <button data-href="/reservation/modify?reservationNumber={{reservationNumber}}"
                  class="res-btn flex-1 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors">
            변경
          </button>
          <button data-href="/reservation/cancel?reservationNumber={{reservationNumber}}"
                  class="res-btn flex-1 py-2 bg-red-500 text-white text-sm font-medium rounded-lg hover:bg-red-600 transition-colors">
            취소
          </button>
        </div>
      </div>
      {{/reservations}}

    </div>
  </main>

  {{> common/footer-public}}
  <script>
    feather.replace();

    // data-href 버튼 클릭 이벤트
    document.addEventListener('click', function (e) {
      const btn = e.target.closest('.res-btn');
      if (btn && btn.dataset.href) {
        location.href = btn.dataset.href;
      }
    });

    function switchTab(tab) {
      const isNumber = tab === 'number';
      document.getElementById('form-number').classList.toggle('hidden', !isNumber);
      document.getElementById('form-name').classList.toggle('hidden', isNumber);
      document.getElementById('tab-number').className = isNumber
        ? 'px-5 py-2 rounded-lg text-sm font-medium bg-indigo-600 text-white transition-colors'
        : 'px-5 py-2 rounded-lg text-sm font-medium bg-white border border-slate-300 text-slate-600 hover:bg-slate-50 transition-colors';
      document.getElementById('tab-name').className = isNumber
        ? 'px-5 py-2 rounded-lg text-sm font-medium bg-white border border-slate-300 text-slate-600 hover:bg-slate-50 transition-colors'
        : 'px-5 py-2 rounded-lg text-sm font-medium bg-indigo-600 text-white transition-colors';
    }

    // URL 파라미터로 활성 탭 결정
    const params = new URLSearchParams(window.location.search);
    if (params.has('name') || params.has('phone')) {
      switchTab('name');
    }
  </script>
</body>
</html>
