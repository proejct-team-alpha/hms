<body class="min-h-screen flex flex-col">
  {{> components/header}}
  <main class="flex-1 overflow-y-auto p-8">
    <div class="max-w-5xl mx-auto">
      <div class="max-w-2xl mx-auto">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
          
          {{#recommendation}}
          <div class="mb-8 p-4 bg-indigo-50 rounded-xl border border-indigo-100 flex items-start gap-3">
            <i data-feather="check-circle" class="w-5 h-5 text-indigo-600 shrink-0 mt-0.5"></i>
            <div class="text-sm text-indigo-900">
              <span class="font-semibold">AI 추천 정보가 적용되었습니다.</span><br />
              추천 진료과: <span>{{dept}}</span> / 추천 전문의: <span>{{doctor}}</span>
            </div>
          </div>
          {{/recommendation}}

          <form action="/reservations/create" method="POST" class="space-y-6">
            <div class="grid grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">환자 성함</label>
                <div class="relative">
                  <i data-feather="user" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                  <input type="text" name="name" required class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500" placeholder="홍길동" />
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">연락처</label>
                <div class="relative">
                  <i data-feather="phone" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                  <input type="tel" name="phone" required class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500" placeholder="010-1234-5678" />
                </div>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">진료과</label>
                <select name="department" required class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500">
                  <option value="">선택해주세요</option>
                  <option value="내과" {{#isInternalMedicine}}selected{{/isInternalMedicine}}>내과</option>
                  </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">예약 날짜</label>
                <div class="relative">
                  <i data-feather="calendar" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                  <input type="date" name="date" required class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500"/>
                </div>
              </div>
            </div>

            <div class="pt-6 border-t border-slate-200">
              <button type="submit" class="w-full py-4 bg-indigo-600 text-white rounded-xl font-medium text-lg hover:bg-indigo-700 shadow-sm">
                예약 완료하기
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </main>
  {{> components/footer}}
  <script>feather.replace();</script>
</body>
</html>