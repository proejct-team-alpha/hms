<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>직접 선택 예약</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="bg-slate-50 min-h-screen flex flex-col">
    <!-- Header (PatientLayout) -->
    <header class="bg-white border-b border-slate-200 h-16 flex items-center px-8 justify-between shrink-0 sticky top-0 z-10">
        <a href="/" class="text-xl font-bold text-slate-800 flex items-center gap-2">
            <i data-lucide="stethoscope" class="text-indigo-600 w-6 h-6"></i>
            MediCare+
        </a>
        <a href="/" class="flex items-center gap-2 text-sm font-medium text-slate-600 hover:text-indigo-600 transition-colors">
            <i data-lucide="home" class="w-4 h-4"></i>
            처음으로
        </a>
    </header>

    <!-- Main Content -->
    <main class="flex-1 overflow-y-auto p-8">
        <div class="max-w-2xl mx-auto">
            <div class="mb-6">
                <a href="/reservation/index" class="inline-flex items-center gap-2 text-slate-500 hover:text-slate-800 font-medium transition-colors">
                    <i data-lucide="arrow-left" class="w-5 h-5"></i>
                    뒤로 가기
                </a>
            </div>

        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
            <div class="flex items-center gap-3 mb-8">
                <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600">
                    <i data-lucide="calendar" class="w-6 h-6"></i>
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-slate-800">진료 예약</h1>
                    <p class="text-slate-500 mt-1">원하시는 진료과와 시간을 선택해주세요.</p>
                </div>
            </div>

            <!-- AI 추천 정보 배너 (초기에는 숨김) -->
            <div id="aiBanner" class="hidden mb-8 p-4 bg-indigo-50 rounded-xl border border-indigo-100 flex items-start gap-3">
                <i data-lucide="check-circle-2" class="w-5 h-5 text-indigo-600 shrink-0 mt-0.5"></i>
                <div class="text-sm text-indigo-900">
                    <span class="font-semibold">AI 추천 정보가 적용되었습니다.</span><br />
                    추천 진료과: <span id="aiDept"></span> / 추천 전문의: <span id="aiDoctor"></span>
                </div>
            </div>

            <form onsubmit="handleSubmit(event)" class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">환자 성함</label>
                        <div class="relative">
                            <i data-lucide="user" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                            <input
                                type="text"
                                id="nameInput"
                                required
                                class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none"
                                placeholder="홍길동"
                            />
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">연락처</label>
                        <div class="relative">
                            <i data-lucide="phone" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                            <input
                                type="tel"
                                id="phoneInput"
                                required
                                class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none"
                                placeholder="010-1234-5678"
                            />
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">진료과</label>
                        <select
                            id="deptSelect"
                            required
                            class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none bg-white"
                        >
                            <option value="">선택해주세요</option>
                            <option value="내과">내과</option>
                            <option value="외과">외과</option>
                            <option value="소아과">소아과</option>
                            <option value="이비인후과">이비인후과</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">전문의</label>
                        <select
                            id="doctorSelect"
                            required
                            class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none bg-white"
                        >
                            <option value="">선택해주세요</option>
                            <option value="김의사 원장">김의사 원장</option>
                            <option value="이의사 과장">이의사 과장</option>
                            <option value="박의사 과장">박의사 과장</option>
                        </select>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">예약 날짜</label>
                        <div class="relative">
                            <i data-lucide="calendar" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                            <input
                                type="date"
                                id="dateInput"
                                required
                                class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none"
                            />
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">예약 시간</label>
                        <div class="relative">
                            <i data-lucide="clock" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                            <select
                                id="timeSelect"
                                required
                                class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none bg-white"
                            >
                                <option value="">선택해주세요</option>
                                <option value="09:00">09:00</option>
                                <option value="10:00">10:00</option>
                                <option value="11:00">11:00</option>
                                <option value="14:00">14:00</option>
                                <option value="15:00">15:00</option>
                                <option value="16:00">16:00</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="pt-6 border-t border-slate-200">
                    <button
                        type="submit"
                        class="w-full py-4 bg-indigo-600 text-white rounded-xl font-medium text-lg hover:bg-indigo-700 transition-colors shadow-sm"
                    >
                        예약 완료하기
                    </button>
                </div>
            </form>
        </div>
    </main>

    <script>
        // 아이콘 초기화
        lucide.createIcons();

        // URL 파라미터 확인 (AI 추천 정보 적용)
        const urlParams = new URLSearchParams(window.location.search);
        const recommendedDept = urlParams.get('dept');
        const recommendedDoctor = urlParams.get('doctor');

        if (recommendedDept && recommendedDoctor) {
            // 배너 표시
            const aiBanner = document.getElementById('aiBanner');
            aiBanner.classList.remove('hidden');
            
            // 텍스트 설정
            document.getElementById('aiDept').textContent = recommendedDept;
            document.getElementById('aiDoctor').textContent = recommendedDoctor;
            
            // 폼 필드 자동 선택
            document.getElementById('deptSelect').value = recommendedDept;
            document.getElementById('doctorSelect').value = recommendedDoctor;
        }

        function handleSubmit(event) {
            event.preventDefault();
            
            // 폼 데이터 수집
            const name = document.getElementById('nameInput').value;
            const dept = document.getElementById('deptSelect').value;
            const doctor = document.getElementById('doctorSelect').value;
            const date = document.getElementById('dateInput').value;
            const time = document.getElementById('timeSelect').value;
            
            // 완료 페이지로 이동하며 데이터 전달
            const queryParams = new URLSearchParams({
                name: name,
                dept: dept,
                doctor: doctor,
                date: date,
                time: time
            });
            
            window.location.href = `/reservation/complete?${queryParams.toString()}`;
        }
    </script>
</body>
</html>
