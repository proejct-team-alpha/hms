<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{pageTitle}}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="bg-slate-50 min-h-screen flex flex-col">
    <!-- Header -->
    <header class="bg-white border-b border-slate-200 h-16 flex items-center px-8 justify-between shrink-0 sticky top-0 z-10">
        <a href="/" class="text-xl font-bold text-slate-800 flex items-center gap-2">
            <i data-lucide="stethoscope" class="text-indigo-600 w-6 h-6"></i>
            MediCare+
        </a>
        <div class="flex items-center gap-4">
            <span class="text-sm font-medium text-slate-600">환자님 환영합니다</span>
            <a href="/logout" class="text-sm text-slate-400 hover:text-slate-600">로그아웃</a>
        </div>
    </header>

    <main class="flex-1 p-8">
        <div class="max-w-4xl mx-auto">
            <h1 class="text-2xl font-bold text-slate-800 mb-6">{{pageTitle}}</h1>
            
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50 border-b border-slate-200">
                            <th class="px-6 py-4 text-sm font-semibold text-slate-600">예약일시</th>
                            <th class="px-6 py-4 text-sm font-semibold text-slate-600">진료과</th>
                            <th class="px-6 py-4 text-sm font-semibold text-slate-600">담당의</th>
                            <th class="px-6 py-4 text-sm font-semibold text-slate-600">상태</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        {{#reservations}}
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-6 py-4 text-sm text-slate-800">{{dateTime}}</td>
                            <td class="px-6 py-4 text-sm text-slate-800">{{department}}</td>
                            <td class="px-6 py-4 text-sm text-slate-800">{{doctor}}</td>
                            <td class="px-6 py-4">
                                <span class="px-2 py-1 text-xs font-medium rounded-full {{statusClass}}">
                                    {{statusText}}
                                </span>
                            </td>
                        </tr>
                        {{/reservations}}
                        {{^reservations}}
                        <tr>
                            <td colspan="4" class="px-6 py-12 text-center text-slate-500">
                                예약 내역이 없습니다.
                            </td>
                        </tr>
                        {{/reservations}}
                    </tbody>
                </table>
            </div>

            <div class="mt-8 flex justify-center">
                <a href="/reservation/index" class="px-6 py-3 bg-indigo-600 text-white font-medium rounded-xl hover:bg-indigo-700 transition-colors shadow-sm">
                    새로운 예약하기
                </a>
            </div>
        </div>
    </main>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>
