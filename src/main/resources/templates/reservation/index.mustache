<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>환자 서비스 - MediCare+</title>
    <link rel="stylesheet" href="/css/tailwind.min.css">
    <script src="/js/lucide.min.js"></script>
    <style>
        /* iframe 스크롤바 스타일링 */
        iframe::-webkit-scrollbar { width: 8px; }
        iframe::-webkit-scrollbar-track { background: #f1f5f9; }
        iframe::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        iframe::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    </style>
</head>
<body class="bg-slate-50 h-screen overflow-hidden flex">
    
    <div class="w-64 bg-white border-r border-slate-200 flex flex-col h-full">
    <div class="h-16 flex items-center px-6 border-b border-slate-200 shrink-0">
        <a href="/reservation" target="_parent" class="text-xl font-bold text-slate-800 flex items-center gap-2">
            <i data-lucide="stethoscope" class="text-indigo-600 w-6 h-6"></i>
            MediCare+
        </a>
    </div>
    <nav class="flex-1 overflow-y-auto py-4 px-3 space-y-1">
        <div class="px-3 mb-2 text-xs font-semibold text-slate-400 uppercase tracking-wider">환자 서비스</div>
        <a href="/reservation/dashboard" target="contentFrame" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition-colors bg-indigo-50 text-indigo-600" data-path="dashboard">
            <i data-lucide="layout-dashboard" class="w-5 h-5"></i>
            대시보드
        </a>
        <a href="/reservation/ai" target="contentFrame" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition-colors" data-path="ai">
            <i data-lucide="sparkles" class="w-5 h-5"></i>
            AI 예약
        </a>
    </nav>
    <div class="p-4 border-t border-slate-200 shrink-0">
        <div class="flex items-center gap-3 px-3 py-2 rounded-xl bg-slate-50 border border-slate-100">
            <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 shrink-0">
                <i data-lucide="user" class="w-4 h-4"></i>
            </div>
            <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-slate-800 truncate">홍길동</p>
                <p class="text-xs text-slate-500 truncate">일반</p>
            </div>
            <a href="/logout" target="_parent" class="text-slate-400 hover:text-slate-600 p-1">
                <i data-lucide="log-out" class="w-4 h-4"></i>
            </a>
        </div>
    </div>
</div>

    <div class="flex-1 flex flex-col h-full overflow-hidden">
        <header class="h-14 border-b border-slate-200 flex items-center px-6 shrink-0 bg-white">
            <h2 id="header-title" class="text-lg font-bold text-slate-800">진료 예약</h2>
            <p id="header-desc" class="ml-4 text-sm text-slate-500">원하시는 예약 방식을 선택해주세요.</p>
        </header>

        <main class="flex-1 overflow-hidden relative bg-slate-50/50">
            <iframe 
                name="contentFrame"
                id="content-frame" 
                src="/reservation/dashboard" 
                class="absolute inset-0 w-full h-full border-none"
                title="환자 서비스 콘텐츠"
            ></iframe>
        </main>

        <footer class="h-12 border-t border-slate-200 flex items-center px-6 shrink-0 bg-white text-sm text-slate-500">
            &copy; 2025 MediCare+
        </footer>
    </div>

    <script>
        lucide.createIcons();

        // iframe 내비게이션 연동
        const iframe = document.getElementById('content-frame');
        const navItems = document.querySelectorAll('.nav-item');
        const headerTitle = document.getElementById('header-title');
        const headerDesc = document.getElementById('header-desc');

        const titleMap = {
            'dashboard.html': { title: '진료 예약', desc: '원하시는 예약 방식을 선택해주세요.' },
            'direct-reservation.html': { title: '직접 선택 예약', desc: '원하시는 진료과와 시간을 선택해주세요.' },
            'symptom-reservation.html': { title: 'AI 증상 분석 예약', desc: '증상을 입력하시면 AI가 적합한 진료과와 전문의를 추천해 드립니다.' },
            'reservation-complete.html': { title: '예약 완료', desc: '진료 예약이 성공적으로 접수되었습니다.' }
        };

        iframe.addEventListener('load', () => {
            try {
                const currentPath = iframe.contentWindow.location.pathname.split('/').pop();
                
                navItems.forEach(item => {
                    const itemPath = item.getAttribute('data-path');
                    if (currentPath === itemPath || (currentPath.includes('reservation') && itemPath === 'dashboard.html')) {
                        item.classList.add('bg-indigo-50', 'text-indigo-600');
                        item.classList.remove('text-slate-600');
                    } else {
                        item.classList.remove('bg-indigo-50', 'text-indigo-600');
                        item.classList.add('text-slate-600');
                    }
                });

                if (titleMap[currentPath] && headerTitle) {
                    headerTitle.textContent = titleMap[currentPath].title;
                    if (headerDesc) headerDesc.textContent = titleMap[currentPath].desc;
                }
            } catch (e) {
                console.log('Cross-origin iframe access denied');
            }
        });
    </script>
</body>
</html>