<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI 증상 분석 예약</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        .animate-in { animation: animateIn 0.3s ease-out forwards; }
        @keyframes animateIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body class="bg-slate-50 min-h-screen flex flex-col">
    <main class="flex-1 overflow-y-auto p-8">
        <div class="max-w-2xl mx-auto">
            <div class="mb-6">
                <a href="{{backUrl}}" class="inline-flex items-center gap-2 text-slate-500 hover:text-slate-800 font-medium transition-colors">
                    <i data-lucide="arrow-left" class="w-5 h-5"></i> 뒤로 가기
                </a>
            </div>

            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600">
                        <i data-lucide="activity" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <h1 class="text-2xl font-bold text-slate-800">AI 증상 분석 예약</h1>
                        <p class="text-slate-500 mt-1">증상을 입력하시면 AI가 적합한 진료과와 전문의를 추천해 드립니다.</p>
                    </div>
                </div>

                <div class="space-y-6">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">어디가 불편하신가요?</label>
                        <textarea
                            id="symptomInput"
                            class="w-full h-32 p-4 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none resize-none"
                            placeholder="예: 어제부터 열이 나고 목이 많이 아파요. 기침도 조금씩 납니다."
                            oninput="checkInput()"
                        ></textarea>
                    </div>

                    <button id="analyzeBtn" onclick="handleAnalyze()" disabled class="w-full py-3 px-4 bg-indigo-600 text-white rounded-xl font-medium hover:bg-indigo-700 disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2 transition-colors">
                        증상 분석하기
                    </button>

                    <div id="resultDiv" class="hidden mt-8 p-6 bg-indigo-50 rounded-xl border border-indigo-100 animate-in">
                        <div class="flex items-start gap-4">
                            <i data-lucide="check-circle-2" class="w-6 h-6 text-indigo-600 shrink-0 mt-0.5"></i>
                            <div class="w-full">
                                <h3 class="text-lg font-semibold text-indigo-900">AI 추천 결과</h3>
                                <p class="text-indigo-700 mt-1 mb-4">입력하신 증상에 가장 적합한 진료과와 전문의입니다.</p>
                                
                                <form action="{{proceedReservationUrl}}" method="POST">
                                    <input type="hidden" name="symptoms" id="hiddenSymptoms">
                                    <input type="hidden" name="deptId" id="hiddenDeptId">
                                    <input type="hidden" name="doctorId" id="hiddenDoctorId">

                                    <div class="grid grid-cols-2 gap-4 mb-6">
                                        <div class="bg-white p-4 rounded-lg border border-indigo-100">
                                            <div class="text-sm text-slate-500 mb-1">추천 진료과</div>
                                            <div id="recDept" class="font-semibold text-slate-800"></div>
                                        </div>
                                        <div class="bg-white p-4 rounded-lg border border-indigo-100">
                                            <div class="text-sm text-slate-500 mb-1">추천 전문의</div>
                                            <div id="recDoctor" class="font-semibold text-slate-800"></div>
                                        </div>
                                    </div>

                                    <button type="submit" class="w-full py-4 bg-indigo-600 text-white rounded-xl font-bold flex items-center justify-center gap-2 hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-200 group">
                                        이 정보로 예약 진행하기
                                        <i data-lucide="arrow-right" class="w-5 h-5 group-hover:translate-x-1 transition-transform"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script>
        lucide.createIcons();

        function checkInput() {
            const val = document.getElementById('symptomInput').value.trim();
            document.getElementById('analyzeBtn').disabled = val.length === 0;
        }

        // 실제 프로젝트에서는 이 부분에서 fetch()를 통해 AI 서버와 통신합니다.
        function handleAnalyze() {
            const symptom = document.getElementById('symptomInput').value.trim();
            if (!symptom) return;

            const btn = document.getElementById('analyzeBtn');
            btn.disabled = true;
            btn.innerHTML = `<div class="w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"></div> AI가 분석 중입니다...`;
            document.getElementById('resultDiv').classList.add('hidden');

            setTimeout(() => {
                btn.innerHTML = '분석 완료';
                btn.classList.replace('bg-indigo-600', 'bg-slate-400');
                
                // 모의 데이터 세팅 (실제로는 API 응답값)
                document.getElementById('recDept').textContent = '내과';
                document.getElementById('recDoctor').textContent = '김의사 원장';
                
                document.getElementById('hiddenSymptoms').value = symptom;
                document.getElementById('hiddenDeptId').value = 'IM'; // 진료과 코드
                document.getElementById('hiddenDoctorId').value = 'DOC1'; // 의사 식별자

                document.getElementById('resultDiv').classList.remove('hidden');
            }, 1500);
        }
    </script>
</body>
</html>