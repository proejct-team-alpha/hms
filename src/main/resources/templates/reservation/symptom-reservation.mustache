<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI 증상 분석 예약 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex flex-col">
  {{> common/header-public}}
  
  <main class="flex-1 overflow-y-auto p-8">
    <div class="max-w-5xl mx-auto">
      <div class="max-w-2xl mx-auto">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600">
              <i data-feather="activity" class="w-6 h-6"></i>
            </div>
            <div>
              <h1 class="text-2xl font-bold text-slate-800">AI 증상 분석 예약</h1>
              <p class="text-slate-500 mt-1">증상을 입력하시면 AI가 적합한 진료과와 전문의를 추천해 드립니다.</p>
            </div>
          </div>

          <div class="space-y-6">
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-2">
                어디가 불편하신가요?
              </label>
              <textarea
                id="symptom-input"
                class="w-full h-32 p-4 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none resize-none"
                placeholder="예: 어제부터 열이 나고 목이 많이 아파요. 기침도 조금씩 납니다."
              ></textarea>
            </div>

            <button
              id="analyze-btn"
              class="w-full py-3 px-4 bg-indigo-600 text-white rounded-xl font-medium hover:bg-indigo-700 disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2 transition-colors"
            >
              <span id="analyze-text">증상 분석하기</span>
            </button>

            <div id="recommendation-result" class="hidden mt-8 p-6 bg-indigo-50 rounded-xl border border-indigo-100 animate-in">
              <div class="flex items-start gap-4">
                <i data-feather="check-circle" class="w-6 h-6 text-indigo-600 shrink-0 mt-0.5"></i>
                <div class="w-full">
                  <h3 class="text-lg font-semibold text-indigo-900">AI 추천 결과</h3>
                  <p class="text-indigo-700 mt-1 mb-4">입력하신 증상에 가장 적합한 진료과와 전문의입니다.</p>
                  
                  <div class="grid grid-cols-2 gap-4 mb-6">
                    <div class="bg-white p-4 rounded-lg border border-indigo-100">
                      <div class="text-sm text-slate-500 mb-1">추천 진료과</div>
                      <div id="rec-dept" class="font-semibold text-slate-800">내과</div>
                    </div>
                    <div class="bg-white p-4 rounded-lg border border-indigo-100">
                      <div class="text-sm text-slate-500 mb-1">추천 전문의</div>
                      <div id="rec-doctor" class="font-semibold text-slate-800">김의사 원장</div>
                    </div>
                  </div>

                  <button
                    onclick="proceedToDirect()"
                    class="w-full py-4 bg-indigo-600 text-white rounded-xl font-bold flex items-center justify-center gap-2 hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-200 group"
                  >
                    이 정보로 예약 진행하기
                    <i data-feather="arrow-right" class="w-5 h-5 group-hover:translate-x-1 transition-transform"></i>
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  {{> common/footer-public}}
  <script>
    feather.replace();

    const symptomInput = document.getElementById('symptom-input');
    const analyzeBtn = document.getElementById('analyze-btn');
    const analyzeText = document.getElementById('analyze-text');
    const recommendationResult = document.getElementById('recommendation-result');

    // 초기 상태
    analyzeBtn.disabled = true;

    symptomInput.addEventListener('input', (e) => {
      analyzeBtn.disabled = e.target.value.trim() === '';
    });

    analyzeBtn.addEventListener('click', () => {
      if (!symptomInput.value.trim()) return;
      
      // 로딩 상태
      analyzeBtn.disabled = true;
      analyzeBtn.innerHTML = `
        <div class="w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
        AI가 분석 중입니다...
      `;
      
      // 시뮬레이션
      setTimeout(() => {
        analyzeBtn.innerHTML = '증상 분석 완료';
        recommendationResult.classList.remove('hidden');
        feather.replace();
      }, 1500);
    });

    function proceedToDirect() {
      const dept = document.getElementById('rec-dept').innerText;
      const doctor = document.getElementById('rec-doctor').innerText;
      // URL 파라미터로 전달
      location.href = \`direct-reservation.html?dept=\${encodeURIComponent(dept)}&doctor=\${encodeURIComponent(doctor)}\`;
    }
  </script>
</body>
</html>
