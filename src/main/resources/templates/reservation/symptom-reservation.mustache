<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI 증상 분석 예약 - MediCare+</title>
  <meta name="_csrf" content="{{_csrf.token}}">
  <meta name="_csrf_header" content="{{_csrf.headerName}}">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/flatpickr.min.css">
  <script src="/js/feather.min.js"></script>
  <script src="/js/flatpickr.min.js"></script>
  <style>
    @keyframes skeleton-shimmer {
      0% { background-position: -200% 0; }
      100% { background-position: 200% 0; }
    }
    .skeleton {
      background: linear-gradient(90deg, #e2e8f0 25%, #f1f5f9 50%, #e2e8f0 75%);
      background-size: 200% 100%;
      animation: skeleton-shimmer 1.5s ease-in-out infinite;
      border-radius: 8px;
    }
    .skeleton-text { height: 14px; margin-bottom: 8px; }
    .skeleton-text.w-60 { width: 60%; }
    .skeleton-text.w-80 { width: 80%; }
    .skeleton-text.w-40 { width: 40%; }
    .skeleton-box { height: 56px; width: 100%; }
  </style>
</head>
<body class="min-h-screen flex flex-col">
  {{> common/header-public}}

  <main class="flex-1 overflow-y-auto p-8">
    <div class="max-w-5xl mx-auto">
      <div class="max-w-2xl mx-auto">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600">
              <i data-feather="activity" class="w-6 h-6"></i>
            </div>
            <div>
              <h1 class="text-2xl font-bold text-slate-800">AI 증상 분석 예약</h1>
              <p class="text-slate-500 mt-1">증상을 입력하시면 AI가 적합한 진료과를 추천해 드립니다.</p>
            </div>
          </div>

          <div class="space-y-6">
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-2">
                어디가 불편하신가요?
              </label>
              <textarea
                id="symptom-input"
                class="w-full h-32 p-4 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none resize-none"
                placeholder="예: 어제부터 열이 나고 목이 많이 아파요. 기침도 조금씩 납니다."
              ></textarea>
            </div>

            <button
              id="analyze-btn"
              class="w-full py-3 px-4 bg-indigo-600 text-white rounded-xl font-medium hover:bg-indigo-700 disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2 transition-colors"
            >
              <span id="analyze-text">증상 분석하기</span>
            </button>

            <!-- 스켈레톤 로딩 -->
            <div id="skeleton-result" class="hidden mt-8 p-6 bg-slate-50 rounded-xl border border-slate-200">
              <div class="flex items-start gap-4">
                <div class="skeleton" style="width:24px;height:24px;border-radius:50%;flex-shrink:0"></div>
                <div class="w-full">
                  <div class="skeleton skeleton-text w-40" style="height:20px;margin-bottom:12px"></div>
                  <div class="skeleton skeleton-text w-80"></div>
                  <div class="skeleton skeleton-text w-60"></div>
                  <div class="skeleton skeleton-box mt-4"></div>
                </div>
              </div>
            </div>

            <!-- AI 추천 결과 + 예약 폼 -->
            <div id="recommendation-result" class="hidden mt-8">
              <!-- 추천 진료과 배너 -->
              <div class="p-4 bg-indigo-50 rounded-xl border border-indigo-100 flex items-start gap-3 mb-6">
                <i data-feather="check-circle" class="w-5 h-5 text-indigo-600 shrink-0 mt-0.5"></i>
                <div>
                  <h3 class="text-lg font-semibold text-indigo-900">AI 추천 결과</h3>
                  <p class="text-indigo-700 mt-1">
                    추천 진료과: <span id="rec-dept" class="font-bold"></span>
                  </p>
                  <p id="rec-reason" class="text-sm text-slate-600 mt-2 hidden"></p>
                  <p class="text-xs text-slate-400 mt-2 flex items-center gap-1">
                    <i data-feather="info" class="w-3 h-3"></i>
                    AI 추천은 참고용이며, 의학적 진단이 아닙니다.
                  </p>
                </div>
              </div>

              <!-- 예약 폼 -->
              <div class="bg-white rounded-xl border border-slate-200 p-6">
                <!-- 인라인 에러 메시지 -->
                <div id="form-error" class="hidden mb-4 p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700 flex items-start gap-2">
                  <i data-feather="alert-triangle" class="w-4 h-4 shrink-0 mt-0.5"></i>
                  <span id="form-error-msg"></span>
                </div>
                <form id="reservation-form" class="space-y-6">
                  <input type="hidden" id="departmentId" name="departmentId" value="">

                  <div class="grid grid-cols-2 gap-6">
                    <div>
                      <label class="block text-sm font-medium text-slate-700 mb-2">환자 성함</label>
                      <div class="relative">
                        <i data-feather="user" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                        <input type="text" id="name" name="name" required
                          class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none"
                          placeholder="홍길동" />
                      </div>
                    </div>
                    <div>
                      <label class="block text-sm font-medium text-slate-700 mb-2">연락처</label>
                      <div class="relative">
                        <i data-feather="phone" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                        <input type="tel" id="phone" name="phone" required
                          class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none"
                          placeholder="010-1234-5678" />
                      </div>
                    </div>
                  </div>

                  <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">전문의 선택</label>
                    <select id="doctor" name="doctorId" required
                      class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none bg-white">
                      <option value="">선택해주세요</option>
                    </select>
                  </div>

                  <div class="grid grid-cols-2 gap-6">
                    <div>
                      <label class="block text-sm font-medium text-slate-700 mb-2">예약 날짜</label>
                      <div class="relative">
                        <i data-feather="calendar" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                        <input type="text" id="date" name="reservationDate" required readonly
                          class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl outline-none bg-slate-100 cursor-not-allowed text-slate-400"
                          placeholder="전문의 선택 후 날짜를 선택하세요" />
                      </div>
                    </div>
                    <div>
                      <label class="block text-sm font-medium text-slate-700 mb-2">예약 시간</label>
                      <div class="relative">
                        <i data-feather="clock" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                        <select id="time" name="timeSlot" required
                          class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none bg-white">
                          <option value="">선택해주세요</option>
                          <option value="09:00">09:00</option>
                          <option value="09:30">09:30</option>
                          <option value="10:00">10:00</option>
                          <option value="10:30">10:30</option>
                          <option value="11:00">11:00</option>
                          <option value="11:30">11:30</option>
                          <option value="12:00">12:00</option>
                          <option value="12:30">12:30</option>
                          <option value="13:00">13:00</option>
                          <option value="13:30">13:30</option>
                          <option value="14:00">14:00</option>
                          <option value="14:30">14:30</option>
                          <option value="15:00">15:00</option>
                          <option value="15:30">15:30</option>
                        </select>
                      </div>
                    </div>
                  </div>

                  <div class="pt-6 border-t border-slate-200">
                    <button type="submit"
                      class="w-full py-4 bg-indigo-600 text-white rounded-xl font-medium text-lg hover:bg-indigo-700 transition-colors shadow-sm">
                      예약 완료하기
                    </button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- 에러 토스트 -->
  <div id="error-toast" class="hidden fixed bottom-6 left-1/2 -translate-x-1/2 flex items-center gap-3 px-5 py-3 bg-slate-800 text-white rounded-xl shadow-lg text-sm z-50">
    <i data-feather="alert-circle" class="w-4 h-4 text-red-400 shrink-0"></i>
    <span>AI 분석에 실패했습니다. 다시 시도해주세요.</span>
  </div>

  {{> common/footer-public}}
  <script>
    feather.replace();

    const symptomInput         = document.getElementById('symptom-input');
    const analyzeBtn           = document.getElementById('analyze-btn');
    const recommendationResult = document.getElementById('recommendation-result');
    const skeletonResult       = document.getElementById('skeleton-result');
    const errorToast           = document.getElementById('error-toast');

    analyzeBtn.disabled = true;

    symptomInput.addEventListener('input', (e) => {
      analyzeBtn.disabled = e.target.value.trim() === '';
    });

    // ── API 호출 ──
    async function callSymptomApi(symptomText) {
      const csrfToken = document.querySelector('meta[name="_csrf"]')?.content || '';
      const res = await fetch('/llm/symptom/analyze', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-TOKEN': csrfToken
        },
        body: JSON.stringify({ symptomText })
      });
      if (!res.ok) throw new Error(`서버 오류: ${res.status}`);
      const json = await res.json();
      return json.body || json;
    }

    // ── 로딩 애니메이션 ──
    const LOADING_STEPS = [
      '증상을 분석하고 있습니다...',
      '진료과를 찾고 있습니다...',
      '전문의를 확인하고 있습니다...',
      '예약 가능 시간을 조회하고 있습니다...',
    ];

    function startLoadingSteps() {
      let step = 0;
      setLoadingText(LOADING_STEPS[step]);
      return setInterval(() => {
        step = (step + 1) % LOADING_STEPS.length;
        setLoadingText(LOADING_STEPS[step]);
      }, 1800);
    }

    function setLoadingText(msg) {
      analyzeBtn.innerHTML = `
        <div class="w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
        ${msg}
      `;
    }

    // ── 분석 버튼 클릭 ──
    analyzeBtn.addEventListener('click', async () => {
      const text = symptomInput.value.trim();
      if (!text) return;

      analyzeBtn.disabled = true;
      const timer = startLoadingSteps();
      skeletonResult.classList.remove('hidden');
      recommendationResult.classList.add('hidden');
      errorToast.classList.add('hidden');

      try {
        const result = await callSymptomApi(text);
        clearInterval(timer);
        console.log('LLM 응답:', result);

        // 추천 진료과 + 이유 표시
        document.getElementById('rec-dept').textContent = result.departmentName;
        document.getElementById('departmentId').value   = result.departmentId;
        const reasonEl = document.getElementById('rec-reason');
        if (result.reason) {
          reasonEl.textContent = result.reason;
          reasonEl.classList.remove('hidden');
        } else {
          reasonEl.classList.add('hidden');
        }

        // 의사 목록 로드 (실패해도 추천 결과는 표시)
        try {
          await loadDoctors(result.departmentId);
        } catch (docErr) {
          console.error('의사 목록 로드 실패:', docErr);
        }

        skeletonResult.classList.add('hidden');
        recommendationResult.classList.remove('hidden');
        feather.replace();
        analyzeBtn.textContent = '';
        const doneSpan = document.createElement('span');
        doneSpan.id = 'analyze-text';
        doneSpan.textContent = '증상 분석 완료';
        analyzeBtn.appendChild(doneSpan);
      } catch (e) {
        console.error('증상 분석 실패:', e);
        clearInterval(timer);
        skeletonResult.classList.add('hidden');
        errorToast.classList.remove('hidden');
        analyzeBtn.disabled = false;
        analyzeBtn.textContent = '';
        const span = document.createElement('span');
        span.id = 'analyze-text';
        span.textContent = '다시 분석하기';
        analyzeBtn.appendChild(span);
        feather.replace();
        setTimeout(() => errorToast.classList.add('hidden'), 5000);
      }
    });

    // ── 의사 목록 로드 ──
    async function loadDoctors(departmentId) {
      const doctorSelect = document.getElementById('doctor');
      doctorSelect.innerHTML = '<option value="">선택해주세요</option>';

      const res = await fetch(`/api/reservation/doctors?departmentId=${departmentId}`);
      if (!res.ok) throw new Error(`의사 목록 조회 실패: ${res.status}`);
      const json = await res.json();
      const doctors = json.body || json;

      doctors.forEach(doctor => {
        const option = document.createElement('option');
        option.value = doctor.id;
        option.textContent = doctor.name;
        option.dataset.availableDays = doctor.availableDays;
        doctorSelect.appendChild(option);
      });
    }

    // ── 슬롯 초기화 ──
    document.querySelectorAll('#time option').forEach(opt => {
      opt.dataset.originalText = opt.textContent;
    });

    function resetSlots() {
      document.querySelectorAll('#time option').forEach(opt => {
        opt.disabled = false;
        opt.classList.remove('text-slate-400');
        opt.textContent = opt.dataset.originalText;
      });
    }

    // ── Flatpickr 날짜 선택 ──
    const DAY_MAP = { SUN: 0, MON: 1, TUE: 2, WED: 3, THU: 4, FRI: 5, SAT: 6 };
    const dateInput = document.getElementById('date');

    function enableDatePicker() {
      dateInput.classList.remove('bg-slate-100', 'cursor-not-allowed', 'text-slate-400');
      dateInput.classList.add('bg-white', 'cursor-pointer', 'focus:ring-2', 'focus:ring-indigo-500', 'focus:border-indigo-500');
      dateInput.placeholder = '날짜를 선택해주세요';
    }

    function disableDatePicker() {
      dateInput.classList.remove('bg-white', 'cursor-pointer', 'focus:ring-2', 'focus:ring-indigo-500', 'focus:border-indigo-500');
      dateInput.classList.add('bg-slate-100', 'cursor-not-allowed', 'text-slate-400');
      dateInput.placeholder = '전문의 선택 후 날짜를 선택하세요';
    }

    const datePicker = flatpickr(dateInput, {
      dateFormat: 'Y-m-d',
      minDate: 'today',
      animate: false,
      position: 'below',
      disable: [() => true],
      onChange: async (selectedDates, dateStr) => {
        const doctorId = document.getElementById('doctor').value;
        if (!dateStr || !doctorId) { resetSlots(); return; }
        try {
          const res = await fetch(`/api/reservation/booked-slots?doctorId=${doctorId}&date=${dateStr}`);
          if (!res.ok) throw new Error(`서버 오류: ${res.status}`);
          const bookedJson = await res.json();
          const booked = bookedJson.body || bookedJson;
          const today = new Date();
          const todayStr = today.getFullYear() + '-'
            + String(today.getMonth() + 1).padStart(2, '0') + '-'
            + String(today.getDate()).padStart(2, '0');
          const isToday = dateStr === todayStr;
          const nowMinutes = today.getHours() * 60 + today.getMinutes();

          document.querySelectorAll('#time option').forEach(opt => {
            const original = opt.dataset.originalText;
            if (!original) return;
            if (booked.includes(original)) {
              opt.disabled = true;
              opt.classList.add('text-slate-400');
              opt.textContent = original + ' (예약불가)';
            } else if (isToday && opt.value) {
              const [h, m] = opt.value.split(':').map(Number);
              if (h * 60 + m <= nowMinutes) {
                opt.disabled = true;
                opt.classList.add('text-slate-400');
                opt.textContent = original;
              } else {
                opt.disabled = false;
                opt.classList.remove('text-slate-400');
                opt.textContent = original;
              }
            } else {
              opt.disabled = false;
              opt.classList.remove('text-slate-400');
              opt.textContent = original;
            }
          });
        } catch (err) {
          console.error('예약 가능 슬롯 조회 실패:', err);
          resetSlots();
        }
      }
    });

    // ── 의사 변경 → 날짜 picker 갱신 ──
    document.getElementById('doctor').addEventListener('change', function () {
      const selectedOption = this.options[this.selectedIndex];
      const availableDaysStr = selectedOption.dataset.availableDays || '';

      const availableDayNums = availableDaysStr
        .split(',')
        .map(d => DAY_MAP[d.trim()])
        .filter(n => n !== undefined);

      datePicker.clear();
      resetSlots();
      if (availableDayNums.length > 0) {
        datePicker.set('disable', [
          function (date) { return !availableDayNums.includes(date.getDay()); }
        ]);
        enableDatePicker();
      } else {
        datePicker.set('disable', [() => true]);
        disableDatePicker();
      }
    });

    // ── 예약 폼 AJAX 제출 ──
    const formError = document.getElementById('form-error');
    const formErrorMsg = document.getElementById('form-error-msg');

    function showFormError(msg) {
      formErrorMsg.textContent = msg;
      formError.classList.remove('hidden');
      feather.replace();
      formError.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    function hideFormError() {
      formError.classList.add('hidden');
    }

    document.getElementById('reservation-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      hideFormError();

      const name = document.getElementById('name').value.trim();
      const phone = document.getElementById('phone').value.trim();
      const doctorId = document.getElementById('doctor').value;
      const departmentId = document.getElementById('departmentId').value;
      const reservationDate = document.getElementById('date').value;
      const timeSlot = document.getElementById('time').value;

      // 클라이언트 검증
      if (!name) { showFormError('이름을 입력해주세요.'); return; }
      if (!phone || !/^01[0-9][-\s]?(\d{3,4})[-\s]?\d{4}$/.test(phone)) {
        showFormError('연락처 형식이 올바르지 않습니다. (예: 010-1234-5678)'); return;
      }
      if (!doctorId) { showFormError('전문의를 선택해주세요.'); return; }
      if (!reservationDate) { showFormError('예약 날짜를 선택해주세요.'); return; }
      if (!timeSlot) { showFormError('예약 시간을 선택해주세요.'); return; }

      const submitBtn = e.target.querySelector('button[type="submit"]');
      submitBtn.disabled = true;
      submitBtn.textContent = '예약 처리 중...';

      try {
        const csrfToken = document.querySelector('meta[name="_csrf"]')?.content || '';
        const res = await fetch('/api/reservation/create', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-TOKEN': csrfToken
          },
          body: JSON.stringify({
            name, phone, doctorId: Number(doctorId),
            departmentId: Number(departmentId),
            reservationDate, timeSlot
          })
        });

        const json = await res.json();

        if (res.ok) {
          // 성공 — 완료 페이지로 이동 (flash attribute 대신 query param)
          const info = json.body;
          const params = new URLSearchParams({
            reservationNumber: info.reservationNumber || '',
            patientName: info.patientName || '',
            departmentName: info.departmentName || '',
            doctorName: info.doctorName || '',
            reservationDate: info.reservationDate || '',
            timeSlot: info.timeSlot || ''
          });
          window.location.href = '/reservation/complete?' + params.toString();
        } else {
          showFormError(json.msg || '예약에 실패했습니다. 다시 시도해주세요.');
          submitBtn.disabled = false;
          submitBtn.textContent = '예약 완료하기';
        }
      } catch (err) {
        console.error('예약 요청 실패:', err);
        showFormError('서버와 통신에 실패했습니다. 다시 시도해주세요.');
        submitBtn.disabled = false;
        submitBtn.textContent = '예약 완료하기';
      }
    });
  </script>
</body>
</html>
