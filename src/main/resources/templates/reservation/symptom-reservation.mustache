<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI 증상 분석 예약</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        .animate-in { animation: animateIn 0.3s ease-out forwards; }
        @keyframes animateIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body class="bg-slate-50 min-h-screen flex flex-col">
    <!-- Header (PatientLayout) -->
    <header class="bg-white border-b border-slate-200 h-16 flex items-center px-8 justify-between shrink-0 sticky top-0 z-10">
        <a href="/" class="text-xl font-bold text-slate-800 flex items-center gap-2">
            <i data-lucide="stethoscope" class="text-indigo-600 w-6 h-6"></i>
            MediCare+
        </a>
        <a href="/" class="flex items-center gap-2 text-sm font-medium text-slate-600 hover:text-indigo-600 transition-colors">
            <i data-lucide="home" class="w-4 h-4"></i>
            처음으로
        </a>
    </header>

    <!-- Main Content -->
    <main class="flex-1 overflow-y-auto p-8">
        <div class="max-w-2xl mx-auto">
            <div class="mb-6">
                <a href="/reservation/index" class="inline-flex items-center gap-2 text-slate-500 hover:text-slate-800 font-medium transition-colors">
                    <i data-lucide="arrow-left" class="w-5 h-5"></i>
                    뒤로 가기
                </a>
            </div>

        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600">
                    <i data-lucide="activity" class="w-6 h-6"></i>
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-slate-800">AI 증상 분석 예약</h1>
                    <p class="text-slate-500 mt-1">증상을 입력하시면 AI가 적합한 진료과와 전문의를 추천해 드립니다.</p>
                </div>
            </div>

            <div class="space-y-6">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">
                        어디가 불편하신가요?
                    </label>
                    <textarea
                        id="symptomInput"
                        class="w-full h-32 p-4 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none resize-none"
                        placeholder="예: 어제부터 열이 나고 목이 많이 아파요. 기침도 조금씩 납니다."
                        oninput="checkInput()"
                    ></textarea>
                </div>

                <button
                    id="analyzeBtn"
                    onclick="handleAnalyze()"
                    disabled
                    class="w-full py-3 px-4 bg-indigo-600 text-white rounded-xl font-medium hover:bg-indigo-700 disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2 transition-colors"
                >
                    증상 분석하기
                </button>

                <!-- AI 추천 결과 (초기에는 숨김) -->
                <div id="resultDiv" class="hidden mt-8 p-6 bg-indigo-50 rounded-xl border border-indigo-100 animate-in">
                    <div class="flex items-start gap-4">
                        <i data-lucide="check-circle-2" class="w-6 h-6 text-indigo-600 shrink-0 mt-0.5"></i>
                        <div class="w-full">
                            <h3 class="text-lg font-semibold text-indigo-900">AI 추천 결과</h3>
                            <p class="text-indigo-700 mt-1 mb-4">입력하신 증상에 가장 적합한 진료과와 전문의입니다.</p>
                            
                            <div class="grid grid-cols-2 gap-4 mb-6">
                                <div class="bg-white p-4 rounded-lg border border-indigo-100">
                                    <div class="text-sm text-slate-500 mb-1">추천 진료과</div>
                                    <div id="recDept" class="font-semibold text-slate-800">내과</div>
                                </div>
                                <div class="bg-white p-4 rounded-lg border border-indigo-100">
                                    <div class="text-sm text-slate-500 mb-1">추천 전문의</div>
                                    <div id="recDoctor" class="font-semibold text-slate-800">김의사 원장</div>
                                </div>
                            </div>

                            <button
                                onclick="handleProceed()"
                                class="w-full py-4 bg-indigo-600 text-white rounded-xl font-bold flex items-center justify-center gap-2 hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-200 group"
                            >
                                이 정보로 예약 진행하기
                                <i data-lucide="arrow-right" class="w-5 h-5 group-hover:translate-x-1 transition-transform"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script>
        // 아이콘 초기화
        lucide.createIcons();

        const symptomInput = document.getElementById('symptomInput');
        const analyzeBtn = document.getElementById('analyzeBtn');
        const resultDiv = document.getElementById('resultDiv');

        function checkInput() {
            if (symptomInput.value.trim().length > 0) {
                analyzeBtn.disabled = false;
            } else {
                analyzeBtn.disabled = true;
            }
        }

        function handleAnalyze() {
            const symptom = symptomInput.value.trim();
            if (!symptom) return;

            // 분석 중 상태로 변경
            analyzeBtn.disabled = true;
            analyzeBtn.innerHTML = `
                <div class="w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
                AI가 분석 중입니다...
            `;
            resultDiv.classList.add('hidden');

            // API 호출 시뮬레이션 (1.5초 후 결과 표시)
            setTimeout(() => {
                analyzeBtn.innerHTML = '분석 완료';
                analyzeBtn.classList.replace('bg-indigo-600', 'bg-slate-400');
                analyzeBtn.classList.replace('hover:bg-indigo-700', 'hover:bg-slate-500');
                
                // 모의 추천 데이터 (실제로는 AI 응답에 따라 변경)
                const recommendedDept = '내과';
                const recommendedDoctor = '김의사 원장';
                
                document.getElementById('recDept').textContent = recommendedDept;
                document.getElementById('recDoctor').textContent = recommendedDoctor;
                
                resultDiv.classList.remove('hidden');
            }, 1500);
        }

        function handleProceed() {
            const dept = document.getElementById('recDept').textContent;
            const doctor = document.getElementById('recDoctor').textContent;
            
            // URL 파라미터로 추천 정보 전달
            window.location.href = `/reservation/direct-reservation?dept=${encodeURIComponent(dept)}&doctor=${encodeURIComponent(doctor)}`;
        }
    </script>
</body>
</html>
