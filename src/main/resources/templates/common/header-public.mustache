<header class="bg-white border-b border-slate-200 h-16 flex items-center px-8 justify-between shrink-0 sticky top-0 z-10">
    <a href="{{homeUrl}}" class="text-xl font-bold text-slate-800 flex items-center gap-2">
        <i data-lucide="stethoscope" class="text-indigo-600 w-6 h-6"></i>
        {{logoText}}
    </a>
    
    <div class="flex items-center gap-6">
        {{#showNotification}}
        <button class="relative p-2 text-slate-400 hover:text-slate-600 transition-colors hidden md:block">
            <i data-lucide="bell" class="w-5 h-5"></i>
            {{#hasNewNotification}}
            <span class="absolute top-1.5 right-1.5 w-2 h-2 bg-red-500 rounded-full border-2 border-white"></span>
            {{/hasNewNotification}}
        </button>
        {{/showNotification}}
        
        <a href="{{homeUrl}}" class="flex items-center gap-2 text-sm font-medium text-slate-600 hover:text-indigo-600 transition-colors">
            <i data-lucide="home" class="w-4 h-4"></i>
            처음으로
        </a>
    </div>
</header>