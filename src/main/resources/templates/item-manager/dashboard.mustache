<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>물품 담당자 대시보드</title>
    <link rel="stylesheet" href="/css/tailwind.min.css">
    <script src="/js/lucide.min.js"></script>
    <script src="/js/chart.min.js"></script>
</head>
<body class="bg-slate-50 min-h-screen p-6">
    <div class="max-w-7xl mx-auto space-y-6">
        <!-- 헤더 -->
        <div class="flex justify-between items-center">
            <h1 class="text-2xl font-bold text-slate-800">물품 담당자 대시보드</h1>
            <a href="item-form.html" class="px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 transition-colors flex items-center gap-2">
                <i data-lucide="plus" class="w-5 h-5"></i>
                물품 등록
            </a>
        </div>
        
        <!-- 통계 카드 -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-indigo-50 rounded-xl flex items-center justify-center text-indigo-600">
                        <i data-lucide="package" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <div class="text-sm font-medium text-slate-500">총 관리 물품</div>
                        <div class="text-2xl font-bold text-slate-800">124개</div>
                    </div>
                </div>
            </div>
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center text-red-600">
                        <i data-lucide="alert-triangle" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <div class="text-sm font-medium text-slate-500">재고 부족 물품</div>
                        <div class="text-2xl font-bold text-red-600">3개</div>
                    </div>
                </div>
            </div>
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-emerald-50 rounded-xl flex items-center justify-center text-emerald-600">
                        <i data-lucide="trending-up" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <div class="text-sm font-medium text-slate-500">금일 입고 건수</div>
                        <div class="text-2xl font-bold text-emerald-600">12건</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- 입출고 현황 차트 -->
            <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-lg font-bold text-slate-800">입출고 현황 (최근 7일)</h2>
                    <div class="flex items-center gap-4 text-xs font-medium">
                        <div class="flex items-center gap-1.5">
                            <div class="w-3 h-3 bg-indigo-500 rounded-sm"></div>
                            <span class="text-slate-600">입고</span>
                        </div>
                        <div class="flex items-center gap-1.5">
                            <div class="w-3 h-3 bg-slate-300 rounded-sm"></div>
                            <span class="text-slate-600">출고</span>
                        </div>
                    </div>
                </div>
                <div class="h-[300px] w-full relative">
                    <canvas id="inventoryChart"></canvas>
                </div>
            </div>

            <!-- 재고 부족 알림 -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
                <div class="flex justify-between items-center mb-4">
                    <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2">
                        <i data-lucide="alert-triangle" class="w-5 h-5 text-red-500"></i>
                        재고 부족 알림
                    </h2>
                    <a href="item-list.html" class="text-sm text-indigo-600 font-medium flex items-center gap-1 hover:text-indigo-800">
                        전체보기 <i data-lucide="arrow-right" class="w-4 h-4"></i>
                    </a>
                </div>
                <div class="space-y-4">
                    <!-- 아이템 1 -->
                    <div class="p-4 bg-red-50/50 rounded-xl border border-red-100 space-y-3">
                        <div class="flex items-center justify-between">
                            <div>
                                <div class="font-bold text-slate-800">주사기 (10ml)</div>
                                <div class="text-xs text-slate-500">의료소모품</div>
                            </div>
                            <div class="text-right">
                                <div class="text-xs font-bold text-red-600">현재 50개</div>
                                <div class="text-[10px] text-slate-400">최소 100개</div>
                            </div>
                        </div>
                        <a href="item-form.html?id=1" class="w-full py-2 bg-white border border-red-200 text-red-600 text-xs font-bold rounded-lg hover:bg-red-50 transition-colors flex items-center justify-center gap-1.5">
                            <i data-lucide="plus" class="w-3.5 h-3.5"></i>
                            재고 추가
                        </a>
                    </div>
                    
                    <!-- 아이템 2 -->
                    <div class="p-4 bg-red-50/50 rounded-xl border border-red-100 space-y-3">
                        <div class="flex items-center justify-between">
                            <div>
                                <div class="font-bold text-slate-800">알코올 솜</div>
                                <div class="text-xs text-slate-500">의료소모품</div>
                            </div>
                            <div class="text-right">
                                <div class="text-xs font-bold text-red-600">현재 120박스</div>
                                <div class="text-[10px] text-slate-400">최소 200박스</div>
                            </div>
                        </div>
                        <a href="item-form.html?id=2" class="w-full py-2 bg-white border border-red-200 text-red-600 text-xs font-bold rounded-lg hover:bg-red-50 transition-colors flex items-center justify-center gap-1.5">
                            <i data-lucide="plus" class="w-3.5 h-3.5"></i>
                            재고 추가
                        </a>
                    </div>
                    
                    <!-- 아이템 3 -->
                    <div class="p-4 bg-red-50/50 rounded-xl border border-red-100 space-y-3">
                        <div class="flex items-center justify-between">
                            <div>
                                <div class="font-bold text-slate-800">A4 용지</div>
                                <div class="text-xs text-slate-500">사무용품</div>
                            </div>
                            <div class="text-right">
                                <div class="text-xs font-bold text-red-600">현재 2박스</div>
                                <div class="text-[10px] text-slate-400">최소 5박스</div>
                            </div>
                        </div>
                        <a href="item-form.html?id=3" class="w-full py-2 bg-white border border-red-200 text-red-600 text-xs font-bold rounded-lg hover:bg-red-50 transition-colors flex items-center justify-center gap-1.5">
                            <i data-lucide="plus" class="w-3.5 h-3.5"></i>
                            재고 추가
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="/js/app.js"></script>
    <script src="/js/pages/item-manager-dashboard.js"></script>
</body>
</html>
