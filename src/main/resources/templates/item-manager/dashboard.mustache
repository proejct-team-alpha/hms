<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>물품 담당자 대시보드 - MediCare+</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/feather-icons"></script>
  <link rel="stylesheet" href="css/style.css">
</head>
<body>
  
  <script src="components/sidebar.js"></script>

  <div class="main-content">
    <script src="components/header.js"></script>
    
    <main class="content-wrapper">
      <div class="space-y-6 max-w-6xl mx-auto">
        <div class="flex justify-between items-center">
          <h1 class="text-2xl font-bold text-slate-800">물품 담당자 대시보드</h1>
          <a href="item-form.html" class="px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 transition-colors flex items-center gap-2">
            <i data-feather="plus" class="w-5 h-5"></i>
            물품 등록
          </a>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6" id="stats-container">
          <!-- Stats injected by JS -->
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <!-- Inbound/Outbound Status Graph -->
          <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
            <div class="flex justify-between items-center mb-6">
              <h2 class="text-lg font-bold text-slate-800">입출고 현황 (최근 7일)</h2>
              <div class="flex items-center gap-4 text-xs font-medium">
                <div class="flex items-center gap-1.5">
                  <div class="w-3 h-3 bg-indigo-500 rounded-sm"></div>
                  <span class="text-slate-600">입고</span>
                </div>
                <div class="flex items-center gap-1.5">
                  <div class="w-3 h-3 bg-slate-300 rounded-sm"></div>
                  <span class="text-slate-600">출고</span>
                </div>
              </div>
            </div>
            <div class="h-[300px] w-full flex items-end justify-between gap-2 pt-8 border-b border-slate-100 relative">
              <!-- Grid lines -->
              <div class="absolute inset-0 flex flex-col justify-between pointer-events-none">
                <div class="w-full border-t border-dashed border-slate-200 h-0"></div>
                <div class="w-full border-t border-dashed border-slate-200 h-0"></div>
                <div class="w-full border-t border-dashed border-slate-200 h-0"></div>
                <div class="w-full border-t border-dashed border-slate-200 h-0"></div>
                <div class="w-full border-t border-dashed border-slate-200 h-0"></div>
              </div>
              
              <!-- Bars (Mocked for HTML version) -->
              <div class="flex-1 flex flex-col items-center gap-2 z-10">
                <div class="flex items-end gap-1 w-full justify-center h-[250px]">
                  <div class="w-4 bg-indigo-500 rounded-t-sm" style="height: 45%"></div>
                  <div class="w-4 bg-slate-300 rounded-t-sm" style="height: 30%"></div>
                </div>
                <div class="text-xs text-slate-500">02/25</div>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2 z-10">
                <div class="flex items-end gap-1 w-full justify-center h-[250px]">
                  <div class="w-4 bg-indigo-500 rounded-t-sm" style="height: 52%"></div>
                  <div class="w-4 bg-slate-300 rounded-t-sm" style="height: 45%"></div>
                </div>
                <div class="text-xs text-slate-500">02/26</div>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2 z-10">
                <div class="flex items-end gap-1 w-full justify-center h-[250px]">
                  <div class="w-4 bg-indigo-500 rounded-t-sm" style="height: 38%"></div>
                  <div class="w-4 bg-slate-300 rounded-t-sm" style="height: 42%"></div>
                </div>
                <div class="text-xs text-slate-500">02/27</div>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2 z-10">
                <div class="flex items-end gap-1 w-full justify-center h-[250px]">
                  <div class="w-4 bg-indigo-500 rounded-t-sm" style="height: 65%"></div>
                  <div class="w-4 bg-slate-300 rounded-t-sm" style="height: 50%"></div>
                </div>
                <div class="text-xs text-slate-500">02/28</div>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2 z-10">
                <div class="flex items-end gap-1 w-full justify-center h-[250px]">
                  <div class="w-4 bg-indigo-500 rounded-t-sm" style="height: 48%"></div>
                  <div class="w-4 bg-slate-300 rounded-t-sm" style="height: 35%"></div>
                </div>
                <div class="text-xs text-slate-500">03/01</div>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2 z-10">
                <div class="flex items-end gap-1 w-full justify-center h-[250px]">
                  <div class="w-4 bg-indigo-500 rounded-t-sm" style="height: 55%"></div>
                  <div class="w-4 bg-slate-300 rounded-t-sm" style="height: 48%"></div>
                </div>
                <div class="text-xs text-slate-500">03/02</div>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2 z-10">
                <div class="flex items-end gap-1 w-full justify-center h-[250px]">
                  <div class="w-4 bg-indigo-500 rounded-t-sm" style="height: 42%"></div>
                  <div class="w-4 bg-slate-300 rounded-t-sm" style="height: 38%"></div>
                </div>
                <div class="text-xs text-slate-500">03/03</div>
              </div>
            </div>
          </div>

          <!-- Low Stock Alerts -->
          <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 flex flex-col">
            <div class="flex justify-between items-center mb-4">
              <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2">
                <i data-feather="alert-triangle" class="w-5 h-5 text-red-500"></i>
                재고 부족 알림
              </h2>
              <a href="item-list.html" class="text-sm text-indigo-600 font-medium flex items-center gap-1 hover:text-indigo-800">
                전체보기 <i data-feather="arrow-right" class="w-4 h-4"></i>
              </a>
            </div>
            <div class="space-y-4 flex-1 overflow-y-auto" id="low-stock-container">
              <!-- Injected by JS -->
            </div>
          </div>
        </div>
      </div>
    </main>

    <script src="components/footer.js"></script>
  </div>

  <script src="js/data.js"></script>
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const items = getItems();
      const history = getHistory();
      
      const totalItems = items.length;
      const lowStockItems = items.filter(i => i.stock <= i.minStock);
      
      const today = new Date().toISOString().split('T')[0];
      const todayInbounds = history.filter(h => h.type === 'IN' && h.date.startsWith(today)).length;
      
      // Render Stats
      document.getElementById('stats-container').innerHTML = `
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-indigo-50 rounded-xl flex items-center justify-center text-indigo-600">
              <i data-feather="package" class="w-6 h-6"></i>
            </div>
            <div>
              <div class="text-sm font-medium text-slate-500">총 관리 물품</div>
              <div class="text-2xl font-bold text-slate-800">${totalItems}개</div>
            </div>
          </div>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center text-red-600">
              <i data-feather="alert-triangle" class="w-6 h-6"></i>
            </div>
            <div>
              <div class="text-sm font-medium text-slate-500">재고 부족 물품</div>
              <div class="text-2xl font-bold text-red-600">${lowStockItems.length}개</div>
            </div>
          </div>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-emerald-50 rounded-xl flex items-center justify-center text-emerald-600">
              <i data-feather="trending-up" class="w-6 h-6"></i>
            </div>
            <div>
              <div class="text-sm font-medium text-slate-500">금일 입고 건수</div>
              <div class="text-2xl font-bold text-emerald-600">${todayInbounds}건</div>
            </div>
          </div>
        </div>
      `;

      // Render Low Stock
      const lowStockContainer = document.getElementById('low-stock-container');
      if (lowStockItems.length > 0) {
        lowStockContainer.innerHTML = lowStockItems.slice(0, 5).map(item => `
          <div class="p-4 bg-red-50/50 rounded-xl border border-red-100 space-y-3">
            <div class="flex items-center justify-between">
              <div>
                <div class="font-bold text-slate-800">${item.name}</div>
                <div class="text-xs text-slate-500">${item.category}</div>
              </div>
              <div class="text-right">
                <div class="text-xs font-bold text-red-600">
                  현재 ${item.stock}${item.unit}
                </div>
                <div class="text-[10px] text-slate-400">
                  최소 ${item.minStock}${item.unit}
                </div>
              </div>
            </div>
            <a href="item-form.html?id=${item.id}" class="w-full py-2 bg-white border border-red-200 text-red-600 text-xs font-bold rounded-lg hover:bg-red-50 transition-colors flex items-center justify-center gap-1.5">
              <i data-feather="plus" class="w-3.5 h-3.5"></i>
              재고 추가
            </a>
          </div>
        `).join('');
      } else {
        lowStockContainer.innerHTML = `
          <div class="p-8 text-center text-slate-500 text-sm bg-slate-50 rounded-xl border border-dashed border-slate-200">
            재고가 부족한 물품이 없습니다.
          </div>
        `;
      }

      feather.replace();
    });
  </script>
</body>
</html>
