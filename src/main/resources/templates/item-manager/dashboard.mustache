</head>
<body>
  
  {{> components/sidebar}}

  <div class="main-content">
    {{> components/header}}
    
    <main class="content-wrapper">
      <div class="space-y-6 max-w-6xl mx-auto">
        <div class="flex justify-between items-center">
          <h1 class="text-2xl font-bold text-slate-800">물품 담당자 대시보드</h1>
          <a href="/items/create" class="px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 transition-colors flex items-center gap-2">
            <i data-feather="plus" class="w-5 h-5"></i>
            물품 등록
          </a>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-indigo-50 rounded-xl flex items-center justify-center text-indigo-600">
                <i data-feather="package" class="w-6 h-6"></i>
              </div>
              <div>
                <div class="text-sm font-medium text-slate-500">총 관리 물품</div>
                <div class="text-2xl font-bold text-slate-800">{{totalItemsCount}}개</div>
              </div>
            </div>
          </div>
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center text-red-600">
                <i data-feather="alert-triangle" class="w-6 h-6"></i>
              </div>
              <div>
                <div class="text-sm font-medium text-slate-500">재고 부족 물품</div>
                <div class="text-2xl font-bold text-red-600">{{lowStockCount}}개</div>
              </div>
            </div>
          </div>
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-emerald-50 rounded-xl flex items-center justify-center text-emerald-600">
                <i data-feather="trending-up" class="w-6 h-6"></i>
              </div>
              <div>
                <div class="text-sm font-medium text-slate-500">금일 입고 건수</div>
                <div class="text-2xl font-bold text-emerald-600">{{todayInboundCount}}건</div>
              </div>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
             </div>

          <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 flex flex-col">
            <div class="flex justify-between items-center mb-4">
              <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2">
                <i data-feather="alert-triangle" class="w-5 h-5 text-red-500"></i>
                재고 부족 알림
              </h2>
              <a href="/items" class="text-sm text-indigo-600 font-medium flex items-center gap-1 hover:text-indigo-800">
                전체보기 <i data-feather="arrow-right" class="w-4 h-4"></i>
              </a>
            </div>
            <div class="space-y-4 flex-1 overflow-y-auto">
              {{#lowStockItems}}
              <div class="p-4 bg-red-50/50 rounded-xl border border-red-100 space-y-3">
                <div class="flex items-center justify-between">
                  <div>
                    <div class="font-bold text-slate-800">{{name}}</div>
                    <div class="text-xs text-slate-500">{{category}}</div>
                  </div>
                  <div class="text-right">
                    <div class="text-xs font-bold text-red-600">현재 {{stock}}{{unit}}</div>
                    <div class="text-[10px] text-slate-400">최소 {{minStock}}{{unit}}</div>
                  </div>
                </div>
                <a href="/items/{{id}}/edit" class="w-full py-2 bg-white border border-red-200 text-red-600 text-xs font-bold rounded-lg hover:bg-red-50 transition-colors flex items-center justify-center gap-1.5">
                  <i data-feather="plus" class="w-3.5 h-3.5"></i>
                  재고 추가
                </a>
              </div>
              {{/lowStockItems}}

              {{^lowStockItems}}
              <div class="p-8 text-center text-slate-500 text-sm bg-slate-50 rounded-xl border border-dashed border-slate-200">
                재고가 부족한 물품이 없습니다.
              </div>
              {{/lowStockItems}}
            </div>
          </div>
        </div>
      </div>
    </main>

    {{> components/footer}}
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      feather.replace();
    });
  </script>
</body>
</html>