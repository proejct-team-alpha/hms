<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>물품 담당자 대시보드 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-item-manager}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="space-y-6 max-w-6xl mx-auto">
        <div class="flex justify-between items-center">
          <h1 class="text-2xl font-bold text-slate-800">물품 담당자 대시보드</h1>
          <a href="/item-manager/item-form" class="px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 transition-colors flex items-center gap-2">
            <i data-feather="plus" class="w-5 h-5"></i>
            물품 등록
          </a>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-indigo-50 rounded-xl flex items-center justify-center text-indigo-600">
                <i data-feather="package" class="w-6 h-6"></i>
              </div>
              <div>
                <div class="text-sm font-medium text-slate-500">총 관리 물품</div>
                <div class="text-2xl font-bold text-slate-800">{{dashboard.totalItems}}개</div>
              </div>
            </div>
          </div>
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center text-red-600">
                <i data-feather="alert-triangle" class="w-6 h-6"></i>
              </div>
              <div>
                <div class="text-sm font-medium text-slate-500">재고 부족 물품</div>
                <div class="text-2xl font-bold text-red-600">{{dashboard.lowStockCount}}개</div>
              </div>
            </div>
          </div>
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-emerald-50 rounded-xl flex items-center justify-center text-emerald-600">
                <i data-feather="trending-up" class="w-6 h-6"></i>
              </div>
              <div>
                <div class="text-sm font-medium text-slate-500">전체 물품 현황</div>
                <div class="text-2xl font-bold text-emerald-600">정상</div>
              </div>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <!-- 입출고 현황 그래프 -->
          <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
            <div class="flex justify-between items-center mb-6">
              <h2 class="text-lg font-bold text-slate-800">입출고 현황 (최근 7일)</h2>
              <div class="flex items-center gap-4 text-xs font-medium">
                <div class="flex items-center gap-1.5">
                  <div class="w-3 h-3 bg-indigo-500 rounded-sm"></div>
                  <span class="text-slate-600">입고</span>
                </div>
                <div class="flex items-center gap-1.5">
                  <div class="w-3 h-3 bg-slate-300 rounded-sm"></div>
                  <span class="text-slate-600">출고</span>
                </div>
              </div>
            </div>
            <div class="h-[220px] w-full flex items-end justify-between gap-2 pb-6 border-b border-slate-100 relative">
              <div class="absolute inset-0 flex flex-col justify-between pointer-events-none pb-6">
                <div class="w-full border-t border-dashed border-slate-200 h-0"></div>
                <div class="w-full border-t border-dashed border-slate-200 h-0"></div>
                <div class="w-full border-t border-dashed border-slate-200 h-0"></div>
                <div class="w-full border-t border-dashed border-slate-200 h-0"></div>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2 z-10">
                <div class="flex items-end gap-1 w-full justify-center" style="height:170px">
                  <div class="w-4 bg-indigo-500 rounded-t-sm" style="height:45%"></div>
                  <div class="w-4 bg-slate-300 rounded-t-sm" style="height:30%"></div>
                </div>
                <div class="text-xs text-slate-500">03/06</div>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2 z-10">
                <div class="flex items-end gap-1 w-full justify-center" style="height:170px">
                  <div class="w-4 bg-indigo-500 rounded-t-sm" style="height:52%"></div>
                  <div class="w-4 bg-slate-300 rounded-t-sm" style="height:45%"></div>
                </div>
                <div class="text-xs text-slate-500">03/07</div>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2 z-10">
                <div class="flex items-end gap-1 w-full justify-center" style="height:170px">
                  <div class="w-4 bg-indigo-500 rounded-t-sm" style="height:38%"></div>
                  <div class="w-4 bg-slate-300 rounded-t-sm" style="height:42%"></div>
                </div>
                <div class="text-xs text-slate-500">03/08</div>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2 z-10">
                <div class="flex items-end gap-1 w-full justify-center" style="height:170px">
                  <div class="w-4 bg-indigo-500 rounded-t-sm" style="height:65%"></div>
                  <div class="w-4 bg-slate-300 rounded-t-sm" style="height:50%"></div>
                </div>
                <div class="text-xs text-slate-500">03/09</div>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2 z-10">
                <div class="flex items-end gap-1 w-full justify-center" style="height:170px">
                  <div class="w-4 bg-indigo-500 rounded-t-sm" style="height:48%"></div>
                  <div class="w-4 bg-slate-300 rounded-t-sm" style="height:35%"></div>
                </div>
                <div class="text-xs text-slate-500">03/10</div>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2 z-10">
                <div class="flex items-end gap-1 w-full justify-center" style="height:170px">
                  <div class="w-4 bg-indigo-500 rounded-t-sm" style="height:55%"></div>
                  <div class="w-4 bg-slate-300 rounded-t-sm" style="height:48%"></div>
                </div>
                <div class="text-xs text-slate-500">03/11</div>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2 z-10">
                <div class="flex items-end gap-1 w-full justify-center" style="height:170px">
                  <div class="w-4 bg-indigo-500 rounded-t-sm" style="height:42%"></div>
                  <div class="w-4 bg-slate-300 rounded-t-sm" style="height:38%"></div>
                </div>
                <div class="text-xs text-slate-500">03/12</div>
              </div>
            </div>
          </div>

          <!-- 재고 부족 알림 -->
          <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 flex flex-col">
            <div class="flex justify-between items-center mb-4">
              <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2">
                <i data-feather="alert-triangle" class="w-5 h-5 text-red-500"></i>
                재고 부족 알림
              </h2>
              <a href="/item-manager/item-list" class="text-sm text-indigo-600 font-medium flex items-center gap-1 hover:text-indigo-800">
                전체보기 <i data-feather="arrow-right" class="w-4 h-4"></i>
              </a>
            </div>
            <div class="space-y-4 flex-1 overflow-y-auto">
              {{#dashboard.lowStockItems}}
              <div class="p-4 bg-red-50 rounded-xl border border-red-100 space-y-3">
                <div class="flex items-center justify-between">
                  <div>
                    <div class="font-bold text-slate-800 text-sm">{{name}}</div>
                    <div class="text-xs text-slate-500">{{categoryText}}</div>
                  </div>
                  <div class="text-right">
                    <div class="text-xs font-bold text-red-600">현재 {{quantity}}개</div>
                    <div class="text-xs text-slate-400">최소 {{minQuantity}}개</div>
                  </div>
                </div>
                <a href="/item-manager/item-form?id={{id}}" class="w-full py-2 bg-white border border-red-200 text-red-600 text-xs font-bold rounded-lg hover:bg-red-50 transition-colors flex items-center justify-center gap-1.5">
                  <i data-feather="plus" class="w-3.5 h-3.5"></i>
                  재고 수정
                </a>
              </div>
              {{/dashboard.lowStockItems}}
              {{^dashboard.lowStockItems}}
              <div class="p-8 text-center text-slate-500 text-sm bg-slate-50 rounded-xl border border-dashed border-slate-200">
                재고가 부족한 물품이 없습니다.
              </div>
              {{/dashboard.lowStockItems}}
            </div>
          </div>
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>feather.replace();</script>
</body>
</html>
