<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>물품 관리</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="bg-slate-50 min-h-screen p-6">
    <div class="max-w-7xl mx-auto space-y-6">
        <!-- 헤더 -->
        <div class="flex justify-between items-center mb-8">
            <div class="flex items-center gap-3">
                <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600">
                    <i data-lucide="package" class="w-6 h-6"></i>
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-slate-800">물품 관리</h1>
                    <p class="text-slate-500 mt-1">병원 내 의료소모품 및 비품 재고를 관리합니다.</p>
                </div>
            </div>
            <a href="item-form.html" class="px-4 py-2 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 transition-colors flex items-center gap-2">
                <i data-lucide="plus" class="w-5 h-5"></i>
                물품 등록
            </a>
        </div>

        <!-- 필터 및 검색 -->
        <div class="bg-white p-4 rounded-xl shadow-sm border border-slate-200 flex flex-col md:flex-row gap-4 items-center justify-between">
            <div class="flex items-center gap-2 overflow-x-auto pb-2 md:pb-0 w-full md:w-auto">
                <button class="px-4 py-2 rounded-lg text-sm font-medium transition-colors whitespace-nowrap bg-indigo-600 text-white">
                    전체
                </button>
                <button class="px-4 py-2 rounded-lg text-sm font-medium transition-colors whitespace-nowrap bg-slate-100 text-slate-600 hover:bg-slate-200">
                    의료소모품
                </button>
                <button class="px-4 py-2 rounded-lg text-sm font-medium transition-colors whitespace-nowrap bg-slate-100 text-slate-600 hover:bg-slate-200">
                    의약품
                </button>
                <button class="px-4 py-2 rounded-lg text-sm font-medium transition-colors whitespace-nowrap bg-slate-100 text-slate-600 hover:bg-slate-200">
                    사무용품
                </button>
                <button class="px-4 py-2 rounded-lg text-sm font-medium transition-colors whitespace-nowrap bg-slate-100 text-slate-600 hover:bg-slate-200">
                    기타비품
                </button>
            </div>
            <div class="relative w-full md:w-64">
                <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
                <input
                    type="text"
                    placeholder="물품명 검색..."
                    class="w-full pl-10 pr-4 py-2 border border-slate-200 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none text-sm"
                />
            </div>
        </div>

        <!-- 테이블 -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-200 text-xs uppercase tracking-wider text-slate-500">
                        <th class="p-4 font-medium">물품명</th>
                        <th class="p-4 font-medium">카테고리</th>
                        <th class="p-4 font-medium text-right">현재 재고</th>
                        <th class="p-4 font-medium text-right">최소 수량</th>
                        <th class="p-4 font-medium text-center">상태</th>
                        <th class="p-4 font-medium text-right">관리</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200">
                    <!-- 아이템 1 -->
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="p-4 text-sm font-bold text-slate-800">주사기 (10ml)</td>
                        <td class="p-4 text-sm text-slate-600">
                            <span class="px-2.5 py-1 rounded-md bg-slate-100 text-slate-600 text-xs font-medium">
                                의료소모품
                            </span>
                        </td>
                        <td class="p-4 text-sm font-bold text-right text-red-600">
                            50 개
                        </td>
                        <td class="p-4 text-sm text-slate-500 text-right">
                            100 개
                        </td>
                        <td class="p-4 text-center">
                            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-bold bg-red-100 text-red-800">
                                <i data-lucide="alert-triangle" class="w-3.5 h-3.5"></i>
                                재고 부족
                            </span>
                        </td>
                        <td class="p-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <a href="item-form.html?id=1" class="p-1.5 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-md transition-colors inline-block">
                                    <i data-lucide="edit-2" class="w-4 h-4"></i>
                                </a>
                                <button class="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-md transition-colors">
                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                </button>
                            </div>
                        </td>
                    </tr>

                    <!-- 아이템 2 -->
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="p-4 text-sm font-bold text-slate-800">타이레놀 정</td>
                        <td class="p-4 text-sm text-slate-600">
                            <span class="px-2.5 py-1 rounded-md bg-slate-100 text-slate-600 text-xs font-medium">
                                의약품
                            </span>
                        </td>
                        <td class="p-4 text-sm font-bold text-right text-slate-800">
                            500 정
                        </td>
                        <td class="p-4 text-sm text-slate-500 text-right">
                            100 정
                        </td>
                        <td class="p-4 text-center">
                            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-green-100 text-green-800">
                                정상
                            </span>
                        </td>
                        <td class="p-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <a href="item-form.html?id=2" class="p-1.5 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-md transition-colors inline-block">
                                    <i data-lucide="edit-2" class="w-4 h-4"></i>
                                </a>
                                <button class="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-md transition-colors">
                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                </button>
                            </div>
                        </td>
                    </tr>

                    <!-- 아이템 3 -->
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="p-4 text-sm font-bold text-slate-800">A4 용지</td>
                        <td class="p-4 text-sm text-slate-600">
                            <span class="px-2.5 py-1 rounded-md bg-slate-100 text-slate-600 text-xs font-medium">
                                사무용품
                            </span>
                        </td>
                        <td class="p-4 text-sm font-bold text-right text-red-600">
                            2 박스
                        </td>
                        <td class="p-4 text-sm text-slate-500 text-right">
                            5 박스
                        </td>
                        <td class="p-4 text-center">
                            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-bold bg-red-100 text-red-800">
                                <i data-lucide="alert-triangle" class="w-3.5 h-3.5"></i>
                                재고 부족
                            </span>
                        </td>
                        <td class="p-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <a href="item-form.html?id=3" class="p-1.5 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-md transition-colors inline-block">
                                    <i data-lucide="edit-2" class="w-4 h-4"></i>
                                </a>
                                <button class="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-md transition-colors">
                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- 페이지네이션 -->
        <div class="flex justify-center mt-6">
            <nav class="flex items-center gap-1">
                <button class="p-2 rounded-lg border border-slate-200 text-slate-400 hover:bg-slate-50 disabled:opacity-50" disabled>
                    <i data-lucide="chevron-left" class="w-4 h-4"></i>
                </button>
                <button class="w-8 h-8 flex items-center justify-center rounded-lg text-sm font-medium bg-indigo-600 text-white">
                    1
                </button>
                <button class="w-8 h-8 flex items-center justify-center rounded-lg text-sm font-medium text-slate-600 hover:bg-slate-50">
                    2
                </button>
                <button class="p-2 rounded-lg border border-slate-200 text-slate-400 hover:bg-slate-50">
                    <i data-lucide="chevron-right" class="w-4 h-4"></i>
                </button>
            </nav>
        </div>
    </div>

    <script>
        // 아이콘 초기화
        lucide.createIcons();
    </script>
</body>
</html>
