<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>환자 정보 관리</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="bg-slate-50 min-h-screen p-6">
    <div class="max-w-3xl mx-auto space-y-6">
        <!-- 상단 헤더 -->
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center text-indigo-600">
                    <i data-lucide="users" class="w-5 h-5"></i>
                </div>
                <h1 class="text-2xl font-bold text-slate-800">환자 정보 관리</h1>
            </div>
            <a href="dashboard.html" class="text-sm font-medium text-slate-500 hover:text-slate-700">
                목록으로 돌아가기
            </a>
        </div>

        <!-- 메인 콘텐츠 카드 -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <!-- 환자 프로필 요약 -->
            <div class="bg-indigo-50 border-b border-indigo-100 p-6 flex items-center gap-4">
                <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center text-indigo-600 shadow-sm border border-indigo-100">
                    <i data-lucide="user" class="w-8 h-8"></i>
                </div>
                <div>
                    <h2 class="text-xl font-bold text-slate-800">김철수</h2>
                    <div class="flex items-center gap-2 text-sm text-slate-600 mt-1">
                        <span class="font-medium">35세 / M</span>
                        <span class="text-slate-300">|</span>
                        <span class="flex items-center gap-1">
                            <i data-lucide="phone" class="w-3.5 h-3.5"></i> 
                            010-1234-5678
                        </span>
                    </div>
                </div>
            </div>

            <!-- 상세 정보 폼 -->
            <div class="p-8 space-y-8">
                <form id="patientForm" class="space-y-8">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <!-- 기본 정보 -->
                        <div class="space-y-6">
                            <h3 class="text-sm font-bold text-slate-400 uppercase tracking-wider border-b border-slate-100 pb-2">기본 정보</h3>
                            
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-2">연락처</label>
                                <div class="relative">
                                    <i data-lucide="phone" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                                    <input
                                        type="tel"
                                        value="010-1234-5678"
                                        class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none"
                                    />
                                </div>
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-2">주소</label>
                                <input
                                    type="text"
                                    value="서울특별시 강남구 테헤란로 123"
                                    class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none"
                                />
                            </div>
                        </div>

                        <!-- 의료 정보 -->
                        <div class="space-y-6">
                            <h3 class="text-sm font-bold text-slate-400 uppercase tracking-wider border-b border-slate-100 pb-2">의료 정보 (특이사항)</h3>
                            
                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-2 flex items-center gap-2">
                                    <i data-lucide="file-text" class="w-4 h-4 text-indigo-500"></i>
                                    알레르기 및 기저질환
                                </label>
                                <textarea
                                    class="w-full p-4 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none h-32 resize-none"
                                >고혈압 약 복용 중. 페니실린 알레르기 있음.</textarea>
                            </div>
                        </div>
                    </div>

                    <!-- 하단 버튼 -->
                    <div class="pt-8 border-t border-slate-200 flex justify-end gap-3">
                        <button 
                            type="submit"
                            id="saveBtn"
                            class="px-8 py-3 bg-indigo-600 text-white font-medium rounded-xl hover:bg-indigo-700 transition-colors shadow-sm flex items-center gap-2"
                        >
                            <i data-lucide="save" class="w-5 h-5" id="saveIcon"></i>
                            <div id="loadingSpinner" class="hidden w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
                            <span id="saveText">정보 저장 (UPDATE)</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        // 아이콘 초기화
        lucide.createIcons();

        // 폼 제출 처리
        document.getElementById('patientForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const btn = document.getElementById('saveBtn');
            const icon = document.getElementById('saveIcon');
            const spinner = document.getElementById('loadingSpinner');
            
            // 로딩 상태 표시
            btn.disabled = true;
            btn.classList.add('opacity-50');
            icon.classList.add('hidden');
            spinner.classList.remove('hidden');
            
            // API 호출 시뮬레이션
            setTimeout(() => {
                // 원상 복구
                btn.disabled = false;
                btn.classList.remove('opacity-50');
                icon.classList.remove('hidden');
                spinner.classList.add('hidden');
                
                alert('환자 정보가 성공적으로 수정되었습니다.');
            }, 1000);
        });
    </script>
</body>
</html>
