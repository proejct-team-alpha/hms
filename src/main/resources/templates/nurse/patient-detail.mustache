<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>처치실 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex bg-[#f8fafc] text-slate-900">
  {{> common/sidebar-nurse}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="max-w-4xl mx-auto space-y-6">
        
        <!-- 상단 타이틀 바 -->
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center text-indigo-600">
              <i data-feather="plus-square" class="w-5 h-5"></i>
            </div>
            <h1 class="text-2xl font-bold text-slate-800">처치실</h1>
          </div>
          <!-- 필터 상태 보존하며 목록으로 돌아가기 -->
          <a href="/nurse/treatment-list?date={{keepDate}}&tab={{keepTab}}&query={{keepQuery}}{{#keepDeptIds}}&deptIds={{.}}{{/keepDeptIds}}{{#keepDoctorIds}}&doctorIds={{.}}{{/keepDoctorIds}}" 
             class="text-sm font-medium text-slate-500 hover:text-slate-700 flex items-center gap-1">
            <i data-feather="arrow-left" class="w-4 h-4"></i>
            목록으로 돌아가기
          </a>
        </div>

        {{#errorMessage}}
          <div class="p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm flex items-center gap-2">
            <i data-feather="alert-circle" class="w-4 h-4"></i> {{errorMessage}}
          </div>
        {{/errorMessage}}
        {{#message}}
          <div class="p-4 bg-green-50 border border-green-200 rounded-xl text-green-700 text-sm flex items-center gap-2">
            <i data-feather="check-circle" class="w-4 h-4"></i> {{message}}
          </div>
        {{/message}}

        <div class="grid grid-cols-3 gap-6">
          <!-- 좌측: 환자 정보 -->
          <div class="col-span-1 space-y-6">
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
              <div class="flex items-center gap-4 mb-6">
                <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center text-slate-500">
                  <i data-feather="user" class="w-8 h-8"></i>
                </div>
                <div>
                  <div class="flex items-center gap-2 mb-1">
                    {{#detail.isFirstVisit}}
                    <span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-[9px] font-medium bg-slate-100 text-slate-500 shrink-0">초</span>
                    {{/detail.isFirstVisit}}
                    {{^detail.isFirstVisit}}
                    <span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-[9px] font-medium bg-slate-100 text-slate-500 shrink-0">재</span>
                    {{/detail.isFirstVisit}}
                    <h2 class="text-xl font-bold text-slate-800">
                      {{detail.patientName}}
                      <span class="text-base font-medium text-slate-400 ml-1">({{detail.genderAge}})</span>
                    </h2>
                  </div>
                  <div class="text-sm text-slate-500">{{detail.patientPhone}}</div>
                  <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-indigo-100 text-indigo-600 mt-1 inline-block">
                    {{detail.statusText}}
                  </span>
                </div>
              </div>

              <div class="space-y-4">
                <div>
                  <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">예약 시간</h3>
                  <div class="bg-slate-50 text-slate-700 p-3 rounded-xl text-sm border border-slate-100 mb-4">
                    {{detail.timeSlot}}
                  </div>
                </div>
                <div>
                  <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">접수 경로</h3>
                  <div class="p-3 rounded-xl text-sm border font-bold flex items-center gap-2 {{detail.sourceBadgeClass}}">
                    <i data-feather="external-link" class="w-4 h-4"></i>
                    {{detail.sourceText}}
                  </div>
                </div>
                <div>
                  <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">내원 사유</h3>
                  <div class="bg-orange-50 text-orange-900 p-3 rounded-xl text-sm border border-orange-100 leading-relaxed">
                    {{detail.visitReason}}
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- 우측: 처치 기록 및 의사 소견 -->
          <div class="col-span-2 bg-white rounded-2xl shadow-sm border border-slate-200 flex flex-col">
            <div class="p-6 border-b border-slate-200 flex items-center justify-between">
              <div class="flex items-center gap-2">
                <i data-feather="edit-3" class="w-5 h-5 text-indigo-600"></i>
                <h2 class="text-lg font-bold text-slate-800">처치 기록</h2>
              </div>
              <div class="flex items-center gap-2">
                {{^detail.isTreatmentCompleted}}
                <button type="submit" form="nurse-note-form" class="px-4 py-2 bg-slate-800 text-white text-sm font-medium rounded-lg hover:bg-slate-900 transition-colors shadow-sm flex items-center gap-1.5">
                  <i data-feather="save" class="w-4 h-4"></i>
                  메모 저장
                </button>
                {{/detail.isTreatmentCompleted}}
              </div>
            </div>

            <!-- 의사 진료 기록 (조회 전용) -->
            <div class="p-6 border-b border-slate-100 bg-slate-50/50 space-y-4">
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <h3 class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">진단명</h3>
                  <div class="text-sm font-bold text-slate-700">{{#detail.diagnosis}}{{detail.diagnosis}}{{/detail.diagnosis}}{{^detail.diagnosis}}-{{/detail.diagnosis}}</div>
                </div>
                <div>
                  <h3 class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">처방 내역</h3>
                  <div class="text-sm text-indigo-600 font-medium">{{#detail.prescription}}{{detail.prescription}}{{/detail.prescription}}{{^detail.prescription}}-{{/detail.prescription}}</div>
                </div>
              </div>
              <div>
                <h3 class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">의사 소견</h3>
                <div class="text-sm text-slate-600 leading-relaxed italic">{{#detail.remark}}"{{detail.remark}}"{{/detail.remark}}{{^detail.remark}}-{{/detail.remark}}</div>
              </div>
            </div>

            <!-- 간호 처치 메모 입력창 -->
            <div class="p-6 flex-1 flex flex-col">
              <form id="nurse-note-form" action="/nurse/treatment/save-note" method="post" class="flex-1 flex flex-col">
                <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
                <input type="hidden" name="id" value="{{detail.reservationId}}">
                <!-- 필터 상태 보존용 hidden 필드 -->
                <input type="hidden" name="date" value="{{keepDate}}">
                <input type="hidden" name="tab" value="{{keepTab}}">
                <input type="hidden" name="query" value="{{keepQuery}}">
                {{#keepDeptIds}}<input type="hidden" name="deptIds" value="{{.}}">{{/keepDeptIds}}
                {{#keepDoctorIds}}<input type="hidden" name="doctorIds" value="{{.}}">{{/keepDoctorIds}}

                <label class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">간호 처치 메모</label>
                <textarea
                  name="nurseNote"
                  class="flex-1 w-full p-4 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none resize-none text-slate-700 leading-relaxed shadow-sm min-h-[200px]"
                  placeholder="환자 처치 내용 및 특이사항을 기록해주세요."
                  {{#detail.isTreatmentCompleted}}readonly{{/detail.isTreatmentCompleted}}
                >{{#detail.nurseNote}}{{detail.nurseNote}}{{/detail.nurseNote}}</textarea>
              </form>
            </div>

            <!-- 푸터: 처치 완료 버튼 -->
            <div class="p-6 border-t border-slate-200 bg-slate-50 rounded-b-2xl flex justify-end items-center">
              {{^detail.isTreatmentCompleted}}
              <form action="/nurse/treatment/complete" method="post">
                <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
                <input type="hidden" name="id" value="{{detail.reservationId}}">
                <!-- 필터 상태 보존용 hidden 필드 -->
                <input type="hidden" name="date" value="{{keepDate}}">
                <input type="hidden" name="tab" value="{{keepTab}}">
                <input type="hidden" name="query" value="{{keepQuery}}">
                {{#keepDeptIds}}<input type="hidden" name="deptIds" value="{{.}}">{{/keepDeptIds}}
                {{#keepDoctorIds}}<input type="hidden" name="doctorIds" value="{{.}}">{{/keepDoctorIds}}

                <button type="submit" class="px-8 py-3 bg-indigo-600 text-white font-medium rounded-xl hover:bg-indigo-700 transition-colors shadow-sm flex items-center gap-2">
                  <i data-feather="check-circle" class="w-5 h-5"></i>
                  처치 완료
                </button>
              </form>
              {{/detail.isTreatmentCompleted}}
              {{#detail.isTreatmentCompleted}}
              <span class="text-sm font-medium text-green-600 flex items-center gap-1">
                <i data-feather="check-circle" class="w-4 h-4"></i>
                처치 완료됨
              </span>
              {{/detail.isTreatmentCompleted}}
            </div>
          </div>
        </div>

        <!-- 물품 사용 섹션 -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 space-y-4">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
              <h3 class="text-base font-bold text-slate-800 flex items-center gap-2">
                <i data-feather="package" class="w-5 h-5 text-indigo-600"></i>
                물품 사용
              </h3>
              {{^detail.isTreatmentCompleted}}
              <button type="button" id="item-batch-use-btn"
                      class="px-3 py-1.5 bg-indigo-600 text-white text-xs font-bold rounded-lg hover:bg-indigo-700 transition-colors shadow-sm flex items-center gap-1.5">
                <i data-feather="plus-square" class="w-4 h-4"></i>
                선택 물품 일괄 사용
              </button>
              {{/detail.isTreatmentCompleted}}
            </div>
            <div class="flex gap-1.5" id="item-category-btns">
              <button type="button" data-cat="" class="item-cat-btn px-3 py-1.5 text-xs font-medium rounded-lg bg-indigo-600 text-white transition-colors">전체</button>
              <button type="button" data-cat="MEDICAL_SUPPLIES" class="item-cat-btn px-3 py-1.5 text-xs font-medium rounded-lg bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors">의료소모품</button>
              <button type="button" data-cat="MEDICAL_EQUIPMENT" class="item-cat-btn px-3 py-1.5 text-xs font-medium rounded-lg bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors">의료기기</button>
              <button type="button" data-cat="GENERAL_SUPPLIES" class="item-cat-btn px-3 py-1.5 text-xs font-medium rounded-lg bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors">사무/비품</button>
            </div>
          </div>

          <div class="bg-slate-50 rounded-xl border border-slate-100 overflow-hidden">
            <table class="w-full text-xs">
              <thead class="bg-slate-100 text-slate-500">
                <tr>
                  <th class="px-3 py-2 text-left font-medium">물품명</th>
                  <th class="px-3 py-2 text-left font-medium">사용자</th>
                  <th class="px-3 py-2 text-right font-medium">수량</th>
                  <th class="px-3 py-2 text-right font-medium">시간</th>
                  <th class="px-3 py-2 text-center font-medium">관리</th>
                </tr>
              </thead>
              <tbody id="usage-log-tbody" class="divide-y divide-slate-100">
                {{#usageLogs}}
                <tr>
                  <td class="px-3 py-2 text-slate-700 font-medium">{{itemName}}</td>
                  <td class="px-3 py-2 text-slate-500">{{usedBy}}</td>
                  <td class="px-3 py-2 text-right text-slate-600">{{amount}}개</td>
                  <td class="px-3 py-2 text-right text-slate-400">{{usedAt}}</td>
                  <td class="px-3 py-2 text-center">
                    {{^detail.isTreatmentCompleted}}
                    <button type="button" onclick="cancelUsage({{id}})"
                            class="p-1 text-red-500 hover:bg-red-50 rounded transition-colors" title="사용 취소">
                      <i data-feather="x-circle" class="w-4 h-4"></i>
                    </button>
                    {{/detail.isTreatmentCompleted}}
                    {{#detail.isTreatmentCompleted}}-{{/detail.isTreatmentCompleted}}
                  </td>
                </tr>
                {{/usageLogs}}
                <tr id="usage-log-empty" style="{{#usageLogs.size}}display:none{{/usageLogs.size}}">
                  <td colspan="5" class="px-3 py-2 text-xs text-slate-400 text-center">사용된 물품이 없습니다.</td>
                </tr>
              </tbody>
            </table>
          </div>

          <div class="relative">
            <i data-feather="search" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"></i>
            <input type="text" id="item-search" placeholder="물품명 검색 (초성·영문 가능)"
                   class="w-full pl-9 pr-4 py-2 text-sm border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-300">
          </div>
          <div class="grid grid-cols-4 gap-3" id="item-use-grid">
            {{#items}}
            <div class="item-card border border-slate-200 rounded-xl p-3 space-y-2" data-category="{{category}}" data-id="{{id}}">
              <div class="item-name text-sm font-bold text-slate-800 truncate">{{name}}</div>
              <div class="text-xs text-slate-500">{{categoryText}}</div>
              <div class="text-xs font-bold {{#lowStock}}text-red-600{{/lowStock}}{{^lowStock}}text-slate-600{{/lowStock}}">
                재고: <span class="quantity-span">{{quantity}}</span>개
              </div>
              {{^detail.isTreatmentCompleted}}
              <form action="/nurse/item/use" method="post" class="flex items-center gap-1 item-use-form">
                <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
                <input type="hidden" name="id" value="{{id}}">
                <input type="hidden" name="reservationId" value="{{detail.reservationId}}">
                <input type="number" name="amount" min="1" placeholder="수량"
                       class="flex-1 w-0 px-2 py-1 text-xs border border-slate-300 rounded-lg text-center focus:outline-none focus:ring-1 focus:ring-indigo-400">
                <button type="submit" class="px-2 py-1 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-bold rounded-lg transition-colors whitespace-nowrap">
                  사용
                </button>
              </form>
              {{/detail.isTreatmentCompleted}}
            </div>
            {{/items}}
          </div>
        </div>

        <!-- 과거 진료 이력 -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
          <div class="p-6 border-b border-slate-200 bg-slate-50 flex items-center justify-between">
            <div class="flex items-center gap-2">
              <i data-feather="clock" class="w-5 h-5 text-indigo-600"></i>
              <h2 class="text-lg font-bold text-slate-800">과거 진료 이력</h2>
            </div>
            
            <div class="flex items-center gap-2">
              <select id="filter-dept" class="text-xs border border-slate-200 rounded-lg px-2 py-1.5 outline-none focus:ring-2 focus:ring-indigo-500 bg-white">
                <option value="">전체 진료과</option>
                {{#filterDepartments}}
                <option value="{{id}}">{{name}}</option>
                {{/filterDepartments}}
              </select>
              <select id="filter-doctor" class="text-xs border border-slate-200 rounded-lg px-2 py-1.5 outline-none focus:ring-2 focus:ring-indigo-500 bg-white">
                <option value="">전체 의사</option>
                {{#filterDoctors}}
                <option value="{{id}}" data-dept-id="{{departmentId}}">{{displayName}}</option>
                {{/filterDoctors}}
              </select>
              <div id="history-pagination" class="flex items-center gap-3 ml-2" style="display: none;">
                <button type="button" id="history-prev" class="p-1.5 rounded-lg border border-slate-200 text-slate-400 hover:bg-white hover:text-indigo-600 disabled:opacity-30 disabled:cursor-not-allowed transition-all">
                  <i data-feather="chevron-left" class="w-4 h-4"></i>
                </button>
                <span class="text-xs font-bold text-slate-500">
                  <span id="history-current-page" class="text-indigo-600">1</span> / <span id="history-total-pages">1</span>
                </span>
                <button type="button" id="history-next" class="p-1.5 rounded-lg border border-slate-200 text-slate-400 hover:bg-white hover:text-indigo-600 disabled:opacity-30 disabled:cursor-not-allowed transition-all">
                  <i data-feather="chevron-right" class="w-4 h-4"></i>
                </button>
              </div>
            </div>
          </div>
          
          <div class="p-6">
            {{#detail.history.size}}
              <div id="history-list-container" class="space-y-8 relative before:absolute before:inset-0 before:left-4 before:w-0.5 before:bg-slate-100 before:content-['']">
                {{#detail.history}}
                  <div class="history-item relative pl-10 transition-all duration-300"
                       data-dept-id="{{deptId}}" 
                       data-doctor-id="{{doctorId}}">
                    <div class="absolute left-2.5 top-1.5 w-3.5 h-3.5 rounded-full bg-white border-4 border-indigo-500 shadow-sm"></div>
                    <div class="bg-slate-50 rounded-2xl p-5 border border-slate-100 space-y-4 transition-all hover:border-indigo-200 hover:bg-white hover:shadow-md">
                      <div class="flex justify-between items-start">
                        <div>
                          <div class="text-sm font-bold text-slate-800 mb-0.5">{{date}}</div>
                          <div class="text-xs font-medium text-slate-500">{{deptName}} · {{doctorName}} 의사</div>
                        </div>
                        <span class="px-2 py-0.5 rounded-full text-[10px] font-bold bg-green-100 text-green-700">진료 완료</span>
                      </div>
                      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="space-y-1">
                          <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">진단 및 소견</span>
                          <div class="text-sm text-slate-700 font-semibold">{{diagnosis}}</div>
                          <div class="text-xs text-slate-500 italic">"{{remark}}"</div>
                        </div>
                        <div class="space-y-1">
                          <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">처방 및 간호메모</span>
                          <div class="text-sm text-slate-600 bg-white p-2 rounded-lg border border-slate-100">{{prescription}}</div>
                          <div class="text-xs text-indigo-600 font-medium mt-1">{{#nurseNote}}Nurse: {{nurseNote}}{{/nurseNote}}</div>
                        </div>
                      </div>
                    </div>
                  </div>
                {{/detail.history}}
              </div>
            {{/detail.history.size}}
            {{^detail.history.size}}
              <div class="py-12 flex flex-col items-center justify-center text-slate-400 gap-3">
                <i data-feather="folder" class="w-8 h-8 opacity-20"></i>
                <p class="text-sm font-medium">과거 진료 기록이 없습니다.</p>
              </div>
            {{/detail.history.size}}
          </div>
        </div>

      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>
    feather.replace();

    (function() {
      // 물품 AJAX 로직
      document.querySelectorAll('.item-use-form').forEach(form => {
        form.addEventListener('submit', function(e) {
          e.preventDefault();
          const input = form.querySelector('input[name="amount"]');
          const amount = input.value || 1;
          const id = form.querySelector('input[name="id"]').value;
          const reservationId = form.querySelector('input[name="reservationId"]').value;
          const csrfInput = form.querySelector('input[name="_csrf"]');

          const params = new URLSearchParams();
          params.append('id', id);
          params.append('amount', amount);
          params.append('reservationId', reservationId);
          params.append('_csrf', csrfInput.value);

          fetch('/nurse/item/use', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: params.toString()
          })
          .then(res => res.json())
          .then(data => {
            if (data.quantity !== undefined) {
              form.closest('.item-card').querySelector('.quantity-span').textContent = data.quantity;
              input.value = '';
              refreshUsageLogs(data.logs || []);
            } else if (data.error) alert(data.error);
          });
        });
      });

      // 일괄 사용
      const batchUseBtn = document.getElementById('item-batch-use-btn');
      if (batchUseBtn) {
        batchUseBtn.addEventListener('click', function() {
          const requests = [];
          const resId = "{{detail.reservationId}}";
          const csrfToken = document.querySelector('input[name="_csrf"]').value;

          document.querySelectorAll('.item-card').forEach(card => {
            const amountInput = card.querySelector('input[name="amount"]');
            const amount = amountInput ? amountInput.value.trim() : "";
            if (amount && parseInt(amount) > 0) {
              requests.push({ id: card.getAttribute('data-id'), amount: parseInt(amount) });
            }
          });

          if (requests.length === 0) return alert('사용할 물품의 수량을 입력해주세요.');

          fetch('/nurse/item/use-batch', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrfToken },
            body: JSON.stringify({ reservationId: resId, requests: requests })
          }).then(res => res.json()).then(data => {
            if (data.successes && data.successes.length > 0) {
              if (data.errors && data.errors.length > 0) alert('일부 물품의 재고가 부족합니다.\n\n' + data.errors.join('\n'));
              location.reload(); 
            } else if (data.errors && data.errors.length > 0) alert('처리에 실패했습니다:\n' + data.errors.join('\n'));
            else if (data.error) alert('오류: ' + data.error);
          });
        });
      }

      window.cancelUsage = function(logId) {
        if(!confirm('정말 취소하시겠습니까?')) return;
        const resId = "{{detail.reservationId}}";
        const csrfToken = document.querySelector('input[name="_csrf"]').value;
        const params = new URLSearchParams();
        params.append('logId', logId);
        params.append('reservationId', resId);
        params.append('_csrf', csrfToken);

        fetch('/nurse/item/cancel', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: params.toString()
        }).then(res => res.json()).then(data => {
          if (data.logs) { location.reload(); }
          else if (data.error) alert(data.error);
        });
      };

      window.refreshUsageLogs = function(logs) {
        const tbody = document.getElementById('usage-log-tbody');
        if (!tbody) return;
        tbody.innerHTML = '';
        if (logs && logs.length > 0) {
          logs.forEach(log => {
            const tr = document.createElement('tr');
            tr.innerHTML = `<td class="px-3 py-2 text-slate-700 font-medium">${log.itemName}</td>
                            <td class="px-3 py-2 text-slate-500">${log.usedBy}</td>
                            <td class="px-3 py-2 text-right text-slate-600">${log.amount}개</td>
                            <td class="px-3 py-2 text-right text-slate-400">${log.usedAt}</td>
                            <td class="px-3 py-2 text-center">-</td>`;
            tbody.appendChild(tr);
          });
        } else {
          tbody.innerHTML = '<tr><td colspan="5" class="px-3 py-2 text-xs text-slate-400 text-center">사용된 물품이 없습니다.</td></tr>';
        }
      };

      // 히스토리 필터링 로직
      (function() {
        var HISTORY_PAGE_SIZE = 3;
        var historyPage = 1;
        const filterDept = document.getElementById('filter-dept');
        const filterDoctor = document.getElementById('filter-doctor');
        if (!filterDept || !filterDoctor) return;
        const doctorOptions = Array.from(filterDoctor.querySelectorAll('option')).filter(opt => opt.value !== "");

        function clean(val) { return String(val || "").replace(/[^0-9]/g, '').trim(); }

        function updateUI() {
          const allItems = Array.from(document.querySelectorAll('.history-item'));
          const selectedDeptId = clean(filterDept.value);
          const selectedDoctorId = clean(filterDoctor.value);
          const filtered = allItems.filter(item => {
            const d = clean(item.getAttribute('data-dept-id'));
            const dr = clean(item.getAttribute('data-doctor-id'));
            return (!selectedDeptId || d === selectedDeptId) && (!selectedDoctorId || dr === selectedDoctorId);
          });
          allItems.forEach(item => item.style.display = 'none');
          const totalPages = Math.ceil(filtered.length / HISTORY_PAGE_SIZE) || 1;
          if (historyPage > totalPages) historyPage = totalPages;
          const start = (historyPage - 1) * HISTORY_PAGE_SIZE;
          filtered.slice(start, start + HISTORY_PAGE_SIZE).forEach(item => item.style.display = 'block');
          document.getElementById('history-pagination').style.display = filtered.length > 0 ? 'flex' : 'none';
          document.getElementById('history-current-page').textContent = historyPage;
          document.getElementById('history-total-pages').textContent = totalPages;
          document.getElementById('history-prev').disabled = (historyPage <= 1);
          document.getElementById('history-next').disabled = (historyPage >= totalPages);
        }

        filterDept.addEventListener('change', function() {
          const sid = clean(this.value);
          filterDoctor.innerHTML = '<option value="">전체 의사</option>';
          doctorOptions.forEach(opt => { if(!sid || clean(opt.getAttribute('data-dept-id')) === sid) filterDoctor.appendChild(opt); });
          historyPage = 1; updateUI();
        });
        filterDoctor.addEventListener('change', () => { historyPage = 1; updateUI(); });
        document.getElementById('history-prev').onclick = () => { if(historyPage > 1) { historyPage--; updateUI(); } };
        document.getElementById('history-next').onclick = () => { if(historyPage < Math.ceil(document.querySelectorAll('.history-item').length / HISTORY_PAGE_SIZE)) { historyPage++; updateUI(); } };
        updateUI();
      })();
    })();
  </script>
</body>
</html>
