<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>환자 정보 관리 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-nurse}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="max-w-3xl mx-auto space-y-6">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center text-indigo-600">
              <i data-feather="users" class="w-5 h-5"></i>
            </div>
            <h1 class="text-2xl font-bold text-slate-800">환자 정보 관리</h1>
          </div>
          <a href="/nurse/reception-list" class="text-sm font-medium text-slate-500 hover:text-slate-700">
            목록으로 돌아가기
          </a>
        </div>

        {{#message}}
        <div class="p-4 bg-green-50 border border-green-200 text-green-800 rounded-xl text-sm">{{message}}</div>
        {{/message}}
        {{#errorMessage}}
        <div class="p-4 bg-red-50 border border-red-200 text-red-800 rounded-xl text-sm">{{errorMessage}}</div>
        {{/errorMessage}}

        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
          <!-- 환자 헤더 -->
          <div class="bg-indigo-50 border-b border-indigo-100 p-6 flex items-center gap-4">
            <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center text-indigo-600 shadow-sm border border-indigo-100">
              <i data-feather="user" class="w-8 h-8"></i>
            </div>
            <div>
              <h2 class="text-xl font-bold text-slate-800">{{detail.patientName}}</h2>
              <div class="flex items-center gap-2 text-sm text-slate-600 mt-1">
                <span class="flex items-center gap-1"><i data-feather="phone" class="w-3.5 h-3.5"></i> {{detail.patientPhone}}</span>
                <span class="text-slate-300">|</span>
                <span>{{detail.departmentName}} / {{detail.doctorName}}</span>
                <span class="text-slate-300">|</span>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">{{detail.statusText}}</span>
              </div>
            </div>
          </div>

          <!-- 접수 버튼 -->
          {{#detail.canReceive}}
          <div class="px-8 pt-6">
            <form method="post" action="/nurse/reservation/receive">
              <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
              <input type="hidden" name="id" value="{{detail.reservationId}}">
              <button type="submit" class="w-full py-3 bg-indigo-600 text-white font-medium rounded-xl hover:bg-indigo-700 transition-colors shadow-sm flex items-center justify-center gap-2">
                <i data-feather="check-circle" class="w-5 h-5"></i>
                환자 접수 처리
              </button>
            </form>
          </div>
          {{/detail.canReceive}}

          <!-- 환자 정보 폼 -->
          <form method="post" action="/nurse/patient/update" class="p-8 space-y-8">
            <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
            <input type="hidden" name="patientId" value="{{detail.patientId}}">
            <input type="hidden" name="reservationId" value="{{detail.reservationId}}">

            <div class="grid grid-cols-2 gap-8">
              <div class="space-y-6">
                <h3 class="text-sm font-bold text-slate-400 uppercase tracking-wider border-b border-slate-100 pb-2">기본 정보</h3>

                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2">연락처</label>
                  <div class="relative">
                    <i data-feather="phone" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                    <input
                      type="tel"
                      name="phone"
                      value="{{detail.patientPhone}}"
                      class="w-full pl-10 pr-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none"
                    />
                  </div>
                </div>

                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2">이메일</label>
                  <div class="relative">
                    <i data-feather="mail" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400"></i>
                    <input
                      type="text"
                      value="{{detail.patientEmail}}"
                      readonly
                      class="w-full pl-10 pr-4 py-3 border border-slate-200 rounded-xl bg-slate-50 text-slate-500 outline-none"
                    />
                  </div>
                </div>

                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2">주소</label>
                  <input
                    type="text"
                    name="address"
                    value="{{detail.patientAddress}}"
                    class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none"
                  />
                </div>
              </div>

              <div class="space-y-6">
                <h3 class="text-sm font-bold text-slate-400 uppercase tracking-wider border-b border-slate-100 pb-2">의료 정보 (특이사항)</h3>

                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2 flex items-center gap-2">
                    <i data-feather="file-text" class="w-4 h-4 text-indigo-500"></i>
                    알레르기 및 기저질환
                  </label>
                  <textarea
                    name="note"
                    class="w-full p-4 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none h-32 resize-none"
                  >{{detail.patientNote}}</textarea>
                </div>

                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2">예약 시간</label>
                  <div class="px-4 py-3 bg-slate-50 rounded-xl text-slate-600 text-sm border border-slate-200">
                    {{detail.timeSlot}}
                  </div>
                </div>
              </div>
            </div>

            <div class="pt-8 border-t border-slate-200 flex justify-end gap-3">
              <a href="/nurse/reception-list" class="px-6 py-3 bg-white border border-slate-300 text-slate-700 font-medium rounded-xl hover:bg-slate-50 transition-colors">
                취소
              </a>
              <button
                type="submit"
                class="px-8 py-3 bg-indigo-600 text-white font-medium rounded-xl hover:bg-indigo-700 transition-colors shadow-sm flex items-center gap-2"
              >
                <i data-feather="save" class="w-5 h-5"></i>
                정보 저장
              </button>
            </div>
          </form>
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>feather.replace();</script>
</body>
</html>
