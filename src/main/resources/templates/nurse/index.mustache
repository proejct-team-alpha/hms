<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{pageTitle}} - 간호사 시스템</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="bg-slate-50 min-h-screen flex">
    
    {{> partials/sidebar-nurse}}

    <main class="flex-1 flex flex-col h-screen overflow-hidden">
        
        {{> partials/header}}
        
        <div class="flex-1 overflow-hidden relative bg-slate-50 flex flex-col">
            <iframe name="contentFrame" src="{{defaultFrameUrl}}" class="w-full flex-1 border-none"></iframe>
            
            {{> partials/footer}}
        </div>
    </main>

    <script>
        lucide.createIcons();

        // iframe 내비게이션 상태 동기화 (간호사 시스템 테마: Teal)
        const iframe = document.querySelector('iframe[name="contentFrame"]');
        const navLinks = document.querySelectorAll('.nav-link');
        
        if(navLinks.length > 0) {
            navLinks[0].classList.remove('text-slate-300', 'hover:bg-slate-800');
            navLinks[0].classList.add('bg-teal-600', 'text-white');
        }

        iframe.addEventListener('load', function() {
            try {
                const currentUrl = iframe.contentWindow.location.href;
                navLinks.forEach(link => {
                    link.classList.remove('bg-teal-600', 'text-white');
                    link.classList.add('text-slate-300', 'hover:bg-slate-800');
                    if (currentUrl.includes(link.getAttribute('href'))) {
                        link.classList.remove('text-slate-300', 'hover:bg-slate-800');
                        link.classList.add('bg-teal-600', 'text-white');
                    }
                });
            } catch (e) {
                console.log('Cross-origin iframe access denied');
            }
        });
    </script>
</body>
</html>