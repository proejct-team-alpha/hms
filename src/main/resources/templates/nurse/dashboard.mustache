<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>간호사 대시보드 - MediCare+</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/feather-icons"></script>
  <link rel="stylesheet" href="css/style.css">
</head>
<body>
  
  <script src="components/sidebar.js"></script>

  <div class="main-content">
    <script src="components/header.js"></script>
    
    <main class="content-wrapper">
      <div class="space-y-6 max-w-5xl mx-auto">
        <h1 class="text-2xl font-bold text-slate-800">간호사 대시보드</h1>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6" id="stats-container">
          <!-- Stats injected by JS -->
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
            <h2 class="text-lg font-bold text-slate-800 mb-6">시간대별 환자 유입 현황</h2>
            <div class="h-64 flex items-center justify-center bg-slate-50 border border-slate-100 rounded-xl">
              <span class="text-slate-400 text-sm">차트 영역 (HTML 버전에서는 정적 이미지 또는 CSS로 대체)</span>
            </div>
          </div>

          <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
            <div class="flex justify-between items-center mb-4">
              <h2 class="text-lg font-bold text-slate-800">진료 대기 환자 (시간순)</h2>
              <a href="reception-list.html" class="text-sm text-indigo-600 font-medium flex items-center gap-1 hover:text-indigo-800">
                전체보기 <i data-feather="arrow-right" class="w-4 h-4"></i>
              </a>
            </div>
            <div class="space-y-3" id="waiting-list-container">
              <!-- Waiting list injected by JS -->
            </div>
          </div>
        </div>
      </div>
    </main>

    <script src="components/footer.js"></script>
  </div>

  <script src="js/data.js"></script>
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const reservations = getReservations();
      const todayReservations = reservations.filter(r => r.status !== 'CANCELLED');
      const receivedReservations = todayReservations.filter(r => r.status === 'RECEIVED' || r.status === 'IN_PROGRESS' || r.status === 'COMPLETED');
      const specialIssueReservations = todayReservations.filter(r => r.symptoms && r.symptoms.length > 10);

      // Render Stats
      document.getElementById('stats-container').innerHTML = \`
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-indigo-50 rounded-xl flex items-center justify-center text-indigo-600">
              <i data-feather="users" class="w-6 h-6"></i>
            </div>
            <div>
              <div class="text-sm font-medium text-slate-500">오늘 담당 환자</div>
              <div class="text-2xl font-bold text-slate-800">\${todayReservations.length}명</div>
            </div>
          </div>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-green-50 rounded-xl flex items-center justify-center text-green-600">
              <i data-feather="clipboard" class="w-6 h-6"></i>
            </div>
            <div>
              <div class="text-sm font-medium text-slate-500">진료 대기 환자</div>
              <div class="text-2xl font-bold text-slate-800">\${receivedReservations.length}명</div>
            </div>
          </div>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-orange-50 rounded-xl flex items-center justify-center text-orange-600">
              <i data-feather="activity" class="w-6 h-6"></i>
            </div>
            <div>
              <div class="text-sm font-medium text-slate-500">특이사항 환자</div>
              <div class="text-2xl font-bold text-slate-800">\${specialIssueReservations.length}명</div>
            </div>
          </div>
        </div>
      \`;

      // Render Waiting List
      const waitingPatients = [...todayReservations]
        .filter(r => r.status === 'RECEIVED')
        .sort((a, b) => a.time.localeCompare(b.time))
        .slice(0, 5);

      const waitingContainer = document.getElementById('waiting-list-container');
      if (waitingPatients.length > 0) {
        waitingContainer.innerHTML = waitingPatients.map(res => {
          let dotClass = 'bg-green-500';
          let badgeClass = 'bg-green-100 text-green-700';
          let statusText = '진료 대기';

          return \`
            <a href="patient-detail.html?id=\${res.id}" class="flex items-center justify-between p-3 bg-slate-50 rounded-lg border border-slate-100 hover:bg-indigo-50 hover:border-indigo-200 transition-all cursor-pointer group">
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full \${dotClass}"></div>
                <span class="font-medium text-slate-800 group-hover:text-indigo-700">\${res.name}</span>
                <span class="text-sm text-slate-500">\${res.dept} / \${res.time}</span>
              </div>
              <span class="text-xs font-medium px-2 py-1 rounded-full \${badgeClass}">
                \${statusText}
              </span>
            </a>
          \`;
        }).join('');
      } else {
        waitingContainer.innerHTML = \`
          <div class="p-4 text-center text-slate-500">
            대기 중인 환자가 없습니다.
          </div>
        \`;
      }

      feather.replace();
    });
  </script>
</body>
</html>
