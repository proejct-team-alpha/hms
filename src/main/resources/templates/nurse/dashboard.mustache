<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>간호사 대시보드</title>
    <link rel="stylesheet" href="/css/tailwind.min.css">
    <script src="/js/lucide.min.js"></script>
    <script src="/js/chart.min.js"></script>
</head>
<body class="bg-slate-50 min-h-screen">
    <div class="max-w-7xl mx-auto p-6 space-y-6">
        <h1 class="text-2xl font-bold text-slate-800">간호사 대시보드</h1>
        
        <!-- 통계 카드 -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-indigo-50 rounded-xl flex items-center justify-center text-indigo-600">
                        <i data-lucide="users" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <div class="text-sm font-medium text-slate-500">오늘 담당 환자</div>
                        <div class="text-2xl font-bold text-slate-800">12명</div>
                    </div>
                </div>
            </div>
            
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-green-50 rounded-xl flex items-center justify-center text-green-600">
                        <i data-lucide="clipboard-list" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <div class="text-sm font-medium text-slate-500">진료 대기 환자</div>
                        <div class="text-2xl font-bold text-slate-800">5명</div>
                    </div>
                </div>
            </div>
            
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-orange-50 rounded-xl flex items-center justify-center text-orange-600">
                        <i data-lucide="activity" class="w-6 h-6"></i>
                    </div>
                    <div>
                        <div class="text-sm font-medium text-slate-500">특이사항 환자</div>
                        <div class="text-2xl font-bold text-slate-800">2명</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- 차트 영역 -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
                <h2 class="text-lg font-bold text-slate-800 mb-6">시간대별 환자 유입 현황</h2>
                <div class="h-64 relative">
                    <canvas id="patientChart"></canvas>
                </div>
            </div>

            <!-- 대기 환자 목록 -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
                <div class="flex justify-between items-center mb-4">
                    <h2 class="text-lg font-bold text-slate-800">진료 대기 환자 (시간순)</h2>
                    <a href="#" class="text-sm text-indigo-600 font-medium flex items-center gap-1 hover:text-indigo-800">
                        전체보기 <i data-lucide="arrow-right" class="w-4 h-4"></i>
                    </a>
                </div>
                
                <div class="space-y-3">
                    <!-- 환자 1 -->
                    <a href="patient-detail.html" class="block">
                        <div class="flex items-center justify-between p-3 bg-slate-50 rounded-lg border border-slate-100 hover:bg-indigo-50 hover:border-indigo-200 transition-all cursor-pointer group">
                            <div class="flex items-center gap-3">
                                <div class="w-2 h-2 rounded-full bg-green-500"></div>
                                <span class="font-medium text-slate-800 group-hover:text-indigo-700">김철수</span>
                                <span class="text-sm text-slate-500">내과 / 10:30</span>
                            </div>
                            <span class="text-xs font-medium px-2 py-1 rounded-full bg-green-100 text-green-700">
                                진료 대기
                            </span>
                        </div>
                    </a>
                    
                    <!-- 환자 2 -->
                    <a href="patient-detail.html" class="block">
                        <div class="flex items-center justify-between p-3 bg-slate-50 rounded-lg border border-slate-100 hover:bg-indigo-50 hover:border-indigo-200 transition-all cursor-pointer group">
                            <div class="flex items-center gap-3">
                                <div class="w-2 h-2 rounded-full bg-orange-500"></div>
                                <span class="font-medium text-slate-800 group-hover:text-indigo-700">이영희</span>
                                <span class="text-sm text-slate-500">이비인후과 / 11:00</span>
                            </div>
                            <span class="text-xs font-medium px-2 py-1 rounded-full bg-indigo-100 text-indigo-700">
                                예약
                            </span>
                        </div>
                    </a>
                    
                    <!-- 환자 3 -->
                    <a href="patient-detail.html" class="block">
                        <div class="flex items-center justify-between p-3 bg-slate-50 rounded-lg border border-slate-100 hover:bg-indigo-50 hover:border-indigo-200 transition-all cursor-pointer group">
                            <div class="flex items-center gap-3">
                                <div class="w-2 h-2 rounded-full bg-green-500"></div>
                                <span class="font-medium text-slate-800 group-hover:text-indigo-700">박지민</span>
                                <span class="text-sm text-slate-500">정형외과 / 11:30</span>
                            </div>
                            <span class="text-xs font-medium px-2 py-1 rounded-full bg-green-100 text-green-700">
                                진료 대기
                            </span>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script src="/js/app.js"></script>
</body>
</html>
