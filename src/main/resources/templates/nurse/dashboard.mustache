<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>간호사 대시보드 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex bg-slate-50">
  {{> common/sidebar-nurse}}

  <!-- 메인 컨텐츠 영역 (flex-col로 구성하여 푸터를 아래로 밀어냄) -->
  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <!-- 메인 본문: flex-1을 주어 남은 공간을 차지하게 함 -->
    <main class="content-wrapper flex-1 p-6">
      <div class="space-y-6 max-w-7xl mx-auto">
        <!-- 타이틀 섹션 -->
        <div class="flex justify-between items-center mb-8">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600">
              <i data-feather="layout" class="w-6 h-6"></i>
            </div>
            <div>
              <h1 class="text-2xl font-bold text-slate-800">대시보드</h1>
              <div class="flex items-center gap-1.5 text-slate-500 mt-1">
                <i data-feather="refresh-cw" class="w-3.5 h-3.5"></i>
                <p class="text-sm">실시간 의료진 진료 현황 동기화 중</p>
              </div>
            </div>
          </div>
          
          <!-- 상단 우측 날짜 표시 -->
          <div class="flex items-center gap-2">
            <div class="bg-white px-4 py-2.5 rounded-2xl border border-slate-200 shadow-sm text-sm font-bold text-slate-600 flex items-center gap-2">
              <i data-feather="calendar" class="w-4 h-4 text-indigo-500"></i>
              <span id="today-date"></span>
            </div>
          </div>
        </div>

        <!-- 카드 리스트 영역 -->
        <div class="space-y-3">
          {{#dashboard.doctorStatuses}}
          <div class="bg-white rounded-2xl border border-slate-200 shadow-sm transition-all flex items-stretch h-24 overflow-hidden {{^isAvailableToday}}grayscale opacity-50 bg-slate-50{{/isAvailableToday}}">
            
            <!-- (1) 의사 프로필 -->
            <div class="flex items-center gap-4 px-6 min-w-[260px] border-r border-slate-100 {{#isAvailableToday}}bg-slate-50/30{{/isAvailableToday}}">
              <div class="w-10 h-10 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600">
                <i data-feather="user" class="w-5 h-5"></i>
              </div>
              <div>
                <h3 class="font-bold text-slate-800">{{doctorName}}</h3>
                <span class="text-xs font-medium text-slate-500">{{departmentName}}</span>
              </div>
            </div>

            <!-- (2) 데이터 섹션 -->
            <div class="flex-1 flex">
              <div class="flex-1 flex items-center justify-center gap-3 border-r border-slate-100 px-4">
                <i data-feather="users" class="w-5 h-5 text-slate-400"></i>
                <div class="text-center">
                  <div class="text-[10px] font-bold text-slate-400 uppercase">전체</div>
                  <div class="text-xl font-bold text-slate-700">{{totalToday}}</div>
                </div>
              </div>

              <div class="flex-1 flex items-center justify-center gap-3 border-r border-slate-100 px-4">
                <i data-feather="clock" class="w-5 h-5 text-yellow-500"></i>
                <div class="text-center">
                  <div class="text-[10px] font-bold text-yellow-500 uppercase">진료 대기</div>
                  <div class="text-xl font-bold {{#waitingCount}}text-yellow-600{{/waitingCount}}{{^waitingCount}}text-slate-200{{/waitingCount}}">{{waitingCount}}</div>
                </div>
              </div>

              <div class="flex-1 flex items-center justify-center gap-3 border-r border-slate-100 px-4">
                <i data-feather="play-circle" class="w-5 h-5 text-indigo-500"></i>
                <div class="text-center">
                  <div class="text-[10px] font-bold text-indigo-500 uppercase">진료 중</div>
                  <div class="text-xl font-bold {{#treatingCount}}text-indigo-600{{/treatingCount}}{{^treatingCount}}text-slate-200{{/treatingCount}}">{{treatingCount}}</div>
                </div>
              </div>

              <div class="flex-1 flex items-center justify-center gap-3 border-r border-slate-100 px-4 bg-blue-50/20">
                <i data-feather="activity" class="w-5 h-5 text-blue-600"></i>
                <div class="text-center">
                  <div class="text-[10px] font-bold text-blue-500 uppercase">처치 대기</div>
                  <div class="text-2xl font-black {{#pendingTreatmentCount}}text-blue-600 underline{{/pendingTreatmentCount}}{{^pendingTreatmentCount}}text-slate-200{{/pendingTreatmentCount}}">{{pendingTreatmentCount}}</div>
                </div>
              </div>

              <div class="flex-1 flex items-center justify-center gap-3 bg-purple-50/20 px-4">
                <i data-feather="check-circle" class="w-5 h-5 text-purple-600"></i>
                <div class="text-center">
                  <div class="text-[10px] font-bold text-purple-500 uppercase">수납 완료</div>
                  <div class="text-xl font-bold {{#paidCount}}text-purple-600{{/paidCount}}{{^paidCount}}text-slate-200{{/paidCount}}">{{paidCount}}</div>
                </div>
              </div>
            </div>
          </div>
          {{/dashboard.doctorStatuses}}
        </div>
      </div>
    </main>

    <!-- [UI 통일] 푸터를 메인 바깥쪽 하단에 배치하여 항상 화면 아래에 머물도록 고정 -->
    {{> common/footer-staff}}
  </div>

  <script>
    feather.replace();
    
    // 오늘 날짜 표시
    document.getElementById('today-date').innerText = new Date().toLocaleDateString('ko-KR', {
      year: 'numeric', month: 'long', day: 'numeric', weekday: 'long'
    });

    // [기능 추가] 60초마다 자동 새로고침
    setInterval(function() {
      location.reload();
    }, 60000);
  </script>
</body>
</html>
