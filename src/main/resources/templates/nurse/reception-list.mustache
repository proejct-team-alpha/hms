<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>예약 현황 - MediCare+</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/feather-icons"></script>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  
  {{> components/sidebar}}

  <div class="main-content">
    {{> components/header}}
    
    <main class="content-wrapper">
      <div class="space-y-6 max-w-5xl mx-auto">
        <div class="flex justify-between items-center">
          <h1 class="text-2xl font-bold text-slate-800">예약 환자 목록</h1>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
          <div class="p-4 border-b border-slate-200 flex justify-between items-center bg-slate-50">
            <div class="flex gap-2" id="filter-container">
              <a href="/receptions?status=ALL" class="filter-btn px-4 py-1.5 rounded-full text-sm font-medium transition-colors {{#filterAll}}bg-slate-800 text-white{{/filterAll}}{{^filterAll}}bg-white border border-slate-300 text-slate-600 hover:bg-slate-100{{/filterAll}}">전체</a>
              <a href="/receptions?status=RECEIVED" class="filter-btn px-4 py-1.5 rounded-full text-sm font-medium transition-colors {{#filterReceived}}bg-green-600 text-white{{/filterReceived}}{{^filterReceived}}bg-white border border-slate-300 text-slate-600 hover:bg-slate-100{{/filterReceived}}">진료 대기</a>
              <a href="/receptions?status=COMPLETED" class="filter-btn px-4 py-1.5 rounded-full text-sm font-medium transition-colors {{#filterCompleted}}bg-blue-600 text-white{{/filterCompleted}}{{^filterCompleted}}bg-white border border-slate-300 text-slate-600 hover:bg-slate-100{{/filterCompleted}}">진료 완료</a>
            </div>
            <div class="flex items-center gap-2">
              <div class="relative">
                <i data-feather="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
                <form action="/receptions" method="GET">
                  <input 
                    type="text" 
                    name="search"
                    value="{{searchQuery}}"
                    placeholder="환자명 또는 연락처 검색..." 
                    class="pl-9 pr-4 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none w-64"
                  />
                </form>
              </div>
            </div>
          </div>

          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-200 text-xs uppercase tracking-wider text-slate-500">
                <th class="p-4 font-medium">시간</th>
                <th class="p-4 font-medium">환자명</th>
                <th class="p-4 font-medium">연락처</th>
                <th class="p-4 font-medium">예약 구분</th>
                <th class="p-4 font-medium">진료과 / 전문의</th>
                <th class="p-4 font-medium">상태</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200" id="table-body">
              {{#reservations}}
              <tr class="hover:bg-slate-50 transition-colors cursor-pointer" onclick="window.location.href='/patients/{{id}}'">
                <td class="p-4 text-sm font-medium text-slate-900">{{time}}</td>
                <td class="p-4 text-sm font-semibold text-slate-800">{{name}}</td>
                <td class="p-4 text-sm text-slate-600">{{phone}}</td>
                <td class="p-4">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium 
                    {{#isOnline}}bg-blue-100 text-blue-800{{/isOnline}}
                    {{#isPhone}}bg-purple-100 text-purple-800{{/isPhone}}
                    {{^isOnline}}{{^isPhone}}bg-orange-100 text-orange-800{{/isPhone}}{{/isOnline}}">
                    {{type}}
                  </span>
                </td>
                <td class="p-4 text-sm text-slate-600">{{dept}} / {{doctor}}</td>
                <td class="p-4">
                  {{#isReceived}}<span class="inline-flex items-center gap-1.5 text-sm font-medium text-green-600"><i data-feather="check-circle" class="w-4 h-4"></i>진료 대기</span>{{/isReceived}}
                  {{#isInProgress}}<span class="inline-flex items-center gap-1.5 text-sm font-medium text-purple-600"><i data-feather="activity" class="w-4 h-4"></i>진료 중</span>{{/isInProgress}}
                  {{#isCompleted}}<span class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-600"><i data-feather="check-circle" class="w-4 h-4"></i>진료 완료</span>{{/isCompleted}}
                </td>
              </tr>
              {{/reservations}}

              {{^reservations}}
              <tr>
                <td colspan="6" class="p-8 text-center text-slate-500">
                  검색 결과가 없습니다.
                </td>
              </tr>
              {{/reservations}}
            </tbody>
          </table>
          
          <div class="p-4 border-t border-slate-200 flex justify-center gap-2">
            {{#pageNumbers}}
            <a href="?page={{page}}&status={{currentStatus}}&search={{searchQuery}}" 
               class="px-3 py-1 rounded {{#isActive}}bg-indigo-600 text-white{{/isActive}}{{^isActive}}bg-slate-100 text-slate-600 hover:bg-slate-200{{/isActive}}">
              {{page}}
            </a>
            {{/pageNumbers}}
          </div>
        </div>
      </div>
    </main>

    {{> components/footer}}
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      feather.replace();
    });
  </script>
</body>
</html>