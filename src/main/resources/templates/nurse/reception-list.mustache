<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>오늘 예약 현황 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-nurse}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="space-y-6 max-w-5xl mx-auto">
        <div class="flex justify-between items-center">
          <h1 class="text-2xl font-bold text-slate-800">오늘 예약 현황</h1>
        </div>

        {{#message}}
        <div class="p-4 bg-green-50 border border-green-200 text-green-800 rounded-xl text-sm">{{message}}</div>
        {{/message}}
        {{#errorMessage}}
        <div class="p-4 bg-red-50 border border-red-200 text-red-800 rounded-xl text-sm">{{errorMessage}}</div>
        {{/errorMessage}}

        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
          <div class="p-4 border-b border-slate-200 bg-slate-50 space-y-4">
            <div class="flex justify-between items-center">
              <div class="flex gap-2">
                {{#statusFilters}}
                <a href="{{url}}" class="px-4 py-1.5 rounded-full text-sm font-medium transition-colors {{#selected}}bg-slate-800 text-white{{/selected}}{{^selected}}bg-white border border-slate-300 text-slate-600 hover:bg-slate-100{{/selected}}">
                  {{label}}
                </a>
                {{/statusFilters}}
              </div>
              <form action="/nurse/reception-list" method="get" class="flex items-center gap-2">
                <input type="hidden" name="status" value="{{currentStatus}}">
                <div class="relative group">
                  <i data-feather="search" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-indigo-500 transition-colors"></i>
                  <input type="text" name="query" value="{{query}}" placeholder="환자명, 연락처 검색"
                         class="pl-12 pr-4 py-2 text-sm border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400 w-72 bg-white shadow-sm transition-all placeholder:text-slate-400">
                </div>
                <button type="button" id="btn-toggle-filter" class="p-2 bg-white border border-slate-200 text-slate-600 rounded-xl hover:bg-slate-50 transition-all shadow-sm">
                  <i data-feather="sliders" class="w-4 h-4"></i>
                </button>
                <a href="/nurse/reception-list" class="p-2 text-slate-400 hover:text-slate-600 transition-colors" title="초기화">
                  <i data-feather="refresh-cw" class="w-4 h-4"></i>
                </a>

                {{! 상세 필터 숨은 필드들 (상태 유지를 위해) }}
                <input type="hidden" name="deptId" id="hidden-deptId" value="{{#deptId}}{{deptId}}{{/deptId}}">
                <input type="hidden" name="doctorId" id="hidden-doctorId" value="{{#doctorId}}{{doctorId}}{{/doctorId}}">
                <input type="hidden" name="source" id="hidden-source" value="{{#source}}{{source}}{{/source}}">
              </form>
            </div>

            {{! 상세 필터 패널 (기본 숨김) }}
            <form id="detailed-filter-form" action="/nurse/reception-list" method="get" class="hidden grid grid-cols-1 md:grid-cols-3 gap-4 p-4 bg-white rounded-xl border border-slate-200 shadow-sm">
              <input type="hidden" name="status" value="{{currentStatus}}">
              <input type="hidden" name="query" value="{{query}}">
              <div class="space-y-1.5">
                <label class="text-xs font-bold text-slate-500 ml-1">진료과</label>
                <select name="deptId" onchange="this.form.submit()" class="w-full bg-slate-50 border border-slate-200 rounded-lg text-sm px-3 py-2 outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all">
                  <option value="">전체 진료과</option>
                  {{#departments}}
                  <option value="{{id}}" {{#selected}}selected{{/selected}}>{{name}}</option>
                  {{/departments}}
                </select>
              </div>
              <div class="space-y-1.5">
                <label class="text-xs font-bold text-slate-500 ml-1">전문의</label>
                <select name="doctorId" onchange="this.form.submit()" class="w-full bg-slate-50 border border-slate-200 rounded-lg text-sm px-3 py-2 outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all">
                  <option value="">전체 전문의</option>
                  {{#doctors}}
                  <option value="{{id}}" {{#selected}}selected{{/selected}}>{{name}}</option>
                  {{/doctors}}
                </select>
              </div>
              <div class="space-y-1.5">
                <label class="text-xs font-bold text-slate-500 ml-1">예약 구분</label>
                <select name="source" onchange="this.form.submit()" class="w-full bg-slate-50 border border-slate-200 rounded-lg text-sm px-3 py-2 outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all">
                  <option value="">전체 구분</option>
                  {{#sources}}
                  <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                  {{/sources}}
                </select>
              </div>
            </form>
          </div>

          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-200 text-xs uppercase tracking-wider text-slate-500">
                <th class="p-4 font-medium">시간</th>
                <th class="p-4 font-medium">환자명</th>
                <th class="p-4 font-medium">연락처</th>
                <th class="p-4 font-medium">예약 구분</th>
                <th class="p-4 font-medium">진료과</th>
                <th class="p-4 font-medium">전문의</th>
                <th class="p-4 font-medium">상태</th>
                <th class="p-4 font-medium">접수</th>
              </tr>
            </thead>
            <tbody id="reception-tbody" class="divide-y divide-slate-200">
              {{#reservations}}
              <tr class="hover:bg-slate-50 transition-colors">
                <td class="p-4 text-sm font-medium text-slate-900">{{timeSlot}}</td>
                <td class="p-4 text-sm font-semibold text-slate-800">
                  <a href="/nurse/patient-detail?id={{id}}" class="hover:text-indigo-600">{{patientName}}</a>
                </td>
                <td class="p-4 text-sm text-slate-600">{{patientPhone}}</td>
                <td class="p-4">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-700">
                    {{sourceText}}
                  </span>
                </td>
                <td class="p-4 text-sm text-slate-600">{{departmentName}}</td>
                <td class="p-4 text-sm text-slate-600">{{doctorName}}</td>
                <td class="p-4">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium {{statusBadgeClass}}">
                    {{statusText}}
                  </span>
                </td>
                <td class="p-4">
                  {{#canReceive}}
                  <form method="post" action="/nurse/reservation/receive">
                    <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
                    <input type="hidden" name="id" value="{{id}}">
                    <button type="submit" class="px-3 py-1.5 bg-indigo-600 text-white text-xs font-medium rounded-lg hover:bg-indigo-700 transition-colors shadow-sm">
                      접수
                    </button>
                  </form>
                  {{/canReceive}}
                  {{^canReceive}}
                  <span class="text-xs text-slate-400">-</span>
                  {{/canReceive}}
                </td>
              </tr>
              {{/reservations}}
              {{^reservations}}
              <tr id="reception-empty">
                <td colspan="8" class="p-8 text-center text-slate-500">
                  {{#query}}"{{query}}"에 대한 검색 결과가 없습니다.{{/query}}
                  {{^query}}오늘 예약된 환자가 없습니다.{{/query}}
                </td>
              </tr>
              {{/reservations}}
            </tbody>
          </table>

          <!-- 페이징 -->
          <div class="flex items-center justify-center gap-1 px-4 py-3 border-t border-slate-200">
            {{#hasPrev}}
            <a href="{{prevUrl}}" class="px-3 py-1.5 rounded-lg text-sm text-slate-600 border border-slate-300 hover:bg-slate-100 transition-colors">이전</a>
            {{/hasPrev}}
            {{#pageLinks}}
            <a href="{{url}}" class="px-3 py-1.5 rounded-lg text-sm font-medium transition-colors {{#current}}bg-indigo-600 text-white{{/current}}{{^current}}text-slate-600 border border-slate-300 hover:bg-slate-100{{/current}}">{{num}}</a>
            {{/pageLinks}}
            {{#hasNext}}
            <a href="{{nextUrl}}" class="px-3 py-1.5 rounded-lg text-sm text-slate-600 border border-slate-300 hover:bg-slate-100 transition-colors">다음</a>
            {{/hasNext}}
          </div>
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>
    // 상세 필터 토글
    const btnToggleFilter = document.getElementById('btn-toggle-filter');
    const filterPanel = document.getElementById('detailed-filter-form');
    
    if (btnToggleFilter && filterPanel) {
      btnToggleFilter.addEventListener('click', () => {
        filterPanel.classList.toggle('hidden');
      });

      // 필터가 설정되어 있으면 자동으로 열어둠
      const hasActiveFilters = {{#deptId}}true{{/deptId}}{{^deptId}}false{{/deptId}} || 
                               {{#doctorId}}true{{/doctorId}}{{^doctorId}}false{{/doctorId}} || 
                               {{#source}}true{{/source}}{{^source}}false{{/source}};
      if (hasActiveFilters) {
        filterPanel.classList.remove('hidden');
      }
    }
  </script>
  <script>feather.replace();</script>
</body>
</html>
