<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>오늘 예약 현황 - MediCare+</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/feather.min.js"></script>
</head>
<body class="min-h-screen flex">
  {{> common/sidebar-nurse}}

  <div class="main-content flex-1 flex flex-col ml-64">
    {{> common/header-staff}}

    <main class="content-wrapper flex-1 p-6">
      <div class="space-y-6 max-w-5xl mx-auto">
        <div class="flex justify-between items-center">
          <h1 class="text-2xl font-bold text-slate-800">오늘 예약 현황</h1>
        </div>

        {{#message}}
        <div class="p-4 bg-green-50 border border-green-200 text-green-800 rounded-xl text-sm">{{message}}</div>
        {{/message}}
        {{#errorMessage}}
        <div class="p-4 bg-red-50 border border-red-200 text-red-800 rounded-xl text-sm">{{errorMessage}}</div>
        {{/errorMessage}}

        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
          <div class="p-4 border-b border-slate-200 flex justify-between items-center bg-slate-50">
            <div class="flex gap-2">
              {{#statusFilters}}
              <a href="{{url}}" class="px-4 py-1.5 rounded-full text-sm font-medium transition-colors {{#selected}}bg-slate-800 text-white{{/selected}}{{^selected}}bg-white border border-slate-300 text-slate-600 hover:bg-slate-100{{/selected}}">
                {{label}}
              </a>
              {{/statusFilters}}
            </div>
            <div class="relative">
              <i data-feather="search" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"></i>
              <input type="text" id="reception-search" placeholder="환자명·연락처 검색"
                     class="pl-9 pr-4 py-1.5 text-sm border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-300 w-56">
            </div>
          </div>

          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-200 text-xs uppercase tracking-wider text-slate-500">
                <th class="p-4 font-medium">시간</th>
                <th class="p-4 font-medium">환자명</th>
                <th class="p-4 font-medium">연락처</th>
                <th class="p-4 font-medium">예약 구분</th>
                <th class="p-4 font-medium">진료과 / 전문의</th>
                <th class="p-4 font-medium">상태</th>
                <th class="p-4 font-medium">접수</th>
              </tr>
            </thead>
            <tbody id="reception-tbody" class="divide-y divide-slate-200">
              {{#reservations}}
              <tr class="hover:bg-slate-50 transition-colors">
                <td class="p-4 text-sm font-medium text-slate-900">{{timeSlot}}</td>
                <td class="p-4 text-sm font-semibold text-slate-800">
                  <a href="/nurse/patient-detail?id={{id}}" class="hover:text-indigo-600">{{patientName}}</a>
                </td>
                <td class="p-4 text-sm text-slate-600">{{patientPhone}}</td>
                <td class="p-4">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-700">
                    {{sourceText}}
                  </span>
                </td>
                <td class="p-4 text-sm text-slate-600">{{departmentName}} / {{doctorName}}</td>
                <td class="p-4">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium {{statusBadgeClass}}">
                    {{statusText}}
                  </span>
                </td>
                <td class="p-4">
                  {{#canReceive}}
                  <form method="post" action="/nurse/reservation/receive">
                    <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}">
                    <input type="hidden" name="id" value="{{id}}">
                    <button type="submit" class="px-3 py-1.5 bg-indigo-600 text-white text-xs font-medium rounded-lg hover:bg-indigo-700 transition-colors">
                      접수
                    </button>
                  </form>
                  {{/canReceive}}
                  {{^canReceive}}
                  <span class="text-xs text-slate-400">-</span>
                  {{/canReceive}}
                </td>
              </tr>
              {{/reservations}}
              {{^reservations}}
              <tr id="reception-empty">
                <td colspan="7" class="p-8 text-center text-slate-500">
                  오늘 예약된 환자가 없습니다.
                </td>
              </tr>
              {{/reservations}}
            </tbody>
          </table>

          <!-- 페이징 -->
          <div class="flex items-center justify-center gap-1 px-4 py-3 border-t border-slate-200">
            {{#hasPrev}}
            <a href="{{prevUrl}}" class="px-3 py-1.5 rounded-lg text-sm text-slate-600 border border-slate-300 hover:bg-slate-100 transition-colors">이전</a>
            {{/hasPrev}}
            {{#pageLinks}}
            <a href="{{url}}" class="px-3 py-1.5 rounded-lg text-sm font-medium transition-colors {{#current}}bg-indigo-600 text-white{{/current}}{{^current}}text-slate-600 border border-slate-300 hover:bg-slate-100{{/current}}">{{num}}</a>
            {{/pageLinks}}
            {{#hasNext}}
            <a href="{{nextUrl}}" class="px-3 py-1.5 rounded-lg text-sm text-slate-600 border border-slate-300 hover:bg-slate-100 transition-colors">다음</a>
            {{/hasNext}}
          </div>
        </div>
      </div>
    </main>

    {{> common/footer-staff}}
  </div>

  <script>
    var receptionSearch = document.getElementById('reception-search');
    if (receptionSearch) {
      receptionSearch.addEventListener('input', function() {
        var query = this.value.trim().toLowerCase();
        document.querySelectorAll('#reception-tbody tr:not(#reception-empty)').forEach(function(row) {
          var cells = row.querySelectorAll('td');
          var name  = cells[1] ? cells[1].textContent.trim().toLowerCase() : '';
          var phone = cells[2] ? cells[2].textContent.trim().toLowerCase() : '';
          row.style.display = (!query || name.includes(query) || phone.includes(query)) ? '' : 'none';
        });
      });
    }
  </script>
  <script>feather.replace();</script>
</body>
</html>
